/* 商品详情 - 与首页风格统一 */
.page {
  min-height: 100vh;
  background-color: var(--color-bg-page);
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
}

/* ==================== 图片区域 ==================== */
.image-section {
  position: relative;
  background-color: #1F2937;
}

.image-swiper {
  height: 560rpx;
}

.swiper-image {
  width: 100%;
  height: 100%;
}

.image-counter {
  position: absolute;
  right: 24rpx;
  bottom: 24rpx;
  padding: 10rpx 24rpx;
  background-color: rgba(0, 0, 0, 0.5);
  backdrop-filter: blur(10rpx);
  -webkit-backdrop-filter: blur(10rpx);
  border-radius: var(--radius-full);
  font-size: 24rpx;
  font-weight: 500;
  color: #FFFFFF;
}

/* ==================== 价格区域 ==================== */
.price-section {
  background-color: var(--color-bg-card);
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.price-row {
  display: flex;
  align-items: baseline;
  margin-bottom: 12rpx;
}

.price-current {
  font-size: 52rpx;
  font-weight: 800;
  color: var(--color-primary);
}

.price-current::before {
  content: '¥';
  font-size: 32rpx;
}

.price-original {
  font-size: 28rpx;
  color: var(--color-text-muted);
  text-decoration: line-through;
  margin-left: 16rpx;
}

.info-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.info-views,
.info-time {
  font-size: 26rpx;
  color: var(--color-text-muted);
}

/* ==================== 商品信息 ==================== */
.info-section {
  background-color: var(--color-bg-card);
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.info-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.info-title {
  flex: 1;
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  line-height: 1.4;
  margin-right: 20rpx;
}

.info-actions {
  flex-shrink: 0;
}

.action-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: var(--color-bg-input);
  border-radius: 50%;
  transition: all var(--transition-fast);
}

.action-btn:active {
  transform: scale(0.92);
}

.action-btn.active {
  background: linear-gradient(135deg, #FEF3C7 0%, #FDE68A 100%);
}

.action-icon {
  font-size: 36rpx;
  color: var(--color-text-muted);
}

.action-btn.active .action-icon {
  color: #F59E0B;
}

.info-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.info-tag {
  padding: 8rpx 20rpx;
  font-size: 24rpx;
  font-weight: 500;
  color: var(--color-text-secondary);
  background-color: var(--color-bg-input);
  border-radius: var(--radius-sm);
}

.info-tag.status-selling {
  color: #27AE60;
  background: linear-gradient(135deg, #E8F8EF 0%, #D1F2E1 100%);
}

.info-tag.status-reserved {
  color: #F39C12;
  background: linear-gradient(135deg, #FEF3C7 0%, #FDE68A 100%);
}

.info-tag.status-sold {
  color: var(--color-text-muted);
  background-color: var(--color-bg-input);
}

/* ==================== 描述 ==================== */
.desc-section {
  padding: 0 24rpx;
  margin-bottom: 20rpx;
}

.section-title {
  display: flex;
  align-items: center;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  margin-bottom: 16rpx;
}

.section-title::before {
  content: '';
  width: 6rpx;
  height: 28rpx;
  background: linear-gradient(180deg, var(--color-primary) 0%, #FF8E8E 100%);
  border-radius: 3rpx;
  margin-right: 12rpx;
}

.desc-card {
  background-color: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: 24rpx;
  box-shadow: var(--shadow-card);
}

.desc-text {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  line-height: 1.8;
}

/* ==================== 联系方式 ==================== */
.contact-section {
  padding: 0 24rpx;
}

.contact-card {
  background-color: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: 0 24rpx;
  box-shadow: var(--shadow-card);
}

.contact-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--color-border-light);
}

.contact-item:last-child {
  border-bottom: none;
}

.contact-label {
  font-size: 28rpx;
  color: var(--color-text-secondary);
}

.contact-value {
  font-size: 28rpx;
  color: var(--color-text-primary);
  font-weight: 600;
}

.contact-value.phone {
  color: var(--color-primary);
}

/* ==================== 底部操作栏 ==================== */
.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background-color: var(--color-bg-card);
  box-shadow: 0 -8rpx 32rpx rgba(0, 0, 0, 0.08);
  z-index: 100;
}

.bottom-left {
  flex-shrink: 0;
  width: 100rpx;
}

.bottom-action {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.bottom-action:active {
  opacity: 0.7;
}

.bottom-icon {
  font-size: 44rpx;
  color: var(--color-text-muted);
  line-height: 1;
}

.bottom-icon.active {
  color: #F59E0B;
}

.bottom-text {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  margin-top: 6rpx;
}

.bottom-right {
  flex: 1;
  overflow: hidden;
  margin-left: 20rpx;
}

.bottom-right .btn {
  width: 100% !important;
}

/* ==================== 空状态 ==================== */
.empty-page {
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-text {
  font-size: 28rpx;
  color: var(--color-text-muted);
}
