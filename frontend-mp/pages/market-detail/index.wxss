/* 商品详情 - 与首页风格统一 */
.page {
  min-height: 100vh;
  background-color: var(--color-bg-page);
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
}

/* ==================== 图片区域 ==================== */
.image-section {
  position: relative;
  background-color: #1F2937;
}

.image-swiper {
  height: 560rpx;
}

.swiper-image {
  width: 100%;
  height: 100%;
}

.image-counter {
  position: absolute;
  right: 24rpx;
  bottom: 24rpx;
  padding: 10rpx 24rpx;
  background-color: rgba(0, 0, 0, 0.5);
  backdrop-filter: blur(10rpx);
  -webkit-backdrop-filter: blur(10rpx);
  border-radius: var(--radius-full);
  font-size: 24rpx;
  font-weight: 500;
  color: #FFFFFF;
}

.status-badge {
  position: absolute;
  top: 24rpx;
  left: 24rpx;
  padding: 10rpx 24rpx;
  border-radius: var(--radius-full);
  backdrop-filter: blur(10rpx);
  -webkit-backdrop-filter: blur(10rpx);
  z-index: 10;
}

.status-badge.status-selling {
  background: linear-gradient(135deg, rgba(39, 174, 96, 0.9) 0%, rgba(46, 204, 113, 0.9) 100%);
}

.status-badge.status-reserved {
  background: linear-gradient(135deg, rgba(243, 156, 18, 0.9) 0%, rgba(241, 196, 15, 0.9) 100%);
}

.status-badge.status-sold {
  background: linear-gradient(135deg, rgba(107, 114, 128, 0.9) 0%, rgba(156, 163, 175, 0.9) 100%);
}

.status-badge-text {
  font-size: 24rpx;
  font-weight: 600;
  color: #FFFFFF;
}

/* ==================== 价格区域 ==================== */
.price-section {
  background-color: var(--color-bg-card);
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.price-row {
  margin-bottom: 12rpx;
}

.price-main {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
}

.price-current {
  font-size: 56rpx;
  font-weight: 800;
  color: var(--color-primary);
  line-height: 1;
}

.price-current::before {
  content: '¥';
  font-size: 32rpx;
  margin-right: 2rpx;
}

.discount-tag {
  padding: 6rpx 16rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  border-radius: var(--radius-sm);
}

.discount-text {
  font-size: 24rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.save-tag {
  padding: 6rpx 16rpx;
  background: linear-gradient(135deg, #FEE2E2 0%, #FECACA 100%);
  border-radius: var(--radius-sm);
}

.save-text {
  font-size: 24rpx;
  font-weight: 600;
  color: #DC2626;
}

.price-original-row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.price-original-label {
  font-size: 24rpx;
  color: var(--color-text-muted);
  margin-right: 8rpx;
}

.price-original {
  font-size: 28rpx;
  color: var(--color-text-muted);
  text-decoration: line-through;
}

.info-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--color-border-light);
}

.info-views {
  display: flex;
  align-items: center;
}

.info-icon {
  font-size: 24rpx;
  margin-right: 6rpx;
}

.info-text {
  font-size: 26rpx;
  color: var(--color-text-muted);
}

.info-dot {
  font-size: 26rpx;
  color: var(--color-text-muted);
  margin: 0 12rpx;
}

.info-time {
  font-size: 26rpx;
  color: var(--color-text-muted);
}

.info-category {
  display: flex;
  align-items: center;
}

.info-category-text {
  font-size: 24rpx;
  color: var(--color-primary);
  background-color: rgba(255, 107, 107, 0.1);
  padding: 4rpx 12rpx;
  border-radius: var(--radius-sm);
}

/* ==================== 商品信息 ==================== */
.info-section {
  background-color: var(--color-bg-card);
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.info-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.info-title {
  flex: 1;
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  line-height: 1.4;
  margin-right: 20rpx;
}

.info-actions {
  flex-shrink: 0;
}

.action-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: var(--color-bg-input);
  border-radius: 50%;
  transition: all var(--transition-fast);
}

.action-btn:active {
  transform: scale(0.92);
}

.action-btn.active {
  background: linear-gradient(135deg, #FEF3C7 0%, #FDE68A 100%);
}

.action-icon {
  font-size: 36rpx;
  color: var(--color-text-muted);
}

.action-btn.active .action-icon {
  color: #F59E0B;
}

.info-tags {
  display: flex;
  flex-wrap: wrap;
}

.info-tags { margin-right: -12rpx; margin-bottom: -12rpx; }

.info-tags > * { margin-right: 12rpx; margin-bottom: 12rpx; }

.info-tag {
  padding: 8rpx 20rpx;
  font-size: 24rpx;
  font-weight: 500;
  color: var(--color-text-secondary);
  background-color: var(--color-bg-input);
  border-radius: var(--radius-sm);
}

.info-tag.status-selling {
  color: #27AE60;
  background: linear-gradient(135deg, #E8F8EF 0%, #D1F2E1 100%);
}

.info-tag.status-reserved {
  color: #F39C12;
  background: linear-gradient(135deg, #FEF3C7 0%, #FDE68A 100%);
}

.info-tag.status-sold {
  color: var(--color-text-muted);
  background-color: var(--color-bg-input);
}

/* ==================== 卖家操作 ==================== */
.owner-actions {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid var(--color-border-light);
}

.owner-title {
  margin-bottom: 20rpx;
}

.owner-title-text {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.owner-btn-group {
  display: flex;
  align-items: center;
}

.owner-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 20rpx 0;
  background-color: var(--color-bg-input);
  border-radius: var(--radius-md);
  margin-right: 16rpx;
  transition: all var(--transition-fast);
}

.owner-btn:last-child {
  margin-right: 0;
}

.owner-btn:active {
  transform: scale(0.96);
  opacity: 0.8;
}

.owner-btn-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.owner-btn-text {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  font-weight: 500;
}

.owner-btn-danger .owner-btn-text {
  color: #EF4444;
}

/* 状态选择面板 */
.status-panel {
  margin-top: 20rpx;
  padding: 20rpx;
  background-color: var(--color-bg-input);
  border-radius: var(--radius-lg);
  animation: slideDown 0.2s ease-out;
}

@keyframes slideDown {
  from {
    opacity: 0;
    transform: translateY(-10rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.status-panel-title {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 16rpx;
}

.status-option {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx;
  background-color: var(--color-bg-card);
  border-radius: var(--radius-md);
  margin-bottom: 12rpx;
  transition: all var(--transition-fast);
}

.status-option:last-child {
  margin-bottom: 0;
}

.status-option:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.status-option.active {
  background: linear-gradient(135deg, rgba(255, 107, 107, 0.1) 0%, rgba(255, 142, 142, 0.1) 100%);
  border: 2rpx solid var(--color-primary);
}

.status-option-main {
  display: flex;
  flex-direction: column;
}

.status-option-label {
  font-size: 28rpx;
  font-weight: 600;
  padding: 4rpx 16rpx;
  border-radius: var(--radius-sm);
  display: inline-block;
  margin-bottom: 6rpx;
}

.status-option-label.status-selling {
  color: #27AE60;
  background: linear-gradient(135deg, #E8F8EF 0%, #D1F2E1 100%);
}

.status-option-label.status-reserved {
  color: #F39C12;
  background: linear-gradient(135deg, #FEF3C7 0%, #FDE68A 100%);
}

.status-option-label.status-sold {
  color: var(--color-text-muted);
  background-color: var(--color-bg-input);
}

.status-option-desc {
  font-size: 24rpx;
  color: var(--color-text-muted);
}

.status-option-check {
  font-size: 36rpx;
  color: var(--color-primary);
  font-weight: bold;
}

/* ==================== 描述 ==================== */
.desc-section {
  padding: 0 24rpx;
  margin-bottom: 20rpx;
}

.section-title {
  display: flex;
  align-items: center;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  margin-bottom: 16rpx;
}

.section-title::before {
  content: '';
  width: 6rpx;
  height: 28rpx;
  background: linear-gradient(180deg, var(--color-primary) 0%, #FF8E8E 100%);
  border-radius: 3rpx;
  margin-right: 12rpx;
}

.desc-card {
  background-color: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: 24rpx;
  box-shadow: var(--shadow-card);
}

.desc-text {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  line-height: 1.8;
}

/* ==================== 联系方式 ==================== */
.contact-section {
  padding: 0 24rpx;
}

.contact-card {
  background-color: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: 0 24rpx;
  box-shadow: var(--shadow-card);
}

.contact-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--color-border-light);
}

.contact-item:last-child {
  border-bottom: none;
}

.contact-label {
  font-size: 28rpx;
  color: var(--color-text-secondary);
}

.contact-value {
  font-size: 28rpx;
  color: var(--color-text-primary);
  font-weight: 600;
}

.contact-value.phone {
  color: var(--color-primary);
}

/* ==================== 底部操作栏 ==================== */
.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background-color: var(--color-bg-card);
  box-shadow: 0 -8rpx 32rpx rgba(0, 0, 0, 0.08);
  z-index: 100;
}

.bottom-left {
  flex-shrink: 0;
  display: flex;
  align-items: center;
}

.bottom-action {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100rpx;
}

.bottom-action:active {
  opacity: 0.7;
}

.bottom-icon {
  font-size: 40rpx;
  color: var(--color-text-muted);
  line-height: 1;
}

.bottom-icon.active {
  color: #F59E0B;
}

.bottom-text {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  margin-top: 6rpx;
}

.bottom-right {
  flex: 1;
  overflow: hidden;
  margin-left: 20rpx;
}

.bottom-right .btn {
  width: 100% !important;
}

/* ==================== 空状态 ==================== */
.empty-page {
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-text {
  font-size: 28rpx;
  color: var(--color-text-muted);
}

/* ==================== 评论区 ==================== */
.comment-section {
  padding: 0 24rpx;
  margin-bottom: 20rpx;
}

.comment-count {
  font-size: 26rpx;
  color: var(--color-text-muted);
  font-weight: 400;
  margin-left: 8rpx;
}

.comment-input-wrap {
  display: flex;
  align-items: center;
  background-color: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: 16rpx 20rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-card);
}

.comment-input {
  flex: 1;
  height: 72rpx;
  font-size: 28rpx;
  color: var(--color-text-primary);
  background-color: var(--color-bg-input);
  border-radius: var(--radius-full);
  padding: 0 24rpx;
  margin-right: 16rpx;
}

.comment-submit {
  padding: 12rpx 28rpx;
  font-size: 28rpx;
  color: var(--color-text-muted);
  background-color: var(--color-bg-input);
  border-radius: var(--radius-full);
  font-weight: 500;
  transition: all var(--transition-fast);
  flex-shrink: 0;
}

.comment-submit.active {
  color: #FFFFFF;
  background: linear-gradient(135deg, var(--color-primary) 0%, #FF8E8E 100%);
}

.comment-submit:active {
  opacity: 0.8;
  transform: scale(0.96);
}

.comment-list {
  background-color: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: 8rpx 0;
  box-shadow: var(--shadow-card);
}

.comment-item {
  display: flex;
  align-items: flex-start;
  padding: 24rpx;
  border-bottom: 1rpx solid var(--color-border-light);
  position: relative;
}

.comment-item:last-child {
  border-bottom: none;
}

.comment-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background-color: var(--color-bg-input);
  flex-shrink: 0;
}

.comment-content {
  flex: 1;
  margin-left: 20rpx;
  min-width: 0;
}

.comment-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.comment-name {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.comment-time {
  font-size: 22rpx;
  color: var(--color-text-muted);
  flex-shrink: 0;
  margin-left: 12rpx;
}

.comment-text {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  line-height: 1.6;
  word-break: break-all;
}

.comment-delete {
  font-size: 24rpx;
  color: #EF4444;
  padding: 8rpx 16rpx;
  background-color: rgba(239, 68, 68, 0.1);
  border-radius: var(--radius-sm);
  flex-shrink: 0;
  margin-left: 16rpx;
}

.comment-delete:active {
  opacity: 0.7;
}

.comment-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60rpx 0;
  background-color: var(--color-bg-card);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-card);
}

.comment-empty-text {
  font-size: 26rpx;
  color: var(--color-text-muted);
}

/* ==================== 交易地点 ==================== */
.location-section {
  padding: 0 24rpx;
  margin-bottom: 20rpx;
}

.location-card {
  background-color: var(--color-bg-card);
  border-radius: var(--radius-xl);
  overflow: hidden;
  box-shadow: var(--shadow-card);
}

.location-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  transition: all var(--transition-fast);
}

.location-header:active {
  background-color: var(--color-bg-input);
}

.location-info {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.location-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, rgba(255, 107, 107, 0.1) 0%, rgba(255, 142, 142, 0.1) 100%);
  border-radius: var(--radius-lg);
  flex-shrink: 0;
  margin-right: 16rpx;
}

.location-icon {
  font-size: 36rpx;
}

.location-text-wrap {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.location-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  line-height: 1.4;
  word-break: break-all;
  margin-bottom: 6rpx;
}

.location-hint {
  font-size: 24rpx;
  color: var(--color-text-muted);
}

.location-nav-btn {
  display: flex;
  align-items: center;
  padding: 14rpx 24rpx;
  background: linear-gradient(135deg, var(--color-primary) 0%, #FF8E8E 100%);
  border-radius: var(--radius-full);
  flex-shrink: 0;
  margin-left: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 107, 0.3);
  transition: all var(--transition-fast);
}

.location-nav-btn:active {
  transform: scale(0.95);
}

.nav-icon {
  font-size: 28rpx;
  margin-right: 6rpx;
}

.nav-text {
  font-size: 26rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.map-container {
  position: relative;
  width: 100%;
  height: 360rpx;
  overflow: hidden;
  border-top: 1rpx solid var(--color-border-light);
}

.map-view {
  width: 100%;
  height: 100%;
}
