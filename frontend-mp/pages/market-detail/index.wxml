<page-meta page-style="background-color: {{darkMode ? '#0F1117' : '#F8F9FA'}}; color: {{darkMode ? '#E8ECF1' : '#2C3E50'}}"/>
<view class="page {{darkMode ? 'dark' : ''}}" wx:if="{{detail}}">
  <!-- 图片轮播 -->
  <view class="image-section">
    <swiper
      class="image-swiper"
      indicator-dots="{{detail.images.length > 1}}"
      indicator-color="rgba(255,255,255,0.5)"
      indicator-active-color="#FFFFFF"
      current="{{currentImageIndex}}"
      bindchange="onSwiperChange"
    >
      <swiper-item
        wx:for="{{detail.images}}"
        wx:key="index"
        bindtap="onPreviewImage"
        data-index="{{index}}"
      >
        <image class="swiper-image" src="{{item}}" mode="aspectFill" />
      </swiper-item>
    </swiper>
    <view class="image-counter">{{currentImageIndex + 1}}/{{detail.images.length}}</view>
    <view class="status-badge status-{{detail.displayStatus}}">
      <text class="status-badge-text">{{detail.statusText}}</text>
    </view>
  </view>

  <!-- 价格信息 -->
  <view class="price-section">
    <view class="price-row">
      <view class="price-main">
        <text class="price-current">¥{{detail.priceText}}</text>
        <view class="discount-tag" wx:if="{{detail.hasDiscount}}">
          <text class="discount-text">{{detail.discountText}}</text>
        </view>
        <view class="save-tag" wx:if="{{detail.hasDiscount && detail.originalPrice}}">
          <text class="save-text">省 ¥{{detail.saveText}}</text>
        </view>
      </view>
    </view>
    <view class="price-original-row" wx:if="{{detail.originalPrice}}">
      <text class="price-original-label">原价</text>
      <text class="price-original">¥{{detail.originalPriceText}}</text>
    </view>
    <view class="info-row">
      <view class="info-views">
        <text class="info-icon">👁️</text>
        <text class="info-text">{{detail.viewsText}} 浏览</text>
      </view>
      <text class="info-dot">·</text>
      <text class="info-time">{{detail.timeText}}</text>
      <text class="info-dot">·</text>
      <view class="info-category">
        <text class="info-category-text">{{detail.categoryText}}</text>
      </view>
    </view>
  </view>

  <!-- 商品信息 -->
  <view class="info-section">
    <view class="info-header">
      <text class="info-title">{{detail.title}}</text>
      <view class="info-actions">
        <view
          class="action-btn {{isFavorite ? 'active' : ''}}"
          bindtap="onToggleFavorite"
        >
          <text class="action-icon">{{isFavorite ? '★' : '☆'}}</text>
        </view>
        <button
          class="action-btn share-btn"
          open-type="share"
          bindtap="onShare"
        >
          <text class="action-icon">↗️</text>
        </button>
        <view
          class="action-btn"
          wx:if="{{!isOwner}}"
          bindtap="onReport"
        >
          <text class="action-icon">🚫</text>
        </view>
      </view>
    </view>
    <view class="info-tags">
      <text class="info-tag">{{detail.categoryText}}</text>
      <text class="info-tag status-{{detail.displayStatus}}">{{detail.statusText}}</text>
    </view>

    <!-- 卖家操作区 -->
    <view class="owner-actions" wx:if="{{isOwner}}">
      <view class="owner-title">
        <text class="owner-title-text">卖家操作</text>
      </view>
      <view class="owner-btn-group">
        <view class="owner-btn" bindtap="onEdit">
          <text class="owner-btn-icon">✏️</text>
          <text class="owner-btn-text">编辑</text>
        </view>
        <view class="owner-btn" bindtap="onToggleStatusAction">
          <text class="owner-btn-icon">🔄</text>
          <text class="owner-btn-text">改状态</text>
        </view>
        <view class="owner-btn owner-btn-danger" bindtap="onDelete">
          <text class="owner-btn-icon">🗑️</text>
          <text class="owner-btn-text">下架</text>
        </view>
      </view>

      <!-- 状态选择面板 -->
      <view class="status-panel" wx:if="{{showStatusAction}}">
        <view class="status-panel-title">选择商品状态</view>
        <view
          class="status-option {{detail.status === item.value ? 'active' : ''}}"
          wx:for="{{statusOptions}}"
          wx:key="value"
          bindtap="onChangeStatus"
          data-status="{{item.value}}"
        >
          <view class="status-option-main">
            <text class="status-option-label status-{{item.value}}">{{item.label}}</text>
            <text class="status-option-desc">{{item.desc}}</text>
          </view>
          <text class="status-option-check" wx:if="{{detail.status === item.value}}">✓</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 描述 -->
  <view class="desc-section">
    <view class="section-title">商品描述</view>
    <view class="desc-card">
      <text class="desc-text">{{detail.description}}</text>
    </view>
  </view>

  <!-- 交易地点 -->
  <view class="location-section" wx:if="{{detail.hasLocation}}">
    <view class="section-title">交易地点</view>
    <view class="location-card">
      <view class="location-header" bindtap="onNavigateToLocation">
        <view class="location-info">
          <view class="location-icon-wrap">
            <text class="location-icon">📍</text>
          </view>
          <view class="location-text-wrap">
            <text class="location-name">{{detail.address}}</text>
            <text class="location-hint">点击查看地图并导航</text>
          </view>
        </view>
        <view class="location-nav-btn">
          <text class="nav-icon">🧭</text>
          <text class="nav-text">导航</text>
        </view>
      </view>
      <view class="map-container" bindtap="onMapTap">
        <map
          wx:if="{{detail.latitude && detail.longitude}}"
          class="map-view"
          latitude="{{detail.latitude}}"
          longitude="{{detail.longitude}}"
          markers="{{markers}}"
          scale="{{mapScale}}"
          show-location="{{false}}"
          enable-zoom="{{true}}"
          enable-scroll="{{true}}"
        />
      </view>
    </view>
  </view>

  <!-- 联系方式 -->
  <view class="contact-section">
    <view class="section-title">卖家信息</view>
    <view class="contact-card">
      <view class="contact-item">
        <text class="contact-label">联系人</text>
        <text class="contact-value">{{detail.contact}}</text>
      </view>
      <view class="contact-item">
        <text class="contact-label">联系电话</text>
        <text class="contact-value phone" bindtap="onContact">{{detail.phone}}</text>
      </view>
    </view>
  </view>

  <!-- 议价记录区 -->
  <view class="offer-section" wx:if="{{canViewOffers}}">
    <view class="section-title">
      议价记录
      <text class="offer-count" wx:if="{{activeOfferCount > 0}}">({{activeOfferCount}}个进行中)</text>
    </view>

    <!-- 卖家视角：所有出价列表 -->
    <view class="offer-list" wx:if="{{isOwner && offers.length > 0}}">
      <view
        class="offer-item"
        wx:for="{{offers}}"
        wx:key="id"
      >
        <view class="offer-header">
          <view class="offer-user">
            <image
              class="offer-avatar"
              src="{{item.userAvatar || '/assets/images/default-avatar.png'}}"
              mode="aspectFill"
            />
            <view class="offer-user-info">
              <text class="offer-user-name">{{item.userName}}</text>
              <text class="offer-time">{{item.timeText}}</text>
            </view>
          </view>
          <view class="offer-status" style="color: {{item.statusColor}}">
            <text class="offer-status-icon">{{item.statusIcon}}</text>
            <text class="offer-status-text">{{item.statusText}}</text>
          </view>
        </view>

        <view class="offer-price-row">
          <text class="offer-price-label">出价：</text>
          <text class="offer-price">¥{{item.priceText}}</text>
          <text class="offer-original-price">(原价 ¥{{item.itemPriceText}})</text>
        </view>

        <view class="offer-message" wx:if="{{item.message}}">
          <text class="offer-message-text">{{item.message}}</text>
        </view>

        <view class="offer-time-left" wx:if="{{item.hasTimeLeft}}" style="color: {{item.timeLeftColor}}">
          <text class="time-left-icon">⏰</text>
          <text class="time-left-text">{{item.timeLeftText}}</text>
        </view>

        <!-- 操作按钮 -->
        <view class="offer-actions" wx:if="{{item.canAccept || item.canReject || item.canCounter}}">
          <view class="offer-btn offer-btn-reject" bindtap="onRejectOffer" data-offer-id="{{item.id}}">
            拒绝
          </view>
          <view class="offer-btn offer-btn-counter" bindtap="onShowCounterModal" data-offer-id="{{item.id}}" data-current-price="{{item.price}}">
            还价
          </view>
          <view class="offer-btn offer-btn-accept" bindtap="onAcceptOffer" data-offer-id="{{item.id}}">
            接受
          </view>
        </view>

        <!-- 议价历史 -->
        <view class="offer-history" wx:if="{{item.history && item.history.length > 1}}">
          <view class="history-title">议价历史</view>
          <view
            class="history-item"
            wx:for="{{item.history}}"
            wx:for-item="h"
            wx:key="time"
          >
            <view class="history-dot"></view>
            <view class="history-content">
              <view class="history-header">
                <text class="history-action">{{h.action === 'offer' ? '买家出价' : h.action === 'counter' ? '卖家还价' : h.action === 'accept' ? '卖家接受' : h.action === 'reject' ? '卖家拒绝' : h.action === 'cancel' ? '买家取消' : h.action === 'auto_cancel' ? '系统取消' : h.action}}</text>
                <text class="history-time">{{h.timeText}}</text>
              </view>
              <view class="history-price" wx:if="{{h.priceText}}">
                <text class="history-price-text">¥{{h.priceText}}</text>
              </view>
              <view class="history-message" wx:if="{{h.message}}">
                <text class="history-message-text">{{h.message}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 买家视角：我的出价 -->
    <view class="my-offer-card" wx:if="{{!isOwner && myOffer}}">
      <view class="my-offer-header">
        <text class="my-offer-title">我的出价</text>
        <view class="my-offer-status" style="color: {{myOffer.statusColor}}">
          <text class="my-offer-status-icon">{{myOffer.statusIcon}}</text>
          <text class="my-offer-status-text">{{myOffer.statusText}}</text>
        </view>
      </view>

      <view class="my-offer-price-row">
        <text class="my-offer-price-label">出价金额：</text>
        <text class="my-offer-price">¥{{myOffer.priceText}}</text>
      </view>

      <view class="my-offer-message" wx:if="{{myOffer.message}}">
        <text class="my-offer-message-label">留言：</text>
        <text class="my-offer-message-text">{{myOffer.message}}</text>
      </view>

      <view class="my-offer-time" wx:if="{{myOffer.hasTimeLeft}}" style="color: {{myOffer.timeLeftColor}}">
        <text class="my-offer-time-icon">⏰</text>
        <text class="my-offer-time-text">{{myOffer.timeLeftText}}</text>
      </view>

      <view class="my-offer-actions" wx:if="{{myOffer.canCancel}}">
        <view class="my-offer-btn my-offer-btn-cancel" bindtap="onCancelOffer" data-offer-id="{{myOffer.id}}">
          取消出价
        </view>
      </view>

      <!-- 议价历史 -->
      <view class="offer-history" wx:if="{{myOffer.history && myOffer.history.length > 1}}">
        <view class="history-title">议价历史</view>
        <view
          class="history-item"
          wx:for="{{myOffer.history}}"
          wx:for-item="h"
          wx:key="time"
        >
          <view class="history-dot"></view>
          <view class="history-content">
            <view class="history-header">
              <text class="history-action">{{h.action === 'offer' ? '我出价' : h.action === 'counter' ? '卖家还价' : h.action === 'accept' ? '卖家接受' : h.action === 'reject' ? '卖家拒绝' : h.action === 'cancel' ? '我取消' : h.action === 'auto_cancel' ? '系统取消' : h.action}}</text>
              <text class="history-time">{{h.timeText}}</text>
            </view>
            <view class="history-price" wx:if="{{h.priceText}}">
              <text class="history-price-text">¥{{h.priceText}}</text>
            </view>
            <view class="history-message" wx:if="{{h.message}}">
              <text class="history-message-text">{{h.message}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 买家视角：未出价 -->
    <view class="offer-empty" wx:if="{{!isOwner && !myOffer}}">
      <text class="offer-empty-text">您还没有出价</text>
      <view class="offer-empty-btn" bindtap="onShowOfferModal">
        立即出价
      </view>
    </view>

    <!-- 空状态 -->
    <view class="offer-empty" wx:if="{{isOwner && offers.length === 0}}">
      <text class="offer-empty-text">暂无买家出价</text>
    </view>
  </view>

  <!-- 评论区 -->
  <view class="comment-section">
    <view class="section-title">
      评论
      <text class="comment-count" wx:if="{{comments.length > 0}}">({{comments.length}})</text>
    </view>

    <!-- 评论输入框 -->
    <view class="comment-input-wrap">
      <input
        class="comment-input"
        placeholder="{{detail.status === 'sold' ? '商品已售出，无法评论' : '说点什么...'}}"
        value="{{commentInput}}"
        bindinput="onCommentInput"
        confirm-type="send"
        bindconfirm="onSubmitComment"
        disabled="{{detail.status === 'sold'}}"
        maxlength="500"
      />
      <view
        class="comment-submit {{commentInput && detail.status !== 'sold' ? 'active' : ''}}"
        bindtap="onSubmitComment"
      >
        发送
      </view>
    </view>

    <!-- 评论列表 -->
    <view class="comment-list" wx:if="{{comments.length > 0}}">
      <view
        class="comment-item"
        wx:for="{{comments}}"
        wx:key="id"
      >
        <image
          class="comment-avatar"
          src="{{item.userAvatar || '/assets/images/default-avatar.png'}}"
          mode="aspectFill"
        />
        <view class="comment-content">
          <view class="comment-header">
            <text class="comment-name">{{item.userName}}</text>
            <text class="comment-time">{{item.timeText}}</text>
          </view>
          <text class="comment-text">{{item.content}}</text>
        </view>
        <view
          class="comment-delete"
          wx:if="{{item.canDelete}}"
          bindtap="onDeleteComment"
          data-comment-id="{{item.id}}"
        >
          删除
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="comment-empty" wx:else>
      <text class="comment-empty-text">暂无评论，快来抢沙发～</text>
    </view>
  </view>

  <!-- 底部操作栏 -->
  <detail-bottom-bar
    isFavorite="{{isFavorite}}"
    isOwner="{{isOwner}}"
    enableFavorite="{{detailConfig.enableFavorite}}"
    enableShare="{{detailConfig.enableShare}}"
    enableReport="{{detailConfig.enableReport}}"
    enableContact="{{detailConfig.enableContact}}"
    enableOffer="{{!isOwner && detail.status === 'selling'}}"
    contactText="联系卖家"
    ownerText="编辑商品"
    offerText="我要出价"
    contactDisabled="{{detail.status === 'sold'}}"
    offerDisabled="{{detail.status !== 'selling' || myOffer && (myOffer.status === 'pending' || myOffer.status === 'countered')}}"
    bind:favorite="onToggleFavorite"
    bind:share="onShare"
    bind:report="onReport"
    bind:contact="{{isOwner ? 'onEdit' : 'onContact'}}"
    bind:offer="onShowOfferModal"
  />

  <!-- 分享卡片 -->
  <share-card
    visible="{{showShareCard}}"
    image="{{detail.images[0]}}"
    title="{{detail.title}}"
    price="{{detail.priceText}}"
    originalPrice="{{detail.originalPriceText}}"
    discount="{{detail.discountText}}"
    statusText="{{detail.statusText}}"
    status="{{detail.status}}"
    bind:close="onCloseShareCard"
    bind:save="onSaveShareImage"
  />

  <!-- 出价弹窗 -->
  <view class="modal-mask" wx:if="{{showOfferModal}}" bindtap="onHideOfferModal">
    <view class="modal-content offer-modal" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">我要出价</text>
        <view class="modal-close" bindtap="onHideOfferModal">
          <text class="close-icon">✕</text>
        </view>
      </view>
      <view class="modal-body">
        <view class="form-item">
          <text class="form-label">出价金额（元）</text>
          <input
            class="form-input"
            type="digit"
            placeholder="请输入出价金额"
            value="{{offerPrice}}"
            bindinput="onOfferPriceInput"
            maxlength="10"
          />
        </view>
        <view class="form-item">
          <text class="form-label">留言（选填）</text>
          <textarea
            class="form-textarea"
            placeholder="可以给卖家留言，说明您的需求..."
            value="{{offerMessage}}"
            bindinput="onOfferMessageInput"
            maxlength="200"
            auto-height
          />
        </view>
        <view class="offer-tip">
          <text class="tip-icon">💡</text>
          <text class="tip-text">出价后请等待卖家回复，48小时内未处理将自动失效</text>
        </view>
      </view>
      <view class="modal-footer">
        <view class="modal-btn modal-btn-cancel" bindtap="onHideOfferModal">
          取消
        </view>
        <view class="modal-btn modal-btn-confirm" bindtap="onSubmitOffer">
          提交出价
        </view>
      </view>
    </view>
  </view>

  <!-- 还价弹窗 -->
  <view class="modal-mask" wx:if="{{showCounterModal}}" bindtap="onHideCounterModal">
    <view class="modal-content offer-modal" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">卖家还价</text>
        <view class="modal-close" bindtap="onHideCounterModal">
          <text class="close-icon">✕</text>
        </view>
      </view>
      <view class="modal-body">
        <view class="form-item">
          <text class="form-label">还价金额（元）</text>
          <input
            class="form-input"
            type="digit"
            placeholder="请输入还价金额"
            value="{{counterPrice}}"
            bindinput="onCounterPriceInput"
            maxlength="10"
          />
        </view>
        <view class="form-item">
          <text class="form-label">留言（选填）</text>
          <textarea
            class="form-textarea"
            placeholder="可以给买家留言，说明原因..."
            value="{{counterMessage}}"
            bindinput="onCounterMessageInput"
            maxlength="200"
            auto-height
          />
        </view>
      </view>
      <view class="modal-footer">
        <view class="modal-btn modal-btn-cancel" bindtap="onHideCounterModal">
          取消
        </view>
        <view class="modal-btn modal-btn-confirm" bindtap="onSubmitCounter">
          发送还价
        </view>
      </view>
    </view>
  </view>
</view>

<view class="page empty-page {{darkMode ? 'dark' : ''}}" wx:else>
  <text class="empty-text">商品不存在或已下架</text>
</view>
