<view class="page" wx:if="{{detail}}">
  <!-- 图片轮播 -->
  <view class="image-section">
    <swiper 
      class="image-swiper"
      indicator-dots="{{detail.images.length > 1}}"
      indicator-color="rgba(255,255,255,0.5)"
      indicator-active-color="#FFFFFF"
      current="{{currentImageIndex}}"
      bindchange="onSwiperChange"
    >
      <swiper-item 
        wx:for="{{detail.images}}" 
        wx:key="index"
        bindtap="onPreviewImage"
        data-index="{{index}}"
      >
        <image class="swiper-image" src="{{item}}" mode="aspectFill" />
      </swiper-item>
    </swiper>
    <view class="image-counter">{{currentImageIndex + 1}}/{{detail.images.length}}</view>
  </view>

  <!-- 价格信息 -->
  <view class="price-section">
    <view class="price-row">
      <text class="price-current">¥{{detail.priceText}}</text>
      <text class="price-original" wx:if="{{detail.originalPrice}}">¥{{detail.originalPriceText}}</text>
    </view>
    <view class="info-row">
      <text class="info-views">{{detail.views}}次浏览</text>
      <text class="info-time">{{detail.timeText}}</text>
    </view>
  </view>

  <!-- 商品信息 -->
  <view class="info-section">
    <view class="info-header">
      <text class="info-title">{{detail.title}}</text>
      <view class="info-actions">
        <view 
          class="action-btn {{isFavorite ? 'active' : ''}}" 
          bindtap="onToggleFavorite"
        >
          <text class="action-icon">{{isFavorite ? '★' : '☆'}}</text>
        </view>
      </view>
    </view>
    <view class="info-tags">
      <text class="info-tag">{{detail.categoryText}}</text>
      <text class="info-tag status-{{detail.status}}">{{detail.statusText}}</text>
    </view>
  </view>

  <!-- 描述 -->
  <view class="desc-section">
    <view class="section-title">商品描述</view>
    <view class="desc-card">
      <text class="desc-text">{{detail.description}}</text>
    </view>
  </view>

  <!-- 联系方式 -->
  <view class="contact-section">
    <view class="section-title">卖家信息</view>
    <view class="contact-card">
      <view class="contact-item">
        <text class="contact-label">联系人</text>
        <text class="contact-value">{{detail.contact}}</text>
      </view>
      <view class="contact-item">
        <text class="contact-label">联系电话</text>
        <text class="contact-value phone" bindtap="onCallPhone">{{detail.phone}}</text>
      </view>
    </view>
  </view>

  <!-- 底部操作 -->
  <view class="bottom-bar">
    <view class="bottom-left">
      <view class="bottom-action" bindtap="onToggleFavorite">
        <text class="bottom-icon {{isFavorite ? 'active' : ''}}">{{isFavorite ? '★' : '☆'}}</text>
        <text class="bottom-text">收藏</text>
      </view>
    </view>
    <view class="bottom-right">
      <btn type="primary" size="large" block="{{true}}" bind:click="onCallPhone">立即联系卖家</btn>
    </view>
  </view>
</view>

<view class="page empty-page" wx:else>
  <text class="empty-text">商品不存在或已下架</text>
</view>
