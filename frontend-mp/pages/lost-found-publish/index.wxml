<view class="page">
  <form bindsubmit="onSubmit">
    <!-- 类型选择 -->
    <view class="form-section">
      <view class="section-title">信息类型</view>
      <view class="type-selector">
        <view 
          class="type-option {{formData.type === 'lost' ? 'active' : ''}}"
          bindtap="onTypeSelect"
          data-type="lost"
        >
          <view class="type-icon lost">🔍</view>
          <text class="type-text">寻物启事</text>
          <text class="type-desc">我丢失了物品</text>
        </view>
        <view 
          class="type-option {{formData.type === 'found' ? 'active' : ''}}"
          bindtap="onTypeSelect"
          data-type="found"
        >
          <view class="type-icon found">📦</view>
          <text class="type-text">失物招领</text>
          <text class="type-desc">我捡到了物品</text>
        </view>
      </view>
    </view>

    <!-- 基本信息 -->
    <view class="form-section">
      <view class="section-title">基本信息</view>
      <view class="form-card">
        <view class="form-item">
          <text class="form-label">标题</text>
          <input 
            class="form-input" 
            placeholder="请输入标题（如：丢失一把钥匙）"
            value="{{formData.title}}"
            bindinput="onInputChange"
            data-field="title"
            maxlength="30"
          />
        </view>
        
        <view class="form-item">
          <text class="form-label">物品类型</text>
          <picker 
            class="form-picker-wrap"
            mode="selector" 
            range="{{itemTypes}}" 
            range-key="label"
            value="{{itemTypeIndex}}"
            bindchange="onItemTypeChange"
          >
            <view class="form-picker">
              <text class="picker-text {{formData.itemType ? '' : 'placeholder'}}">{{formData.itemType ? itemTypeText : '请选择物品类型'}}</text>
              <text class="picker-arrow">›</text>
            </view>
          </picker>
        </view>

        <view class="form-item">
          <text class="form-label">{{formData.type === 'lost' ? '丢失地点' : '拾取地点'}}</text>
          <picker 
            class="form-picker-wrap"
            mode="selector" 
            range="{{locations}}" 
            range-key="label"
            value="{{locationIndex}}"
            bindchange="onLocationChange"
          >
            <view class="form-picker">
              <text class="picker-text {{formData.location ? '' : 'placeholder'}}">{{formData.location ? locationText : '请选择地点'}}</text>
              <text class="picker-arrow">›</text>
            </view>
          </picker>
        </view>

        <view class="form-item">
          <text class="form-label">{{formData.type === 'lost' ? '丢失时间' : '拾取时间'}}</text>
          <picker 
            class="form-picker-wrap"
            mode="date" 
            value="{{formData.date}}"
            end="{{today}}"
            bindchange="onDateChange"
          >
            <view class="form-picker">
              <text class="picker-text {{formData.date ? '' : 'placeholder'}}">{{formData.date || '请选择日期'}}</text>
              <text class="picker-arrow">›</text>
            </view>
          </picker>
        </view>
      </view>
    </view>

    <!-- 详细描述 -->
    <view class="form-section">
      <view class="section-title">详细描述</view>
      <view class="form-card">
        <textarea 
          class="form-textarea"
          placeholder="请详细描述物品特征，便于失主/拾取者辨认"
          value="{{formData.description}}"
          bindinput="onInputChange"
          data-field="description"
          maxlength="500"
        />
        <text class="textarea-count">{{formData.description.length || 0}}/500</text>
      </view>
    </view>

    <!-- 图片上传 -->
    <view class="form-section">
      <view class="section-title">上传图片（选填）</view>
      <view class="form-card">
        <view class="image-list">
          <view 
            class="image-item"
            wx:for="{{formData.images}}"
            wx:key="index"
          >
            <image class="preview-image" src="{{item}}" mode="aspectFill" />
            <view class="image-delete" catchtap="onDeleteImage" data-index="{{index}}">×</view>
          </view>
          <view 
            class="image-add"
            wx:if="{{formData.images.length < 3}}"
            bindtap="onChooseImage"
          >
            <text class="add-icon">+</text>
            <text class="add-text">添加图片</text>
          </view>
        </view>
        <text class="image-tip">最多上传3张图片</text>
      </view>
    </view>

    <!-- 联系方式 -->
    <view class="form-section">
      <view class="section-title">联系方式</view>
      <view class="form-card">
        <view class="form-item">
          <text class="form-label">联系人</text>
          <input 
            class="form-input" 
            placeholder="请输入联系人姓名"
            value="{{formData.contact}}"
            bindinput="onInputChange"
            data-field="contact"
            maxlength="20"
          />
        </view>
        <view class="form-item no-border">
          <text class="form-label">联系电话</text>
          <input 
            class="form-input" 
            type="number"
            placeholder="请输入联系电话"
            value="{{formData.phone}}"
            bindinput="onInputChange"
            data-field="phone"
            maxlength="11"
          />
        </view>
      </view>
    </view>

    <!-- 提交按钮 -->
    <view class="submit-section">
      <btn type="primary" size="large" block="{{true}}" loading="{{submitting}}" bind:click="onSubmit">
        发布信息
      </btn>
    </view>
  </form>
</view>
