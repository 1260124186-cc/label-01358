<page-meta page-style="background-color: {{darkMode ? '#0F1117' : '#F8F9FA'}}; color: {{darkMode ? '#E8ECF1' : '#2C3E50'}}"/>
<view class="page {{darkMode ? 'dark' : ''}}">
  <form bindsubmit="onSubmit">
    <!-- 类型选择 -->
    <view class="form-section">
      <view class="section-title">信息类型</view>
      <view class="type-selector">
        <view
          class="type-option {{formData.type === 'lost' ? 'active' : ''}}"
          bindtap="onTypeSelect"
          data-type="lost"
        >
          <view class="type-icon lost">🔍</view>
          <text class="type-text">寻物启事</text>
          <text class="type-desc">我丢失了物品</text>
        </view>
        <view
          class="type-option {{formData.type === 'found' ? 'active' : ''}}"
          bindtap="onTypeSelect"
          data-type="found"
        >
          <view class="type-icon found">📦</view>
          <text class="type-text">失物招领</text>
          <text class="type-desc">我捡到了物品</text>
        </view>
      </view>
    </view>

    <!-- 基本信息 -->
    <view class="form-section">
      <view class="section-title">基本信息</view>
      <view class="form-card">
        <view class="form-item">
          <text class="form-label">标题</text>
          <input
            class="form-input"
            placeholder="请输入标题（如：丢失一把钥匙）"
            value="{{formData.title}}"
            bindinput="onInputChange"
            data-field="title"
            maxlength="30"
          />
        </view>

        <view class="form-item">
          <text class="form-label">物品类型</text>
          <picker
            class="form-picker-wrap"
            mode="selector"
            range="{{itemTypes}}"
            range-key="label"
            value="{{itemTypeIndex}}"
            bindchange="onItemTypeChange"
          >
            <view class="form-picker">
              <text class="picker-text {{formData.itemType ? '' : 'placeholder'}}">{{formData.itemType ? itemTypeText : '请选择物品类型'}}</text>
              <text class="picker-arrow">›</text>
            </view>
          </picker>
        </view>

        <view class="form-item">
          <text class="form-label">{{formData.type === 'lost' ? '丢失地点' : '拾取地点'}}</text>
          <view class="location-selector">
            <view class="form-picker" bindtap="onSelectLocation">
              <text class="picker-text {{formData.location ? '' : 'placeholder'}}">{{formData.location ? locationText : '请选择地点'}}</text>
              <text class="picker-arrow">›</text>
            </view>
            <view class="map-location-btn" bindtap="onOpenMapPicker">
              <text class="map-icon">🗺️</text>
              <text class="map-btn-text">地图选点</text>
            </view>
          </view>
        </view>

        <view class="form-item" wx:if="{{selectedPOI}}">
          <view class="poi-location-card" bindtap="onViewPOIOnMap">
            <view class="poi-location-icon" style="background: {{selectedPOI.categoryColor}}20;">
              <text>{{selectedPOI.categoryIcon}}</text>
            </view>
            <view class="poi-location-info">
              <text class="poi-location-name">{{selectedPOI.name}}</text>
              <text class="poi-location-addr">{{selectedPOI.address || '已在地图中标记位置'}}</text>
            </view>
            <view class="poi-location-action">
              <text>查看</text>
              <text class="arrow">›</text>
            </view>
          </view>
        </view>

        <view class="form-item">
          <text class="form-label">{{formData.type === 'lost' ? '丢失时间' : '拾取时间'}}</text>
          <picker
            class="form-picker-wrap"
            mode="date"
            value="{{formData.date}}"
            end="{{today}}"
            bindchange="onDateChange"
          >
            <view class="form-picker">
              <text class="picker-text {{formData.date ? '' : 'placeholder'}}">{{formData.date || '请选择日期'}}</text>
              <text class="picker-arrow">›</text>
            </view>
          </picker>
        </view>
      </view>
    </view>

    <!-- 详细描述 -->
    <view class="form-section">
      <view class="section-title">详细描述</view>
      <view class="form-card">
        <textarea
          class="form-textarea"
          placeholder="请详细描述物品特征，便于失主/拾取者辨认"
          value="{{formData.description}}"
          bindinput="onInputChange"
          data-field="description"
          maxlength="500"
        />
        <text class="textarea-count">{{formData.description.length || 0}}/500</text>
      </view>
    </view>

    <!-- 图片上传 -->
    <view class="form-section">
      <view class="section-title">
        上传图片（选填）
        <view class="ai-switch" bindtap="onToggleAIRecognition">
          <text class="ai-icon">🤖</text>
          <text class="ai-text">AI识别</text>
          <view class="switch {{enableAIRecognition ? 'active' : ''}}">
            <view class="switch-dot"></view>
          </view>
        </view>
      </view>
      <view class="form-card">
        <view class="image-list">
          <view
            class="image-item"
            wx:for="{{formData.images}}"
            wx:key="index"
          >
            <image class="preview-image" src="{{item}}" mode="aspectFill" />
            <view class="image-delete" catchtap="onDeleteImage" data-index="{{index}}">×</view>
            <view class="ai-badge" wx:if="{{enableAIRecognition && aiTags.colors.length > 0}}">
              <text class="ai-badge-icon">✓</text>
            </view>
          </view>
          <view
            class="image-add"
            wx:if="{{formData.images.length < 3}}"
            bindtap="onChooseImage"
          >
            <text class="add-icon">+</text>
            <text class="add-text">添加图片</text>
          </view>
        </view>
        <text class="image-tip">最多上传3张图片{{enableAIRecognition ? '，上传后将自动AI识别特征' : ''}}</text>
        
        <!-- AI识别进度 -->
        <view class="ai-progress" wx:if="{{aiRecognizing}}">
          <view class="ai-progress-bar">
            <view class="ai-progress-fill" style="width: {{aiRecognitionProgress}}%;"></view>
          </view>
          <text class="ai-progress-text">AI正在识别图片特征... {{aiRecognitionProgress}}%</text>
        </view>
        
        <!-- AI识别结果 -->
        <view class="ai-result" wx:if="{{!aiRecognizing && (aiTags.colors.length > 0 || aiTags.brands.length > 0 || aiTags.category)}}">
          <view class="ai-result-header" bindtap="onToggleAIPanel">
            <view class="ai-result-title">
              <text class="ai-result-icon">✨</text>
              <text>AI识别结果</text>
              <text class="ai-confidence">置信度 {{aiRecognitionResult ? (aiRecognitionResult.confidence * 100).toFixed(0) : 0}}%</text>
            </view>
            <text class="ai-toggle {{showAIPanel ? 'expanded' : ''}}">▼</text>
          </view>
          
          <view class="ai-result-content" wx:if="{{showAIPanel}}">
            <view class="ai-tag-section" wx:if="{{aiTags.category}}">
              <text class="ai-tag-label">物品类型</text>
              <view class="ai-tags">
                <view 
                  class="ai-tag category" 
                  bindtap="onApplyTag"
                  data-type="category"
                  data-value="{{aiTags.category.value}}"
                  data-label="{{aiTags.category.label}}"
                >
                  <text class="tag-text">{{aiTags.category.label}}</text>
                  <text class="tag-confidence">{{(aiTags.category.confidence * 100).toFixed(0)}}%</text>
                  <text class="tag-apply">应用</text>
                </view>
              </view>
            </view>
            
            <view class="ai-tag-section" wx:if="{{aiTags.colors.length > 0}}">
              <text class="ai-tag-label">颜色特征</text>
              <view class="ai-tags">
                <view 
                  class="ai-tag color"
                  wx:for="{{aiTags.colors}}"
                  wx:key="value"
                  bindtap="onApplyTag"
                  data-type="color"
                  data-value="{{item.value}}"
                  data-label="{{item.label}}"
                >
                  <text class="tag-text">{{item.label}}</text>
                  <text class="tag-confidence">{{(item.confidence * 100).toFixed(0)}}%</text>
                  <text class="tag-apply">使用</text>
                </view>
              </view>
            </view>
            
            <view class="ai-tag-section" wx:if="{{aiTags.brands.length > 0}}">
              <text class="ai-tag-label">品牌特征</text>
              <view class="ai-tags">
                <view 
                  class="ai-tag brand"
                  wx:for="{{aiTags.brands}}"
                  wx:key="value"
                  bindtap="onApplyTag"
                  data-type="brand"
                  data-value="{{item.value}}"
                  data-label="{{item.label}}"
                >
                  <text class="tag-text">{{item.label}}</text>
                  <text class="tag-confidence">{{(item.confidence * 100).toFixed(0)}}%</text>
                  <text class="tag-apply">使用</text>
                </view>
              </view>
            </view>
            
            <view class="ai-actions">
              <view class="ai-action-btn" bindtap="onReRecognize">
                <text class="action-icon">🔄</text>
                <text>重新识别</text>
              </view>
              <view class="ai-action-btn danger" bindtap="onClearAITags">
                <text class="action-icon">🗑️</text>
                <text>清除标签</text>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 联系方式 -->
    <view class="form-section">
      <view class="section-title">联系方式</view>
      <view class="form-card">
        <view class="form-item">
          <text class="form-label">联系人</text>
          <input
            class="form-input"
            placeholder="请输入联系人姓名"
            value="{{formData.contact}}"
            bindinput="onInputChange"
            data-field="contact"
            maxlength="20"
          />
        </view>
        <view class="form-item no-border">
          <text class="form-label">联系电话</text>
          <input
            class="form-input"
            type="number"
            placeholder="请输入联系电话"
            value="{{formData.phone}}"
            bindinput="onInputChange"
            data-field="phone"
            maxlength="11"
          />
        </view>
      </view>
    </view>

    <!-- 提交按钮 -->
    <view class="submit-section">
      <btn type="primary" size="large" block="{{true}}" loading="{{submitting}}" bind:click="onSubmit">
        {{mode === 'edit' ? '保存修改' : '发布信息'}}
      </btn>
    </view>
  </form>

  <!-- POI 选择器弹窗 -->
  <view class="poi-picker" wx:if="{{showPOIPicker}}">
    <view class="picker-mask" bindtap="onClosePOIPicker"></view>
    <view class="picker-content">
      <view class="picker-header">
        <text class="picker-title">选择地点</text>
        <view class="picker-close" bindtap="onClosePOIPicker">
          <text>✕</text>
        </view>
      </view>
      <view class="picker-search">
        <text class="search-icon">🔍</text>
        <input
          class="search-input"
          placeholder="搜索地点..."
          value="{{poiSearchKeyword}}"
          bindinput="onPOISearchInput"
        />
      </view>
      <scroll-view class="picker-list" scroll-y="{{true}}">
        <view
          class="picker-item"
          wx:for="{{poiList}}"
          wx:key="id"
          bindtap="onPOIPickerSelect"
          data-poi="{{item}}"
        >
          <view class="picker-icon" style="background: {{item.categoryColor}}20;">
            <text>{{item.categoryIcon}}</text>
          </view>
          <view class="picker-info">
            <text class="picker-name">{{item.name}}</text>
            <text class="picker-category">{{item.categoryLabel}}</text>
          </view>
          <text class="picker-arrow">›</text>
        </view>
      </scroll-view>
    </view>
  </view>
</view>
