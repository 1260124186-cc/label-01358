/* 发布失物招领 - 与首页风格统一 */
.page {
  min-height: 100vh;
  background-color: var(--color-bg-page);
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.form-section {
  padding: 24rpx 24rpx 0;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-secondary);
  margin-bottom: 16rpx;
  padding-left: 8rpx;
}

/* ==================== 类型选择 ==================== */
.type-selector {
  display: flex;
}

.type-selector > * { margin-right: 20rpx; }

.type-selector > *:last-child { margin-right: 0; }

.type-option {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 20rpx;
  background-color: var(--color-bg-card);
  border-radius: var(--radius-xl);
  border: 3rpx solid transparent;
  box-shadow: var(--shadow-card);
  transition: all var(--transition-normal);
}

.type-option:active {
  transform: scale(0.98);
}

.type-option.active {
  border-color: var(--color-primary);
  background: linear-gradient(135deg, rgba(255, 107, 107, 0.08) 0%, rgba(255, 142, 142, 0.05) 100%);
}

.type-icon {
  font-size: 52rpx;
  margin-bottom: 14rpx;
}

.type-text {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  margin-bottom: 6rpx;
}

.type-desc {
  font-size: 24rpx;
  color: var(--color-text-muted);
}

/* ==================== 表单卡片 ==================== */
.form-card {
  background-color: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: 0 24rpx;
  box-shadow: var(--shadow-card);
}

.form-item {
  display: flex;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 1rpx solid var(--color-border-light);
}

.form-item.no-border {
  border-bottom: none;
}

.form-label {
  min-width: 140rpx;
  max-width: 180rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: var(--color-text-primary);
  flex-shrink: 0;
  white-space: nowrap;
  line-height: 40rpx;
}

.form-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--color-text-primary);
  text-align: right;
  line-height: 40rpx;
  height: 40rpx;
}

.form-input::placeholder {
  color: var(--color-text-muted);
}

/* picker组件需要占满剩余空间 */
.form-picker-wrap {
  flex: 1;
}

.form-picker {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  height: 40rpx;
}

.picker-text {
  font-size: 28rpx;
  color: var(--color-text-primary);
  line-height: 40rpx;
}

.picker-text.placeholder {
  color: var(--color-text-muted);
}

.picker-arrow {
  font-size: 28rpx;
  color: var(--color-text-muted);
  margin-left: 8rpx;
  line-height: 40rpx;
}

/* ==================== 文本域 ==================== */
.form-textarea {
  width: 100%;
  min-height: 200rpx;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: var(--color-text-primary);
  line-height: 1.7;
}

.form-textarea::placeholder {
  color: var(--color-text-muted);
}

.textarea-count {
  display: block;
  text-align: right;
  font-size: 24rpx;
  color: var(--color-text-muted);
  padding-bottom: 16rpx;
}

/* ==================== 图片上传 ==================== */
.image-list {
  display: flex;
  flex-wrap: wrap;
  padding: 24rpx 0;
}

.image-list { margin-right: -16rpx; margin-bottom: -16rpx; }

.image-list > * { margin-right: 16rpx; margin-bottom: 16rpx; }

.image-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
}

.preview-image {
  width: 100%;
  height: 100%;
  border-radius: var(--radius-lg);
}

.image-delete {
  position: absolute;
  top: -12rpx;
  right: -12rpx;
  width: 44rpx;
  height: 44rpx;
  background: linear-gradient(135deg, #E74C3C 0%, #EC7063 100%);
  color: #FFFFFF;
  font-size: 28rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(231, 76, 60, 0.4);
}

.image-add {
  width: 200rpx;
  height: 200rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: var(--color-bg-input);
  border: 2rpx dashed var(--color-border);
  border-radius: var(--radius-lg);
  transition: all var(--transition-fast);
}

.image-add:active {
  background-color: var(--color-border);
}

.add-icon {
  font-size: 48rpx;
  color: var(--color-text-muted);
  line-height: 1;
}

.add-text {
  font-size: 24rpx;
  color: var(--color-text-muted);
  margin-top: 10rpx;
}

.image-tip {
  font-size: 24rpx;
  color: var(--color-text-muted);
  padding-bottom: 16rpx;
}

/* ==================== 提交按钮 ==================== */
.submit-section {
  padding: 40rpx 24rpx;
}

/* ==================== 地图选点 ==================== */
.location-selector {
  flex: 1;
  display: flex;
  align-items: center;
}

.location-selector > * { margin-right: 16rpx; }

.location-selector > *:last-child { margin-right: 0; }

.location-selector .form-picker {
  flex: 1;
}

.map-location-btn {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: linear-gradient(135deg, #CFFAFE 0%, #A5F3FC 100%);
  border-radius: 24rpx;
  flex-shrink: 0;
}

.map-location-btn > * { margin-right: 8rpx; }

.map-location-btn > *:last-child { margin-right: 0; }

.map-icon {
  font-size: 28rpx;
}

.map-btn-text {
  font-size: 24rpx;
  color: #0891B2;
  font-weight: 500;
}

.poi-location-card {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #F0F9FF;
  border-radius: 16rpx;
  flex: 1;
}

.poi-location-card > * { margin-right: 20rpx; }

.poi-location-card > *:last-child { margin-right: 0; }

.page.dark .poi-location-card {
  background: rgba(59, 130, 246, 0.1);
}

.poi-location-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.poi-location-icon text {
  font-size: 32rpx;
}

.poi-location-info {
  flex: 1;
  min-width: 0;
}

.poi-location-name {
  font-size: 28rpx;
  color: #0369A1;
  font-weight: 500;
  display: block;
  margin-bottom: 6rpx;
}

.page.dark .poi-location-name {
  color: #60A5FA;
}

.poi-location-addr {
  font-size: 24rpx;
  color: #64748B;
}

.page.dark .poi-location-addr {
  color: #94A3B8;
}

.poi-location-action {
  display: flex;
  align-items: center;
  flex-shrink: 0;
}

.poi-location-action > * { margin-right: 4rpx; }

.poi-location-action > *:last-child { margin-right: 0; }

.poi-location-action text {
  font-size: 24rpx;
  color: #3B82F6;
}

.poi-location-action .arrow {
  font-size: 28rpx;
}

/* ==================== POI 选择器弹窗 ==================== */
.poi-picker {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
}

.picker-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.picker-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  max-height: 70vh;
  display: flex;
  flex-direction: column;
}

.page.dark .picker-content {
  background: #1E2230;
}

.picker-header {
  padding: 32rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1rpx solid #F0F2F5;
}

.page.dark .picker-header {
  border-bottom-color: #2D3142;
}

.picker-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2C3E50;
}

.page.dark .picker-title {
  color: #E8ECF1;
}

.picker-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.picker-close text {
  font-size: 32rpx;
  color: #95A5A6;
}

.picker-search {
  padding: 24rpx 32rpx;
  display: flex;
  align-items: center;
  background: #F8F9FA;
  margin: 24rpx 32rpx;
  border-radius: 16rpx;
}

.picker-search > * { margin-right: 16rpx; }

.picker-search > *:last-child { margin-right: 0; }

.page.dark .picker-search {
  background: #2D3142;
}

.search-icon {
  font-size: 28rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #2C3E50;
}

.page.dark .search-input {
  color: #E8ECF1;
}

.picker-list {
  flex: 1;
  padding: 0 32rpx 32rpx;
}

.picker-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #F0F2F5;
}

.picker-item > * { margin-right: 20rpx; }

.picker-item > *:last-child { margin-right: 0; }

.page.dark .picker-item {
  border-bottom-color: #2D3142;
}

.picker-item:last-child {
  border-bottom: none;
}

.picker-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.picker-icon text {
  font-size: 36rpx;
}

.picker-info {
  flex: 1;
  min-width: 0;
}

.picker-name {
  font-size: 28rpx;
  color: #2C3E50;
  display: block;
  margin-bottom: 6rpx;
}

.page.dark .picker-name {
  color: #E8ECF1;
}

.picker-category {
  font-size: 24rpx;
  color: #95A5A6;
}

.picker-arrow {
  font-size: 32rpx;
  color: #BDC3C7;
}
