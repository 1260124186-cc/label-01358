<page-meta page-style="background-color: {{darkMode ? '#0F1117' : '#F8F9FA'}}; color: {{darkMode ? '#E8ECF1' : '#2C3E50'}}"/>
<view class="page {{darkMode ? 'dark' : ''}}">
  <!-- 顶部积分卡片 -->
  <view class="header-section">
    <view class="points-card">
      <view class="points-info">
        <view class="points-label">我的积分</view>
        <view class="points-value">{{userPoints}}</view>
      </view>
      <view class="points-action">
        <text class="points-action-text">积分明细</text>
        <text class="points-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- Tab 切换 -->
  <view class="tabs-section">
    <view class="tabs-container">
      <view
        class="tab-item {{currentTab === item.value ? 'active' : ''}}"
        wx:for="{{tabs}}"
        wx:key="value"
        bindtap="onTabChange"
        data-tab="{{item.value}}"
      >
        <text class="tab-text">{{item.label}}</text>
        <view class="tab-indicator" wx:if="{{currentTab === item.value}}"></view>
      </view>
    </view>
    <view class="filter-btn" bindtap="onShowStatusPicker">
      <text class="filter-btn-text">{{currentStatusText}}</text>
      <text class="filter-btn-arrow">▼</text>
    </view>
  </view>

  <!-- 列表区域 -->
  <scroll-view
    class="list-scroll"
    scroll-y="{{true}}"
    refresher-enabled="{{true}}"
    refresher-triggered="{{refreshing}}"
    bindrefresherrefresh="onListRefresh"
    bindscrolltolower="onListLoadMore"
    lower-threshold="50"
  >
    <!-- 骨架屏 -->
    <skeleton
      wx:if="{{showSkeleton}}"
      type="{{skeletonConfig.type}}"
      count="{{skeletonConfig.count}}"
      loading="{{true}}"
    />

    <!-- 列表内容 -->
    <view class="list-container" wx:if="{{!showSkeleton && list.length > 0}}">
      <view
        class="reward-card"
        wx:for="{{list}}"
        wx:key="id"
        hover-class="reward-card-hover"
        bindtap="onItemTap"
        data-item="{{item}}"
      >
        <view class="card-header">
          <view class="card-title">
            <text class="title-text">{{item.title}}</text>
          </view>
          <view class="status-tag" style="background-color: {{item.statusColor}}20; color: {{item.statusColor}};">
            {{item.statusText}}
          </view>
        </view>

        <view class="card-meta">
          <view class="meta-item">
            <text class="meta-icon">{{item.categoryIcon}}</text>
            <text class="meta-text">{{item.categoryText}}</text>
          </view>
          <view class="meta-item" wx:if="{{item.courseName}}">
            <text class="meta-icon">📖</text>
            <text class="meta-text">{{item.courseName}}</text>
          </view>
        </view>

        <view class="card-footer">
          <view class="reward-points">
            <text class="points-icon">💰</text>
            <text class="points-value">{{item.rewardPoints}}</text>
            <text class="points-label">积分</text>
          </view>
          <view class="card-stats">
            <view class="stat-item">
              <text class="stat-icon">💬</text>
              <text class="stat-text">{{item.responseCount}}回答</text>
            </view>
          </view>
        </view>

        <view class="card-publisher">
          <view class="publisher-info">
            <text class="publisher-credit-icon" style="color: {{item.creditColor}};">{{item.creditIcon}}</text>
            <text class="publisher-name">{{item.publisherName}}</text>
            <text class="publisher-credit" style="color: {{item.creditColor}};">{{item.creditLabel}}</text>
          </view>
          <text class="publish-time">{{item.timeText}}</text>
        </view>

        <view class="my-response-badge" wx:if="{{item.isAnswered && item.myResponseAdopted}}">
          <text class="badge-icon">✅</text>
          <text class="badge-text">我的回答已采纳</text>
        </view>
        <view class="my-response-badge pending" wx:elif="{{item.isAnswered}}">
          <text class="badge-icon">💬</text>
          <text class="badge-text">我已回答，待采纳</text>
        </view>
      </view>
    </view>

    <!-- 加载更多 -->
    <view class="load-more" wx:if="{{!showSkeleton && list.length > 0}}">
      <view class="load-more-loading" wx:if="{{loadingMore}}">
        <view class="loading-spinner"></view>
        <text class="load-more-text">加载中...</text>
      </view>
      <view class="load-more-no-more" wx:elif="{{noMore}}">
        <text class="load-more-text">没有更多了</text>
      </view>
      <view class="load-more-tip" wx:else>
        <text class="load-more-text">上拉加载更多</text>
      </view>
    </view>

    <!-- 空状态 -->
    <empty
      wx:if="{{!showSkeleton && !loading && list.length === 0}}"
      image="{{emptyConfig.image}}"
      text="{{emptyConfig.text}}"
      showAction="{{emptyConfig.showAction}}"
      actionText="{{emptyConfig.actionText}}"
      bindaction="onEmptyAction"
    />
  </scroll-view>

  <!-- 状态选择器 -->
  <view class="picker-mask {{showStatusPicker ? 'show' : ''}}" bindtap="onHideStatusPicker">
    <view class="picker-content" catchtap="stopPropagation">
      <view class="picker-header">
        <text class="picker-title">选择状态</text>
        <text class="picker-close" bindtap="onHideStatusPicker">×</text>
      </view>
      <view class="picker-options">
        <view
          class="picker-option {{currentStatus === '' ? 'active' : ''}}"
          bindtap="onStatusSelect"
          data-value=""
        >全部状态</view>
        <view
          class="picker-option {{currentStatus === item.value ? 'active' : ''}}"
          wx:for="{{statusFilters}}"
          wx:key="value"
          wx:if="{{item.value !== ''}}"
          bindtap="onStatusSelect"
          data-value="{{item.value}}"
        >
          <view class="status-dot" style="background-color: {{item.color}};"></view>
          <text class="option-label">{{item.label}}</text>
        </view>
      </view>
    </view>
  </view>
</view>
