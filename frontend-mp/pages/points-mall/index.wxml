<page-meta page-style="background-color: {{darkMode ? '#0F1117' : '#F8F9FA'}}; color: {{darkMode ? '#E8ECF1' : '#2C3E50'}}"/>
<view class="page {{darkMode ? 'dark' : ''}}">
  <view class="header-card">
    <view class="header-bg"></view>
    <view class="header-content">
      <view class="points-row">
        <view class="points-info">
          <text class="points-label">我的积分</text>
          <text class="points-value">{{currentPoints}}</text>
          <view class="expiring-notice" wx:if="{{expiringPoints && expiringPoints.amount > 0}}">
            <text class="expiring-text">⚠️ 即将过期 {{expiringPoints.amount}} 积分</text>
          </view>
        </view>
        <view class="header-actions">
          <view class="header-action" bindtap="goHistory">
            <text class="action-icon">📋</text>
            <text class="action-text">流水</text>
          </view>
          <view class="header-action" bindtap="goTasks">
            <text class="action-icon">🎯</text>
            <text class="action-text">任务</text>
          </view>
        </view>
      </view>

      <view class="tab-row">
        <view 
          class="tab-item {{!showOrdersTab ? 'active' : ''}}" 
          data-tab="mall" 
          bindtap="switchTab"
        >
          <text class="tab-text">积分商城</text>
        </view>
        <view 
          class="tab-item {{showOrdersTab ? 'active' : ''}}" 
          data-tab="orders" 
          bindtap="switchTab"
        >
          <text class="tab-text">我的订单</text>
        </view>
      </view>
    </view>
  </view>

  <view class="content" wx:if="{{!showOrdersTab}}">
    <scroll-view class="category-scroll" scroll-x="{{true}}" show-scrollbar="{{false}}">
      <view 
        class="category-item {{item.value === activeCategory ? 'active' : ''}}" 
        wx:for="{{categories}}" 
        wx:key="value"
        data-category="{{item.value}}"
        bindtap="switchCategory"
      >
        <text class="category-icon">{{item.icon}}</text>
        <text class="category-label">{{item.label}}</text>
      </view>
    </scroll-view>

    <view class="products-grid">
      <view 
        class="product-card" 
        wx:for="{{filteredProducts}}" 
        wx:key="id"
        data-product="{{item}}"
        bindtap="openExchangeModal"
      >
        <view class="product-image">
          <text class="product-emoji">{{item.icon}}</text>
          <view class="product-tag" wx:if="{{item.tag}}">
            <text>{{item.tag}}</text>
          </view>
          <view class="product-sold-out" wx:if="{{item.stock !== undefined && item.stock <= 0}}">
            <text>已兑换完毕</text>
          </view>
        </view>
        <view class="product-info">
          <text class="product-name">{{item.name}}</text>
          <text class="product-desc">{{item.description}}</text>
          <view class="product-footer">
            <view class="product-price">
              <text class="price-value">{{item.price}}</text>
              <text class="price-unit">积分</text>
            </view>
            <view class="product-btn {{item.stock !== undefined && item.stock <= 0 ? 'disabled' : ''}}">
              <text>立即兑换</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="empty-state" wx:if="{{filteredProducts.length === 0 && !loading}}">
      <text class="empty-icon">📦</text>
      <text class="empty-text">该分类暂无商品</text>
    </view>
  </view>

  <view class="orders-content" wx:if="{{showOrdersTab}}">
    <view class="orders-list" wx:if="{{userOrders.length > 0}}">
      <view 
        class="order-item" 
        wx:for="{{userOrders}}" 
        wx:key="id"
        data-order="{{item}}"
        bindtap="showOrderDetail"
      >
        <view class="order-header">
          <text class="order-icon">{{item.productIcon}}</text>
          <view class="order-info">
            <text class="order-name">{{item.productName}}</text>
            <text class="order-time">{{item.createTime}}</text>
          </view>
          <view class="order-status status-{{item.status}}">
            <text>{{item.status === 'pending' ? '待使用' : item.status === 'used' ? '已使用' : item.status === 'expired' ? '已过期' : '已退款'}}</text>
          </view>
        </view>
        <view class="order-details">
          <text class="order-points">-{{item.totalPoints}}积分</text>
          <text class="order-quantity">x{{item.quantity}}</text>
        </view>
        <view class="order-actions" wx:if="{{item.status === 'pending'}}">
          <view class="use-btn" data-order="{{item}}" catchtap="useCoupon">
            <text>{{item.type === 'coupon' ? '复制券码' : '去使用'}}</text>
          </view>
        </view>
        <view class="coupon-code" wx:if="{{item.couponCode && item.status === 'pending'}}">
          <text class="code-label">券码：</text>
          <text class="code-value">{{item.couponCode}}</text>
        </view>
      </view>
    </view>

    <view class="empty-state" wx:if="{{userOrders.length === 0 && !loading}}">
      <text class="empty-icon">📭</text>
      <text class="empty-text">暂无兑换记录</text>
      <view class="empty-btn" data-tab="mall" bindtap="switchTab">
        <text>去兑换</text>
      </view>
    </view>
  </view>

  <view class="exchange-modal {{showExchangeModal ? 'show' : ''}}">
    <view class="modal-mask" bindtap="closeExchangeModal"></view>
    <view class="modal-content">
      <view class="modal-header">
        <text class="modal-title">确认兑换</text>
        <view class="modal-close" bindtap="closeExchangeModal">
          <text>✕</text>
        </view>
      </view>
      <view class="modal-body" wx:if="{{selectedProduct}}">
        <view class="exchange-product">
          <view class="exchange-image">
            <text class="exchange-emoji">{{selectedProduct.icon}}</text>
          </view>
          <view class="exchange-info">
            <text class="exchange-name">{{selectedProduct.name}}</text>
            <text class="exchange-desc">{{selectedProduct.description}}</text>
            <view class="exchange-price">
              <text class="price-value">{{selectedProduct.price}}</text>
              <text class="price-unit">积分 / {{selectedProduct.unit || '件'}}</text>
            </view>
          </view>
        </view>

        <view class="quantity-section">
          <text class="quantity-label">兑换数量</text>
          <view class="quantity-control">
            <view class="quantity-btn" data-type="minus" bindtap="changeQuantity">
              <text>-</text>
            </view>
            <text class="quantity-value">{{exchangeQuantity}}</text>
            <view class="quantity-btn" data-type="plus" bindtap="changeQuantity">
              <text>+</text>
            </view>
          </view>
        </view>

        <view class="total-section">
          <text class="total-label">合计积分</text>
          <text class="total-value">{{selectedProduct.price * exchangeQuantity}}</text>
        </view>

        <view class="balance-section">
          <text class="balance-label">当前积分：</text>
          <text class="balance-value {{currentPoints < selectedProduct.price * exchangeQuantity ? 'insufficient' : ''}}">
            {{currentPoints}}
          </text>
          <text class="balance-result" wx:if="{{currentPoints >= selectedProduct.price * exchangeQuantity}}">
            兑换后剩余：{{currentPoints - selectedProduct.price * exchangeQuantity}}
          </text>
          <text class="balance-result insufficient" wx:else>
            积分不足，还差 {{selectedProduct.price * exchangeQuantity - currentPoints}} 积分
          </text>
        </view>
      </view>
      <view class="modal-footer">
        <view class="modal-btn cancel" bindtap="closeExchangeModal">
          <text>取消</text>
        </view>
        <view class="modal-btn confirm" bindtap="confirmExchange">
          <text>确认兑换</text>
        </view>
      </view>
    </view>
  </view>

  <view class="loading-state" wx:if="{{loading}}">
    <text class="loading-icon">⏳</text>
    <text class="loading-text">加载中...</text>
  </view>

  <view class="rules-entry" bindtap="goRules">
    <text class="rules-icon">📖</text>
    <text class="rules-text">查看积分规则说明</text>
    <text class="rules-arrow">›</text>
  </view>

  <view class="bottom-space"></view>
</view>
