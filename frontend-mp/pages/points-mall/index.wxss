.page {
  min-height: 100vh;
  background-color: #F8F9FA;
  padding-bottom: 40rpx;
}

.page.dark {
  background-color: #0F1117;
}

.header-card {
  position: relative;
  margin: 0;
  border-radius: 0 0 32rpx 32rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 50%, #FFA726 100%);
}

.header-content {
  position: relative;
  padding: 32rpx;
  padding-top: 48rpx;
}

.points-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.points-info {
  display: flex;
  flex-direction: column;
}

.points-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-bottom: 8rpx;
}

.points-value {
  font-size: 72rpx;
  font-weight: 700;
  color: #FFFFFF;
  line-height: 1;
}

.expiring-notice {
  margin-top: 12rpx;
  padding: 6rpx 16rpx;
  background: rgba(255, 215, 0, 0.3);
  border-radius: 20rpx;
  align-self: flex-start;
}

.expiring-text {
  font-size: 22rpx;
  color: #FFD700;
}

.header-actions {
  display: flex;
  gap: 16rpx;
}

.header-action {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 20rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
  min-width: 100rpx;
}

.action-icon {
  font-size: 32rpx;
  margin-bottom: 4rpx;
}

.action-text {
  font-size: 22rpx;
  color: #FFFFFF;
}

.tab-row {
  display: flex;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 40rpx;
  padding: 6rpx;
}

.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx;
  border-radius: 36rpx;
  transition: all 0.3s ease;
}

.tab-item.active {
  background: #FFFFFF;
}

.tab-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  font-weight: 500;
}

.tab-item.active .tab-text {
  color: #FF6B6B;
  font-weight: 600;
}

.content {
  padding: 24rpx;
}

.category-scroll {
  white-space: nowrap;
  margin-bottom: 24rpx;
}

.category-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 24rpx;
  margin-right: 16rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.page.dark .category-item {
  background: #1E2128;
}

.category-item.active {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
}

.category-icon {
  font-size: 32rpx;
  margin-bottom: 4rpx;
}

.category-label {
  font-size: 24rpx;
  color: #666666;
}

.page.dark .category-label {
  color: #8B95A7;
}

.category-item.active .category-label {
  color: #FFFFFF;
}

.products-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.product-card {
  width: calc(50% - 10rpx);
  background: #FFFFFF;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.page.dark .product-card {
  background: #1E2128;
}

.product-image {
  position: relative;
  height: 180rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #FFF5F5 0%, #FFE8E8 100%);
}

.product-emoji {
  font-size: 80rpx;
}

.product-tag {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  padding: 4rpx 12rpx;
  background: #FF6B6B;
  border-radius: 16rpx;
}

.product-tag text {
  font-size: 20rpx;
  color: #FFFFFF;
}

.product-sold-out {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
}

.product-sold-out text {
  font-size: 28rpx;
  color: #FFFFFF;
  font-weight: 600;
}

.product-info {
  padding: 16rpx;
}

.product-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 8rpx;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.page.dark .product-name {
  color: #E8ECF1;
}

.product-desc {
  font-size: 22rpx;
  color: #999999;
  margin-bottom: 16rpx;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.page.dark .product-desc {
  color: #8B95A7;
}

.product-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.product-price {
  display: flex;
  align-items: baseline;
}

.price-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #FF6B6B;
}

.price-unit {
  font-size: 22rpx;
  color: #FF6B6B;
  margin-left: 4rpx;
}

.product-btn {
  padding: 8rpx 16rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  border-radius: 20rpx;
}

.product-btn text {
  font-size: 22rpx;
  color: #FFFFFF;
  font-weight: 500;
}

.product-btn.disabled {
  background: #E0E0E0;
}

.page.dark .product-btn.disabled {
  background: #3A3F4B;
}

.product-btn.disabled text {
  color: #999999;
}

.orders-content {
  padding: 24rpx;
}

.orders-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.order-item {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.page.dark .order-item {
  background: #1E2128;
}

.order-header {
  display: flex;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.order-icon {
  font-size: 48rpx;
  margin-right: 16rpx;
}

.order-info {
  flex: 1;
  min-width: 0;
}

.order-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  display: block;
  margin-bottom: 4rpx;
}

.page.dark .order-name {
  color: #E8ECF1;
}

.order-time {
  font-size: 22rpx;
  color: #999999;
}

.page.dark .order-time {
  color: #8B95A7;
}

.order-status {
  padding: 4rpx 12rpx;
  border-radius: 16rpx;
  margin-left: 12rpx;
}

.order-status text {
  font-size: 20rpx;
  font-weight: 500;
}

.order-status.status-pending {
  background: #E8F5E9;
}

.order-status.status-pending text {
  color: #4CAF50;
}

.order-status.status-used {
  background: #E3F2FD;
}

.order-status.status-used text {
  color: #2196F3;
}

.order-status.status-expired {
  background: #FFEBEE;
}

.order-status.status-expired text {
  color: #F44336;
}

.order-status.status-refunded {
  background: #F5F5F5;
}

.order-status.status-refunded text {
  color: #999999;
}

.order-details {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid #F0F0F0;
}

.page.dark .order-details {
  border-top-color: #2A2E37;
}

.order-points {
  font-size: 26rpx;
  font-weight: 600;
  color: #FF6B6B;
}

.order-quantity {
  font-size: 24rpx;
  color: #999999;
}

.page.dark .order-quantity {
  color: #8B95A7;
}

.order-actions {
  margin-top: 16rpx;
  display: flex;
  justify-content: flex-end;
}

.use-btn {
  padding: 10rpx 24rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  border-radius: 24rpx;
}

.use-btn text {
  font-size: 24rpx;
  color: #FFFFFF;
  font-weight: 500;
}

.coupon-code {
  margin-top: 16rpx;
  padding: 12rpx 16rpx;
  background: #FFF5F5;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
}

.page.dark .coupon-code {
  background: #2A1F1F;
}

.code-label {
  font-size: 24rpx;
  color: #999999;
}

.page.dark .code-label {
  color: #8B95A7;
}

.code-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #FF6B6B;
  letter-spacing: 2rpx;
}

.exchange-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.exchange-modal.show {
  opacity: 1;
  visibility: visible;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.modal-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  max-height: 80vh;
  overflow-y: auto;
}

.page.dark .modal-content {
  background: #1E2128;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.page.dark .modal-header {
  border-bottom-color: #2A2E37;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.page.dark .modal-title {
  color: #E8ECF1;
}

.modal-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-close text {
  font-size: 32rpx;
  color: #999999;
}

.modal-body {
  padding: 24rpx 32rpx;
}

.exchange-product {
  display: flex;
  margin-bottom: 32rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.page.dark .exchange-product {
  border-bottom-color: #2A2E37;
}

.exchange-image {
  width: 140rpx;
  height: 140rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #FFF5F5 0%, #FFE8E8 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.exchange-emoji {
  font-size: 64rpx;
}

.exchange-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.exchange-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 8rpx;
}

.page.dark .exchange-name {
  color: #E8ECF1;
}

.exchange-desc {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 12rpx;
}

.page.dark .exchange-desc {
  color: #8B95A7;
}

.exchange-price {
  display: flex;
  align-items: baseline;
}

.quantity-section {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.quantity-label {
  font-size: 28rpx;
  color: #333333;
}

.page.dark .quantity-label {
  color: #E8ECF1;
}

.quantity-control {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.quantity-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #F5F5F5;
  display: flex;
  align-items: center;
  justify-content: center;
}

.page.dark .quantity-btn {
  background: #2A2E37;
}

.quantity-btn text {
  font-size: 36rpx;
  color: #666666;
  font-weight: 500;
}

.page.dark .quantity-btn text {
  color: #8B95A7;
}

.quantity-value {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  min-width: 60rpx;
  text-align: center;
}

.page.dark .quantity-value {
  color: #E8ECF1;
}

.total-section {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  margin-bottom: 16rpx;
  border-top: 1rpx solid #F0F0F0;
  border-bottom: 1rpx solid #F0F0F0;
}

.page.dark .total-section {
  border-top-color: #2A2E37;
  border-bottom-color: #2A2E37;
}

.total-label {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
}

.page.dark .total-label {
  color: #E8ECF1;
}

.total-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #FF6B6B;
}

.balance-section {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 8rpx;
}

.balance-label {
  font-size: 24rpx;
  color: #999999;
}

.page.dark .balance-label {
  color: #8B95A7;
}

.balance-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #4CAF50;
}

.balance-value.insufficient {
  color: #F44336;
}

.balance-result {
  width: 100%;
  font-size: 22rpx;
  color: #4CAF50;
}

.balance-result.insufficient {
  color: #F44336;
}

.modal-footer {
  display: flex;
  gap: 24rpx;
  padding: 24rpx 32rpx;
  padding-bottom: 48rpx;
}

.modal-btn {
  flex: 1;
  padding: 24rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-btn.cancel {
  background: #F5F5F5;
}

.page.dark .modal-btn.cancel {
  background: #2A2E37;
}

.modal-btn.cancel text {
  font-size: 28rpx;
  color: #666666;
}

.page.dark .modal-btn.cancel text {
  color: #8B95A7;
}

.modal-btn.confirm {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
}

.modal-btn.confirm text {
  font-size: 28rpx;
  color: #FFFFFF;
  font-weight: 600;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
  margin-bottom: 32rpx;
}

.page.dark .empty-text {
  color: #8B95A7;
}

.empty-btn {
  padding: 16rpx 48rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  border-radius: 40rpx;
}

.empty-btn text {
  font-size: 28rpx;
  color: #FFFFFF;
  font-weight: 500;
}

.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}

.loading-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #999999;
}

.page.dark .loading-text {
  color: #8B95A7;
}

.rules-entry {
  display: flex;
  align-items: center;
  margin: 24rpx;
  padding: 24rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.page.dark .rules-entry {
  background: #1E2128;
}

.rules-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.rules-text {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
}

.page.dark .rules-text {
  color: #E8ECF1;
}

.rules-arrow {
  font-size: 32rpx;
  color: #999999;
}

.bottom-space {
  height: 40rpx;
}
