.page {
  min-height: 100vh;
  background-color: var(--color-bg-page);
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
}

.filter-section {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background-color: var(--color-bg-card);
  border-bottom: 1rpx solid var(--color-border-light);
  position: sticky;
  top: 0;
  z-index: 100;
}

.filter-scroll {
  flex: 1;
  white-space: nowrap;
}

.filter-tabs {
  display: inline-flex;
}

.filter-tabs > * { margin-right: 12rpx; }

.filter-tabs > *:last-child { margin-right: 0; }

.filter-tab {
  display: inline-block;
  padding: 14rpx 24rpx;
  font-size: 26rpx;
  font-weight: 500;
  color: var(--color-text-secondary);
  background-color: var(--color-bg-input);
  border-radius: var(--radius-full);
  transition: all var(--transition-fast);
}

.filter-tab:active {
  transform: scale(0.96);
}

.filter-tab.active {
  color: #FFFFFF;
  background: linear-gradient(135deg, var(--color-primary) 0%, #FF8E8E 100%);
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 107, 0.3);
}

.list-scroll {
  height: calc(100vh - 100rpx);
}

.list-container {
  padding: 16rpx 24rpx;
}

.survey-card {
  margin-bottom: 20rpx;
  transition: all var(--transition-fast);
}

.survey-card-hover {
  transform: scale(0.98);
  box-shadow: var(--shadow-sm);
}

.survey-header {
  margin-bottom: 20rpx;
}

.survey-title-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.survey-title-row > * { margin-right: 16rpx; }

.survey-title-row > *:last-child { margin-right: 0; }

.survey-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  line-height: 1.4;
  flex: 1;
}

.survey-status {
  flex-shrink: 0;
  padding: 6rpx 16rpx;
  font-size: 22rpx;
  font-weight: 600;
  border-radius: var(--radius-sm);
}

.survey-status.active {
  color: #2ECC71;
  background-color: rgba(46, 204, 113, 0.1);
}

.survey-status.closed {
  color: #95A5A6;
  background-color: rgba(149, 165, 166, 0.1);
}

.survey-desc {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.5;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.survey-meta {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.survey-meta > * { margin-right: 24rpx; }

.survey-meta > *:last-child { margin-right: 0; }

.meta-item {
  display: flex;
  align-items: center;
}

.meta-item > * { margin-right: 6rpx; }

.meta-item > *:last-child { margin-right: 0; }

.meta-icon {
  font-size: 24rpx;
}

.meta-text {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.survey-actions {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--color-border-light);
}

.action-left {
  display: flex;
  align-items: center;
}

.action-left > * { margin-right: 12rpx; }

.action-left > *:last-child { margin-right: 0; }

.responded-tag {
  padding: 6rpx 16rpx;
  font-size: 22rpx;
  font-weight: 500;
  color: var(--color-info);
  background-color: rgba(52, 152, 219, 0.1);
  border-radius: var(--radius-sm);
}

.action-right {
  display: flex;
  align-items: center;
}

.action-right > * { margin-right: 12rpx; }

.action-right > *:last-child { margin-right: 0; }

.action-btn {
  padding: 8rpx 20rpx;
  font-size: 24rpx;
  font-weight: 500;
  border-radius: var(--radius-sm);
  transition: all var(--transition-fast);
}

.action-btn:active {
  transform: scale(0.95);
}

.result-btn {
  color: var(--color-primary);
  background-color: var(--color-primary-light);
}

.close-btn {
  color: var(--color-warning);
  background-color: rgba(243, 156, 18, 0.1);
}

.delete-btn {
  color: var(--color-danger);
  background-color: rgba(231, 76, 60, 0.1);
}

.create-btn {
  position: fixed;
  right: 32rpx;
  bottom: calc(200rpx + env(safe-area-inset-bottom));
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, var(--color-primary) 0%, #FF8E8E 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(255, 107, 107, 0.45);
  transition: all var(--transition-normal);
  z-index: 100;
}

.create-btn::before {
  content: '';
  position: absolute;
  top: -8rpx;
  left: -8rpx;
  right: -8rpx;
  bottom: -8rpx;
  background: linear-gradient(135deg, var(--color-primary) 0%, #FF8E8E 100%);
  border-radius: 50%;
  opacity: 0.3;
  z-index: -1;
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); opacity: 0.3; }
  50% { transform: scale(1.1); opacity: 0.15; }
}

.create-btn:active {
  transform: scale(0.92);
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 107, 0.35);
}

.create-icon {
  font-size: 56rpx;
  color: #FFFFFF;
  font-weight: 300;
  line-height: 1;
}
