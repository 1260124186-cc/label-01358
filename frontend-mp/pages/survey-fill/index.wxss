.page {
  min-height: 100vh;
  background-color: var(--color-bg-page);
  padding: 24rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.survey-header {
  margin-bottom: 20rpx;
}

.survey-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  line-height: 1.4;
  display: block;
  margin-bottom: 12rpx;
}

.survey-desc {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  line-height: 1.6;
  display: block;
  margin-bottom: 16rpx;
}

.survey-info {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 16rpx;
}

.info-text {
  font-size: 24rpx;
  color: var(--color-text-muted);
}

.closed-banner {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background-color: rgba(239, 68, 68, 0.08);
  border-radius: var(--radius-lg);
  margin-bottom: 20rpx;
  gap: 12rpx;
}

.closed-icon {
  font-size: 36rpx;
}

.closed-text {
  font-size: 28rpx;
  color: var(--color-danger);
  font-weight: 500;
}

.responded-banner {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  background-color: rgba(52, 152, 219, 0.08);
  border-radius: var(--radius-lg);
  margin-bottom: 20rpx;
  gap: 12rpx;
}

.responded-icon {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: var(--color-info);
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: 700;
  border-radius: 50%;
  flex-shrink: 0;
}

.responded-text {
  flex: 1;
  font-size: 28rpx;
  color: var(--color-info);
  font-weight: 500;
}

.responded-action {
  padding: 8rpx 20rpx;
  font-size: 24rpx;
  font-weight: 500;
  color: var(--color-info);
  background-color: rgba(52, 152, 219, 0.15);
  border-radius: var(--radius-sm);
}

.question-card {
  margin-bottom: 20rpx;
}

.question-header {
  display: flex;
  align-items: flex-start;
  margin-bottom: 20rpx;
  flex-wrap: wrap;
  gap: 10rpx;
}

.question-index {
  min-width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, var(--color-primary) 0%, #FF8E8E 100%);
  color: #FFFFFF;
  font-size: 22rpx;
  font-weight: 700;
  border-radius: 50%;
  flex-shrink: 0;
  margin-top: 4rpx;
}

.question-title {
  flex: 1;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  line-height: 1.5;
}

.question-required {
  color: var(--color-danger);
  font-size: 28rpx;
  font-weight: 700;
  margin-top: 4rpx;
}

.question-type-tag {
  padding: 4rpx 12rpx;
  font-size: 20rpx;
  font-weight: 600;
  border-radius: var(--radius-xs);
  margin-top: 4rpx;
}

.question-type-tag.single {
  color: var(--color-info);
  background-color: rgba(52, 152, 219, 0.1);
}

.question-type-tag.multiple {
  color: var(--color-secondary);
  background-color: rgba(78, 205, 196, 0.1);
}

.question-type-tag.fill {
  color: var(--color-warning);
  background-color: rgba(243, 156, 18, 0.1);
}

.question-type-tag.nps {
  color: #8B5CF6;
  background-color: rgba(139, 92, 246, 0.1);
}

.question-type-tag.likert {
  color: #F59E0B;
  background-color: rgba(245, 158, 11, 0.1);
}

.question-type-tag.date {
  color: #10B981;
  background-color: rgba(16, 185, 129, 0.1);
}

.option-group {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.option-item {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  background-color: var(--color-bg-input);
  border-radius: var(--radius-lg);
  transition: all var(--transition-fast);
  border: 2rpx solid transparent;
  gap: 16rpx;
}

.option-item:active:not(.disabled) {
  transform: scale(0.98);
}

.option-item.selected {
  background-color: var(--color-primary-light);
  border-color: var(--color-primary);
}

.option-item.disabled {
  pointer-events: none;
  opacity: 0.8;
}

.option-radio {
  width: 40rpx;
  height: 40rpx;
  border: 3rpx solid var(--color-border);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all var(--transition-fast);
}

.option-item.selected .option-radio {
  border-color: var(--color-primary);
}

.radio-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background-color: transparent;
  transition: all var(--transition-fast);
}

.radio-dot.checked {
  background: linear-gradient(135deg, var(--color-primary) 0%, #FF8E8E 100%);
}

.option-checkbox {
  width: 40rpx;
  height: 40rpx;
  flex-shrink: 0;
}

.checkbox-inner {
  width: 40rpx;
  height: 40rpx;
  border: 3rpx solid var(--color-border);
  border-radius: var(--radius-xs);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all var(--transition-fast);
  font-size: 24rpx;
  color: #FFFFFF;
}

.checkbox-inner.checked {
  background: linear-gradient(135deg, var(--color-primary) 0%, #FF8E8E 100%);
  border-color: var(--color-primary);
}

.option-text {
  flex: 1;
  font-size: 28rpx;
  color: var(--color-text-primary);
  line-height: 1.5;
}

.option-item.selected .option-text {
  font-weight: 500;
}

.fill-textarea {
  width: 100%;
  min-height: 180rpx;
  padding: 20rpx;
  font-size: 28rpx;
  color: var(--color-text-primary);
  line-height: 1.7;
  background-color: var(--color-bg-input);
  border-radius: var(--radius-lg);
  border: 2rpx solid var(--color-border-light);
}

.fill-textarea::placeholder {
  color: var(--color-text-muted);
}

.fill-textarea:focus {
  border-color: var(--color-primary);
}

.nps-question {
  padding: 8rpx 0;
}

.nps-labels {
  display: flex;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.nps-label-left {
  font-size: 22rpx;
  color: var(--color-text-muted);
}

.nps-label-right {
  font-size: 22rpx;
  color: var(--color-text-muted);
}

.nps-scale {
  display: flex;
  gap: 6rpx;
}

.nps-item {
  flex: 1;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 600;
  border-radius: var(--radius-sm);
  background-color: var(--color-bg-input);
  color: var(--color-text-secondary);
  transition: all var(--transition-fast);
}

.nps-item.detractor {
  color: #EF4444;
}

.nps-item.passive {
  color: #F59E0B;
}

.nps-item.promoter {
  color: #10B981;
}

.nps-item.selected {
  color: #FFFFFF;
  transform: scale(1.08);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}

.nps-item.detractor.selected {
  background-color: #EF4444;
}

.nps-item.passive.selected {
  background-color: #F59E0B;
}

.nps-item.promoter.selected {
  background-color: #10B981;
}

.nps-item.disabled {
  pointer-events: none;
  opacity: 0.8;
}

.likert-question {
  padding: 8rpx 0;
}

.likert-options {
  display: flex;
  justify-content: space-between;
  gap: 8rpx;
}

.likert-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 4rpx;
  border-radius: var(--radius-lg);
  background-color: var(--color-bg-input);
  transition: all var(--transition-fast);
}

.likert-item.selected {
  background-color: rgba(245, 158, 11, 0.15);
  border: 2rpx solid #F59E0B;
}

.likert-item.disabled {
  pointer-events: none;
  opacity: 0.8;
}

.likert-circle {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  color: var(--color-text-secondary);
  border: 2rpx solid var(--color-border);
  transition: all var(--transition-fast);
}

.likert-item.selected .likert-circle {
  background-color: #F59E0B;
  color: #FFFFFF;
  border-color: #F59E0B;
}

.likert-label {
  font-size: 18rpx;
  color: var(--color-text-muted);
  text-align: center;
  white-space: nowrap;
}

.likert-item.selected .likert-label {
  color: #F59E0B;
  font-weight: 500;
}

.date-question {
  padding: 8rpx 0;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.date-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.date-label {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  min-width: 60rpx;
  font-weight: 500;
}

.date-picker {
  flex: 1;
  padding: 16rpx 20rpx;
  background-color: var(--color-bg-input);
  border-radius: var(--radius-lg);
  font-size: 28rpx;
  color: var(--color-text-primary);
  border: 2rpx solid var(--color-border-light);
}

.date-picker.placeholder {
  color: var(--color-text-muted);
}

.submit-section {
  padding: 20rpx 0 40rpx;
}
