<page-meta page-style="background-color: {{darkMode ? '#0F1117' : '#F8F9FA'}}; color: {{darkMode ? '#E8ECF1' : '#2C3E50'}}"/>
<view class="page {{darkMode ? 'dark' : ''}}">
  <block wx:if="{{!canFill}}">
    <view class="closed-banner">
      <text class="closed-icon">⚠️</text>
      <text class="closed-text">{{fillReason}}</text>
    </view>
  </block>

  <block wx:if="{{survey && canFill}}">
    <view class="survey-header card">
      <view class="card-body">
        <text class="survey-title">{{survey.title}}</text>
        <text class="survey-desc" wx:if="{{survey.description}}">{{survey.description}}</text>
        <view class="survey-info">
          <text class="info-text">共{{visibleQuestions.length}}题</text>
          <text class="info-text">{{survey.responseCount}}人已填</text>
          <text class="info-text" wx:if="{{survey.settings.deadline}}">截止：{{survey.settings.deadlineStr || ''}}</text>
        </view>
      </view>
    </view>

    <view wx:if="{{alreadyResponded}}" class="responded-banner">
      <text class="responded-icon">✓</text>
      <text class="responded-text">您已填写过此问卷</text>
      <view class="responded-action" bindtap="onViewResult">查看结果</view>
    </view>

    <view
      class="question-card card"
      wx:for="{{visibleQuestions}}"
      wx:key="id"
    >
      <view class="card-body">
        <view class="question-header">
          <text class="question-index">{{index + 1}}</text>
          <text class="question-title">{{item.title}}</text>
          <text class="question-required">*</text>
          <view class="question-type-tag {{item.type}}">
            {{questionTypeLabels[item.type] || item.type}}
          </view>
        </view>

        <block wx:if="{{item.type === 'single'}}">
          <view class="option-group">
            <view
              class="option-item {{answers[item.id] === opt ? 'selected' : ''}} {{alreadyResponded ? 'disabled' : ''}}"
              wx:for="{{item.options}}"
              wx:for-item="opt"
              wx:for-index="oIndex"
              wx:key="oIndex"
              bindtap="onSingleSelect"
              data-q-id="{{item.id}}"
              data-value="{{opt}}"
            >
              <view class="option-radio">
                <view class="radio-dot {{answers[item.id] === opt ? 'checked' : ''}}"></view>
              </view>
              <text class="option-text">{{opt}}</text>
            </view>
          </view>
        </block>

        <block wx:if="{{item.type === 'multiple'}}">
          <view class="option-group">
            <view
              class="option-item {{opt.selected ? 'selected' : ''}} {{alreadyResponded ? 'disabled' : ''}}"
              wx:for="{{questionOptionsWithState[item.id]}}"
              wx:for-item="opt"
              wx:for-index="oIndex"
              wx:key="label"
              bindtap="onMultipleSelect"
              data-q-id="{{item.id}}"
              data-value="{{opt.label}}"
            >
              <view class="option-checkbox">
                <view class="checkbox-inner {{opt.selected ? 'checked' : ''}}">
                  <text wx:if="{{opt.selected}}">✓</text>
                </view>
              </view>
              <text class="option-text">{{opt.label}}</text>
            </view>
          </view>
        </block>

        <block wx:if="{{item.type === 'fill'}}">
          <textarea
            class="fill-textarea"
            placeholder="请输入您的回答"
            value="{{answers[item.id]}}"
            bindinput="onFillInput"
            data-q-id="{{item.id}}"
            maxlength="500"
            disabled="{{alreadyResponded}}"
          />
        </block>

        <block wx:if="{{item.type === 'nps'}}">
          <view class="nps-question">
            <view class="nps-labels">
              <text class="nps-label-left">完全不可能</text>
              <text class="nps-label-right">非常可能</text>
            </view>
            <view class="nps-scale">
              <view
                class="nps-item {{answers[item.id] === String(n) ? 'selected' : ''}} {{n <= 6 ? 'detractor' : n <= 8 ? 'passive' : 'promoter'}} {{alreadyResponded ? 'disabled' : ''}}"
                wx:for="{{11}}"
                wx:key="*this"
                wx:for-index="n"
                bindtap="onNpsSelect"
                data-q-id="{{item.id}}"
                data-value="{{n}}"
              >
                {{n}}
              </view>
            </view>
          </view>
        </block>

        <block wx:if="{{item.type === 'likert'}}">
          <view class="likert-question">
            <view class="likert-options">
              <view
                class="likert-item {{answers[item.id] === String(li + 1) ? 'selected' : ''}} {{alreadyResponded ? 'disabled' : ''}}"
                wx:for="{{5}}"
                wx:key="*this"
                wx:for-index="li"
                bindtap="onLikertSelect"
                data-q-id="{{item.id}}"
                data-value="{{li + 1}}"
              >
                <view class="likert-circle">{{li + 1}}</view>
                <text class="likert-label">{{li === 0 ? '非常不同意' : li === 1 ? '不同意' : li === 2 ? '一般' : li === 3 ? '同意' : '非常同意'}}</text>
              </view>
            </view>
          </view>
        </block>

        <block wx:if="{{item.type === 'date'}}">
          <view class="date-question">
            <view class="date-row">
              <text class="date-label">日期</text>
              <picker mode="date" bindchange="onDateChange" data-q-id="{{item.id}}">
                <view class="date-picker {{answers[item.id] ? '' : 'placeholder'}}">
                  {{answers[item.id] ? answers[item.id].split(' ')[0] : '请选择日期'}}
                </view>
              </picker>
            </view>
            <view class="date-row">
              <text class="date-label">时间</text>
              <picker mode="time" bindchange="onTimeChange" data-q-id="{{item.id}}">
                <view class="date-picker {{answers[item.id] && answers[item.id].split(' ')[1] ? '' : 'placeholder'}}">
                  {{answers[item.id] && answers[item.id].split(' ')[1] ? answers[item.id].split(' ')[1] : '请选择时间'}}
                </view>
              </picker>
            </view>
          </view>
        </block>
      </view>
    </view>

    <view class="submit-section" wx:if="{{!alreadyResponded}}">
      <btn type="primary" size="large" block="{{true}}" loading="{{submitting}}" bind:click="onSubmit">
        提交问卷
      </btn>
    </view>
  </block>
</view>
