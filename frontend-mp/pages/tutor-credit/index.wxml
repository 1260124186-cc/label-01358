<page-meta page-style="background-color: {{darkMode ? '#0F1117' : '#F8F9FA'}}; color: {{darkMode ? '#E8ECF1' : '#2C3E50'}}"/>
<view class="page {{darkMode ? 'dark' : ''}}">

  <view class="credit-header">
    <view class="score-card">
      <view class="score-top">
        <text class="score-label">我的信用分</text>
        <view class="recalc-btn" bindtap="onRecalculateScore">
          <text class="recalc-icon">🔄</text>
          <text class="recalc-text">重新计算</text>
        </view>
      </view>
      <view class="score-main">
        <text class="score-number">{{creditScore}}</text>
        <view class="level-tag" wx:if="{{creditLevel}}" style="background-color: {{creditLevel.color}}20; color: {{creditLevel.color}}">
          <text class="level-icon">{{creditLevel.icon}}</text>
          <text class="level-text">{{creditLevel.label}}</text>
        </view>
      </view>
      <view class="score-stats">
        <view class="stat-item">
          <text class="stat-value">{{approvedCount}}</text>
          <text class="stat-label">已通过认证</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <text class="stat-value">{{creditTypes.length}}</text>
          <text class="stat-label">可认证项目</text>
        </view>
      </view>
      <view class="score-bar">
        <view class="score-bar-fill" style="width: {{creditScore}}%"></view>
      </view>
    </view>
  </view>

  <view class="tab-section">
    <view class="tab-bar">
      <view
        class="tab-item {{currentTab === item.value ? 'active' : ''}}"
        wx:for="{{tabs}}"
        wx:key="value"
        bindtap="onTabTap"
        data-value="{{item.value}}"
      >
        <text class="tab-text">{{item.label}}</text>
        <view class="tab-underline" wx:if="{{currentTab === item.value}}"></view>
      </view>
    </view>
  </view>

  <view class="content-area" wx:if="{{currentTab === 'certify'}}">
    <view class="credit-type-list">
      <view
        class="credit-card"
        wx:for="{{creditTypes}}"
        wx:key="value"
        bindtap="onCreditTypeTap"
        data-type="{{item.value}}"
        hover-class="credit-card-hover"
      >
        <view class="card-left">
          <view class="type-icon-wrap" style="background-color: rgba(59, 130, 246, 0.1)">
            <text class="type-icon">{{item.icon}}</text>
          </view>
          <view class="type-info">
            <text class="type-name">{{item.label}}</text>
            <view class="type-score">
              <text class="score-plus">+</text>
              <text class="score-num">{{item.score}}</text>
              <text class="score-unit">分</text>
            </view>
          </view>
        </view>
        <view class="card-right">
          <block wx:if="{{creditTypeStatusMap[item.value].status === 'approved'}}">
            <view class="status-tag approved">
              <text class="status-text">已通过</text>
            </view>
          </block>
          <block wx:elif="{{creditTypeStatusMap[item.value].status === 'pending'}}">
            <view class="status-tag pending">
              <text class="status-text">审核中</text>
            </view>
          </block>
          <block wx:elif="{{creditTypeStatusMap[item.value].status === 'rejected'}}">
            <view class="status-tag rejected">
              <text class="status-text">重新提交</text>
            </view>
          </block>
          <block wx:else>
            <view class="go-btn">
              <text class="go-text">去认证</text>
              <text class="go-arrow">›</text>
            </view>
          </block>
        </view>
      </view>
    </view>
  </view>

  <view class="content-area" wx:if="{{currentTab === 'records'}}">
    <view class="record-list" wx:if="{{creditBinds.length > 0}}">
      <view
        class="record-card"
        wx:for="{{creditBinds}}"
        wx:key="id"
      >
        <view class="record-top">
          <view class="record-icon-wrap" style="background-color: rgba(59, 130, 246, 0.1)">
            <text class="record-icon">{{item.typeIcon}}</text>
          </view>
          <view class="record-info">
            <text class="record-name">{{item.typeName}}</text>
            <text class="record-time">{{item.submitTimeText}}</text>
          </view>
          <view class="record-status" style="background-color: {{item.statusColor}}15; color: {{item.statusColor}}">
            <text class="record-status-text">{{item.statusLabel}}</text>
          </view>
        </view>
        <view class="record-bottom" wx:if="{{item.name || item.idNumber}}">
          <view class="record-detail-row" wx:if="{{item.name}}">
            <text class="detail-label">名称：</text>
            <text class="detail-value">{{item.name}}</text>
          </view>
          <view class="record-detail-row" wx:if="{{item.idNumber}}">
            <text class="detail-label">证件：</text>
            <text class="detail-value">{{item.idNumber}}</text>
          </view>
        </view>
        <view class="record-score-row" wx:if="{{item.status === 'approved'}}">
          <text class="score-badge">+{{item.typeScore}} 分</text>
        </view>
        <view class="record-reject" wx:if="{{item.status === 'rejected' && item.rejectReason}}">
          <text class="reject-label">拒绝原因：</text>
          <text class="reject-text">{{item.rejectReason}}</text>
        </view>
      </view>
    </view>

    <view class="empty-wrap" wx:else>
      <text class="empty-icon">📭</text>
      <text class="empty-text">暂无认证记录</text>
      <view class="empty-action" bindtap="onTabTap" data-value="certify">
        <text class="empty-action-text">去认证</text>
      </view>
    </view>
  </view>

  <view class="modal-mask" wx:if="{{showModal}}" bindtap="onCloseModal"></view>
  <view class="modal-container {{showModal ? 'show' : ''}}" wx:if="{{showModal}}">
    <view class="modal-content" catchtap="">
      <view class="modal-header">
        <text class="modal-title">提交{{currentCreditType.label || '认证'}}</text>
        <view class="modal-close" catchtap="onCloseModal">
          <text class="close-icon">✕</text>
        </view>
      </view>

      <view class="modal-body">
        <view class="form-item">
          <text class="form-label">认证名称 <text class="required">*</text></text>
          <input
            class="form-input"
            placeholder="请输入真实姓名/证件名称"
            placeholder-class="input-placeholder"
            value="{{formName}}"
            bindinput="onFormNameInput"
            maxlength="50"
          />
        </view>

        <view class="form-item">
          <text class="form-label">证件号码</text>
          <input
            class="form-input"
            placeholder="选填，请输入证件号码"
            placeholder-class="input-placeholder"
            value="{{formIdNumber}}"
            bindinput="onFormIdNumberInput"
            maxlength="30"
          />
        </view>

        <view class="form-item">
          <text class="form-label">证件照片 <text class="required">*</text></text>
          <view class="photo-upload-wrap">
            <view
              class="photo-item"
              wx:for="{{formPhotos}}"
              wx:key="*this"
              bindtap="onPreviewPhoto"
              data-index="{{index}}"
            >
              <image class="photo-img" src="{{item}}" mode="aspectFill"/>
              <view class="photo-remove" catchtap="onRemovePhoto" data-index="{{index}}">
                <text class="remove-icon">✕</text>
              </view>
            </view>
            <view
              class="photo-add"
              wx:if="{{formPhotos.length < 2}}"
              bindtap="onChoosePhoto"
            >
              <text class="add-icon">+</text>
              <text class="add-text">上传照片</text>
              <text class="add-hint">最多2张</text>
            </view>
          </view>
        </view>
      </view>

      <view class="modal-footer">
        <view class="footer-btn cancel" catchtap="onCloseModal">
          <text class="btn-text">取消</text>
        </view>
        <view class="footer-btn confirm {{submitting ? 'disabled' : ''}}" catchtap="onSubmitCredit">
          <text class="btn-text">{{submitting ? '提交中...' : '提交审核'}}</text>
        </view>
      </view>
    </view>
  </view>

</view>
