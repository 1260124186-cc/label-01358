<page-meta page-style="background-color: {{darkMode ? '#0F1117' : '#F8F9FA'}}; color: {{darkMode ? '#E8ECF1' : '#2C3E50'}}"/>
<view class="page {{darkMode ? 'dark' : ''}}">
  <!-- 顶部标签栏 -->
  <scroll-view class="top-tabs" scroll-x="{{true}}" enhanced="{{true}}" show-scrollbar="{{false}}">
    <view class="tabs-inner">
      <view
        class="tab-item {{currentTab === item.value ? 'active' : ''}}"
        wx:for="{{tabs}}"
        wx:key="value"
        bindtap="onTabTap"
        data-value="{{item.value}}"
      >
        <text class="tab-label">{{item.label}}</text>
      </view>
    </view>
  </scroll-view>

  <!-- 预约列表 -->
  <scroll-view class="appointment-list" scroll-y="{{true}}" enhanced="{{true}}" show-scrollbar="{{false}}">
    <view class="list-inner" wx:if="{{filteredAppointments.length > 0}}">
      <view
        class="appointment-card"
        wx:for="{{filteredAppointments}}"
        wx:key="id"
        bindtap="onAppointmentTap"
        data-id="{{item.id}}"
      >
        <!-- 卡片头部 -->
        <view class="card-header">
          <view class="lab-info">
            <text class="lab-name">{{item.labName || '实验室'}}</text>
            <view class="status-tag" style="background: {{item.statusColor}}15; color: {{item.statusColor}};">
              <text class="status-icon">{{item.statusIcon}}</text>
              <text class="status-text">{{item.statusLabel}}</text>
            </view>
          </view>
        </view>

        <!-- 预约信息 -->
        <view class="card-body">
          <view class="info-row">
            <text class="info-icon">📅</text>
            <text class="info-label">预约日期</text>
            <text class="info-value">{{item.appointmentDate}}</text>
          </view>
          <view class="info-row">
            <text class="info-icon">⏰</text>
            <text class="info-label">预约时段</text>
            <text class="info-value">{{item.timeSlot}}</text>
          </view>
          <view class="info-row">
            <text class="info-icon">👥</text>
            <text class="info-label">使用人数</text>
            <text class="info-value">{{item.participantCount}} 人</text>
          </view>
          <view class="info-row" wx:if="{{item.checkInTime}}">
            <text class="info-icon">🔓</text>
            <text class="info-label">签到时间</text>
            <text class="info-value">{{item.checkInTimeText}}</text>
          </view>
          <view class="info-row" wx:if="{{item.checkOutTime}}">
            <text class="info-icon">🔒</text>
            <text class="info-label">签退时间</text>
            <text class="info-value">{{item.checkOutTimeText}}</text>
          </view>
          <view class="info-row" wx:if="{{item.violationDesc}}">
            <text class="info-icon">⚠️</text>
            <text class="info-label">违规说明</text>
            <text class="info-value violation-text">{{item.violationDesc}}</text>
          </view>
        </view>

        <!-- 操作按钮 -->
        <view class="card-footer">
          <text class="create-time">申请时间：{{item.createTimeText}}</text>
          <view class="action-buttons">
            <view
              class="action-btn secondary"
              wx:if="{{item.status === 'pending' || item.status === 'approved'}}"
              catchtap="onCancel"
              data-id="{{item.id}}"
            >
              取消预约
            </view>
            <view
              class="action-btn primary"
              wx:if="{{item.status === 'approved'}}"
              catchtap="onCheckIn"
              data-id="{{item.id}}"
            >
              签到使用
            </view>
            <view
              class="action-btn primary"
              wx:if="{{item.status === 'checked_in'}}"
              catchtap="onCheckOut"
              data-id="{{item.id}}"
            >
              签退离开
            </view>
          </view>
        </view>
      </view>
    </view>

    <empty wx:else text="暂无预约记录" icon="📋" />
  </scroll-view>

  <!-- 加载状态 -->
  <view class="loading-overlay" wx:if="{{loading}}">
    <view class="loading-content">
      <view class="loading-spinner"></view>
      <text class="loading-text">加载中...</text>
    </view>
  </view>
</view>
