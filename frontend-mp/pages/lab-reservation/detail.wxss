.page {
  min-height: 100vh;
  background: var(--color-bg-page);
  display: flex;
  flex-direction: column;
  padding-bottom: 140rpx;
}

.page.dark {
  --color-bg-page: #0F1117;
  --color-bg-card: #1A1D29;
  --color-bg-secondary: #252936;
  --color-text-primary: #E8ECF1;
  --color-text-secondary: #9CA3AF;
  --color-text-placeholder: #6B7280;
  --color-border: #2D3142;
  --color-primary: #FF6B6B;
  --color-primary-dark: #E55555;
}

.page-scroll {
  flex: 1;
  height: calc(100vh - 140rpx);
}

.lab-hero {
  position: relative;
  width: 100%;
  height: 400rpx;
}

.hero-image {
  width: 100%;
  height: 100%;
}

.hero-overlay {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 200rpx;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.7), transparent);
}

.hero-info {
  position: absolute;
  left: 32rpx;
  right: 32rpx;
  bottom: 32rpx;
}

.hero-tags {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.hero-tag {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  backdrop-filter: blur(10rpx);
}

.hero-tag .tag-icon {
  font-size: 24rpx;
}

.hero-tag .tag-text {
  font-size: 22rpx;
  color: #FFFFFF;
  font-weight: 500;
}

.type-tag {
  background: rgba(255, 255, 255, 0.25);
}

.hero-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #FFFFFF;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
}

.info-section {
  margin: 24rpx 32rpx;
  background: var(--color-bg-card, #FFFFFF);
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary, #2C3E50);
  margin-bottom: 20rpx;
}

.info-grid {
  display: flex;
  flex-wrap: wrap;
}

.info-item {
  width: 50%;
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.info-item:nth-child(odd) {
  padding-right: 16rpx;
}

.info-item:nth-child(even) {
  padding-left: 16rpx;
}

.info-icon {
  font-size: 32rpx;
  flex-shrink: 0;
}

.info-content {
  flex: 1;
}

.info-label {
  font-size: 24rpx;
  color: var(--color-text-secondary, #9CA3AF);
  display: block;
  margin-bottom: 4rpx;
}

.info-value {
  font-size: 28rpx;
  color: var(--color-text-primary, #2C3E50);
  font-weight: 500;
}

.desc-box {
  background: var(--color-bg-secondary, #F9FAFB);
  border-radius: 16rpx;
  padding: 20rpx;
}

.desc-text {
  font-size: 26rpx;
  color: var(--color-text-secondary, #6B7280);
  line-height: 1.6;
}

.time-slots-display {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.time-slot-tag {
  padding: 12rpx 20rpx;
  background: var(--color-bg-secondary, #F3F4F6);
  border-radius: 16rpx;
  font-size: 24rpx;
  color: var(--color-text-secondary, #6B7280);
}

.facilities-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.facility-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  width: calc(50% - 8rpx);
}

.facility-dot {
  font-size: 16rpx;
  color: var(--color-primary, #FF6B6B);
}

.facility-name {
  font-size: 26rpx;
  color: var(--color-text-primary, #2C3E50);
}

.rules-box {
  background: linear-gradient(135deg, #FFF8E1 0%, #FFECB3 100%);
  border-radius: 16rpx;
  padding: 20rpx;
}

.page.dark .rules-box {
  background: linear-gradient(135deg, rgba(255, 193, 7, 0.15) 0%, rgba(255, 152, 0, 0.15) 100%);
}

.rules-text {
  font-size: 26rpx;
  color: #E65100;
  line-height: 1.8;
  white-space: pre-wrap;
}

.page.dark .rules-text {
  color: #FFB74D;
}

.warning-card {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  background: #FFF3E0;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.page.dark .warning-card {
  background: rgba(255, 152, 0, 0.15);
}

.warning-icon {
  font-size: 40rpx;
  flex-shrink: 0;
}

.warning-content {
  flex: 1;
}

.warning-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #E65100;
  display: block;
  margin-bottom: 8rpx;
}

.page.dark .warning-title {
  color: #FFB74D;
}

.warning-text {
  font-size: 24rpx;
  color: #F57C00;
  display: block;
  margin-bottom: 16rpx;
}

.page.dark .warning-text {
  color: #FFCC80;
}

.warning-btn {
  display: inline-block;
  padding: 12rpx 24rpx;
  background: #FF9800;
  border-radius: 20rpx;
}

.warning-btn .btn-text {
  font-size: 24rpx;
  color: #FFFFFF;
  font-weight: 500;
}

.form-section {
  margin: 24rpx 32rpx;
  background: var(--color-bg-card, #FFFFFF);
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.form-item {
  margin-bottom: 28rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.label-text {
  font-size: 28rpx;
  color: var(--color-text-primary, #2C3E50);
  font-weight: 500;
}

.required {
  color: #F5222D;
  margin-left: 6rpx;
  font-size: 28rpx;
}

.form-picker-wrap {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 24rpx;
  background: var(--color-bg-secondary, #F9FAFB);
  border-radius: 16rpx;
  border: 2rpx solid transparent;
}

.form-picker-text {
  font-size: 28rpx;
  color: var(--color-text-primary, #2C3E50);
}

.form-picker-text.placeholder {
  color: var(--color-text-placeholder, #9CA3AF);
}

.picker-arrow {
  font-size: 32rpx;
  color: var(--color-text-secondary, #9CA3AF);
}

.time-slot-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.time-slot-item {
  width: calc(33.333% - 11rpx);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 12rpx;
  background: var(--color-bg-secondary, #F9FAFB);
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.time-slot-item.active {
  background: rgba(255, 107, 107, 0.1);
  border-color: var(--color-primary, #FF6B6B);
}

.time-slot-item.disabled {
  opacity: 0.5;
}

.slot-text {
  font-size: 26rpx;
  color: var(--color-text-primary, #2C3E50);
  font-weight: 500;
  margin-bottom: 6rpx;
}

.time-slot-item.active .slot-text {
  color: var(--color-primary, #FF6B6B);
}

.slot-available {
  font-size: 22rpx;
  color: var(--color-text-secondary, #9CA3AF);
}

.form-input-wrap {
  height: 88rpx;
  padding: 0 24rpx;
  background: var(--color-bg-secondary, #F9FAFB);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
}

.form-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--color-text-primary, #2C3E50);
}

.form-placeholder {
  color: var(--color-text-placeholder, #9CA3AF);
}

.form-textarea-wrap {
  padding: 20rpx 24rpx;
  background: var(--color-bg-secondary, #F9FAFB);
  border-radius: 16rpx;
  min-height: 120rpx;
}

.form-textarea {
  width: 100%;
  font-size: 28rpx;
  color: var(--color-text-primary, #2C3E50);
  line-height: 1.5;
}

.word-count {
  text-align: right;
  font-size: 22rpx;
  color: var(--color-text-secondary, #9CA3AF);
  margin-top: 8rpx;
}

.bottom-space {
  height: 40rpx;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: var(--color-bg-card, #FFFFFF);
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.06);
  z-index: 100;
}

.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 255, 255, 0.8);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.page.dark .loading-overlay {
  background: rgba(15, 17, 23, 0.8);
}

.loading-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid var(--color-bg-secondary, #E5E7EB);
  border-top-color: var(--color-primary, #FF6B6B);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: 26rpx;
  color: var(--color-text-secondary, #6B7280);
}
