.page {
  min-height: 100vh;
  background: var(--color-bg-page);
  display: flex;
  flex-direction: column;
}

.page.dark {
  --color-bg-page: #0F1117;
  --color-bg-card: #1A1D29;
  --color-bg-secondary: #252936;
  --color-text-primary: #E8ECF1;
  --color-text-secondary: #9CA3AF;
  --color-text-placeholder: #6B7280;
  --color-border: #2D3142;
  --color-primary: #FF6B6B;
  --color-primary-dark: #E55555;
}

.top-bar {
  display: flex;
  align-items: center;
  padding: 20rpx 32rpx;
  gap: 20rpx;
  background: var(--color-bg-card, #FFFFFF);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.search-box {
  flex: 1;
  display: flex;
  align-items: center;
  background: var(--color-bg-secondary, #F3F4F6);
  border-radius: 40rpx;
  padding: 16rpx 24rpx;
  gap: 12rpx;
}

.search-icon {
  font-size: 28rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--color-text-primary, #2C3E50);
}

.search-placeholder {
  color: var(--color-text-placeholder, #9CA3AF);
}

.search-clear {
  font-size: 24rpx;
  color: var(--color-text-secondary, #9CA3AF);
  padding: 4rpx 8rpx;
}

.my-appointments-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 20rpx;
  background: linear-gradient(135deg, var(--color-primary, #FF6B6B), var(--color-primary-dark, #E55555));
  border-radius: 32rpx;
  flex-shrink: 0;
}

.my-appointments-btn .btn-icon {
  font-size: 28rpx;
}

.my-appointments-btn .btn-text {
  font-size: 26rpx;
  color: #FFFFFF;
  font-weight: 500;
}

.type-tabs {
  white-space: nowrap;
  padding: 20rpx 0;
  background: var(--color-bg-card, #FFFFFF);
}

.type-tabs-inner {
  display: inline-flex;
  padding: 0 24rpx;
  gap: 16rpx;
}

.type-tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 28rpx;
  background: var(--color-bg-secondary, #F3F4F6);
  border-radius: 20rpx;
  gap: 8rpx;
  transition: all 0.3s ease;
}

.type-tab-item.active {
  background: linear-gradient(135deg, var(--color-primary, #FF6B6B), var(--color-primary-dark, #E55555));
}

.type-tab-item .tab-icon {
  font-size: 36rpx;
}

.type-tab-item .tab-label {
  font-size: 24rpx;
  color: var(--color-text-secondary, #6B7280);
}

.type-tab-item.active .tab-label {
  color: #FFFFFF;
  font-weight: 500;
}

.lab-list {
  flex: 1;
  padding: 20rpx 32rpx 40rpx;
}

.lab-list-inner {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.lab-card {
  background: var(--color-bg-card, #FFFFFF);
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.lab-cover {
  position: relative;
  width: 100%;
  height: 280rpx;
}

.cover-image {
  width: 100%;
  height: 100%;
}

.safety-badge {
  position: absolute;
  top: 20rpx;
  left: 20rpx;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

.safety-text {
  font-size: 22rpx;
  color: #FFFFFF;
  font-weight: 500;
}

.type-badge {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  width: 56rpx;
  height: 56rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.type-badge .type-icon {
  font-size: 32rpx;
}

.page.dark .type-badge {
  background: rgba(26, 29, 41, 0.95);
}

.lab-info {
  padding: 24rpx;
}

.lab-header {
  margin-bottom: 16rpx;
}

.lab-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-primary, #2C3E50);
  display: block;
}

.lab-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-bottom: 16rpx;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.meta-icon {
  font-size: 24rpx;
}

.meta-text {
  font-size: 24rpx;
  color: var(--color-text-secondary, #6B7280);
}

.lab-desc {
  margin-bottom: 20rpx;
}

.desc-text {
  font-size: 26rpx;
  color: var(--color-text-secondary, #6B7280);
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.lab-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--color-border, #E5E7EB);
}

.facilities-preview {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
  flex: 1;
}

.facility-tag {
  font-size: 22rpx;
  color: var(--color-text-secondary, #6B7280);
  background: var(--color-bg-secondary, #F3F4F6);
  padding: 6rpx 14rpx;
  border-radius: 12rpx;
}

.facility-more {
  font-size: 22rpx;
  color: var(--color-text-secondary, #9CA3AF);
}

.book-btn-text {
  font-size: 26rpx;
  color: var(--color-primary, #FF6B6B);
  font-weight: 500;
  flex-shrink: 0;
}

.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 255, 255, 0.8);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.page.dark .loading-overlay {
  background: rgba(15, 17, 23, 0.8);
}

.loading-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid var(--color-bg-secondary, #E5E7EB);
  border-top-color: var(--color-primary, #FF6B6B);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: 26rpx;
  color: var(--color-text-secondary, #6B7280);
}
