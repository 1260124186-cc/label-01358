.page {
  min-height: 100vh;
  background-color: var(--color-bg-page);
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
}

.user-section {
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 50%, var(--color-accent) 100%);
  padding: 48rpx 32rpx 64rpx;
  position: relative;
  overflow: hidden;
}

.user-section::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -20%;
  width: 400rpx;
  height: 400rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.user-section::after {
  content: '';
  position: absolute;
  bottom: -30%;
  left: -10%;
  width: 300rpx;
  height: 300rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 50%;
}

.user-card {
  display: flex;
  align-items: center;
  position: relative;
  z-index: 1;
}

.user-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(255, 255, 255, 0.4);
  flex-shrink: 0;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
}

.user-info {
  flex: 1;
  margin-left: 28rpx;
}

.user-name {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 8rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.user-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

.user-action {
  display: flex;
  align-items: center;
  padding: 14rpx 28rpx;
  background-color: rgba(255, 255, 255, 0.25);
  backdrop-filter: blur(10rpx);
  -webkit-backdrop-filter: blur(10rpx);
  border-radius: var(--radius-full);
  transition: all var(--transition-fast);
}

.user-action:active {
  background-color: rgba(255, 255, 255, 0.35);
  transform: scale(0.96);
}

.action-text {
  font-size: 26rpx;
  font-weight: 500;
  color: #FFFFFF;
}

.action-arrow {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-left: 4rpx;
}

.stats-section {
  margin: -40rpx 24rpx 24rpx;
  position: relative;
  z-index: 10;
}

.stats-card {
  display: flex;
  background-color: var(--color-bg-card);
  border-radius: var(--radius-2xl);
  padding: 32rpx 0;
  box-shadow: var(--shadow-lg);
}

.stats-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}

.stats-item:not(:last-child)::after {
  content: '';
  position: absolute;
  right: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 1rpx;
  height: 60rpx;
  background-color: var(--color-border);
}

.stats-value {
  font-size: 44rpx;
  font-weight: 800;
  color: var(--color-text-primary);
  margin-bottom: 8rpx;
}

.stats-label {
  font-size: 24rpx;
  color: var(--color-text-muted);
}

.menu-section {
  padding: 0 24rpx 24rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-secondary);
  margin-bottom: 16rpx;
  padding-left: 8rpx;
}

.menu-card {
  background-color: var(--color-bg-card);
  border-radius: var(--radius-2xl);
  overflow: hidden;
  box-shadow: var(--shadow-card);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  transition: all var(--transition-fast);
}

.menu-item:not(:last-child) {
  border-bottom: 1rpx solid var(--color-border-light);
}

.menu-item:active {
  background-color: var(--color-bg-page);
}

.menu-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: var(--radius-lg);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  position: relative;
  overflow: hidden;
}

.menu-icon-wrap::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(255,255,255,0.5) 0%, transparent 100%);
}

.menu-icon {
  font-size: 36rpx;
  position: relative;
  z-index: 1;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  font-weight: 500;
  color: var(--color-text-primary);
}

.menu-count {
  font-size: 26rpx;
  color: var(--color-text-muted);
  margin-right: 12rpx;
  padding: 4rpx 16rpx;
  background-color: var(--color-bg-input);
  border-radius: var(--radius-full);
}

.menu-arrow {
  font-size: 32rpx;
  color: var(--color-text-muted);
}

.menu-desc {
  font-size: 24rpx;
  color: var(--color-text-muted);
  margin-right: 8rpx;
}

.menu-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.menu-info .menu-text {
  flex: none;
}

.menu-info .menu-desc {
  margin-right: 0;
}

.theme-switch.no-border {
  border-bottom: none;
}

.color-scheme-list {
  display: flex;
  padding: 0 8rpx;
}

.color-scheme-list > view { margin-right: 16rpx; }

.color-scheme-list > view:last-child { margin-right: 0; }

.color-scheme-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 12rpx;
  background-color: var(--color-bg-card);
  border-radius: var(--radius-xl);
  border: 3rpx solid transparent;
  transition: all var(--transition-fast);
  box-shadow: var(--shadow-card);
  position: relative;
}

.color-scheme-item > view { margin-bottom: 12rpx; }

.color-scheme-item > view:last-child { margin-bottom: 0; }

.color-scheme-item.active {
  border-color: var(--color-primary);
  background-color: var(--color-primary-light);
}

.color-scheme-item:active {
  transform: scale(0.96);
}

.color-scheme-dot {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}

.color-scheme-name {
  font-size: 24rpx;
  font-weight: 500;
  color: var(--color-text-primary);
}

.color-scheme-check {
  position: absolute;
  top: 8rpx;
  right: 12rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: var(--color-primary);
}

.font-size-group {
  display: flex;
  background-color: var(--color-bg-input);
  border-radius: var(--radius-lg);
  padding: 6rpx;
  margin: 0 8rpx;
}

.font-size-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 20rpx 0;
  border-radius: var(--radius-md);
  transition: all var(--transition-fast);
}

.font-size-item > view { margin-bottom: 8rpx; }

.font-size-item > view:last-child { margin-bottom: 0; }

.font-size-item.active {
  background-color: var(--color-bg-card);
  box-shadow: var(--shadow-sm);
}

.font-size-label {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text-secondary);
}

.font-size-label-lg {
  font-size: 40rpx;
}

.font-size-label-xl {
  font-size: 48rpx;
}

.font-size-item.active .font-size-label {
  color: var(--color-primary);
}

.font-size-desc {
  font-size: 22rpx;
  color: var(--color-text-muted);
}

.font-size-item.active .font-size-desc {
  color: var(--color-primary);
}

.font-size-preview {
  margin: 16rpx 8rpx 0;
  padding: 24rpx;
  background-color: var(--color-bg-card);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-card);
}

.preview-text {
  font-size: calc(var(--font-md) * var(--font-scale));
  color: var(--color-text-secondary);
  line-height: 1.6;
}

.version-section {
  padding: 48rpx 24rpx;
  text-align: center;
}

.version-text {
  font-size: 24rpx;
  color: var(--color-text-muted);
}

.dark .user-section {
  background: linear-gradient(135deg, #5A2A2A 0%, #6A3A3A 50%, #5A4A3A 100%);
}

.color-scheme-blue .user-section {
  background: linear-gradient(135deg, #4A90D9 0%, #3A7BC8 50%, #A8D8FF 100%);
}

.dark.color-scheme-blue .user-section {
  background: linear-gradient(135deg, #2A3F5F 0%, #3A5070 50%, #2A4060 100%);
}

.color-scheme-green .user-section {
  background: linear-gradient(135deg, #2ECC71 0%, #27AE60 50%, #A8E6CF 100%);
}

.dark.color-scheme-green .user-section {
  background: linear-gradient(135deg, #1E5035 0%, #2A6045 50%, #1E4530 100%);
}

.color-scheme-purple .user-section {
  background: linear-gradient(135deg, #8B5CF6 0%, #7C3AED 50%, #DDD6FE 100%);
}

.dark.color-scheme-purple .user-section {
  background: linear-gradient(135deg, #3B1F6E 0%, #4A2F80 50%, #3B1F5E 100%);
}

.dark .menu-icon-wrap {
  opacity: 0.9;
}

.dark .menu-item:active {
  background-color: var(--color-bg-input);
}

.theme-switch {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 24rpx;
  transition: all var(--transition-fast);
}

.theme-switch-label {
  display: flex;
  align-items: center;
}

.theme-switch-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: var(--radius-lg);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  position: relative;
  overflow: hidden;
}

.theme-switch-icon::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(255,255,255,0.5) 0%, transparent 100%);
}

.theme-switch-text {
  flex: 1;
  font-size: 30rpx;
  font-weight: 500;
  color: var(--color-text-primary);
}

.theme-switch-desc {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-top: 4rpx;
}

.switch-track {
  width: 100rpx;
  height: 56rpx;
  border-radius: 28rpx;
  background-color: var(--color-bg-input);
  position: relative;
  transition: background-color var(--transition-normal);
  flex-shrink: 0;
  border: 2rpx solid var(--color-border);
}

.switch-track.active {
  background-color: var(--color-primary);
  border-color: var(--color-primary);
}

.switch-thumb {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background-color: #FFFFFF;
  position: absolute;
  top: 2rpx;
  left: 2rpx;
  transition: transform var(--transition-normal);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
}

.switch-track.active .switch-thumb {
  transform: translateX(44rpx);
}

.theme-mode-group {
  display: flex;
  background-color: var(--color-bg-input);
  border-radius: var(--radius-lg);
  padding: 6rpx;
  margin: 0 24rpx 24rpx;
}

.theme-mode-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 0;
  font-size: 26rpx;
  font-weight: 500;
  color: var(--color-text-secondary);
  border-radius: var(--radius-md);
  transition: all var(--transition-fast);
}

.theme-mode-item.active {
  background-color: var(--color-bg-card);
  color: var(--color-text-primary);
  box-shadow: var(--shadow-sm);
}
