/* 个人中心 - 参考小红书/抖音设计 */
.page {
  min-height: 100vh;
  background-color: var(--color-bg-page);
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
}

/* ==================== 用户信息区域 ==================== */
.user-section {
  background: linear-gradient(135deg, var(--color-primary) 0%, #FF8E8E 50%, #FFB88C 100%);
  padding: 48rpx 32rpx 64rpx;
  position: relative;
  overflow: hidden;
}

.user-section::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -20%;
  width: 400rpx;
  height: 400rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.user-section::after {
  content: '';
  position: absolute;
  bottom: -30%;
  left: -10%;
  width: 300rpx;
  height: 300rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 50%;
}

.user-card {
  display: flex;
  align-items: center;
  position: relative;
  z-index: 1;
}

.user-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(255, 255, 255, 0.4);
  flex-shrink: 0;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
}

.user-info {
  flex: 1;
  margin-left: 28rpx;
}

.user-name {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 8rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.user-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

.user-action {
  display: flex;
  align-items: center;
  padding: 14rpx 28rpx;
  background-color: rgba(255, 255, 255, 0.25);
  backdrop-filter: blur(10rpx);
  -webkit-backdrop-filter: blur(10rpx);
  border-radius: var(--radius-full);
  transition: all var(--transition-fast);
}

.user-action:active {
  background-color: rgba(255, 255, 255, 0.35);
  transform: scale(0.96);
}

.action-text {
  font-size: 26rpx;
  font-weight: 500;
  color: #FFFFFF;
}

.action-arrow {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-left: 4rpx;
}

/* ==================== 统计数据 ==================== */
.stats-section {
  margin: -40rpx 24rpx 24rpx;
  position: relative;
  z-index: 10;
}

.stats-card {
  display: flex;
  background-color: var(--color-bg-card);
  border-radius: var(--radius-2xl);
  padding: 32rpx 0;
  box-shadow: var(--shadow-lg);
}

.stats-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}

.stats-item:not(:last-child)::after {
  content: '';
  position: absolute;
  right: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 1rpx;
  height: 60rpx;
  background-color: var(--color-border);
}

.stats-value {
  font-size: 44rpx;
  font-weight: 800;
  color: var(--color-text-primary);
  margin-bottom: 8rpx;
}

.stats-label {
  font-size: 24rpx;
  color: var(--color-text-muted);
}

/* ==================== 菜单区域 ==================== */
.menu-section {
  padding: 0 24rpx 24rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-secondary);
  margin-bottom: 16rpx;
  padding-left: 8rpx;
}

.menu-card {
  background-color: var(--color-bg-card);
  border-radius: var(--radius-2xl);
  overflow: hidden;
  box-shadow: var(--shadow-card);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  transition: all var(--transition-fast);
}

.menu-item:not(:last-child) {
  border-bottom: 1rpx solid var(--color-border-light);
}

.menu-item:active {
  background-color: var(--color-bg-page);
}

.menu-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: var(--radius-lg);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  position: relative;
  overflow: hidden;
}

.menu-icon-wrap::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(255,255,255,0.5) 0%, transparent 100%);
}

.menu-icon {
  font-size: 36rpx;
  position: relative;
  z-index: 1;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  font-weight: 500;
  color: var(--color-text-primary);
}

.menu-count {
  font-size: 26rpx;
  color: var(--color-text-muted);
  margin-right: 12rpx;
  padding: 4rpx 16rpx;
  background-color: var(--color-bg-input);
  border-radius: var(--radius-full);
}

.menu-arrow {
  font-size: 32rpx;
  color: var(--color-text-muted);
}

/* ==================== 版本信息 ==================== */
.version-section {
  padding: 48rpx 24rpx;
  text-align: center;
}

.version-text {
  font-size: 24rpx;
  color: var(--color-text-muted);
}
