<page-meta page-style="background-color: {{darkMode ? '#0F1117' : '#F8F9FA'}}; color: {{darkMode ? '#E8ECF1' : '#2C3E50'}}"/>
<view class="page {{darkMode ? 'dark' : ''}} color-scheme-{{colorScheme}} {{fontSizeClass}}" aria-role="main" aria-label="个人中心">
  <view class="user-section" aria-label="用户信息">
    <view class="user-card">
      <image class="user-avatar" src="{{userInfo.avatarUrl || '/assets/images/default-avatar.png'}}" mode="aspectFill" aria-label="用户头像" />
      <view class="user-info">
        <text class="user-name">{{userInfo.nickName || '未登录'}}</text>
        <text class="user-desc" wx:if="{{userInfo.nickName}}">欢迎使用校园生活服务</text>
        <text class="user-desc" wx:else>登录后享受更多服务</text>
      </view>
      <view class="user-action" bindtap="onEditProfile" aria-role="button" aria-label="{{userInfo.nickName ? '编辑资料' : '登录'}}">
        <text class="action-text">{{userInfo.nickName ? '编辑' : '登录'}}</text>
        <text class="action-arrow">›</text>
      </view>
    </view>
  </view>

  <view class="menu-section" aria-label="功能菜单">
    <view class="menu-card">
      <view class="menu-item" hover-class="menu-item-hover" bindtap="onMenuTap" data-type="notifications" aria-role="button" aria-label="消息通知 {{unreadCount > 0 ? unreadCount + '条未读' : ''}}">
        <view class="menu-icon-wrap" style="background-color: #FEE2E2;">
          <text class="menu-icon">🔔</text>
        </view>
        <text class="menu-text">消息通知</text>
        <text class="menu-count" wx:if="{{unreadCount > 0}}">{{unreadCount > 99 ? '99+' : unreadCount}}</text>
        <text class="menu-arrow">›</text>
      </view>

      <view class="menu-item" hover-class="menu-item-hover" bindtap="onMenuTap" data-type="favorites" aria-role="button" aria-label="我的收藏">
        <view class="menu-icon-wrap" style="background-color: #FEF3C7;">
          <text class="menu-icon">★</text>
        </view>
        <text class="menu-text">我的收藏</text>
        <text class="menu-count" wx:if="{{favoritesCount > 0}}">{{favoritesCount}}</text>
        <text class="menu-arrow">›</text>
      </view>

      <view class="menu-item" hover-class="menu-item-hover" bindtap="onMenuTap" data-type="history" aria-role="button" aria-label="浏览历史">
        <view class="menu-icon-wrap" style="background-color: #DBEAFE;">
          <text class="menu-icon">🕐</text>
        </view>
        <text class="menu-text">浏览历史</text>
        <text class="menu-count" wx:if="{{historyCount > 0}}">{{historyCount}}</text>
        <text class="menu-arrow">›</text>
      </view>

      <view class="menu-item no-border" hover-class="menu-item-hover" bindtap="onMenuTap" data-type="keywordSubscription" aria-role="button" aria-label="关键词订阅">
        <view class="menu-icon-wrap" style="background-color: #FEF3C7;">
          <text class="menu-icon">🔔</text>
        </view>
        <text class="menu-text">关键词订阅</text>
        <text class="menu-desc">{{keywordSubscriptionCount}}个订阅</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>

  <view class="menu-section" aria-label="我的发布">
    <view class="section-title">我的发布</view>
    <view class="menu-card">
      <view class="menu-item" hover-class="menu-item-hover" bindtap="onMenuTap" data-type="myLostFound" aria-role="button" aria-label="失物招领">
        <view class="menu-icon-wrap" style="background-color: #FEE2E2;">
          <text class="menu-icon">🔍</text>
        </view>
        <text class="menu-text">失物招领</text>
        <text class="menu-arrow">›</text>
      </view>

      <view class="menu-item" hover-class="menu-item-hover" bindtap="onMenuTap" data-type="myMarket" aria-role="button" aria-label="二手商品">
        <view class="menu-icon-wrap" style="background-color: #D1FAE5;">
          <text class="menu-icon">🛒</text>
        </view>
        <text class="menu-text">二手商品</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>

  <view class="menu-section" aria-label="内容管理">
    <view class="section-title">内容管理</view>
    <view class="menu-card">
      <view class="menu-item" hover-class="menu-item-hover" bindtap="onMenuTap" data-type="admin" aria-role="button" aria-label="内容管理">
        <view class="menu-icon-wrap" style="background-color: #E0F2FE;">
          <text class="menu-icon">⚙️</text>
        </view>
        <text class="menu-text">内容管理</text>
        <text class="menu-desc">公告/动态/广播/风光</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>

  <view class="menu-section" aria-label="校区设置">
    <view class="section-title">校区设置</view>
    <view class="menu-card">
      <view class="menu-item" hover-class="menu-item-hover" bindtap="onCampusTap" aria-role="button" aria-label="切换校区">
        <view class="menu-icon-wrap" style="background-color: #E0F2FE;">
          <text class="menu-icon">{{currentCampusIcon || '🏫'}}</text>
        </view>
        <view class="menu-info">
          <text class="menu-text">当前校区</text>
          <text class="menu-desc">{{currentCampusName || '请选择校区'}}</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>

      <view class="theme-switch no-border" aria-role="switch" aria-checked="{{favoritesCrossCampus}}" aria-label="收藏跨校区可见">
        <view class="theme-switch-label">
          <view class="theme-switch-icon" style="background-color: #FEF3C7;">
            <text class="menu-icon">⭐</text>
          </view>
          <view>
            <text class="theme-switch-text">收藏跨校区可见</text>
            <text class="theme-switch-desc">{{favoritesCrossCampus ? '开启：切换校区收藏保留' : '关闭：按校区分别存储收藏'}}</text>
          </view>
        </view>
        <switch checked="{{favoritesCrossCampus}}" color="#1890ff" bindchange="onToggleFavoritesCrossCampus" />
      </view>
    </view>
  </view>

  <view class="menu-section" aria-label="外观设置">
    <view class="section-title">外观设置</view>
    <view class="menu-card">
      <view class="theme-switch" bindtap="onThemeToggle" aria-role="switch" aria-checked="{{darkMode}}" aria-label="深色模式">
        <view class="theme-switch-label">
          <view class="theme-switch-icon" style="background-color: {{darkMode ? '#1E1B4B' : '#FEF3C7'}};">
            <text class="menu-icon">{{darkMode ? '🌙' : '☀️'}}</text>
          </view>
          <view>
            <text class="theme-switch-text">深色模式</text>
            <text class="theme-switch-desc">{{themeMode === 'system' ? '跟随系统' : (darkMode ? '已开启' : '已关闭')}}</text>
          </view>
        </view>
        <view class="switch-track {{darkMode ? 'active' : ''}}">
          <view class="switch-thumb"></view>
        </view>
      </view>
    </view>
    <view class="theme-mode-group" aria-label="主题模式选择">
      <view class="theme-mode-item {{themeMode === 'light' ? 'active' : ''}}" bindtap="onThemeModeChange" data-mode="light" aria-role="radio" aria-checked="{{themeMode === 'light'}}" aria-label="浅色模式">
        ☀️ 浅色
      </view>
      <view class="theme-mode-item {{themeMode === 'dark' ? 'active' : ''}}" bindtap="onThemeModeChange" data-mode="dark" aria-role="radio" aria-checked="{{themeMode === 'dark'}}" aria-label="深色模式">
        🌙 深色
      </view>
      <view class="theme-mode-item {{themeMode === 'system' ? 'active' : ''}}" bindtap="onThemeModeChange" data-mode="system" aria-role="radio" aria-checked="{{themeMode === 'system'}}" aria-label="跟随系统">
        🔄 跟随系统
      </view>
    </view>
  </view>

  <view class="menu-section" aria-label="主题色选择">
    <view class="section-title">主题色</view>
    <view class="color-scheme-list">
      <view 
        class="color-scheme-item {{colorScheme === item.value ? 'active' : ''}}" 
        wx:for="{{colorSchemes}}" 
        wx:key="value"
        bindtap="onColorSchemeChange"
        data-scheme="{{item.value}}"
        aria-role="radio"
        aria-checked="{{colorScheme === item.value}}"
        aria-label="{{item.name}}"
      >
        <view class="color-scheme-dot" style="background-color: {{item.primary}};"></view>
        <text class="color-scheme-name">{{item.name}}</text>
        <view class="color-scheme-check" wx:if="{{colorScheme === item.value}}">✓</view>
      </view>
    </view>
  </view>

  <view class="menu-section" aria-label="字体大小设置">
    <view class="section-title">字体大小</view>
    <view class="font-size-group">
      <view class="font-size-item {{fontSize === 'standard' ? 'active' : ''}}" bindtap="onFontSizeChange" data-size="standard" aria-role="radio" aria-checked="{{fontSize === 'standard'}}" aria-label="标准字体">
        <text class="font-size-label">A</text>
        <text class="font-size-desc">标准</text>
      </view>
      <view class="font-size-item {{fontSize === 'large' ? 'active' : ''}}" bindtap="onFontSizeChange" data-size="large" aria-role="radio" aria-checked="{{fontSize === 'large'}}" aria-label="大字体">
        <text class="font-size-label font-size-label-lg">A</text>
        <text class="font-size-desc">大</text>
      </view>
      <view class="font-size-item {{fontSize === 'xl' ? 'active' : ''}}" bindtap="onFontSizeChange" data-size="xl" aria-role="radio" aria-checked="{{fontSize === 'xl'}}" aria-label="特大字体">
        <text class="font-size-label font-size-label-xl">A</text>
        <text class="font-size-desc">特大</text>
      </view>
    </view>
    <view class="font-size-preview">
      <text class="preview-text">预览文字效果，校园生活服务</text>
    </view>
  </view>

  <view class="menu-section" aria-label="更多功能">
    <view class="section-title">更多</view>
    <view class="menu-card">
      <view class="menu-item" hover-class="menu-item-hover" bindtap="onMenuTap" data-type="feedback" aria-role="button" aria-label="意见反馈">
        <view class="menu-icon-wrap" style="background-color: #E9D5FF;">
          <text class="menu-icon">💬</text>
        </view>
        <text class="menu-text">意见反馈</text>
        <text class="menu-arrow">›</text>
      </view>

      <view class="menu-item" hover-class="menu-item-hover" bindtap="onMenuTap" data-type="changelog" aria-role="button" aria-label="更新日志">
        <view class="menu-icon-wrap" style="background-color: #DBEAFE;">
          <text class="menu-icon">📋</text>
        </view>
        <text class="menu-text">更新日志</text>
        <text class="menu-arrow">›</text>
      </view>

      <view class="menu-item" hover-class="menu-item-hover" bindtap="onClearCache" aria-role="button" aria-label="清除缓存">
        <view class="menu-icon-wrap" style="background-color: #F3F4F6;">
          <text class="menu-icon">🗑</text>
        </view>
        <text class="menu-text">清除缓存</text>
        <text class="menu-arrow">›</text>
      </view>

      <view class="menu-item" hover-class="menu-item-hover" bindtap="onAbout" aria-role="button" aria-label="关于我们">
        <view class="menu-icon-wrap" style="background-color: #F3F4F6;">
          <text class="menu-icon">ℹ</text>
        </view>
        <text class="menu-text">关于我们</text>
        <text class="menu-arrow">›</text>
      </view>

      <view class="menu-item" hover-class="menu-item-hover" bindtap="onLogout" wx:if="{{userInfo.nickName}}" aria-role="button" aria-label="退出登录">
        <view class="menu-icon-wrap" style="background-color: #FEE2E2;">
          <text class="menu-icon">🚪</text>
        </view>
        <text class="menu-text">退出登录</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>

  <view class="version-section" aria-label="版本信息">
    <text class="version-text">校园生活服务 v2.0.0</text>
  </view>

  <!-- 校区选择器 -->
  <campus-selector
    visible="{{showCampusSelector}}"
    required="{{false}}"
    showClose="{{true}}"
    title="切换校区"
    bind:confirm="onCampusConfirm"
    bind:close="onCampusClose"
  />
</view>
