<view class="pets-page {{darkMode ? 'dark' : ''}}">

  <skeleton wx:if="{{showSkeleton}}" />

  <block wx:else>

    <view class="search-bar">
      <view class="search-input-wrap">
        <text class="search-icon">🔍</text>
        <input 
          class="search-input" 
          placeholder="搜索动物名称、品种..." 
          value="{{keyword}}"
          bindinput="onSearchInput"
          bindconfirm="onSearchConfirm"
          confirm-type="search"
        />
      </view>
      <view class="filter-btn" bindtap="onFilterTap">
        <text>筛选</text>
        <text class="filter-icon">⚙️</text>
      </view>
    </view>

    <scroll-view class="tab-bar" scroll-x="{{true}}" enhanced="{{true}}" show-scrollbar="{{false}}">
      <view 
        class="tab-item {{currentTab === item.value ? 'active' : ''}}" 
        wx:for="{{filterTabs}}" 
        wx:key="value"
        data-value="{{item.value}}"
        bindtap="onTabTap"
      >
        <text class="tab-icon" wx:if="{{item.icon}}">{{item.icon}}</text>
        <text>{{item.label}}</text>
      </view>
    </scroll-view>

    <view class="result-info" wx:if="{{totalCount !== undefined}}">
      <text>共找到 {{totalCount}} 只毛孩子</text>
    </view>

    <view class="animal-list" wx:if="{{filteredAnimals.length > 0}}">
      <view 
        class="animal-card" 
        wx:for="{{filteredAnimals}}" 
        wx:key="id"
        data-id="{{item.id}}"
        bindtap="onAnimalTap"
      >
        <view class="animal-image">
          <image src="{{item.avatar}}" mode="aspectFill" />
          <view class="animal-status-tag" style="background: {{item.statusColor}};">
            {{item.statusLabel}}
          </view>
          <view class="animal-health-tag" style="background: {{item.healthColor}};">
            {{item.healthIcon}}
          </view>
        </view>
        <view class="animal-info">
          <view class="animal-name-row">
            <text class="animal-name">{{item.name}}</text>
            <text class="animal-gender" style="color: {{item.gender === 'male' ? '#3B82F6' : '#EC4899'}};">
              {{item.genderIcon}} {{item.genderLabel}}
            </text>
          </view>
          <view class="animal-basic">
            <text class="animal-type">{{item.typeIcon}} {{item.breed}}</text>
            <text class="animal-dot">·</text>
            <text class="animal-age">{{item.ageText}}</text>
            <text class="animal-dot">·</text>
            <text class="animal-weight">{{item.weight}}</text>
          </view>
          <view class="animal-tags">
            <view 
              class="animal-tag" 
              wx:for="{{item.personalityTags}}" 
              wx:for-item="tag" 
              wx:key="value"
              style="background: {{tag.color}}15; color: {{tag.color}};"
            >
              {{tag.label}}
            </view>
          </view>
          <view class="animal-footer">
            <view class="animal-stats">
              <text class="stat-item">👁 {{item.views}}</text>
              <text class="stat-item">❤️ {{item.likes}}</text>
            </view>
            <view 
              class="adopt-btn" 
              catchtap="onAdoptTap" 
              data-id="{{item.id}}"
              wx:if="{{item.status === 'available'}}"
            >
              申请领养
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="load-more" wx:if="{{filteredAnimals.length > 0}}">
      <text wx:if="{{hasMore}}">加载更多...</text>
      <text wx:else class="no-more">— 已经到底啦 —</text>
    </view>

    <empty wx:else text="暂无符合条件的动物" />

    <view class="filter-mask" wx:if="{{showFilterModal}}" bindtap="onFilterClose"></view>
    <view class="filter-modal {{showFilterModal ? 'show' : ''}}" catchtap="catchNoop">
      <view class="filter-header">
        <text class="filter-title">筛选条件</text>
        <text class="filter-reset" bindtap="onFilterReset">重置</text>
      </view>
      
      <view class="filter-section">
        <text class="filter-section-title">健康状况</text>
        <view class="filter-options">
          <view 
            class="filter-option {{healthFilter === 'all' ? 'active' : ''}}"
            data-value="all"
            bindtap="onHealthFilterTap"
          >
            全部
          </view>
          <view 
            class="filter-option {{healthFilter === item.value ? 'active' : ''}}"
            wx:for="{{ANIMAL_HEALTH_STATUS}}"
            wx:key="value"
            data-value="{{item.value}}"
            bindtap="onHealthFilterTap"
            style="border-color: {{healthFilter === item.value ? item.color : ''}}; color: {{healthFilter === item.value ? item.color : ''}};"
          >
            {{item.icon}} {{item.label}}
          </view>
        </view>
      </view>

      <view class="filter-section">
        <text class="filter-section-title">性别</text>
        <view class="filter-options">
          <view 
            class="filter-option {{genderFilter === 'all' ? 'active' : ''}}"
            data-value="all"
            bindtap="onGenderFilterTap"
          >
            全部
          </view>
          <view 
            class="filter-option {{genderFilter === 'male' ? 'active' : ''}}"
            data-value="male"
            bindtap="onGenderFilterTap"
            style="border-color: {{genderFilter === 'male' ? '#3B82F6' : ''}}; color: {{genderFilter === 'male' ? '#3B82F6' : ''}};"
          >
            ♂ 男孩
          </view>
          <view 
            class="filter-option {{genderFilter === 'female' ? 'active' : ''}}"
            data-value="female"
            bindtap="onGenderFilterTap"
            style="border-color: {{genderFilter === 'female' ? '#EC4899' : ''}}; color: {{genderFilter === 'female' ? '#EC4899' : ''}};"
          >
            ♀ 女孩
          </view>
        </view>
      </view>

      <view class="filter-footer">
        <view class="filter-cancel" bindtap="onFilterClose">取消</view>
        <view class="filter-confirm" bindtap="onFilterConfirm">确定</view>
      </view>
    </view>

  </block>

</view>
