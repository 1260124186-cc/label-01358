<view class="volunteer-page {{darkMode ? 'dark' : ''}}">

  <skeleton wx:if="{{showSkeleton}}" />

  <block wx:else>

    <view class="banner">
      <view class="banner-content">
        <view class="banner-icon">🙋</view>
        <view class="banner-text">
          <view class="banner-title">加入我们</view>
          <view class="banner-desc">用爱心温暖每一个生命</view>
        </view>
      </view>
      <view class="banner-stats">
        <view class="stat-item">
          <view class="stat-num">{{activities.length}}</view>
          <view class="stat-label">进行中活动</view>
        </view>
        <view class="stat-item">
          <view class="stat-num">{{activities.reduce((s, a) => s + a.currentParticipants, 0)}}</view>
          <view class="stat-label">志愿者</view>
        </view>
      </view>
    </view>

    <view class="tab-bar">
      <view 
        class="tab-item {{currentTab === 'activities' ? 'active' : ''}}"
        data-value="activities"
        bindtap="onTabTap"
      >
        📅 志愿活动
      </view>
      <view 
        class="tab-item {{currentTab === 'signup' ? 'active' : ''}}"
        data-value="signup"
        bindtap="onTabTap"
      >
        📝 我要报名
      </view>
    </view>

    <view class="activities-section" wx:if="{{currentTab === 'activities'}}">
      <view class="activity-list" wx:if="{{activities.length > 0}}">
        <view 
          class="activity-card" 
          wx:for="{{activities}}" 
          wx:key="id"
          data-id="{{item.id}}"
          bindtap="onActivityTap"
        >
          <view class="activity-header">
            <view class="activity-type" style="background: {{item.typeColor}}15; color: {{item.typeColor}};">
              <text>{{item.typeIcon}} {{item.typeLabel}}</text>
            </view>
            <view class="activity-status {{item.status}}">
              {{item.status === 'upcoming' ? '即将开始' : item.status === 'ongoing' ? '进行中' : '已结束'}}
            </view>
          </view>
          <view class="activity-title">{{item.title}}</view>
          <view class="activity-info">
            <view class="info-item">
              <text class="info-icon">📅</text>
              <text>{{item.dateText}} {{item.timeText}}</text>
            </view>
            <view class="info-item">
              <text class="info-icon">📍</text>
              <text>{{item.location}}</text>
            </view>
          </view>
          <view class="activity-progress">
            <view class="progress-bar">
              <view class="progress-fill" style="width: {{item.progress}}%;"></view>
            </view>
            <text class="progress-text">{{item.currentParticipants}}/{{item.maxParticipants}}人</text>
          </view>
          <view class="activity-footer">
            <text class="start-time">{{item.startText}}开始</text>
            <view class="join-btn">立即报名</view>
          </view>
        </view>
      </view>
      <empty wx:else text="暂无志愿活动" />
    </view>

    <view class="signup-section" wx:if="{{currentTab === 'signup'}}">
      <view class="form-card">
        <view class="section-title">
          <text>📝 基本信息</text>
        </view>

        <view class="form-item">
          <text class="label">姓名 <text class="required">*</text></text>
          <input 
            class="input" 
            placeholder="请输入您的真实姓名" 
            value="{{form.name}}"
            data-field="name"
            bindinput="onInputChange"
          />
        </view>

        <view class="form-item">
          <text class="label">手机号 <text class="required">*</text></text>
          <input 
            class="input" 
            type="number" 
            maxlength="11" 
            placeholder="请输入手机号" 
            value="{{form.phone}}"
            data-field="phone"
            bindinput="onInputChange"
          />
        </view>

        <view class="form-item">
          <text class="label">微信号</text>
          <input 
            class="input" 
            placeholder="请输入微信号" 
            value="{{form.wechat}}"
            data-field="wechat"
            bindinput="onInputChange"
          />
        </view>

        <view class="form-item">
          <text class="label">年龄</text>
          <input 
            class="input" 
            type="number" 
            placeholder="请输入年龄" 
            value="{{form.age}}"
            data-field="age"
            bindinput="onInputChange"
          />
        </view>

        <view class="form-item">
          <text class="label">职业</text>
          <input 
            class="input" 
            placeholder="请输入您的职业" 
            value="{{form.occupation}}"
            data-field="occupation"
            bindinput="onInputChange"
          />
        </view>
      </view>

      <view class="form-card">
        <view class="section-title">
          <text>🎯 服务意向 <text class="required">*</text></text>
        </view>

        <view class="form-item">
          <text class="label">服务角色</text>
          <view class="role-grid">
            <view 
              class="role-item {{form.role === item.value ? 'active' : ''}}"
              wx:for="{{roles}}"
              wx:key="value"
              data-value="{{item.value}}"
              bindtap="onRoleTap"
              style="border-color: {{form.role === item.value ? item.color : ''}};"
            >
              <text class="role-icon" style="color: {{form.role === item.value ? item.color : ''}};">{{item.icon}}</text>
              <text class="role-label" style="color: {{form.role === item.value ? item.color : ''}};">{{item.label}}</text>
            </view>
          </view>
        </view>

        <view class="form-item">
          <text class="label">可服务时间 <text class="required">*</text></text>
          <input 
            class="input" 
            placeholder="例如：每周六下午、周末全天" 
            value="{{form.availableTime}}"
            data-field="availableTime"
            bindinput="onInputChange"
          />
        </view>

        <view class="form-item">
          <text class="label">相关经验</text>
          <textarea 
            class="textarea" 
            placeholder="请描述您的养宠或志愿服务经验" 
            value="{{form.experience}}"
            data-field="experience"
            bindinput="onInputChange"
          />
        </view>

        <view class="form-item">
          <text class="label">特长/技能</text>
          <input 
            class="input" 
            placeholder="例如：摄影、文案、医疗、设计等" 
            value="{{form.skills}}"
            data-field="skills"
            bindinput="onInputChange"
          />
        </view>
      </view>

      <view class="form-card">
        <view class="section-title">
          <text>💝 报名理由 <text class="required">*</text></text>
        </view>

        <view class="form-item">
          <textarea 
            class="textarea large" 
            placeholder="请告诉我们您为什么想要成为志愿者..." 
            value="{{form.reason}}"
            data-field="reason"
            bindinput="onInputChange"
            maxlength="500"
          />
          <text class="count">{{form.reason.length}}/500</text>
        </view>
      </view>

      <view class="agreement-section">
        <view class="agreement-row">
          <switch 
            checked="{{form.agreeProtocol}}" 
            data-field="agreeProtocol"
            bindchange="onInputChange"
            color="#f5576c"
          />
          <text class="agreement-text">
            我已阅读并同意 
            <text class="link" bindtap="onProtocolTap">《志愿者协议》</text>
          </text>
        </view>
      </view>

      <view class="contact-section">
        <text class="contact-text">如有疑问，欢迎联系我们</text>
        <view class="contact-btn" bindtap="onCallPhone">
          📞 联系负责人
        </view>
      </view>

      <view class="submit-footer">
        <button 
          class="submit-btn {{submitting ? 'loading' : ''}}"
          bindtap="onSubmit"
          disabled="{{submitting}}"
        >
          <text wx:if="{{submitting}}">提交中...</text>
          <text wx:else>提交报名</text>
        </button>
      </view>
    </view>

  </block>

  <view class="success-mask" wx:if="{{showSuccess}}" bindtap="onSuccessClose">
    <view class="success-content" catchtap="catchNoop">
      <view class="success-icon">🎉</view>
      <view class="success-title">报名成功！</view>
      <view class="success-desc">
        我们的工作人员将在1-3个工作日内与您联系，\n感谢您的爱心与支持！
      </view>
      <view class="success-btn" bindtap="onSuccessClose">我知道了</view>
    </view>
  </view>

</view>
