.donation-page {
  min-height: 100vh;
  background: var(--bg-page, #f5f7fa);
}

.donation-page.dark {
  background: var(--bg-page-dark, #1a1a2e);
}

.banner {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  padding: 48rpx 32rpx;
  color: #fff;
}

.banner-content {
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
}

.banner-icon {
  font-size: 72rpx;
  margin-right: 24rpx;
}

.banner-title {
  font-size: 40rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.banner-desc {
  font-size: 26rpx;
  opacity: 0.9;
}

.banner-stats {
  display: flex;
  justify-content: space-around;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 16rpx;
  padding: 24rpx 0;
}

.stat-item {
  text-align: center;
}

.stat-num {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 4rpx;
}

.stat-label {
  font-size: 22rpx;
  opacity: 0.85;
}

.tab-bar {
  display: flex;
  background: var(--bg-card, #fff);
  padding: 16rpx 24rpx;
  gap: 16rpx;
}

.dark .tab-bar {
  background: var(--bg-card-dark, #2a2a40);
}

.tab-item {
  flex: 1;
  padding: 20rpx;
  text-align: center;
  background: var(--bg-gray, #f5f7fa);
  border-radius: 16rpx;
  font-size: 28rpx;
  color: var(--text-secondary, #666);
}

.dark .tab-item {
  background: var(--bg-gray-dark, #3a3a50);
  color: var(--text-secondary-dark, #999);
}

.tab-item.active {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  color: #fff;
}

.section-card {
  background: var(--bg-card, #fff);
  border-radius: 24rpx;
  margin: 24rpx;
  padding: 32rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.dark .section-card {
  background: var(--bg-card-dark, #2a2a40);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary, #1a1a2e);
  margin-bottom: 24rpx;
}

.dark .section-title {
  color: var(--text-primary-dark, #fff);
}

.amount-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.amount-item {
  padding: 24rpx 16rpx;
  background: var(--bg-gray, #f5f7fa);
  border: 2rpx solid transparent;
  border-radius: 16rpx;
  text-align: center;
}

.dark .amount-item {
  background: var(--bg-gray-dark, #3a3a50);
}

.amount-item.active {
  background: rgba(245, 87, 108, 0.1);
  border-color: #f5576c;
}

.amount-value {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary, #1a1a2e);
  margin-bottom: 8rpx;
}

.dark .amount-value {
  color: var(--text-primary-dark, #fff);
}

.amount-item.active .amount-value {
  color: #f5576c;
}

.amount-desc {
  font-size: 22rpx;
  color: var(--text-tertiary, #999);
}

.dark .amount-desc {
  color: var(--text-tertiary-dark, #666);
}

.custom-amount {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: var(--bg-gray, #f5f7fa);
  border-radius: 16rpx;
  margin-bottom: 24rpx;
}

.dark .custom-amount {
  background: var(--bg-gray-dark, #3a3a50);
}

.amount-prefix {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary, #1a1a2e);
  margin-right: 12rpx;
}

.dark .amount-prefix {
  color: var(--text-primary-dark, #fff);
}

.amount-input {
  flex: 1;
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary, #1a1a2e);
}

.dark .amount-input {
  color: var(--text-primary-dark, #fff);
}

.donate-btn {
  width: 100%;
  padding: 28rpx;
  text-align: center;
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  color: #fff;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
}

.donate-btn.loading {
  opacity: 0.7;
}

.protocol-row {
  text-align: center;
  margin-top: 20rpx;
  font-size: 24rpx;
  color: var(--text-tertiary, #999);
}

.dark .protocol-row {
  color: var(--text-tertiary-dark, #666);
}

.supply-list {
  padding: 0 24rpx;
}

.supply-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx;
  background: var(--bg-card, #fff);
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.dark .supply-item {
  background: var(--bg-card-dark, #2a2a40);
}

.supply-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  flex-shrink: 0;
}

.supply-info {
  flex: 1;
}

.supply-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary, #1a1a2e);
  margin-bottom: 8rpx;
}

.dark .supply-name {
  color: var(--text-primary-dark, #fff);
}

.supply-desc {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary, #666);
  margin-bottom: 4rpx;
}

.dark .supply-desc {
  color: var(--text-secondary-dark, #999);
}

.supply-need {
  font-size: 22rpx;
  color: #f5576c;
}

.supply-action {
  text-align: right;
}

.supply-price {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #f5576c;
  margin-bottom: 12rpx;
}

.supply-btn {
  padding: 12rpx 24rpx;
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  color: #fff;
  border-radius: 32rpx;
  font-size: 24rpx;
  display: inline-block;
}

.delivery-info {
  background: var(--bg-card, #fff);
  border-radius: 24rpx;
  margin: 0 24rpx 24rpx;
  padding: 32rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.dark .delivery-info {
  background: var(--bg-card-dark, #2a2a40);
}

.info-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary, #1a1a2e);
  margin-bottom: 20rpx;
}

.dark .info-title {
  color: var(--text-primary-dark, #fff);
}

.info-row {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  margin-bottom: 16rpx;
  font-size: 26rpx;
  color: var(--text-secondary, #666);
}

.dark .info-row {
  color: var(--text-secondary-dark, #999);
}

.info-label {
  flex-shrink: 0;
}

.info-value {
  flex: 1;
  line-height: 1.5;
}

.copy-btn {
  flex-shrink: 0;
  padding: 4rpx 16rpx;
  background: var(--bg-gray, #f5f7fa);
  border-radius: 8rpx;
  font-size: 22rpx;
  color: #3B82F6;
}

.dark .copy-btn {
  background: var(--bg-gray-dark, #3a3a50);
}

.usage-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.usage-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.usage-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  flex-shrink: 0;
}

.usage-info {
  flex: 1;
}

.usage-title {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary, #1a1a2e);
  margin-bottom: 4rpx;
}

.dark .usage-title {
  color: var(--text-primary-dark, #fff);
}

.usage-desc {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary, #666);
  margin-bottom: 2rpx;
}

.dark .usage-desc {
  color: var(--text-secondary-dark, #999);
}

.usage-date {
  font-size: 22rpx;
  color: var(--text-tertiary, #999);
}

.dark .usage-date {
  color: var(--text-tertiary-dark, #666);
}

.usage-amount {
  font-size: 28rpx;
  font-weight: 600;
  color: #f5576c;
}

.records-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.record-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.record-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #fecaca 0%, #fca5a5 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  flex-shrink: 0;
}

.record-info {
  flex: 1;
}

.record-name {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 28rpx;
  color: var(--text-primary, #1a1a2e);
  margin-bottom: 4rpx;
}

.dark .record-name {
  color: var(--text-primary-dark, #fff);
}

.record-type {
  font-size: 20rpx;
  padding: 2rpx 8rpx;
  background: #fef3c7;
  color: #b45309;
  border-radius: 6rpx;
}

.dark .record-type {
  background: #78350f;
  color: #fef3c7;
}

.record-desc {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary, #666);
  margin-bottom: 2rpx;
}

.dark .record-desc {
  color: var(--text-secondary-dark, #999);
}

.record-time {
  font-size: 22rpx;
  color: var(--text-tertiary, #999);
}

.dark .record-time {
  color: var(--text-tertiary-dark, #666);
}

.record-amount {
  font-size: 28rpx;
  font-weight: 600;
  color: #ec4899;
}

.footer-notice {
  text-align: center;
  padding: 32rpx;
  font-size: 24rpx;
  color: var(--text-tertiary, #999);
}

.dark .footer-notice {
  color: var(--text-tertiary-dark, #666);
}

.success-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.success-content {
  width: 600rpx;
  padding: 64rpx 48rpx;
  background: var(--bg-card, #fff);
  border-radius: 32rpx;
  text-align: center;
}

.dark .success-content {
  background: var(--bg-card-dark, #2a2a40);
}

.success-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.success-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary, #1a1a2e);
  margin-bottom: 16rpx;
}

.dark .success-title {
  color: var(--text-primary-dark, #fff);
}

.success-desc {
  font-size: 28rpx;
  line-height: 1.8;
  color: var(--text-secondary, #666);
  margin-bottom: 40rpx;
  white-space: pre-line;
}

.dark .success-desc {
  color: var(--text-secondary-dark, #999);
}

.success-btns {
  display: flex;
  gap: 24rpx;
}

.success-btn {
  flex: 1;
  padding: 24rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.success-btn.secondary {
  background: var(--bg-gray, #f5f7fa);
  color: var(--text-secondary, #666);
}

.dark .success-btn.secondary {
  background: var(--bg-gray-dark, #3a3a50);
  color: var(--text-secondary-dark, #999);
}

.success-btn.primary {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  color: #fff;
}
