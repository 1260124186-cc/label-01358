.shelter-home {
  min-height: 100vh;
  background: var(--bg-page, #f5f7fa);
  padding-bottom: 40rpx;
}

.shelter-home.dark {
  background: var(--bg-page-dark, #1a1a2e);
}

.banner {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 48rpx 32rpx;
  color: #fff;
  margin-bottom: 24rpx;
}

.banner-content {
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
}

.banner-icon {
  font-size: 72rpx;
  margin-right: 24rpx;
}

.banner-title {
  font-size: 40rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.banner-desc {
  font-size: 26rpx;
  opacity: 0.9;
}

.banner-stats {
  display: flex;
  align-items: center;
  justify-content: space-around;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 16rpx;
  padding: 24rpx 0;
}

.stat-item {
  text-align: center;
  flex: 1;
}

.stat-num {
  font-size: 40rpx;
  font-weight: 600;
  margin-bottom: 4rpx;
}

.stat-num.success {
  color: #69f0ae;
}

.stat-num.warning {
  color: #ffeb3b;
}

.stat-label {
  font-size: 24rpx;
  opacity: 0.85;
}

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.3);
}

.card-section {
  background: var(--bg-card, #fff);
  margin: 0 24rpx 24rpx;
  border-radius: 24rpx;
  padding: 32rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.dark .card-section {
  background: var(--bg-card-dark, #2a2a40);
}

.section-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.title-text {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary, #1a1a2e);
}

.dark .title-text {
  color: var(--text-primary-dark, #fff);
}

.title-action {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: var(--text-secondary, #666);
}

.dark .title-action {
  color: var(--text-secondary-dark, #999);
}

.title-action .arrow {
  font-size: 32rpx;
  margin-left: 4rpx;
}

.entry-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 32rpx 24rpx;
}

.entry-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.entry-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-emoji {
  font-size: 48rpx;
}

.entry-title {
  font-size: 26rpx;
  color: var(--text-primary, #1a1a2e);
}

.dark .entry-title {
  color: var(--text-primary-dark, #fff);
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
}

.stat-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx;
  background: var(--bg-gray, #f5f7fa);
  border-radius: 16rpx;
}

.dark .stat-card {
  background: var(--bg-gray-dark, #3a3a50);
}

.stat-card-icon {
  font-size: 48rpx;
}

.stat-card-num {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary, #1a1a2e);
  margin-bottom: 4rpx;
}

.dark .stat-card-num {
  color: var(--text-primary-dark, #fff);
}

.stat-card-label {
  font-size: 24rpx;
  color: var(--text-secondary, #666);
}

.dark .stat-card-label {
  color: var(--text-secondary-dark, #999);
}

.pet-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.pet-card {
  display: flex;
  gap: 24rpx;
  padding: 20rpx;
  background: var(--bg-gray, #f5f7fa);
  border-radius: 20rpx;
}

.dark .pet-card {
  background: var(--bg-gray-dark, #3a3a50);
}

.pet-image {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  overflow: hidden;
  flex-shrink: 0;
}

.pet-image image {
  width: 100%;
  height: 100%;
}

.pet-health-tag {
  position: absolute;
  top: 8rpx;
  left: 8rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  color: #fff;
}

.pet-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.pet-name-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.pet-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary, #1a1a2e);
}

.dark .pet-name {
  color: var(--text-primary-dark, #fff);
}

.pet-gender {
  font-size: 32rpx;
}

.pet-desc {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: var(--text-secondary, #666);
}

.dark .pet-desc {
  color: var(--text-secondary-dark, #999);
}

.pet-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 12rpx;
}

.pet-tag {
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.pet-stats {
  display: flex;
  justify-content: space-between;
  margin-top: 12rpx;
  font-size: 22rpx;
  color: var(--text-tertiary, #999);
}

.dark .pet-stats {
  color: var(--text-tertiary-dark, #666);
}

.knowledge-swiper {
  height: 180rpx;
}

.knowledge-card {
  height: 100%;
  padding: 24rpx;
  background: linear-gradient(135deg, #fff5f5 0%, #fff0f6 100%);
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.dark .knowledge-card {
  background: linear-gradient(135deg, #4a2a3a 0%, #3a2a4a 100%);
}

.knowledge-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #c53030;
  margin-bottom: 8rpx;
}

.dark .knowledge-title {
  color: #feb2b2;
}

.knowledge-summary {
  font-size: 24rpx;
  color: #744210;
  line-height: 1.5;
  margin-bottom: 8rpx;
}

.dark .knowledge-summary {
  color: #fed7d7;
}

.knowledge-more {
  font-size: 22rpx;
  color: #b83280;
}

.dark .knowledge-more {
  color: #fbb6ce;
}

.knowledge-dots {
  display: flex;
  justify-content: center;
  gap: 8rpx;
  margin-top: 16rpx;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--border-color, #e0e0e0);
  transition: all 0.3s;
}

.dark .dot {
  background: var(--border-color-dark, #4a4a6a);
}

.dot.active {
  width: 32rpx;
  border-radius: 6rpx;
  background: #ec4899;
}

.donation-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.donation-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 16rpx 0;
}

.donation-item:not(:last-child) {
  border-bottom: 1rpx solid var(--border-color, #f0f0f0);
}

.dark .donation-item:not(:last-child) {
  border-bottom-color: var(--border-color-dark, #3a3a50);
}

.donation-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #fecaca 0%, #fca5a5 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  flex-shrink: 0;
}

.donation-info {
  flex: 1;
}

.donation-name {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 28rpx;
  color: var(--text-primary, #1a1a2e);
  margin-bottom: 4rpx;
}

.dark .donation-name {
  color: var(--text-primary-dark, #fff);
}

.donation-type-tag {
  font-size: 20rpx;
  padding: 2rpx 8rpx;
  background: #fef3c7;
  color: #b45309;
  border-radius: 8rpx;
}

.dark .donation-type-tag {
  background: #78350f;
  color: #fef3c7;
}

.donation-time {
  font-size: 22rpx;
  color: var(--text-tertiary, #999);
}

.dark .donation-time {
  color: var(--text-tertiary-dark, #666);
}

.donation-amount {
  font-size: 28rpx;
  font-weight: 600;
  color: #ec4899;
}

.action-banner {
  margin: 0 24rpx 24rpx;
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  border-radius: 24rpx;
  padding: 32rpx;
  color: #fff;
}

.action-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.action-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.action-desc {
  font-size: 24rpx;
  opacity: 0.9;
}

.action-btn {
  padding: 16rpx 32rpx;
  background: #fff;
  color: #f5576c;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.footer {
  text-align: center;
  padding: 32rpx;
  font-size: 24rpx;
  color: var(--text-tertiary, #999);
}

.dark .footer {
  color: var(--text-tertiary-dark, #666);
}
