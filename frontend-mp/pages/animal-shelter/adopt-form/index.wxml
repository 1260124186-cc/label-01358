<view class="adopt-form {{darkMode ? 'dark' : ''}}">

  <view class="animal-card" wx:if="{{animal}}" bindtap="catchNoop">
    <image src="{{animal.avatar}}" mode="aspectFill" class="animal-avatar" />
    <view class="animal-info">
      <text class="animal-name">申请领养：{{animal.name}}</text>
      <text class="animal-desc">{{animal.typeLabel}} · {{animal.breed}}</text>
    </view>
    <view class="change-btn" bindtap="onSelectAnimal">更换</view>
  </view>

  <view class="animal-select" wx:else bindtap="onSelectAnimal">
    <text class="select-icon">🐾</text>
    <text class="select-text">请选择要领养的动物</text>
    <text class="select-arrow">›</text>
  </view>

  <view class="form-section">
    <view class="section-title">
      <text>📝 基本信息</text>
    </view>

    <view class="form-item">
      <text class="label">姓名 <text class="required">*</text></text>
      <input 
        class="input" 
        placeholder="请输入您的真实姓名" 
        value="{{form.name}}"
        data-field="name"
        bindinput="onInputChange"
      />
    </view>

    <view class="form-item">
      <text class="label">手机号 <text class="required">*</text></text>
      <input 
        class="input" 
        type="number" 
        maxlength="11" 
        placeholder="请输入手机号" 
        value="{{form.phone}}"
        data-field="phone"
        bindinput="onInputChange"
      />
    </view>

    <view class="form-item">
      <text class="label">微信号</text>
      <input 
        class="input" 
        placeholder="请输入微信号" 
        value="{{form.wechat}}"
        data-field="wechat"
        bindinput="onInputChange"
      />
    </view>

    <view class="form-item">
      <text class="label">年龄</text>
      <input 
        class="input" 
        type="number" 
        placeholder="请输入年龄" 
        value="{{form.age}}"
        data-field="age"
        bindinput="onInputChange"
      />
    </view>

    <view class="form-item">
      <text class="label">职业</text>
      <input 
        class="input" 
        placeholder="请输入您的职业" 
        value="{{form.occupation}}"
        data-field="occupation"
        bindinput="onInputChange"
      />
    </view>
  </view>

  <view class="form-section">
    <view class="section-title">
      <text>🏠 居住环境</text>
    </view>

    <view class="form-item">
      <text class="label">详细地址 <text class="required">*</text></text>
      <input 
        class="input" 
        placeholder="请输入详细居住地址" 
        value="{{form.address}}"
        data-field="address"
        bindinput="onInputChange"
      />
    </view>

    <view class="form-item">
      <text class="label">住房类型</text>
      <view class="type-options">
        <view 
          class="type-option {{form.housingType === item.value ? 'active' : ''}}"
          wx:for="{{housingTypes}}"
          wx:key="value"
          data-value="{{item.value}}"
          bindtap="onHousingTypeChange"
        >
          {{item.label}}
        </view>
      </view>
    </view>

    <view class="form-item">
      <text class="label">住房面积 <text class="required">*</text></text>
      <input 
        class="input" 
        placeholder="例如：80㎡" 
        value="{{form.housingArea}}"
        data-field="housingArea"
        bindinput="onInputChange"
      />
    </view>

    <view class="form-item switch-item">
      <text class="label">是否有养宠经验</text>
      <switch 
        checked="{{form.hasExperience}}" 
        data-field="hasExperience"
        bindchange="onSwitchChange"
        color="#f5576c"
      />
    </view>

    <view class="form-item switch-item">
      <text class="label">是否有其他宠物</text>
      <switch 
        checked="{{form.hasOtherPets}}" 
        data-field="hasOtherPets"
        bindchange="onSwitchChange"
        color="#f5576c"
      />
    </view>

    <view class="form-item" wx:if="{{form.hasOtherPets}}">
      <text class="label">其他宠物说明</text>
      <textarea 
        class="textarea" 
        placeholder="请描述您现有的宠物情况" 
        value="{{form.otherPetsDesc}}"
        data-field="otherPetsDesc"
        bindinput="onInputChange"
      />
    </view>

    <view class="form-item switch-item">
      <text class="label">家人是否同意 <text class="required">*</text></text>
      <switch 
        checked="{{form.familyAgree}}" 
        data-field="familyAgree"
        bindchange="onSwitchChange"
        color="#f5576c"
      />
    </view>
  </view>

  <view class="form-section">
    <view class="section-title">
      <text>💼 经济状况</text>
    </view>

    <view class="form-item">
      <text class="label">工作时间</text>
      <input 
        class="input" 
        placeholder="例如：朝九晚五" 
        value="{{form.workTime}}"
        data-field="workTime"
        bindinput="onInputChange"
      />
    </view>

    <view class="form-item">
      <text class="label">月收入</text>
      <input 
        class="input" 
        placeholder="例如：8000-10000" 
        value="{{form.monthlyIncome}}"
        data-field="monthlyIncome"
        bindinput="onInputChange"
      />
    </view>
  </view>

  <view class="form-section">
    <view class="section-title">
      <text>💝 领养宣言</text>
    </view>

    <view class="form-item">
      <text class="label">领养理由 <text class="required">*</text></text>
      <textarea 
        class="textarea large" 
        placeholder="请告诉我们您为什么想要领养它..." 
        value="{{form.adoptionReason}}"
        data-field="adoptionReason"
        bindinput="onInputChange"
        maxlength="500"
      />
      <text class="count">{{form.adoptionReason.length}}/500</text>
    </view>
  </view>

  <view class="agreement-section">
    <view class="agreement-row">
      <switch 
        checked="{{form.agreeProtocol}}" 
        data-field="agreeProtocol"
        bindchange="onSwitchChange"
        color="#f5576c"
      />
      <text class="agreement-text">
        我已阅读并同意 
        <text class="link" bindtap="onProtocolTap">《领养协议》</text>
      </text>
    </view>
  </view>

  <view class="footer">
    <view class="notice">
      <text>📌 提交后工作人员将在1-3个工作日内与您联系</text>
    </view>
    <button 
      class="submit-btn {{submitting ? 'loading' : ''}}" 
      bindtap="onSubmit"
      disabled="{{submitting}}"
    >
      <text wx:if="{{submitting}}">提交中...</text>
      <text wx:else>提交申请</text>
    </button>
  </view>

  <view class="success-mask" wx:if="{{showSuccess}}" bindtap="onSuccessClose">
    <view class="success-content" catchtap="catchNoop">
      <view class="success-icon">🎉</view>
      <view class="success-title">申请提交成功！</view>
      <view class="success-desc">
        我们的工作人员将在1-3个工作日内与您联系，\n请保持手机畅通。
      </view>
      <view class="success-btn" bindtap="onSuccessClose">我知道了</view>
    </view>
  </view>

</view>
