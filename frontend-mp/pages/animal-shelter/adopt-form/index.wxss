.adopt-form {
  min-height: 100vh;
  background: var(--bg-page, #f5f7fa);
  padding: 24rpx 24rpx 200rpx;
}

.adopt-form.dark {
  background: var(--bg-page-dark, #1a1a2e);
}

.animal-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
  border-radius: 24rpx;
  margin-bottom: 24rpx;
}

.dark .animal-card {
  background: linear-gradient(135deg, #92400e 0%, #78350f 100%);
}

.animal-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;
}

.animal-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.animal-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #92400e;
}

.dark .animal-name {
  color: #fef3c7;
}

.animal-desc {
  font-size: 26rpx;
  color: #78350f;
}

.dark .animal-desc {
  color: #fde68a;
}

.change-btn {
  padding: 12rpx 24rpx;
  background: rgba(255, 255, 255, 0.8);
  border-radius: 20rpx;
  font-size: 26rpx;
  color: #92400e;
}

.dark .change-btn {
  background: rgba(0, 0, 0, 0.3);
  color: #fef3c7;
}

.animal-select {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 32rpx 24rpx;
  background: var(--bg-card, #fff);
  border: 2rpx dashed var(--border-color, #e0e0e0);
  border-radius: 24rpx;
  margin-bottom: 24rpx;
}

.dark .animal-select {
  background: var(--bg-card-dark, #2a2a40);
  border-color: var(--border-color-dark, #4a4a6a);
}

.select-icon {
  font-size: 48rpx;
}

.select-text {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-secondary, #666);
}

.dark .select-text {
  color: var(--text-secondary-dark, #999);
}

.select-arrow {
  font-size: 36rpx;
  color: var(--text-tertiary, #999);
}

.dark .select-arrow {
  color: var(--text-tertiary-dark, #666);
}

.form-section {
  background: var(--bg-card, #fff);
  border-radius: 24rpx;
  padding: 32rpx 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.dark .form-section {
  background: var(--bg-card-dark, #2a2a40);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary, #1a1a2e);
  margin-bottom: 24rpx;
}

.dark .section-title {
  color: var(--text-primary-dark, #fff);
}

.form-item {
  margin-bottom: 24rpx;
}

.label {
  display: block;
  font-size: 28rpx;
  color: var(--text-secondary, #666);
  margin-bottom: 12rpx;
}

.dark .label {
  color: var(--text-secondary-dark, #999);
}

.required {
  color: #f5576c;
}

.input {
  padding: 24rpx;
  background: var(--bg-gray, #f5f7fa);
  border-radius: 16rpx;
  font-size: 28rpx;
  color: var(--text-primary, #1a1a2e);
}

.dark .input {
  background: var(--bg-gray-dark, #3a3a50);
  color: var(--text-primary-dark, #fff);
}

.type-options {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.type-option {
  padding: 16rpx 32rpx;
  background: var(--bg-gray, #f5f7fa);
  border: 2rpx solid transparent;
  border-radius: 40rpx;
  font-size: 26rpx;
  color: var(--text-secondary, #666);
}

.dark .type-option {
  background: var(--bg-gray-dark, #3a3a50);
  color: var(--text-secondary-dark, #999);
}

.type-option.active {
  background: rgba(245, 87, 108, 0.1);
  border-color: #f5576c;
  color: #f5576c;
}

.textarea {
  width: 100%;
  min-height: 160rpx;
  padding: 24rpx;
  background: var(--bg-gray, #f5f7fa);
  border-radius: 16rpx;
  font-size: 28rpx;
  color: var(--text-primary, #1a1a2e);
  line-height: 1.6;
  box-sizing: border-box;
}

.dark .textarea {
  background: var(--bg-gray-dark, #3a3a50);
  color: var(--text-primary-dark, #fff);
}

.textarea.large {
  min-height: 240rpx;
}

.count {
  display: block;
  text-align: right;
  font-size: 22rpx;
  color: var(--text-tertiary, #999);
  margin-top: 8rpx;
}

.dark .count {
  color: var(--text-tertiary-dark, #666);
}

.switch-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.switch-item .label {
  margin-bottom: 0;
}

.agreement-section {
  background: var(--bg-card, #fff);
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.dark .agreement-section {
  background: var(--bg-card-dark, #2a2a40);
}

.agreement-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.agreement-text {
  flex: 1;
  font-size: 26rpx;
  color: var(--text-secondary, #666);
  line-height: 1.6;
}

.dark .agreement-text {
  color: var(--text-secondary-dark, #999);
}

.link {
  color: #3B82F6;
}

.footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 24rpx;
  background: var(--bg-card, #fff);
  border-top: 1rpx solid var(--border-color, #f0f0f0);
}

.dark .footer {
  background: var(--bg-card-dark, #2a2a40);
  border-top-color: var(--border-color-dark, #3a3a50);
}

.notice {
  text-align: center;
  font-size: 24rpx;
  color: var(--text-tertiary, #999);
  margin-bottom: 16rpx;
}

.dark .notice {
  color: var(--text-tertiary-dark, #666);
}

.submit-btn {
  width: 100%;
  padding: 28rpx;
  text-align: center;
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  color: #fff;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
}

.submit-btn.loading {
  opacity: 0.7;
}

.success-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.success-content {
  width: 600rpx;
  padding: 64rpx 48rpx;
  background: var(--bg-card, #fff);
  border-radius: 32rpx;
  text-align: center;
}

.dark .success-content {
  background: var(--bg-card-dark, #2a2a40);
}

.success-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.success-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary, #1a1a2e);
  margin-bottom: 16rpx;
}

.dark .success-title {
  color: var(--text-primary-dark, #fff);
}

.success-desc {
  font-size: 28rpx;
  line-height: 1.8;
  color: var(--text-secondary, #666);
  margin-bottom: 40rpx;
  white-space: pre-line;
}

.dark .success-desc {
  color: var(--text-secondary-dark, #999);
}

.success-btn {
  padding: 24rpx 80rpx;
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  color: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 500;
  display: inline-block;
}
