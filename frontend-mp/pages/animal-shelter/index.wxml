<view class="shelter-home {{darkMode ? 'dark' : ''}}">

  <skeleton wx:if="{{showSkeleton}}" />

  <block wx:else>

    <view class="banner">
      <view class="banner-content">
        <view class="banner-icon">🐾</view>
        <view class="banner-text">
          <view class="banner-title">生命关怀 · 流浪动物救助</view>
          <view class="banner-desc">每一个生命都值得被温柔对待</view>
        </view>
      </view>
      <view class="banner-stats">
        <view class="stat-item">
          <view class="stat-num">{{stats.totalAnimals}}</view>
          <view class="stat-label">在院动物</view>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <view class="stat-num success">{{stats.totalAdopted}}</view>
          <view class="stat-label">累计领养</view>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <view class="stat-num warning">{{stats.successRate}}%</view>
          <view class="stat-label">成功率</view>
        </view>
      </view>
    </view>

    <view class="quick-entries card-section">
      <view class="section-title">
        <text class="title-text">功能入口</text>
      </view>
      <view class="entry-grid">
        <view 
          class="entry-item" 
          wx:for="{{quickEntries}}" 
          wx:key="id"
          data-path="{{item.path}}"
          bindtap="onEntryTap"
        >
          <view class="entry-icon" style="background: {{item.color}}15;">
            <text class="icon-emoji">{{item.icon}}</text>
          </view>
          <text class="entry-title">{{item.title}}</text>
        </view>
      </view>
    </view>

    <view class="stats-card card-section">
      <view class="section-title">
        <text class="title-text">救助站概况</text>
      </view>
      <view class="stats-grid">
        <view class="stat-card">
          <view class="stat-card-icon" style="color: #10B981;">🐕</view>
          <view class="stat-card-info">
            <view class="stat-card-num">{{stats.availableAnimals}}</view>
            <view class="stat-card-label">待领养</view>
          </view>
        </view>
        <view class="stat-card">
          <view class="stat-card-icon" style="color: #3B82F6;">🏠</view>
          <view class="stat-card-info">
            <view class="stat-card-num">{{stats.adoptedThisMonth}}</view>
            <view class="stat-card-label">本月领养</view>
          </view>
        </view>
        <view class="stat-card">
          <view class="stat-card-icon" style="color: #8B5CF6;">🙋</view>
          <view class="stat-card-info">
            <view class="stat-card-num">{{stats.volunteers}}</view>
            <view class="stat-card-label">志愿者</view>
          </view>
        </view>
        <view class="stat-card">
          <view class="stat-card-icon" style="color: #EC4899;">💝</view>
          <view class="stat-card-info">
            <view class="stat-card-num">¥{{stats.donationsThisMonth}}</view>
            <view class="stat-card-label">本月捐款</view>
          </view>
        </view>
      </view>
    </view>

    <view class="featured-pets card-section">
      <view class="section-title">
        <text class="title-text">待领养毛孩子</text>
        <view class="title-action" bindtap="onViewAllAnimals">
          <text>查看全部</text>
          <text class="arrow">›</text>
        </view>
      </view>

      <view class="pet-list" wx:if="{{featuredAnimals.length > 0}}">
        <view 
          class="pet-card" 
          wx:for="{{featuredAnimals}}" 
          wx:key="id"
          data-id="{{item.id}}"
          bindtap="onAnimalTap"
        >
          <view class="pet-image">
            <image src="{{item.avatar}}" mode="aspectFill" />
            <view class="pet-health-tag" style="background: {{item.healthColor}};">
              <text>{{item.healthIcon}} {{item.healthLabel}}</text>
            </view>
          </view>
          <view class="pet-info">
            <view class="pet-name-row">
              <text class="pet-name">{{item.name}}</text>
              <text class="pet-gender" style="color: {{item.gender === 'male' ? '#3B82F6' : '#EC4899'}};">
                {{item.genderIcon}}
              </text>
            </view>
            <view class="pet-desc">
              <text class="pet-type">{{item.typeIcon}} {{item.typeLabel}}</text>
              <text class="pet-age">· {{item.ageText}}</text>
            </view>
            <view class="pet-tags">
              <view 
                class="pet-tag" 
                wx:for="{{item.personalityTags}}" 
                wx:for-item="tag" 
                wx:key="value"
                style="background: {{tag.color}}15; color: {{tag.color}};"
              >
                {{tag.label}}
              </view>
            </view>
            <view class="pet-stats">
              <text class="pet-views">👁 {{item.views}}</text>
              <text class="pet-rescue">救助 {{item.rescueText}}</text>
            </view>
          </view>
        </view>
      </view>

      <empty wx:else text="暂无待领养动物" />
    </view>

    <view class="knowledge-section card-section">
      <view class="section-title">
        <text class="title-text">💡 养宠小知识</text>
      </view>
      <swiper 
        class="knowledge-swiper" 
        autoplay="{{true}}" 
        interval="4000" 
        circular="{{true}}"
        bindchange="onKnowledgeChange"
      >
        <swiper-item 
          wx:for="{{knowledgeList}}" 
          wx:key="id"
          data-id="{{item.id}}"
          bindtap="onKnowledgeTap"
        >
          <view class="knowledge-card">
            <view class="knowledge-title">{{item.title}}</view>
            <view class="knowledge-summary">{{item.summary}}</view>
            <view class="knowledge-more">点击了解详情 ›</view>
          </view>
        </swiper-item>
      </swiper>
      <view class="knowledge-dots">
        <view 
          class="dot {{currentKnowledgeIndex === index ? 'active' : ''}}" 
          wx:for="{{knowledgeList}}" 
          wx:key="id"
        ></view>
      </view>
    </view>

    <view class="donation-section card-section">
      <view class="section-title">
        <text class="title-text">🎁 最新爱心捐赠</text>
        <view class="title-action" bindtap="onDonateTap">
          <text>我要捐赠</text>
          <text class="arrow">›</text>
        </view>
      </view>
      <view class="donation-list">
        <view class="donation-item" wx:for="{{recentDonations}}" wx:key="id">
          <view class="donation-avatar">
            <text>{{item.anonymous ? '🙏' : '爱心人士'}}</text>
          </view>
          <view class="donation-info">
            <view class="donation-name">
              {{item.anonymous ? '好心人' : item.donorName}}
              <text class="donation-type-tag">{{item.typeText}}</text>
            </view>
            <view class="donation-time">{{item.timeText}}</view>
          </view>
          <view class="donation-amount">{{item.amountText}}</view>
        </view>
      </view>
    </view>

    <view class="action-banner">
      <view class="action-content">
        <view class="action-text">
          <view class="action-title">想成为志愿者？</view>
          <view class="action-desc">用爱心温暖每一个生命</view>
        </view>
        <view class="action-btn" bindtap="onVolunteerTap">立即报名</view>
      </view>
    </view>

    <view class="footer">
      <text>用爱守护每一个毛孩子 🐾</text>
    </view>

  </block>

</view>
