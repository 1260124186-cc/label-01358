.page {
  min-height: 100vh;
  background-color: var(--color-bg-page);
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.tabs-bar {
  display: flex;
  background-color: var(--color-bg-card);
  padding: 16rpx 8rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
  position: sticky;
  top: 0;
  z-index: 100;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 8rpx;
  border-radius: var(--radius-md);
  transition: all 0.2s ease;
}

.tab-item.active {
  background-color: var(--color-primary-light);
}

.tab-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.tab-text {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  font-weight: 500;
}

.tab-item.active .tab-text {
  color: var(--color-primary);
  font-weight: 600;
}

.content {
  padding: 24rpx;
}

.form-section {
  margin-bottom: 20rpx;
}

.form-card {
  background-color: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: 0 24rpx;
  box-shadow: var(--shadow-card);
}

.form-item {
  display: flex;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 1rpx solid var(--color-border);
}

.form-item.no-border {
  border-bottom: none;
}

.form-label {
  width: 160rpx;
  font-size: 28rpx;
  color: var(--color-text-primary);
  flex-shrink: 0;
  line-height: 40rpx;
}

.form-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--color-text-primary);
  text-align: right;
  line-height: 40rpx;
  height: 40rpx;
}

.form-input::placeholder {
  color: var(--color-text-tertiary);
}

.form-picker-wrap {
  flex: 1;
}

.form-picker {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  height: 40rpx;
}

.picker-text {
  font-size: 28rpx;
  color: var(--color-text-primary);
  line-height: 40rpx;
}

.picker-arrow {
  font-size: 28rpx;
  color: var(--color-text-tertiary);
  margin-left: 8rpx;
  line-height: 40rpx;
}

.color-list {
  flex: 1;
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-end;
}

.color-list { margin-right: -12rpx; margin-bottom: -12rpx; }

.color-list > view { margin-right: 12rpx; margin-bottom: 12rpx; }

.color-item {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  border: 3rpx solid;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  transition: transform 0.2s ease;
}

.color-item.selected {
  transform: scale(1.1);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}

.color-check {
  font-size: 28rpx;
  font-weight: bold;
}

.submit-section {
  padding: 40rpx 24rpx;
}

.paste-section {
  margin-bottom: 20rpx;
}

.paste-title {
  display: flex;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 1rpx solid var(--color-border);
}

.paste-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.paste-title-text {
  font-size: 30rpx;
  color: var(--color-text-primary);
  font-weight: 600;
}

.paste-textarea {
  width: 100%;
  min-height: 240rpx;
  padding: 24rpx 0;
  font-size: 26rpx;
  line-height: 1.6;
  color: var(--color-text-primary);
  box-sizing: border-box;
  border-bottom: 1rpx solid var(--color-border);
}

.paste-desc {
  padding: 24rpx 0;
}

.desc-title {
  display: block;
  font-size: 26rpx;
  color: var(--color-text-primary);
  font-weight: 600;
  margin-bottom: 12rpx;
}

.desc-text {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-bottom: 12rpx;
}

.desc-format {
  background-color: var(--color-bg-page);
  padding: 16rpx;
  border-radius: var(--radius-md);
  font-size: 24rpx;
  color: var(--color-primary);
  margin-bottom: 16rpx;
  line-height: 1.6;
}

.desc-example {
  background-color: var(--color-bg-page);
  padding: 16rpx;
  border-radius: var(--radius-md);
  font-size: 22rpx;
  color: var(--color-text-secondary);
  line-height: 1.8;
}

.scan-section {
  margin-bottom: 20rpx;
}

.scan-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 24rpx;
  border-bottom: 1rpx solid var(--color-border);
}

.scan-icon {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--color-primary-light) 0%, var(--color-primary) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(63, 81, 181, 0.25);
}

.scan-emoji {
  font-size: 80rpx;
}

.scan-title {
  font-size: 32rpx;
  color: var(--color-text-primary);
  font-weight: 600;
}

.scan-desc {
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--color-border);
}

.scan-desc .desc-text {
  text-align: center;
  margin: 0;
}

.scan-tips {
  padding: 24rpx 0;
}

.tips-title {
  display: block;
  font-size: 26rpx;
  color: var(--color-primary);
  font-weight: 600;
  margin-bottom: 12rpx;
}

.tips-text {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  line-height: 1.6;
}

.page.dark .form-card,
.page.dark .tabs-bar {
  background-color: var(--color-bg-card-dark);
}

.page.dark .color-item {
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
}
