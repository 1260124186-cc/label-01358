<page-meta page-style="background-color: {{darkMode ? '#0F1117' : '#F8F9FA'}}; color: {{darkMode ? '#E8ECF1' : '#2C3E50'}}"/>
<view class="page {{darkMode ? 'dark' : ''}}">
  <view class="tabs-bar">
    <view
      wx:if="{{mode !== 'import'"
      class="tab-item {{activeTab === 'manual' ? 'active' : ''}}"
      bindtap="onTabChange"
      data-tab="manual"
    >
      <text class="tab-icon">✏️</text>
      <text class="tab-text">手动添加</text>
    </view>
    <view
      class="tab-item {{activeTab === 'paste' ? 'active' : ''}}"
      bindtap="onTabChange"
      data-tab="paste"
    >
      <text class="tab-icon">📋</text>
      <text class="tab-text">粘贴导入</text>
    </view>
    <view
      class="tab-item {{activeTab === 'scan' ? 'active' : ''}}"
      bindtap="onTabChange"
      data-tab="scan"
    >
      <text class="tab-icon">📷</text>
      <text class="tab-text">扫码导入</text>
    </view>
  </view>

  <view wx:if="{{activeTab === 'manual'" class="content">
    <view class="form-section">
      <view class="form-card">
        <view class="form-item">
          <text class="form-label">课程名</text>
          <input
            class="form-input"
            placeholder="请输入课程名"
            value="{{formData.name}}"
            bindinput="onInputChange"
            data-field="name"
            maxlength="30"
          />
        </view>

        <view class="form-item">
          <text class="form-label">教师</text>
          <input
            class="form-input"
            placeholder="请输入教师姓名"
            value="{{formData.teacher}}"
            bindinput="onInputChange"
            data-field="teacher"
            maxlength="20"
          />
        </view>

        <view class="form-item">
          <text class="form-label">教室</text>
          <input
            class="form-input"
            placeholder="请输入教室"
            value="{{formData.classroom}}"
            bindinput="onInputChange"
            data-field="classroom"
            maxlength="30"
          />
        </view>

        <view class="form-item">
          <text class="form-label">星期</text>
          <picker
            class="form-picker-wrap"
            mode="selector"
            range="{{weekDays}}"
            range-key="label"
            value="{{weekDayIndex}}"
            bindchange="onWeekDayChange"
          >
            <view class="form-picker">
              <text class="picker-text">{{weekDays[weekDayIndex].label}}</text>
              <text class="picker-arrow">›</text>
            </view>
          </picker>
        </view>

        <view class="form-item">
          <text class="form-label">开始节次</text>
          <picker
            class="form-picker-wrap"
            mode="selector"
            range="{{courseTimeSlots}}"
            range-key="label"
            value="{{startSlotIndex}}"
            bindchange="onStartSlotChange"
          >
            <view class="form-picker">
              <text class="picker-text">{{courseTimeSlots[startSlotIndex].label}} ({{courseTimeSlots[startSlotIndex].start}}-{{courseTimeSlots[startSlotIndex].end}})</text>
              <text class="picker-arrow">›</text>
            </view>
          </picker>
        </view>

        <view class="form-item">
          <text class="form-label">结束节次</text>
          <picker
            class="form-picker-wrap"
            mode="selector"
            range="{{courseTimeSlots}}"
            range-key="label"
            value="{{endSlotIndex}}"
            bindchange="onEndSlotChange"
          >
            <view class="form-picker">
              <text class="picker-text">{{courseTimeSlots[endSlotIndex].label}} ({{courseTimeSlots[endSlotIndex].start}}-{{courseTimeSlots[endSlotIndex].end}})</text>
              <text class="picker-arrow">›</text>
            </view>
          </picker>
        </view>

        <view class="form-item">
          <text class="form-label">周次</text>
          <input
            class="form-input"
            placeholder="如：1-16周"
            value="{{formData.weeks}}"
            bindinput="onWeeksInput"
            maxlength="30"
          />
        </view>

        <view class="form-item">
          <text class="form-label">学分</text>
          <input
            class="form-input"
            type="digit"
            placeholder="请输入学分"
            value="{{formData.credit}}"
            bindinput="onCreditChange"
            maxlength="4"
          />
        </view>

        <view class="form-item no-border">
          <text class="form-label">颜色</text>
          <view class="color-list">
            <view
              wx:for="{{courseColors}}"
              wx:key="index"
              class="color-item {{colorIndex === index ? 'selected' : ''}}"
              style="background-color: {{item.bg}}; border-color: {{item.border}}"
              bindtap="onColorSelect"
              data-index="{{index}}"
            >
              <view wx:if="{{colorIndex === index}}" class="color-check" style="color: {{item.text}};">✓</view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="submit-section">
      <btn type="primary" size="large" block="{{true}}" loading="{{saving}}" bind:click="onSave">
        {{mode === 'edit' ? '更新课程' : '保存课程'}}
      </btn>
    </view>
  </view>

  <view wx:if="{{activeTab === 'paste'}}" class="content">
    <view class="paste-section">
      <view class="form-card">
        <view class="paste-title">
          <text class="paste-icon">📝</text>
          <text class="paste-title-text">粘贴课程文本</text>
        </view>
        <textarea
          class="paste-textarea"
          placeholder="请粘贴课程列表，每行一门课程"
          value="{{pasteText}}"
          bindinput="onPasteInput"
          maxlength="5000"
          auto-height
        />
        <view class="paste-desc">
          <text class="desc-title">格式说明：</text>
          <text class="desc-text">每行一门课程，逗号分隔格式如下字段：</text>
          <view class="desc-format">课程名,教师,教室,星期,节次,周次,学分</view>
          <text class="desc-title">示例：</text>
          <view class="desc-example">{{pasteExample}}</view>
        </view>
      </view>
    </view>

    <view class="submit-section">
      <btn type="primary" size="large" block="{{true}}" loading="{{saving}}" bind:click="onParseImport">
        解析并导入
      </btn>
    </view>
  </view>

  <view wx:if="{{activeTab === 'scan'}}" class="content">
    <view class="scan-section">
      <view class="form-card">
        <view class="scan-area" bindtap="onScanImport">
        <view class="scan-icon">
          <text class="scan-emoji">📷</text>
        </view>
          <text class="scan-title">点击扫码</text>
        </view>
        <view class="scan-desc">
          <text class="desc-text">点击上方区域调用摄像头扫描课程二维码</text>
        </view>
        <view class="scan-tips">
          <text class="tips-title">💡 演示说明</text>
          <text class="tips-text">无论扫描什么内容，都将演示导入3门示例课程</text>
        </view>
      </view>
    </view>

    <view class="submit-section">
      <btn type="primary" size="large" block="{{true}}" loading="{{saving}}" bind:click="onScanImport">
        扫码导入课程
      </btn>
    </view>
  </view>
</view>
