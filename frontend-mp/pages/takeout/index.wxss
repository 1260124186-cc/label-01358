.page {
  min-height: 100vh;
  background-color: var(--color-bg-page);
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

/* ==================== 搜索栏 ==================== */
.search-section {
  padding: 16rpx 24rpx 20rpx;
  background-color: var(--color-bg-card);
  border-bottom: 1rpx solid var(--color-border-light);
  position: sticky;
  top: 0;
  z-index: 100;
}

.search-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background-color: var(--color-bg-input);
  border-radius: var(--radius-full);
  transition: all var(--transition-fast);
}

.search-bar:active {
  background-color: var(--color-border);
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  font-size: var(--font-base);
  color: var(--color-text-primary);
  height: 40rpx;
  line-height: 40rpx;
}

.search-placeholder {
  color: var(--color-text-muted);
  font-size: var(--font-sm);
}

/* ==================== 主滚动区域 ==================== */
.main-scroll {
  height: calc(100vh - 120rpx);
}

/* ==================== 通用区块 ==================== */
.section {
  padding: 24rpx 24rpx 0;
}

.section-category {
  padding-bottom: 16rpx;
}

.section-sort {
  padding-top: 0;
  padding-bottom: 16rpx;
}

.section-merchant {
  padding-bottom: 24rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-title-wrap {
  display: flex;
  align-items: center;
}

.section-icon {
  width: 8rpx;
  height: 32rpx;
  background: linear-gradient(180deg, var(--color-primary) 0%, #FF8E8E 100%);
  border-radius: 4rpx;
  margin-right: 12rpx;
}

.section-icon-discount {
  background: linear-gradient(180deg, #FA8C16 0%, #FFA940 100%);
}

.section-icon-merchant {
  background: linear-gradient(180deg, #722ED1 0%, #9254DE 100%);
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

.section-subtitle {
  font-size: 24rpx;
  color: var(--color-text-muted);
  margin-left: 12rpx;
  font-weight: 500;
}

/* ==================== 优惠横幅 ==================== */
.banner-section {
  padding: 24rpx 24rpx 0;
}

.banner-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.banner-card {
  flex: 1;
  min-width: calc(50% - 8rpx);
  max-width: calc(50% - 8rpx);
  display: flex;
  align-items: center;
  padding: 24rpx 20rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  transition: all var(--transition-fast);
}

.banner-card-hover {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.banner-card-icon {
  font-size: 44rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.banner-card-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.banner-card-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #FFFFFF;
  line-height: 1.3;
}

.banner-card-subtitle {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-top: 6rpx;
  line-height: 1.3;
}

/* ==================== 今日优惠 ==================== */
.discount-scroll {
  white-space: nowrap;
  margin: 0 -24rpx;
  padding: 0 24rpx;
}

.discount-list {
  display: inline-flex;
  padding-right: 24rpx;
}

.discount-list > view { margin-right: 20rpx; }
.discount-list > view:last-child { margin-right: 0; }

.discount-card {
  width: 280rpx;
  background-color: var(--color-bg-card);
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: var(--shadow-card);
  display: inline-block;
  vertical-align: top;
  transition: all var(--transition-fast);
  position: relative;
}

.discount-card-hover {
  transform: scale(0.98);
  box-shadow: var(--shadow-sm);
}

.discount-badge {
  position: absolute;
  top: 0;
  left: 0;
  padding: 6rpx 16rpx;
  background: linear-gradient(135deg, #FF4D4F 0%, #FF7875 100%);
  color: #FFFFFF;
  font-size: 22rpx;
  font-weight: 700;
  border-bottom-right-radius: 12rpx;
  z-index: 2;
}

.discount-image {
  width: 280rpx;
  height: 160rpx;
}

.discount-info {
  padding: 14rpx 18rpx 18rpx;
}

.discount-name {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.discount-price-row {
  display: flex;
  align-items: baseline;
  margin-top: 8rpx;
}

.discount-price-symbol {
  font-size: 20rpx;
  font-weight: 600;
  color: #FF4D4F;
}

.discount-price {
  font-size: 30rpx;
  font-weight: 700;
  color: #FF4D4F;
  margin-left: 2rpx;
}

.discount-price-origin {
  font-size: 20rpx;
  color: var(--color-text-muted);
  text-decoration: line-through;
  margin-left: 8rpx;
}

.discount-limit {
  margin-top: 6rpx;
}

.discount-limit-text {
  font-size: 20rpx;
  color: #FA8C16;
  font-weight: 500;
}

.discount-merchant {
  display: block;
  font-size: 20rpx;
  color: var(--color-text-muted);
  margin-top: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ==================== 分类导航 ==================== */
.category-scroll {
  white-space: nowrap;
  margin: 0 -24rpx;
  padding: 0 24rpx;
}

.category-list {
  display: inline-flex;
  padding-right: 24rpx;
}

.category-list > view { margin-right: 16rpx; }
.category-list > view:last-child { margin-right: 0; }

.category-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 16rpx 20rpx;
  background-color: var(--color-bg-card);
  border-radius: 16rpx;
  box-shadow: var(--shadow-sm);
  transition: all var(--transition-fast);
  border: 2rpx solid transparent;
}

.category-item-hover {
  transform: scale(0.96);
}

.category-item.active {
  background: linear-gradient(135deg, rgba(255, 107, 107, 0.1) 0%, rgba(255, 142, 142, 0.1) 100%);
  border-color: var(--color-primary);
}

.category-icon {
  font-size: 36rpx;
  margin-bottom: 6rpx;
}

.category-name {
  font-size: 22rpx;
  font-weight: 500;
  color: var(--color-text-secondary);
  line-height: 1.2;
}

.category-item.active .category-name {
  color: var(--color-primary);
  font-weight: 600;
}

/* ==================== 排序选项 ==================== */
.sort-list {
  display: flex;
  align-items: center;
  background-color: var(--color-bg-card);
  border-radius: 16rpx;
  padding: 8rpx;
  box-shadow: var(--shadow-sm);
}

.sort-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx 16rpx;
  border-radius: 12rpx;
  transition: all var(--transition-fast);
}

.sort-item-hover {
  background-color: var(--color-bg-input);
}

.sort-item.active {
  background: linear-gradient(135deg, var(--color-primary) 0%, #FF8E8E 100%);
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 107, 0.3);
}

.sort-name {
  font-size: 24rpx;
  font-weight: 500;
  color: var(--color-text-secondary);
}

.sort-item.active .sort-name {
  color: #FFFFFF;
  font-weight: 600;
}

/* ==================== 商家列表 ==================== */
.merchant-list {
  display: flex;
  flex-direction: column;
}

.merchant-list > view { margin-bottom: 20rpx; }
.merchant-list > view:last-child { margin-bottom: 0; }

.merchant-card {
  background-color: var(--color-bg-card);
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: var(--shadow-card);
  transition: all var(--transition-fast);
}

.merchant-card-hover {
  transform: scale(0.985);
  box-shadow: var(--shadow-sm);
}

.merchant-top {
  position: relative;
}

.merchant-cover-wrap {
  width: 100%;
  height: 280rpx;
  overflow: hidden;
  position: relative;
}

.merchant-cover {
  width: 100%;
  height: 100%;
  transition: transform 0.4s ease;
}

.merchant-card-hover .merchant-cover {
  transform: scale(1.03);
}

.merchant-status {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
}

.merchant-status-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #FFFFFF;
  background-color: rgba(0, 0, 0, 0.6);
  padding: 12rpx 32rpx;
  border-radius: 100rpx;
}

.merchant-tag-row {
  position: absolute;
  left: 12rpx;
  bottom: 12rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.merchant-tag {
  padding: 4rpx 12rpx;
  background-color: rgba(255, 255, 255, 0.95);
  border-radius: 8rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.merchant-tag-text {
  font-size: 20rpx;
  font-weight: 600;
  color: var(--color-primary);
  line-height: 1.2;
}

.merchant-favorite {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 64rpx;
  height: 64rpx;
  background-color: rgba(255, 255, 255, 0.95);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
  transition: all var(--transition-fast);
}

.merchant-favorite:active {
  transform: scale(0.9);
}

.favorite-icon {
  font-size: 32rpx;
  transition: transform 0.3s ease;
}

.favorite-icon.active {
  animation: heartBeat 0.4s ease;
}

@keyframes heartBeat {
  0% { transform: scale(1); }
  25% { transform: scale(1.3); }
  50% { transform: scale(0.95); }
  100% { transform: scale(1); }
}

/* ==================== 商家信息 ==================== */
.merchant-info {
  padding: 20rpx 24rpx 24rpx;
}

.merchant-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.merchant-name {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  line-height: 1.3;
}

.merchant-meta {
  display: flex;
  align-items: center;
  margin-top: 12rpx;
  flex-wrap: wrap;
  gap: 12rpx;
}

.merchant-rating {
  display: flex;
  align-items: center;
}

.stars {
  display: flex;
  align-items: center;
}

.star {
  font-size: 24rpx;
  margin-right: 2rpx;
}

.star.full {
  color: #FAAD14;
}

.star.half {
  color: #FAAD14;
  opacity: 0.7;
}

.star.empty {
  color: var(--color-text-muted);
  opacity: 0.5;
}

.rating-num {
  font-size: 26rpx;
  font-weight: 700;
  color: #FAAD14;
  margin-left: 10rpx;
}

.review-count {
  font-size: 24rpx;
  color: var(--color-text-muted);
}

.sales-text {
  font-size: 24rpx;
  color: var(--color-text-muted);
}

.merchant-basic {
  display: flex;
  align-items: center;
  margin-top: 16rpx;
  flex-wrap: wrap;
}

.basic-item {
  display: flex;
  align-items: center;
}

.basic-icon {
  font-size: 24rpx;
  margin-right: 6rpx;
  flex-shrink: 0;
}

.basic-text {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.basic-divider {
  font-size: 22rpx;
  color: var(--color-border);
  margin: 0 12rpx;
}

.merchant-price-info {
  display: flex;
  align-items: center;
  margin-top: 16rpx;
  flex-wrap: wrap;
  gap: 12rpx;
}

.price-tag {
  padding: 6rpx 16rpx;
  background-color: var(--color-bg-input);
  border-radius: var(--radius-sm);
}

.price-tag.free-tag {
  background-color: rgba(82, 196, 26, 0.1);
}

.price-tag-text {
  font-size: 22rpx;
  font-weight: 500;
  color: var(--color-text-secondary);
}

.price-tag.free-tag .price-tag-text {
  color: #52C41A;
}

.merchant-hours {
  display: flex;
  align-items: center;
  margin-top: 16rpx;
  padding: 14rpx 18rpx;
  background-color: var(--color-bg-input);
  border-radius: var(--radius-md);
}

.hours-icon {
  font-size: 24rpx;
  margin-right: 10rpx;
  flex-shrink: 0;
}

.hours-text {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  line-height: 1.5;
}

/* ==================== 商家活动 ==================== */
.merchant-promotions {
  display: flex;
  flex-direction: column;
  margin-top: 16rpx;
  gap: 10rpx;
}

.promotion-item {
  display: flex;
  align-items: center;
}

.promotion-icon-wrap {
  width: 32rpx;
  height: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 10rpx;
  flex-shrink: 0;
}

.promotion-icon {
  font-size: 24rpx;
}

.promotion-text {
  font-size: 24rpx;
  color: #FF4D4F;
  font-weight: 500;
  line-height: 1.4;
}

/* ==================== 今日特价 ==================== */
.merchant-today-discount {
  margin-top: 16rpx;
  padding: 16rpx 18rpx;
  background: linear-gradient(135deg, rgba(250, 140, 22, 0.08) 0%, rgba(255, 169, 64, 0.08) 100%);
  border-radius: var(--radius-md);
  border: 1rpx solid rgba(250, 140, 22, 0.2);
}

.today-discount-label {
  display: inline-flex;
  margin-bottom: 12rpx;
}

.today-discount-label-text {
  font-size: 22rpx;
  font-weight: 700;
  color: #FA8C16;
  background: linear-gradient(135deg, rgba(250, 140, 22, 0.15) 0%, rgba(255, 169, 64, 0.15) 100%);
  padding: 6rpx 16rpx;
  border-radius: var(--radius-sm);
}

.today-discount-list {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.today-discount-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.dish-name-text {
  font-size: 24rpx;
  color: var(--color-text-primary);
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-right: 12rpx;
}

.dish-price-wrap {
  display: flex;
  align-items: baseline;
  flex-shrink: 0;
}

.dish-price-text {
  font-size: 26rpx;
  font-weight: 700;
  color: #FF4D4F;
}

.dish-origin-text {
  font-size: 20rpx;
  color: var(--color-text-muted);
  text-decoration: line-through;
  margin-left: 8rpx;
}

/* ==================== 底部提示 ==================== */
.list-bottom {
  padding: 40rpx 24rpx 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.list-bottom-text {
  font-size: 22rpx;
  color: var(--color-text-muted);
  position: relative;
  padding: 0 24rpx;
}

.list-bottom-text::before,
.list-bottom-text::after {
  content: '';
  position: absolute;
  top: 50%;
  width: 60rpx;
  height: 1rpx;
  background-color: var(--color-border-light);
}

.list-bottom-text::before {
  left: -40rpx;
}

.list-bottom-text::after {
  right: -40rpx;
}

.bottom-safe {
  height: env(safe-area-inset-bottom);
}

/* ==================== 暗色模式适配 ==================== */
.page.dark .search-section {
  border-bottom: 1rpx solid var(--color-border);
}

.page.dark .merchant-favorite {
  background-color: rgba(30, 32, 40, 0.95);
}

.page.dark .category-item.active {
  background: linear-gradient(135deg, rgba(255, 107, 107, 0.2) 0%, rgba(255, 142, 142, 0.2) 100%);
}

.page.dark .merchant-today-discount {
  background: linear-gradient(135deg, rgba(250, 140, 22, 0.15) 0%, rgba(255, 169, 64, 0.15) 100%);
}
