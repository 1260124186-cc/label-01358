.page {
  min-height: 100vh;
  background-color: #F8F9FA;
}

.page.dark {
  background-color: #0F1117;
  color: #E8ECF1;
}

.tabs {
  display: flex;
  background-color: #fff;
  padding: 0 20rpx;
  position: sticky;
  top: 0;
  z-index: 10;
}

.page.dark .tabs {
  background-color: #1A1D29;
}

.tab-item {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 28rpx;
  color: #6B7280;
  position: relative;
  transition: all 0.2s ease;
}

.page.dark .tab-item {
  color: #9AA0A6;
}

.tab-item.active {
  color: #FF6B6B;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  background-color: #FF6B6B;
  border-radius: 3rpx;
}

.list-container {
  padding: 20rpx;
}

.appointment-card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  transition: all 0.2s ease;
}

.page.dark .appointment-card {
  background-color: #1A1D29;
}

.appointment-card:active {
  transform: scale(0.98);
}

.card-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.house-info {
  display: flex;
  flex: 1;
  min-width: 0;
}

.house-cover {
  width: 120rpx;
  height: 90rpx;
  border-radius: 8rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.house-detail {
  flex: 1;
  min-width: 0;
}

.house-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #111;
  margin-bottom: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.page.dark .house-title {
  color: #E8ECF1;
}

.house-address {
  font-size: 24rpx;
  color: #9CA3AF;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.status-badge {
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.card-body {
  padding: 16rpx 0;
  border-top: 1rpx solid #F3F4F6;
  border-bottom: 1rpx solid #F3F4F6;
}

.page.dark .card-body {
  border-top-color: #2A2F3D;
  border-bottom-color: #2A2F3D;
}

.info-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.info-row:last-child {
  margin-bottom: 0;
}

.info-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.info-label {
  font-size: 26rpx;
  color: #6B7280;
  width: 120rpx;
  flex-shrink: 0;
}

.page.dark .info-label {
  color: #9AA0A6;
}

.info-value {
  flex: 1;
  font-size: 26rpx;
  color: #111;
}

.page.dark .info-value {
  color: #E8ECF1;
}

.info-value.message {
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 16rpx;
}

.create-time {
  font-size: 22rpx;
  color: #9CA3AF;
}

.card-actions {
  display: flex;
}

.card-actions > view {
  margin-left: 16rpx;
}

.action-btn {
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 500;
  transition: all 0.2s ease;
}

.action-btn.outline {
  border: 2rpx solid #E5E7EB;
  color: #6B7280;
}

.page.dark .action-btn.outline {
  border-color: #3A3F4D;
  color: #9AA0A6;
}

.action-btn.primary {
  background-color: #FF6B6B;
  color: #fff;
}

.reject-reason {
  margin-top: 16rpx;
  padding: 16rpx;
  background-color: #FEF2F2;
  border-radius: 12rpx;
}

.page.dark .reject-reason {
  background-color: rgba(239, 68, 68, 0.1);
}

.reject-label {
  font-size: 24rpx;
  color: #EF4444;
  font-weight: 500;
}

.reject-text {
  font-size: 24rpx;
  color: #B91C1C;
}

.page.dark .reject-text {
  color: #FCA5A5;
}

.empty-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 30rpx;
  font-weight: 500;
  color: #6B7280;
  margin-bottom: 12rpx;
}

.page.dark .empty-text {
  color: #9AA0A6;
}

.empty-desc {
  font-size: 26rpx;
  color: #9CA3AF;
}

.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #E5E7EB;
  border-top-color: #FF6B6B;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 16rpx;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: 26rpx;
  color: #9CA3AF;
}
