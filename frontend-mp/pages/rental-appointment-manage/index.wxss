.page {
  min-height: 100vh;
  background-color: #F8F9FA;
}

.page.dark {
  background-color: #0F1117;
  color: #E8ECF1;
}

.tabs {
  display: flex;
  background-color: #fff;
  padding: 0 20rpx;
  position: sticky;
  top: 0;
  z-index: 10;
}

.page.dark .tabs {
  background-color: #1A1D29;
}

.tab-item {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 28rpx;
  color: #6B7280;
  position: relative;
  transition: all 0.2s ease;
}

.page.dark .tab-item {
  color: #9AA0A6;
}

.tab-item.active {
  color: #FF6B6B;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  background-color: #FF6B6B;
  border-radius: 3rpx;
}

.list-container {
  padding: 20rpx;
}

.appointment-card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  transition: all 0.2s ease;
}

.page.dark .appointment-card {
  background-color: #1A1D29;
}

.card-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.user-info {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.user-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.user-detail {
  flex: 1;
  min-width: 0;
}

.user-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #111;
  margin-bottom: 6rpx;
}

.page.dark .user-name {
  color: #E8ECF1;
}

.house-title {
  font-size: 24rpx;
  color: #9CA3AF;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.status-badge {
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.card-body {
  padding: 16rpx 0;
  border-top: 1rpx solid #F3F4F6;
  border-bottom: 1rpx solid #F3F4F6;
}

.page.dark .card-body {
  border-top-color: #2A2F3D;
  border-bottom-color: #2A2F3D;
}

.info-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.info-row:last-child {
  margin-bottom: 0;
}

.info-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.info-label {
  font-size: 26rpx;
  color: #6B7280;
  width: 120rpx;
  flex-shrink: 0;
}

.page.dark .info-label {
  color: #9AA0A6;
}

.info-value {
  flex: 1;
  font-size: 26rpx;
  color: #111;
}

.page.dark .info-value {
  color: #E8ECF1;
}

.info-value.link {
  color: #FF6B6B;
}

.info-value.message {
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 16rpx;
}

.create-time {
  font-size: 22rpx;
  color: #9CA3AF;
}

.card-actions {
  display: flex;
}

.card-actions > view {
  margin-left: 16rpx;
}

.action-btn {
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 500;
  transition: all 0.2s ease;
}

.action-btn.outline {
  border: 2rpx solid #E5E7EB;
  color: #6B7280;
}

.page.dark .action-btn.outline {
  border-color: #3A3F4D;
  color: #9AA0A6;
}

.action-btn.primary {
  background-color: #FF6B6B;
  color: #fff;
}

.empty-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 30rpx;
  font-weight: 500;
  color: #6B7280;
}

.page.dark .empty-text {
  color: #9AA0A6;
}

.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #E5E7EB;
  border-top-color: #FF6B6B;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 16rpx;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: 26rpx;
  color: #9CA3AF;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.modal-mask.show {
  opacity: 1;
  visibility: visible;
}

.modal-content {
  width: 100%;
  max-width: 640rpx;
  background-color: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  transform: translateY(20rpx);
  transition: transform 0.3s ease;
}

.modal-mask.show .modal-content {
  transform: translateY(0);
}

.page.dark .modal-content {
  background-color: #1A1D29;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.page.dark .modal-header {
  border-bottom-color: #2A2F3D;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #111;
}

.page.dark .modal-title {
  color: #E8ECF1;
}

.modal-close {
  font-size: 40rpx;
  color: #999;
  padding: 10rpx;
  line-height: 1;
}

.modal-body {
  padding: 30rpx;
}

.form-group {
  margin-bottom: 24rpx;
}

.form-group:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #374151;
  margin-bottom: 16rpx;
}

.page.dark .form-label {
  color: #D1D5DB;
}

.form-textarea {
  width: 100%;
  min-height: 160rpx;
  padding: 20rpx 24rpx;
  background-color: #F8F9FA;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #111;
  line-height: 1.7;
  box-sizing: border-box;
}

.page.dark .form-textarea {
  background-color: #2A2F3D;
  color: #E8ECF1;
}

.form-textarea::placeholder {
  color: #9CA3AF;
}

.modal-footer {
  display: flex;
  padding: 0 30rpx 30rpx;
}

.modal-footer > view { margin-right: 24rpx; }

.modal-footer > view:last-child { margin-right: 0; }

.modal-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 44rpx;
  font-size: 28rpx;
  font-weight: 600;
  transition: all 0.2s ease;
}

.modal-btn:active {
  opacity: 0.8;
}

.modal-btn.cancel {
  background-color: #F5F5F5;
  color: #4B5563;
}

.page.dark .modal-btn.cancel {
  background-color: #2A2F3D;
  color: #D1D5DB;
}

.modal-btn.confirm {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  color: #fff;
}

.reschedule-modal {
  max-height: 80vh;
  display: flex;
  flex-direction: column;
}

.reschedule-modal .modal-body {
  flex: 1;
  max-height: 50vh;
  overflow-y: auto;
}

.date-scroll {
  white-space: nowrap;
}

.date-list {
  display: inline-flex;
}

.date-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 120rpx;
  height: 100rpx;
  margin-right: 16rpx;
  background-color: #F8F9FA;
  border-radius: 12rpx;
  transition: all 0.2s ease;
}

.page.dark .date-item {
  background-color: #2A2F3D;
}

.date-item:last-child {
  margin-right: 0;
}

.date-item.active {
  background-color: #FF6B6B;
}

.date-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #374151;
  margin-bottom: 4rpx;
}

.date-item.active .date-label {
  color: #fff;
}

.date-sub {
  font-size: 22rpx;
  color: #9CA3AF;
}

.date-item.active .date-sub {
  color: rgba(255, 255, 255, 0.8);
}

.time-slot-grid {
  display: flex;
  flex-wrap: wrap;
}

.time-slot-grid > view {
  margin-right: 16rpx;
  margin-bottom: 16rpx;
}

.time-slot-grid > view:nth-child(3n) {
  margin-right: 0;
}

.time-slot-item {
  width: calc((100% - 32rpx) / 3);
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  font-size: 26rpx;
  color: #4B5563;
  background-color: #F8F9FA;
  border-radius: 12rpx;
  box-sizing: border-box;
  transition: all 0.2s ease;
}

.page.dark .time-slot-item {
  background-color: #2A2F3D;
  color: #D1D5DB;
}

.time-slot-item.active {
  background-color: #FF6B6B;
  color: #fff;
}
