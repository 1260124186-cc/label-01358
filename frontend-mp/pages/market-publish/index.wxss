/* 发布商品 - 与首页风格统一 */
.page {
  min-height: 100vh;
  background-color: var(--color-bg-page);
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.form-section {
  padding: 24rpx 24rpx 0;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-secondary);
  margin-bottom: 16rpx;
  padding-left: 8rpx;
}

/* ==================== 图片上传 ==================== */
.image-card {
  background-color: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: 24rpx;
  box-shadow: var(--shadow-card);
}

.image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.image-item {
  position: relative;
  width: calc((100% - 32rpx) / 3);
  aspect-ratio: 1;
}

.preview-image {
  width: 100%;
  height: 100%;
  border-radius: var(--radius-lg);
}

.image-delete {
  position: absolute;
  top: -12rpx;
  right: -12rpx;
  width: 44rpx;
  height: 44rpx;
  background: linear-gradient(135deg, #E74C3C 0%, #EC7063 100%);
  color: #FFFFFF;
  font-size: 28rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(231, 76, 60, 0.4);
}

.image-add {
  width: calc((100% - 32rpx) / 3);
  aspect-ratio: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: var(--color-bg-input);
  border: 2rpx dashed var(--color-border);
  border-radius: var(--radius-lg);
  transition: all var(--transition-fast);
}

.image-add:active {
  background-color: var(--color-border);
}

.add-icon {
  font-size: 48rpx;
  color: var(--color-text-muted);
  line-height: 1;
}

.add-text {
  font-size: 24rpx;
  color: var(--color-text-muted);
  margin-top: 10rpx;
}

.image-tip {
  font-size: 24rpx;
  color: var(--color-text-muted);
  margin-top: 16rpx;
}

/* ==================== 表单卡片 ==================== */
.form-card {
  background-color: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: 0 24rpx;
  box-shadow: var(--shadow-card);
}

.form-item {
  display: flex;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 1rpx solid var(--color-border-light);
}

.form-item.no-border {
  border-bottom: none;
}

.form-label {
  min-width: 140rpx;
  max-width: 180rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: var(--color-text-primary);
  flex-shrink: 0;
  white-space: nowrap;
  line-height: 40rpx;
}

.form-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--color-text-primary);
  text-align: right;
  line-height: 40rpx;
  height: 40rpx;
}

.form-input::placeholder {
  color: var(--color-text-muted);
}

/* picker组件需要占满剩余空间 */
.form-picker-wrap {
  flex: 1;
}

.form-picker {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  height: 40rpx;
}

.picker-text {
  font-size: 28rpx;
  color: var(--color-text-primary);
  line-height: 40rpx;
}

.picker-text.placeholder {
  color: var(--color-text-muted);
}

.picker-arrow {
  font-size: 28rpx;
  color: var(--color-text-muted);
  margin-left: 8rpx;
  line-height: 40rpx;
}

/* ==================== 价格输入 ==================== */
.price-input-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.price-symbol {
  font-size: 30rpx;
  color: var(--color-primary);
  font-weight: 700;
  line-height: 40rpx;
}

.price-input {
  width: 160rpx;
  height: 40rpx;
  font-size: 30rpx;
  color: var(--color-primary);
  font-weight: 700;
  text-align: right;
  line-height: 40rpx;
}

.price-input::placeholder {
  color: var(--color-text-muted);
  font-weight: 400;
}

/* ==================== 文本域 ==================== */
.form-textarea {
  width: 100%;
  min-height: 200rpx;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: var(--color-text-primary);
  line-height: 1.7;
}

.form-textarea::placeholder {
  color: var(--color-text-muted);
}

.textarea-count {
  display: block;
  text-align: right;
  font-size: 24rpx;
  color: var(--color-text-muted);
  padding-bottom: 16rpx;
}

/* ==================== 提交按钮 ==================== */
.submit-section {
  padding: 40rpx 24rpx;
}
