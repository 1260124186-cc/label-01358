<page-meta page-style="background-color: {{darkMode ? '#0F1117' : '#F8F9FA'}}; color: {{darkMode ? '#E8ECF1' : '#2C3E50'}}"/>
<view class="page {{darkMode ? 'dark' : ''}}">
  <view class="search-section">
    <view class="search-box">
      <text class="search-icon">🔍</text>
      <input
        class="search-input"
        placeholder="搜索线路名称、站点"
        value="{{searchKeyword}}"
        bindinput="onSearchInput"
        bindconfirm="onSearchConfirm"
        confirm-type="search"
      />
    </view>
  </view>

  <view class="stats-section">
    <view class="stat-card">
      <text class="stat-icon">🚌</text>
      <view class="stat-info">
        <text class="stat-value">{{runningVehiclesCount}}</text>
        <text class="stat-label">运营车辆</text>
      </view>
    </view>
    <view class="stat-card">
      <text class="stat-icon">🔔</text>
      <view class="stat-info">
        <text class="stat-value">{{activeRemindersCount}}</text>
        <text class="stat-label">到站提醒</text>
      </view>
    </view>
  </view>

  <view class="tab-section">
    <scroll-view class="tab-scroll" scroll-x="{{true}}" enhanced="{{true}}" show-scrollbar="{{false}}">
      <view class="tabs">
        <view
          class="tab-item {{currentTab === item.value ? 'active' : ''}}"
          wx:for="{{tabs}}"
          wx:key="value"
          bindtap="onTabChange"
          data-value="{{item.value}}"
        >{{item.label}}</view>
      </view>
    </scroll-view>
  </view>

  <scroll-view
    class="list-scroll"
    scroll-y="{{true}}"
    refresher-enabled="{{true}}"
    refresher-triggered="{{refreshing}}"
    bindrefresherrefresh="onRefresh"
  >
    <view class="list-container" wx:if="{{list.length > 0}}">
      <view
        class="bus-card"
        wx:for="{{list}}"
        wx:key="id"
        hover-class="bus-card-hover"
        bindtap="onItemTap"
        data-item="{{item}}"
      >
        <view class="card-header">
          <view class="route-badge" style="background-color: {{item.typeColor}}15; color: {{item.typeColor}}">
            <text class="route-icon">{{item.typeIcon}}</text>
            <text class="route-type">{{item.typeText}}</text>
          </view>
          <view
            class="favorite-btn {{item.isFavorite ? 'active' : ''}}"
            catchtap="onToggleFavorite"
            data-item="{{item}}"
          >
            <text>{{item.isFavorite ? '❤️' : '🤍'}}</text>
          </view>
        </view>

        <view class="card-title">
          <text class="route-name">{{item.name}}</text>
          <view class="running-badge" wx:if="{{item.runningCount > 0}}">
            <text class="running-dot"></text>
            <text>{{item.runningCount}}辆运行中</text>
          </view>
        </view>

        <view class="card-route">
          <view class="route-stations">
            <view class="station-item">
              <view class="station-dot start"></view>
              <text class="station-name">{{item.firstStation}}</text>
            </view>
            <view class="station-line">
              <view class="line-track"></view>
              <text class="station-count">{{item.stationCount}}站</text>
            </view>
            <view class="station-item">
              <view class="station-dot end"></view>
              <text class="station-name">{{item.lastStation}}</text>
            </view>
          </view>
        </view>

        <view class="card-info">
          <view class="info-item">
            <text class="info-icon">🕐</text>
            <text class="info-text">{{item.operatingHours}}</text>
          </view>
          <view class="info-item">
            <text class="info-icon">⏱️</text>
            <text class="info-text">发车间隔 {{item.interval}}分钟</text>
          </view>
        </view>

        <view class="card-footer">
          <view class="arrival-info">
            <text class="arrival-text">{{item.nextArrivalText}}</text>
          </view>
          <view class="arrow-icon">›</view>
        </view>
      </view>
    </view>

    <empty
      wx:if="{{!loading && list.length === 0}}"
      text="{{currentTab === 'favorite' ? '暂无收藏线路' : '暂无班车线路'}}"
      showAction="{{false}}"
    />
  </scroll-view>
</view>
