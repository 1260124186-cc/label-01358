.page {
  min-height: 100vh;
  background-color: #F8F9FA;
  padding-bottom: 40rpx;
}

.page.dark {
  background-color: #0F1117;
  color: #E8ECF1;
}

.route-header {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  padding: 40rpx 30rpx 60rpx;
  color: #fff;
}

.header-content {
  position: relative;
}

.route-title-row {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.route-badge {
  display: flex;
  align-items: center;
  padding: 8rpx 20rpx;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.route-icon {
  margin-right: 8rpx;
  font-size: 26rpx;
}

.favorite-btn {
  margin-left: auto;
  font-size: 40rpx;
  padding: 8rpx;
}

.favorite-btn.active {
  animation: heartBeat 0.3s ease;
}

@keyframes heartBeat {
  0% { transform: scale(1); }
  50% { transform: scale(1.3); }
  100% { transform: scale(1); }
}

.route-name {
  font-size: 40rpx;
  font-weight: 700;
  display: block;
  margin-bottom: 12rpx;
}

.route-desc {
  font-size: 26rpx;
  opacity: 0.9;
  margin-bottom: 24rpx;
}

.route-info-row {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
}

.route-info-row .info-item {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  opacity: 0.9;
}

.route-info-row .info-icon {
  margin-right: 8rpx;
  font-size: 24rpx;
}

.vehicles-section {
  margin: -30rpx 20rpx 20rpx;
  background-color: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  position: relative;
  z-index: 10;
}

.page.dark .vehicles-section {
  background-color: #1A1D29;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.3);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #111;
}

.page.dark .section-title {
  color: #E8ECF1;
}

.update-time {
  font-size: 22rpx;
  color: #999;
}

.page.dark .update-time {
  color: #666;
}

.vehicles-scroll {
  white-space: nowrap;
}

.vehicles-list {
  display: inline-flex;
  gap: 16rpx;
}

.vehicle-card {
  flex-shrink: 0;
  width: 280rpx;
  padding: 20rpx;
  background-color: #F8F9FA;
  border-radius: 16rpx;
  border: 1rpx solid #EEEEEE;
}

.page.dark .vehicle-card {
  background-color: #2A2F3D;
  border-color: #3A3F4D;
}

.vehicle-status {
  display: flex;
  align-items: center;
  font-size: 22rpx;
  margin-bottom: 12rpx;
}

.vehicle-status.running {
  color: #10B981;
}

.vehicle-status.waiting {
  color: #F59E0B;
}

.vehicle-status.stopped {
  color: #6B7280;
}

.status-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin-right: 8rpx;
  background-color: currentColor;
  animation: pulse 2s infinite;
}

.vehicle-plate {
  font-size: 28rpx;
  font-weight: 600;
  color: #111;
  display: block;
  margin-bottom: 12rpx;
}

.page.dark .vehicle-plate {
  color: #E8ECF1;
}

.vehicle-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.current-station,
.passenger-count {
  font-size: 22rpx;
  color: #666;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.page.dark .current-station,
.page.dark .passenger-count {
  color: #9AA0A6;
}

.schedule-tabs {
  background-color: #fff;
  border-bottom: 1rpx solid #EEEEEE;
}

.page.dark .schedule-tabs {
  background-color: #1A1D29;
  border-bottom-color: #2A2F3D;
}

.tab-scroll {
  white-space: nowrap;
}

.tabs {
  display: inline-flex;
  padding: 0 20rpx;
}

.tab-item {
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.page.dark .tab-item {
  color: #9AA0A6;
}

.tab-icon {
  margin-right: 8rpx;
  font-size: 28rpx;
}

.tab-item.active {
  color: #FF6B6B;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 6rpx;
  background-color: #FF6B6B;
  border-radius: 3rpx;
}

.stations-scroll {
  height: calc(100vh - 560rpx);
}

.stations-container {
  padding: 20rpx;
}

.station-timeline {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 20rpx 0;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.page.dark .station-timeline {
  background-color: #1A1D29;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.3);
}

.station-item {
  display: flex;
  padding: 0 24rpx;
}

.timeline-col {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 60rpx;
  flex-shrink: 0;
}

.timeline-line {
  width: 4rpx;
  flex: 1;
  background-color: #E5E7EB;
}

.page.dark .timeline-line {
  background-color: #3A3F4D;
}

.timeline-line.top {
  height: 30rpx;
  flex: none;
}

.timeline-line.bottom {
  flex: 1;
  min-height: 30rpx;
}

.station-item.first .timeline-line.top {
  background-color: transparent;
}

.station-item.last .timeline-line.bottom {
  background-color: transparent;
}

.timeline-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background-color: #E5E7EB;
  border: 4rpx solid #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  z-index: 1;
}

.page.dark .timeline-dot {
  border-color: #1A1D29;
  background-color: #3A3F4D;
}

.timeline-dot.arriving {
  background-color: #10B981;
  width: 36rpx;
  height: 36rpx;
  border-color: #D1FAE5;
  animation: pulse 1.5s infinite;
}

.page.dark .timeline-dot.arriving {
  border-color: rgba(16, 185, 129, 0.3);
}

.station-content {
  flex: 1;
  padding-bottom: 30rpx;
  padding-top: 0;
  min-height: 80rpx;
}

.station-item.last .station-content {
  padding-bottom: 0;
}

.station-main {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-left: 16rpx;
}

.station-info {
  flex: 1;
  min-width: 0;
}

.station-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #111;
  display: block;
  margin-bottom: 8rpx;
}

.page.dark .station-name {
  color: #E8ECF1;
}

.station-meta {
  display: flex;
  align-items: center;
}

.schedule-time {
  font-size: 22rpx;
  color: #666;
}

.page.dark .schedule-time {
  color: #9AA0A6;
}

.arrival-section {
  display: flex;
  align-items: center;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.arrival-info {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  margin-right: 16rpx;
}

.arrival-text {
  font-size: 26rpx;
  color: #666;
  font-weight: 500;
}

.page.dark .arrival-text {
  color: #9AA0A6;
}

.arrival-text.urgent {
  color: #10B981;
  font-weight: 600;
}

.vehicle-plate {
  font-size: 20rpx;
  color: #999;
  margin-top: 4rpx;
}

.reminder-btn {
  padding: 12rpx 16rpx;
  background-color: #F3F4F6;
  border-radius: 12rpx;
  font-size: 22rpx;
  color: #666;
  flex-shrink: 0;
}

.page.dark .reminder-btn {
  background-color: #2A2F3D;
  color: #9AA0A6;
}

.reminder-btn.active {
  background-color: #FEF3C7;
  color: #D97706;
}

.page.dark .reminder-btn.active {
  background-color: rgba(245, 158, 11, 0.15);
  color: #FBBF24;
}

.picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 200;
  display: flex;
  align-items: flex-end;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.picker-mask.show {
  opacity: 1;
  visibility: visible;
}

.picker-content {
  width: 100%;
  max-height: 80vh;
  background-color: #fff;
  border-radius: 30rpx 30rpx 0 0;
  transform: translateY(100%);
  transition: transform 0.3s ease;
}

.picker-mask.show .picker-content {
  transform: translateY(0);
}

.page.dark .picker-content {
  background-color: #1A1D29;
}

.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.page.dark .picker-header {
  border-bottom-color: #2A2F3D;
}

.picker-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.page.dark .picker-title {
  color: #E8ECF1;
}

.picker-subtitle {
  padding: 16rpx 30rpx;
  font-size: 26rpx;
  color: #666;
  background-color: #F8F9FA;
}

.page.dark .picker-subtitle {
  color: #9AA0A6;
  background-color: #2A2F3D;
}

.picker-close {
  font-size: 40rpx;
  color: #999;
  padding: 10rpx;
}

.picker-options {
  padding: 20rpx;
  max-height: 60vh;
  overflow-y: auto;
}

.picker-option {
  padding: 28rpx 30rpx;
  font-size: 28rpx;
  color: #333;
  border-radius: 12rpx;
  margin-bottom: 8rpx;
}

.page.dark .picker-option {
  color: #E8ECF1;
}

.picker-option.active {
  background-color: #FFEAEA;
  color: #FF6B6B;
  font-weight: 500;
}

.page.dark .picker-option.active {
  background-color: rgba(255, 107, 107, 0.2);
  color: #FF6B6B;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}
