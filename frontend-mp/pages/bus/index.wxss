.page {
  min-height: 100vh;
  background-color: #F8F9FA;
  padding-bottom: 40rpx;
}

.page.dark {
  background-color: #0F1117;
  color: #E8ECF1;
}

.search-section {
  padding: 20rpx 30rpx;
  background-color: #fff;
}

.page.dark .search-section {
  background-color: #1A1D29;
}

.search-box {
  display: flex;
  align-items: center;
  background-color: #F5F5F5;
  border-radius: 40rpx;
  padding: 20rpx 30rpx;
}

.page.dark .search-box {
  background-color: #2A2F3D;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 16rpx;
  color: #999;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.page.dark .search-input {
  color: #E8ECF1;
}

.stats-section {
  display: flex;
  padding: 20rpx 30rpx;
  gap: 20rpx;
  background-color: #fff;
}

.page.dark .stats-section {
  background-color: #1A1D29;
}

.stat-card {
  flex: 1;
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: linear-gradient(135deg, #FF6B6B10 0%, #FF6B6B20 100%);
  border-radius: 16rpx;
}

.page.dark .stat-card {
  background: linear-gradient(135deg, rgba(255, 107, 107, 0.1) 0%, rgba(255, 107, 107, 0.2) 100%);
}

.stat-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.stat-info {
  display: flex;
  flex-direction: column;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #FF6B6B;
  line-height: 1.2;
}

.stat-label {
  font-size: 22rpx;
  color: #666;
  margin-top: 4rpx;
}

.page.dark .stat-label {
  color: #9AA0A6;
}

.tab-section {
  background-color: #fff;
  border-bottom: 1rpx solid #EEEEEE;
}

.page.dark .tab-section {
  background-color: #1A1D29;
  border-bottom-color: #2A2F3D;
}

.tab-scroll {
  white-space: nowrap;
}

.tabs {
  display: inline-flex;
  padding: 0 20rpx;
}

.tab-item {
  padding: 24rpx 30rpx;
  font-size: 30rpx;
  color: #666;
  position: relative;
}

.page.dark .tab-item {
  color: #9AA0A6;
}

.tab-item.active {
  color: #FF6B6B;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 6rpx;
  background-color: #FF6B6B;
  border-radius: 3rpx;
}

.list-scroll {
  height: calc(100vh - 380rpx);
}

.list-container {
  padding: 20rpx;
}

.bus-card {
  background-color: #fff;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.page.dark .bus-card {
  background-color: #1A1D29;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.3);
}

.bus-card-hover {
  transform: scale(0.98);
  opacity: 0.9;
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.route-badge {
  display: flex;
  align-items: center;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.route-icon {
  margin-right: 8rpx;
  font-size: 26rpx;
}

.favorite-btn {
  margin-left: auto;
  font-size: 36rpx;
  padding: 4rpx;
}

.favorite-btn.active {
  color: #FF6B6B;
}

.card-title {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.route-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #111;
  flex: 1;
}

.page.dark .route-name {
  color: #E8ECF1;
}

.running-badge {
  display: flex;
  align-items: center;
  padding: 6rpx 16rpx;
  background-color: #ECFDF5;
  border-radius: 12rpx;
  font-size: 22rpx;
  color: #10B981;
}

.page.dark .running-badge {
  background-color: rgba(16, 185, 129, 0.15);
  color: #34D399;
}

.running-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background-color: #10B981;
  margin-right: 8rpx;
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

.card-route {
  margin-bottom: 20rpx;
}

.route-stations {
  display: flex;
  align-items: center;
}

.station-item {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.station-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.station-dot.start {
  background-color: #10B981;
}

.station-dot.end {
  background-color: #EF4444;
}

.station-name {
  font-size: 26rpx;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.page.dark .station-name {
  color: #E8ECF1;
}

.station-line {
  display: flex;
  align-items: center;
  padding: 0 16rpx;
  flex-shrink: 0;
}

.line-track {
  width: 60rpx;
  height: 2rpx;
  background: linear-gradient(90deg, #10B981, #EF4444);
}

.station-count {
  position: absolute;
  font-size: 20rpx;
  color: #999;
  background-color: #fff;
  padding: 0 8rpx;
  transform: translateX(50%);
}

.page.dark .station-count {
  color: #9AA0A6;
  background-color: #1A1D29;
}

.station-line {
  position: relative;
}

.card-info {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 20rpx;
}

.card-info { margin-right: -20rpx; margin-bottom: -16rpx; }

.card-info > view { margin-right: 20rpx; margin-bottom: 16rpx; }

.info-item {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #666;
}

.page.dark .info-item {
  color: #9AA0A6;
}

.info-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 20rpx;
  border-top: 1rpx solid #F5F5F5;
}

.page.dark .card-footer {
  border-top-color: #2A2F3D;
}

.arrival-info {
  display: flex;
  align-items: center;
}

.arrival-text {
  font-size: 26rpx;
  color: #FF6B6B;
  font-weight: 500;
}

.arrow-icon {
  font-size: 40rpx;
  color: #CCC;
  line-height: 1;
}

.page.dark .arrow-icon {
  color: #555;
}
