<view class="page {{darkMode ? 'dark' : ''}}">
  <view wx:if="{{selectMode}}" class="select-mode-bar">
    <view class="select-mode-icon">📍</view>
    <view class="select-mode-title">{{selectModeTitle}}</view>
    <view class="select-mode-cancel" bindtap="onCancelSelect">取消</view>
  </view>

  <view class="search-bar">
    <view class="search-input-wrap">
      <text class="search-icon">🔍</text>
      <input
        class="search-input"
        placeholder="搜索地点、建筑..."
        value="{{searchKeyword}}"
        bindinput="onSearchInput"
        bindconfirm="onSearchConfirm"
        bindfocus="onSearchFocus"
      />
      <view wx:if="{{searchKeyword}}" class="search-clear" bindtap="onClearSearch">✕</view>
    </view>
    <view wx:if="{{showSearchFocus}}" class="search-cancel" bindtap="onSearchBlur">取消</view>
  </view>

  <view wx:if="{{showSearchFocus}}" class="search-panel">
    <view wx:if="{{searchHistory.length > 0}}" class="search-history">
      <view class="section-header">
        <text class="section-title">搜索历史</text>
        <text class="clear-btn" bindtap="onClearHistory">清空</text>
      </view>
      <view class="history-tags">
        <view
          wx:for="{{searchHistory}}"
          wx:key="*this"
          class="history-tag"
          data-keyword="{{item}}"
          bindtap="onHistoryTap"
        >
          {{item}}
        </view>
      </view>
    </view>

    <view wx:if="{{searchResults.length > 0}}" class="search-results">
      <view class="section-header">
        <text class="section-title">搜索结果</text>
      </view>
      <view
        wx:for="{{searchResults}}"
        wx:key="id"
        class="search-result-item"
        data-poi="{{item}}"
        bindtap="onSearchResultTap"
      >
        <text class="poi-icon">{{item.categoryIcon}}</text>
        <view class="result-info">
          <text class="result-name">{{item.name}}</text>
          <text class="result-address">{{item.address}}</text>
        </view>
        <text class="result-arrow">›</text>
      </view>
    </view>

    <view wx:if="{{hotPOIs.length > 0}}" class="hot-places">
      <view class="section-header">
        <text class="section-title">🔥 热门地点</text>
      </view>
      <view class="hot-grid">
        <view
          wx:for="{{hotPOIs}}"
          wx:key="id"
          class="hot-item"
          data-poi="{{item}}"
          bindtap="onHotPOITap"
        >
          <text class="hot-icon">{{item.categoryIcon}}</text>
          <text class="hot-name">{{item.name}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="map-toolbar">
    <scroll-view class="category-scroll" scroll-x="{{true}}" show-scrollbar="{{false}}">
      <view class="category-list">
        <view
          wx:for="{{categories}}"
          wx:key="value"
          class="category-item {{currentCategory === item.value ? 'active' : ''}}"
          data-category="{{item.value}}"
          bindtap="onCategoryChange"
        >
          <text class="category-icon">{{item.icon}}</text>
          <text class="category-label">{{item.label}}</text>
        </view>
      </view>
    </scroll-view>

    <view class="toolbar-actions">
      <view class="map-type-switch">
        <view
          class="type-btn {{mapType === 'handdrawn' ? 'active' : ''}}"
          data-type="handdrawn"
          bindtap="onMapTypeChange"
        >
          🗺️ 手绘
        </view>
        <view
          class="type-btn {{mapType === 'satellite' ? 'active' : ''}}"
          data-type="satellite"
          bindtap="onMapTypeChange"
        >
          🛰️ 卫星
        </view>
      </view>
    </view>
  </view>

  <view class="map-container">
    <view class="map-wrapper" bindtouchstart="onMapTouchStart" bindtouchmove="onMapTouchMove" bindtouchend="onMapTouchEnd">
      <image
        class="map-bg"
        src="{{mapType === 'handdrawn' ? '/assets/images/default-scenery.png' : 'https://picsum.photos/seed/satellite/800/1200'}}"
        mode="aspectFill"
      />

      <view
        wx:for="{{filteredPOIs}}"
        wx:key="id"
        class="poi-marker {{selectedPOI && selectedPOI.id === item.id ? 'selected' : ''}} {{item.isHighlight ? 'highlight' : ''}}"
        style="left: {{item.x}}%; top: {{item.y}}%"
        data-poi="{{item}}"
        bindtap="onPOITap"
      >
        <view class="marker-icon" style="background-color: {{item.categoryColor}}">
          {{item.categoryIcon}}
        </view>
        <view wx:if="{{showLabels}}" class="marker-label">{{item.name}}</view>
      </view>

      <view wx:if="{{currentRoute && currentRoute.path.length > 0}}" class="route-path">
        <view
          wx:for="{{currentRoute.path}}"
          wx:for-index="idx"
          wx:key="idx"
          class="route-point"
          style="left: {{item.x}}%; top: {{item.y}}%"
        ></view>
        <view
          wx:for="{{routeLines}}"
          wx:key="id"
          class="route-line"
          style="left: {{item.x1}}%; top: {{item.y1}}%; width: {{item.length}}px; transform: rotate({{item.angle}}deg);"
        ></view>
        <view class="route-start" style="left: {{currentRoute.startPoint.x}}%; top: {{currentRoute.startPoint.y}}%">
          <text class="start-marker">🚩</text>
        </view>
        <view class="route-end" style="left: {{currentRoute.endPoint.x}}%; top: {{currentRoute.endPoint.y}}%">
          <text class="end-marker">🎯</text>
        </view>
      </view>

      <view wx:if="{{highlightPOIs.length > 0 && showFreshmanGuide}}" class="highlight-overlay">
        <view
          wx:for="{{highlightPOIs}}"
          wx:key="id"
          class="highlight-pulse"
          style="left: {{item.x}}%; top: {{item.y}}%"
        ></view>
      </view>
    </view>

    <view class="map-controls">
      <view class="control-btn" bindtap="onLocate">
        <text>📍</text>
      </view>
      <view class="control-btn" bindtap="onToggleLabels">
        <text>{{showLabels ? '🏷️' : '🏷️'}}</text>
      </view>
      <view class="control-btn" bindtap="onZoomIn">
        <text>➕</text>
      </view>
      <view class="control-btn" bindtap="onZoomOut">
        <text>➖</text>
      </view>
    </view>
  </view>

  <view class="quick-actions">
    <view class="action-item" bindtap="onRoutePlanner">
      <text class="action-icon">🧭</text>
      <text class="action-label">路线规划</text>
    </view>
    <view class="action-item" bindtap="onFreshmanGuide">
      <text class="action-icon">🎓</text>
      <text class="action-label">新生报到</text>
    </view>
    <view class="action-item" bindtap="onARNavigation">
      <text class="action-icon">📱</text>
      <text class="action-label">AR导览</text>
    </view>
    <view class="action-item" bindtap="onMyFavorites">
      <text class="action-icon">⭐</text>
      <text class="action-label">我的收藏</text>
    </view>
  </view>

  <view wx:if="{{currentRoute}}" class="route-info">
    <view class="route-header">
      <text class="route-name">{{currentRoute.name}}</text>
      <view class="route-stats">
        <text class="stat-item">📏 {{currentRoute.distance}}米</text>
        <text class="stat-item">⏱️ {{currentRoute.duration}}分钟</text>
      </view>
    </view>
    <scroll-view class="route-steps" scroll-y="{{true}}">
      <view
        wx:for="{{currentRoute.instructions}}"
        wx:key="step"
        class="step-item"
      >
        <view class="step-number">{{item.step}}</view>
        <view class="step-content">
          <text class="step-text">{{item.text}}</text>
          <text wx:if="{{item.distance > 0}}" class="step-distance">{{item.distance}}米</text>
        </view>
      </view>
    </scroll-view>
    <view class="route-actions">
      <button class="btn-secondary" bindtap="onCloseRoute">关闭路线</button>
      <button class="btn-primary" bindtap="onStartNavigation">开始导航</button>
    </view>
  </view>

  <view wx:if="{{selectedPOI && !currentRoute}}" class="poi-preview">
    <view class="preview-header">
      <text class="preview-icon" style="background-color: {{selectedPOI.categoryColor}}">
        {{selectedPOI.categoryIcon}}
      </text>
      <view class="preview-info">
        <text class="preview-name">{{selectedPOI.name}}</text>
        <text class="preview-address">{{selectedPOI.address}} · {{selectedPOI.openTime}}</text>
      </view>
      <view class="preview-rating">
        <text class="rating-stars">⭐</text>
        <text class="rating-value">{{selectedPOI.rating}}</text>
      </view>
    </view>
    <view class="preview-actions">
      <view class="action-btn" bindtap="onViewDetail">
        <text>📋</text>
        <text>详情</text>
      </view>
      <view class="action-btn" bindtap="onNavigateTo">
        <text>🧭</text>
        <text>导航</text>
      </view>
      <view class="action-btn" bindtap="onToggleFavorite">
        <text>{{isFavorited ? '❤️' : '🤍'}}</text>
        <text>{{isFavorited ? '已收藏' : '收藏'}}</text>
      </view>
    </view>
  </view>

  <view wx:if="{{showFreshmanPanel}}" class="freshman-panel">
    <view class="panel-header">
      <text class="panel-title">🎓 新生报到流程</text>
      <view class="panel-close" bindtap="onCloseFreshmanPanel">✕</view>
    </view>
    <scroll-view class="flow-steps" scroll-x="{{true}}" show-scrollbar="{{false}}">
      <view
        wx:for="{{freshmanFlow}}"
        wx:key="step"
        class="flow-step {{item.isKeyPoint ? 'key' : ''}}"
        data-item="{{item}}"
        bindtap="onFlowStepTap"
      >
        <view class="step-icon">{{item.icon}}</view>
        <view class="step-dot"></view>
        <view class="step-info">
          <text class="step-num">步骤 {{item.step}}</text>
          <text class="step-title">{{item.title}}</text>
        </view>
      </view>
    </scroll-view>
  </view>
</view>