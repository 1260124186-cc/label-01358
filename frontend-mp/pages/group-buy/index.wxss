.page {
  min-height: 100vh;
  background-color: #F8F9FA;
  padding-bottom: 140rpx;
}

.page.dark {
  background-color: #0F1117;
  color: #E8ECF1;
}

.search-section {
  padding: 20rpx 30rpx;
  background-color: #fff;
}

.page.dark .search-section {
  background-color: #1A1D29;
}

.search-box {
  display: flex;
  align-items: center;
  background-color: #F5F5F5;
  border-radius: 40rpx;
  padding: 20rpx 30rpx;
}

.page.dark .search-box {
  background-color: #2A2F3D;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 16rpx;
  color: #999;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.page.dark .search-input {
  color: #E8ECF1;
}

.tab-section {
  background-color: #fff;
  border-bottom: 1rpx solid #EEEEEE;
}

.page.dark .tab-section {
  background-color: #1A1D29;
  border-bottom-color: #2A2F3D;
}

.tab-scroll {
  white-space: nowrap;
}

.tabs {
  display: inline-flex;
  padding: 0 20rpx;
}

.tab-item {
  padding: 24rpx 30rpx;
  font-size: 30rpx;
  color: #666;
  position: relative;
}

.page.dark .tab-item {
  color: #9AA0A6;
}

.tab-item.active {
  color: #FF6B6B;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 6rpx;
  background-color: #FF6B6B;
  border-radius: 3rpx;
}

.filter-section {
  background-color: #fff;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #EEEEEE;
}

.page.dark .filter-section {
  background-color: #1A1D29;
  border-bottom-color: #2A2F3D;
}

.filter-scroll {
  white-space: nowrap;
}

.filter-row {
  display: inline-flex;
  padding: 0 20rpx;
  align-items: center;
}

.filter-row > view { margin-right: 16rpx; }

.filter-row > view:last-child { margin-right: 0; }

.filter-chip {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 24rpx;
  background-color: #F5F5F5;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #666;
  flex-shrink: 0;
}

.page.dark .filter-chip {
  background-color: #2A2F3D;
  color: #9AA0A6;
}

.filter-chip.active {
  background-color: #FFEAEA;
  color: #FF6B6B;
}

.page.dark .filter-chip.active {
  background-color: rgba(255, 107, 107, 0.2);
  color: #FF6B6B;
}

.chip-icon {
  margin-right: 6rpx;
}

.chip-arrow {
  font-size: 20rpx;
  margin-left: 8rpx;
  color: #999;
}

.list-scroll {
  height: calc(100vh - 380rpx);
}

.list-container {
  padding: 20rpx;
}

.groupbuy-card {
  background-color: #fff;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.page.dark .groupbuy-card {
  background-color: #1A1D29;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.3);
}

.groupbuy-card-hover {
  transform: scale(0.98);
  opacity: 0.9;
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.category-badge {
  display: flex;
  align-items: center;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.category-icon {
  margin-right: 8rpx;
  font-size: 26rpx;
}

.status-badge {
  margin-left: 16rpx;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.product-name {
  font-size: 34rpx;
  font-weight: 600;
  color: #111;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.page.dark .product-name {
  color: #E8ECF1;
}

.product-desc {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 20rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.page.dark .product-desc {
  color: #9AA0A6;
}

.progress-section {
  margin-bottom: 20rpx;
}

.progress-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.progress-count {
  font-size: 28rpx;
  font-weight: 600;
  color: #FF6B6B;
}

.progress-hint {
  font-size: 24rpx;
  color: #FF8C19;
}

.progress-bar-wrap {
  width: 100%;
  height: 12rpx;
  background-color: #F0F0F0;
  border-radius: 6rpx;
  overflow: hidden;
}

.page.dark .progress-bar-wrap {
  background-color: #2A2F3D;
}

.progress-bar {
  height: 100%;
  background: linear-gradient(90deg, #FF6B6B 0%, #FF8E8E 100%);
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

.card-info {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 20rpx;
}

.card-info { margin-right: -20rpx; margin-bottom: -16rpx; }

.card-info > view { margin-right: 20rpx; margin-bottom: 16rpx; }

.info-item {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #666;
}

.page.dark .info-item {
  color: #9AA0A6;
}

.info-icon {
  font-size: 26rpx;
  margin-right: 8rpx;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  padding-top: 20rpx;
  border-top: 1rpx solid #F5F5F5;
}

.page.dark .card-footer {
  border-top-color: #2A2F3D;
}

.price-info {
  display: flex;
  align-items: baseline;
}

.price-currency {
  font-size: 28rpx;
  color: #FF6B6B;
  font-weight: 600;
}

.price-value {
  font-size: 44rpx;
  color: #FF6B6B;
  font-weight: 700;
  margin: 0 4rpx;
}

.price-unit {
  font-size: 24rpx;
  color: #999;
}

.card-meta {
  display: flex;
  align-items: center;
}

.card-meta > text { margin-right: 12rpx; }

.card-meta > text:last-child { margin-right: 0; }

.meta-text {
  font-size: 22rpx;
  color: #999;
}

.publish-btn {
  position: fixed;
  right: 40rpx;
  bottom: 80rpx;
  width: 110rpx;
  height: 110rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 107, 0.4);
  z-index: 99;
}

.publish-btn-hover {
  transform: scale(0.95);
  opacity: 0.9;
}

.publish-icon {
  font-size: 60rpx;
  color: #fff;
  font-weight: 300;
  line-height: 1;
}

.picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 200;
  display: flex;
  align-items: flex-end;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.picker-mask.show {
  opacity: 1;
  visibility: visible;
}

.picker-content {
  width: 100%;
  max-height: 80vh;
  background-color: #fff;
  border-radius: 30rpx 30rpx 0 0;
  transform: translateY(100%);
  transition: transform 0.3s ease;
}

.picker-mask.show .picker-content {
  transform: translateY(0);
}

.page.dark .picker-content {
  background-color: #1A1D29;
}

.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.page.dark .picker-header {
  border-bottom-color: #2A2F3D;
}

.picker-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.page.dark .picker-title {
  color: #E8ECF1;
}

.picker-close {
  font-size: 40rpx;
  color: #999;
  padding: 10rpx;
}

.picker-options {
  padding: 20rpx;
  max-height: 60vh;
  overflow-y: auto;
}

.picker-option {
  padding: 28rpx 30rpx;
  font-size: 28rpx;
  color: #333;
  border-radius: 12rpx;
  margin-bottom: 8rpx;
}

.page.dark .picker-option {
  color: #E8ECF1;
}

.picker-option.active {
  background-color: #FFEAEA;
  color: #FF6B6B;
  font-weight: 500;
}

.page.dark .picker-option.active {
  background-color: rgba(255, 107, 107, 0.2);
  color: #FF6B6B;
}
