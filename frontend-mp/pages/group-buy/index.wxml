<page-meta page-style="background-color: {{darkMode ? '#0F1117' : '#F8F9FA'}}; color: {{darkMode ? '#E8ECF1' : '#2C3E50'}}"/>
<view class="page {{darkMode ? 'dark' : ''}}">
  <view class="search-section">
    <view class="search-box">
      <text class="search-icon">🔍</text>
      <input
        class="search-input"
        placeholder="搜索商品名称"
        value="{{searchKeyword}}"
        bindinput="onSearchInput"
        bindconfirm="onSearchConfirm"
        confirm-type="search"
      />
    </view>
  </view>

  <view class="tab-section">
    <scroll-view class="tab-scroll" scroll-x="{{true}}" enhanced="{{true}}" show-scrollbar="{{false}}">
      <view class="tabs">
        <view
          class="tab-item {{currentTab === item.value ? 'active' : ''}}"
          wx:for="{{tabs}}"
          wx:key="value"
          bindtap="onTabChange"
          data-value="{{item.value}}"
        >{{item.label}}</view>
      </view>
    </scroll-view>
  </view>

  <view class="filter-section">
    <scroll-view class="filter-scroll" scroll-x="{{true}}" enhanced="{{true}}" show-scrollbar="{{false}}">
      <view class="filter-row">
        <view
          class="filter-chip {{currentCategory === item.value ? 'active' : ''}}"
          wx:for="{{categories}}"
          wx:key="value"
          bindtap="onCategoryChange"
          data-value="{{item.value}}"
        >
          <text class="chip-icon">{{item.icon}}</text>
          <text>{{item.label}}</text>
        </view>
        <view class="filter-chip" bindtap="onShowPricePicker">
          <text>{{currentPriceText || '价格'}}</text>
          <text class="chip-arrow">▼</text>
        </view>
        <view class="filter-chip" bindtap="onShowSortPicker">
          <text>排序</text>
          <text class="chip-arrow">▼</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <scroll-view
    class="list-scroll"
    scroll-y="{{true}}"
    refresher-enabled="{{true}}"
    refresher-triggered="{{refreshing}}"
    bindrefresherrefresh="onRefresh"
  >
    <view class="list-container" wx:if="{{list.length > 0}}">
      <view
        class="groupbuy-card"
        wx:for="{{list}}"
        wx:key="id"
        hover-class="groupbuy-card-hover"
        bindtap="onItemTap"
        data-item="{{item}}"
      >
        <view class="card-header">
          <view class="category-badge" style="background-color: #FFF4E5; color: #FF8C19;">
            <text class="category-icon">{{item.categoryIcon}}</text>
            <text class="category-text">{{item.categoryText}}</text>
          </view>
          <view class="status-badge" style="background-color: {{item.statusColor}}15; color: {{item.statusColor}}">
            {{item.statusText}}
          </view>
        </view>

        <view class="product-name">{{item.productName}}</view>
        <view class="product-desc">{{item.description}}</view>

        <view class="progress-section">
          <view class="progress-info">
            <text class="progress-count">{{item.joinedCount}}/{{item.minCount}}件</text>
            <text class="progress-hint">还差{{item.remainingCount}}件成团</text>
          </view>
          <view class="progress-bar-wrap">
            <view class="progress-bar" style="width: {{item.progressPercent}}%;"></view>
          </view>
        </view>

        <view class="card-info">
          <view class="info-item">
            <text class="info-icon">⏰</text>
            <text class="info-text">{{item.deadlineLabel}}</text>
          </view>
          <view class="info-item">
            <text class="info-icon">📍</text>
            <text class="info-text">{{item.pickupPointText}}</text>
          </view>
        </view>

        <view class="card-footer">
          <view class="price-info">
            <text class="price-currency">¥</text>
            <text class="price-value">{{item.unitPrice}}</text>
            <text class="price-unit">/件</text>
          </view>
          <view class="card-meta">
            <text class="meta-text">{{item.views}}浏览</text>
            <text class="meta-text">{{item.timeText}}</text>
          </view>
        </view>
      </view>
    </view>

    <empty
      wx:if="{{!loading && list.length === 0}}"
      text="暂无团购信息"
      showAction="{{true}}"
      actionText="发起团购"
      bindaction="onPublish"
    />
  </scroll-view>

  <view class="publish-btn" hover-class="publish-btn-hover" bindtap="onPublish">
    <text class="publish-icon">+</text>
  </view>

  <view class="picker-mask {{showPricePicker ? 'show' : ''}}" bindtap="onHidePricePicker">
    <view class="picker-content" catchtap="stopPropagation">
      <view class="picker-header">
        <text class="picker-title">选择价格区间</text>
        <text class="picker-close" bindtap="onHidePricePicker">×</text>
      </view>
      <view class="picker-options">
        <view
          class="picker-option {{currentPriceRange === '' ? 'active' : ''}}"
          bindtap="onPriceSelect"
          data-value=""
        >不限价格</view>
        <view
          class="picker-option {{currentPriceRange === item.value ? 'active' : ''}}"
          wx:for="{{priceRanges}}"
          wx:key="value"
          bindtap="onPriceSelect"
          data-value="{{item.value}}"
          data-min="{{item.min}}"
          data-max="{{item.max}}"
        >{{item.label}}</view>
      </view>
    </view>
  </view>

  <view class="picker-mask {{showSortPicker ? 'show' : ''}}" bindtap="onHideSortPicker">
    <view class="picker-content" catchtap="stopPropagation">
      <view class="picker-header">
        <text class="picker-title">选择排序方式</text>
        <text class="picker-close" bindtap="onHideSortPicker">×</text>
      </view>
      <view class="picker-options">
        <view
          class="picker-option {{currentSort === item.value ? 'active' : ''}}"
          wx:for="{{sortOptions}}"
          wx:key="value"
          bindtap="onSortSelect"
          data-value="{{item.value}}"
        >{{item.label}}</view>
      </view>
    </view>
  </view>
</view>
