.page {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

.hero-banner {
  position: relative;
  padding: 48rpx 32rpx 64rpx;
  overflow: hidden;
  background: linear-gradient(135deg, #667EEA 0%, #764BA2 100%);
}

.hero-bg {
  position: absolute;
  top: -100rpx;
  right: -100rpx;
  width: 400rpx;
  height: 400rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 50%;
}

.hero-content {
  position: relative;
  z-index: 1;
}

.hero-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.hero-title-wrap {
  flex: 1;
}

.hero-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #FFFFFF;
  line-height: 1.3;
}

.lang-switch {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.2);
  padding: 12rpx 24rpx;
  border-radius: 40rpx;
  backdrop-filter: blur(10px);
}

.lang-switch text {
  margin-right: 8rpx;
}

.lang-switch text:last-child {
  margin-right: 0;
}

.lang-icon {
  font-size: 28rpx;
}

.lang-text {
  font-size: 24rpx;
  color: #FFFFFF;
  font-weight: 500;
}

.hero-subtitle {
  display: block;
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.95);
  margin-bottom: 12rpx;
  font-weight: 500;
}

.hero-desc {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.75);
}

.hero-decoration {
  position: absolute;
  bottom: 24rpx;
  right: 32rpx;
  z-index: 1;
}

.deco-emoji {
  font-size: 100rpx;
  opacity: 0.3;
}

.section {
  margin: 32rpx 24rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.page.dark .section {
  background: #1E2230;
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 28rpx;
}

.section-header text {
  margin-right: 12rpx;
}

.section-header text:last-child {
  margin-right: 0;
}

.section-icon {
  font-size: 36rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2C3E50;
}

.page.dark .section-title {
  color: #E8ECF1;
}

.guide-grid {
  display: flex;
  flex-wrap: wrap;
  margin-right: -20rpx;
  margin-bottom: -20rpx;
}

.guide-item {
  width: calc(25% - 15rpx);
  margin-right: 20rpx;
  margin-bottom: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.guide-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.guide-icon text {
  font-size: 44rpx;
}

.guide-name {
  font-size: 24rpx;
  color: #2C3E50;
  text-align: center;
  font-weight: 500;
}

.page.dark .guide-name {
  color: #E8ECF1;
}

.service-list {
  display: flex;
  flex-direction: column;
}

.service-list view {
  margin-bottom: 20rpx;
}

.service-list view:last-child {
  margin-bottom: 0;
}

.service-card {
  border-radius: 20rpx;
  padding: 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.service-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.service-left view,
.service-left text {
  margin-right: 20rpx;
}

.service-left view:last-child,
.service-left text:last-child {
  margin-right: 0;
}

.service-icon {
  font-size: 56rpx;
}

.service-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.service-info text {
  margin-right: 0;
}

.service-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 6rpx;
}

.service-subtitle {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
}

.service-action {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.2);
  padding: 12rpx 20rpx;
  border-radius: 32rpx;
  backdrop-filter: blur(10px);
}

.service-action text {
  margin-right: 8rpx;
  font-size: 22rpx;
  color: #FFFFFF;
  font-weight: 500;
}

.service-action text:last-child {
  margin-right: 0;
}

.action-arrow {
  font-size: 24rpx;
}

.tips-section {
  background: transparent;
  box-shadow: none;
  padding: 0;
  margin: 32rpx 24rpx;
}

.tips-section .section-header {
  padding: 0 8rpx;
}

.tips-list {
  display: flex;
  flex-direction: column;
}

.tips-list view {
  margin-bottom: 16rpx;
}

.tips-list view:last-child {
  margin-bottom: 0;
}

.tip-item {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  padding: 24rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.page.dark .tip-item {
  background: #1E2230;
}

.tip-item text {
  margin-right: 20rpx;
}

.tip-item text:last-child,
.tip-item view text {
  margin-right: 0;
}

.tip-icon {
  font-size: 40rpx;
  flex-shrink: 0;
}

.tip-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.tip-title {
  font-size: 28rpx;
  color: #2C3E50;
  font-weight: 600;
  margin-bottom: 6rpx;
}

.page.dark .tip-title {
  color: #E8ECF1;
}

.tip-desc {
  font-size: 22rpx;
  color: #95A5A6;
}

.bottom-spacer {
  height: 40rpx;
}
