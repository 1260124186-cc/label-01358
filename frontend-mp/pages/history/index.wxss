.page {
  min-height: 100vh;
  background-color: var(--color-bg-page);
}

/* 顶部操作 */
.header-section {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  background-color: var(--color-bg-card);
  border-bottom: 1rpx solid var(--color-border);
  box-shadow: var(--shadow-sm);
}

.header-count {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.header-action {
  padding: 8rpx 20rpx;
}

.action-text {
  font-size: 26rpx;
  color: var(--color-primary);
}

/* 列表 */
.list-scroll {
  height: calc(100vh - 80rpx);
}

.list-container {
  padding: 24rpx;
}

.item-card {
  display: flex;
  background-color: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-card);
  transition: all 0.2s ease;
}

.item-card-hover {
  transform: scale(0.98);
  box-shadow: var(--shadow-sm);
}

.item-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: var(--radius-lg);
  flex-shrink: 0;
}

.item-info {
  flex: 1;
  margin-left: 20rpx;
  margin-right: 16rpx;
  display: flex;
  flex-direction: column;
}

.item-type-tag {
  display: inline-block;
  padding: 4rpx 12rpx;
  font-size: 22rpx;
  border-radius: 6rpx;
  margin-bottom: 8rpx;
  align-self: flex-start;
}

.item-type-tag.lostFound {
  color: var(--color-primary);
  background-color: var(--color-primary-light);
}

.item-type-tag.market {
  color: #059669;
  background-color: #D1FAE5;
}

.item-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 8rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  overflow: hidden;
}

.item-desc {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-bottom: 8rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.item-time {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
  margin-top: auto;
}

.item-action {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 56rpx;
  height: 56rpx;
  background-color: var(--color-bg-secondary);
  border-radius: 50%;
  flex-shrink: 0;
  align-self: center;
  transition: all 0.2s ease;
}

.item-action:active {
  background-color: var(--color-primary-light);
}

.action-icon {
  font-size: 32rpx;
  color: var(--color-text-tertiary);
}
