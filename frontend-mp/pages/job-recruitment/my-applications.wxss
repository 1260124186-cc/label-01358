.container {
  min-height: 100vh;
  background: #f5f6fa;
  padding-bottom: 40rpx;
}

.container.dark {
  background: #1a1a1a;
}

.header {
  background: linear-gradient(135deg, #4F46E5 0%, #7C3AED 100%);
  padding: 40rpx 32rpx 60rpx;
  color: #fff;
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.header-subtitle {
  font-size: 26rpx;
  opacity: 0.9;
  margin-bottom: 32rpx;
}

.stats-row {
  display: flex;
  justify-content: space-around;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 16rpx;
  padding: 24rpx 16rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.stat-number {
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 4rpx;
}

.stat-number.pending { color: #F59E0B; }
.stat-number.reviewing { color: #3B82F6; }
.stat-number.interview { color: #8B5CF6; }
.stat-number.offer { color: #10B981; }
.stat-number.rejected { color: #EF4444; }

.stat-label {
  font-size: 22rpx;
  opacity: 0.9;
}

.tabs-scroll {
  white-space: nowrap;
  width: 100%;
}

.tabs {
  display: inline-flex;
  padding: 0 24rpx;
  margin: 20rpx 0;
}

.tab-item {
  padding: 16rpx 32rpx;
  font-size: 26rpx;
  color: #6b7280;
  background: #fff;
  border-radius: 30rpx;
  margin-right: 16rpx;
}

.container.dark .tab-item {
  background: #2a2a2a;
  color: #9ca3af;
}

.tab-item.active {
  background: #4F46E5;
  color: #fff;
  font-weight: 600;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #6b7280;
  margin-bottom: 12rpx;
}

.empty-tip {
  font-size: 26rpx;
  color: #9ca3af;
}

.application-list {
  padding: 0 24rpx;
}

.application-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.container.dark .application-card {
  background: #2a2a2a;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.job-info {
  flex: 1;
  min-width: 0;
  margin-right: 16rpx;
}

.job-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 6rpx;
}

.container.dark .job-title {
  color: #fff;
}

.company-name {
  font-size: 26rpx;
  color: #6b7280;
}

.container.dark .company-name {
  color: #9ca3af;
}

.status-badge {
  display: flex;
  align-items: center;
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  flex-shrink: 0;
}

.status-badge text:first-child {
  margin-right: 6rpx;
}

.latest-status {
  display: flex;
  align-items: center;
  padding: 16rpx;
  background: #f9fafb;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.container.dark .latest-status {
  background: #3a3a3a;
}

.status-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.status-text {
  flex: 1;
  font-size: 26rpx;
  color: #4b5563;
  margin-right: 12rpx;
}

.container.dark .status-text {
  color: #d1d5db;
}

.status-time {
  font-size: 22rpx;
  color: #9ca3af;
  flex-shrink: 0;
}

.card-info-row {
  display: flex;
  gap: 24rpx;
  margin-bottom: 16rpx;
}

.info-item {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #6b7280;
}

.info-icon {
  margin-right: 6rpx;
  font-size: 24rpx;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.container.dark .card-footer {
  border-top-color: #3a3a3a;
}

.timeline-count {
  font-size: 24rpx;
  color: #9ca3af;
}

.card-actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  color: #6b7280;
  background: #f3f4f6;
  border-radius: 20rpx;
}

.container.dark .action-btn {
  background: #3a3a3a;
  color: #9ca3af;
}

.action-btn.primary {
  background: #EEF2FF;
  color: #4F46E5;
  font-weight: 500;
}

.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  padding: 40rpx;
}

.modal-content {
  width: 100%;
  max-height: 80vh;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.container.dark .modal-content {
  background: #2a2a2a;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.container.dark .modal-header {
  border-bottom-color: #3a3a3a;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1f2937;
}

.container.dark .modal-title {
  color: #fff;
}

.modal-close {
  font-size: 36rpx;
  color: #6b7280;
  padding: 8rpx;
}

.modal-body {
  flex: 1;
  overflow-y: auto;
  padding: 32rpx;
}

.detail-header {
  text-align: center;
  margin-bottom: 24rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.container.dark .detail-header {
  border-bottom-color: #3a3a3a;
}

.detail-job-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1f2937;
  margin-bottom: 8rpx;
}

.container.dark .detail-job-title {
  color: #fff;
}

.detail-company {
  font-size: 28rpx;
  color: #6b7280;
  margin-bottom: 16rpx;
}

.container.dark .detail-company {
  color: #9ca3af;
}

.detail-status {
  display: inline-block;
  padding: 10rpx 24rpx;
  border-radius: 20rpx;
  font-size: 26rpx;
  font-weight: 500;
}

.detail-info {
  background: #f9fafb;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.container.dark .detail-info {
  background: #3a3a3a;
}

.info-row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.info-row:last-child {
  margin-bottom: 0;
}

.info-row .info-icon {
  width: 32rpx;
  font-size: 28rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.info-row .info-label {
  width: 120rpx;
  font-size: 26rpx;
  color: #6b7280;
  flex-shrink: 0;
}

.info-row .info-value {
  flex: 1;
  font-size: 26rpx;
  color: #1f2937;
}

.container.dark .info-row .info-value {
  color: #fff;
}

.detail-section {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 16rpx;
}

.container.dark .section-title {
  color: #fff;
}

.form-data-list {
  background: #f9fafb;
  border-radius: 16rpx;
  padding: 16rpx 24rpx;
}

.container.dark .form-data-list {
  background: #3a3a3a;
}

.form-data-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.container.dark .form-data-item {
  border-bottom-color: #3a3a3a;
}

.form-data-item:last-child {
  border-bottom: none;
}

.form-data-label {
  font-size: 26rpx;
  color: #6b7280;
}

.form-data-value {
  font-size: 26rpx;
  color: #1f2937;
}

.container.dark .form-data-value {
  color: #fff;
}

.resume-info {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #f9fafb;
  border-radius: 16rpx;
}

.container.dark .resume-info {
  background: #3a3a3a;
}

.resume-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.resume-name {
  font-size: 28rpx;
  color: #1f2937;
}

.container.dark .resume-name {
  color: #fff;
}

.timeline {
  position: relative;
  padding-left: 20rpx;
}

.timeline-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 0;
  position: relative;
}

.timeline-line {
  position: absolute;
  left: 13rpx;
  width: 2rpx;
  background: #e5e7eb;
}

.container.dark .timeline-line {
  background: #4a4a4a;
}

.timeline-item:not(.last) .timeline-line {
  height: calc(100% - 24rpx);
  top: 24rpx;
}

.timeline-item:not(.first) .timeline-line {
  height: 50%;
  top: 0;
}

.timeline-item:not(.first):not(.last) .timeline-line:first-child {
  height: 50%;
  top: 0;
}

.timeline-item:not(.first):not(.last) .timeline-line:last-child {
  height: 50%;
  top: 50%;
}

.timeline-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  flex-shrink: 0;
  margin-right: 20rpx;
  margin-top: 4rpx;
  z-index: 1;
  position: relative;
  border: 4rpx solid #fff;
  box-shadow: 0 0 0 2rpx currentColor;
}

.container.dark .timeline-dot {
  border-color: #2a2a2a;
}

.timeline-content {
  flex: 1;
  padding-bottom: 32rpx;
}

.timeline-item.last .timeline-content {
  padding-bottom: 0;
}

.timeline-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.timeline-status {
  font-size: 26rpx;
  font-weight: 600;
}

.timeline-time {
  font-size: 22rpx;
  color: #9ca3af;
}

.timeline-remark {
  font-size: 26rpx;
  color: #4b5563;
  line-height: 1.5;
}

.container.dark .timeline-remark {
  color: #d1d5db;
}

.modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 24rpx 32rpx;
  border-top: 1rpx solid #f0f0f0;
}

.container.dark .modal-footer {
  border-top-color: #3a3a3a;
}

.btn-withdraw {
  flex: 1;
  text-align: center;
  padding: 24rpx;
  font-size: 28rpx;
  color: #EF4444;
  background: #FEF2F2;
  border-radius: 12rpx;
}

.btn-contact {
  flex: 1;
  text-align: center;
  padding: 24rpx;
  font-size: 28rpx;
  color: #fff;
  background: linear-gradient(135deg, #4F46E5 0%, #7C3AED 100%);
  border-radius: 12rpx;
}

.safe-bottom {
  height: env(safe-area-inset-bottom);
}
