.container {
  min-height: 100vh;
  background: #f5f6fa;
  padding-bottom: 40rpx;
}

.container.dark {
  background: #1a1a1a;
}

.header {
  background: linear-gradient(135deg, #4F46E5 0%, #7C3AED 100%);
  padding: 40rpx 32rpx 60rpx;
  color: #fff;
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.header-subtitle {
  font-size: 26rpx;
  opacity: 0.9;
}

.search-bar {
  display: flex;
  align-items: center;
  margin: -30rpx 24rpx 20rpx;
  background: #fff;
  border-radius: 40rpx;
  padding: 0 24rpx;
  height: 72rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
  position: relative;
  z-index: 10;
}

.container.dark .search-bar {
  background: #2a2a2a;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  height: 72rpx;
}

.container.dark .search-input {
  color: #fff;
}

.clear-btn {
  width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  background: #e5e7eb;
  color: #6b7280;
  border-radius: 50%;
  font-size: 24rpx;
  margin-left: 12rpx;
}

.action-bar {
  padding: 0 24rpx 20rpx;
}

.publish-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  background: #fff;
  border-radius: 16rpx;
  color: #4F46E5;
  font-size: 28rpx;
  font-weight: 600;
  border: 2rpx dashed #4F46E5;
}

.container.dark .publish-btn {
  background: #2a2a2a;
}

.publish-icon {
  margin-right: 8rpx;
  font-size: 28rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #6b7280;
  margin-bottom: 12rpx;
}

.empty-tip {
  font-size: 26rpx;
  color: #9ca3af;
}

.referral-list {
  padding: 0 24rpx;
}

.referral-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  position: relative;
}

.container.dark .referral-card {
  background: #2a2a2a;
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.company-logo {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #4F46E5 0%, #7C3AED 100%);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.company-info {
  flex: 1;
  min-width: 0;
}

.company-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 4rpx;
}

.container.dark .company-name {
  color: #fff;
}

.position-name {
  font-size: 26rpx;
  color: #6b7280;
}

.container.dark .position-name {
  color: #9ca3af;
}

.status-tag {
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  margin-left: 16rpx;
  flex-shrink: 0;
}

.card-description {
  font-size: 26rpx;
  color: #4b5563;
  line-height: 1.6;
  margin-bottom: 20rpx;
  padding: 16rpx;
  background: #f9fafb;
  border-radius: 12rpx;
}

.container.dark .card-description {
  background: #3a3a3a;
  color: #d1d5db;
}

.code-section {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: linear-gradient(135deg, #FEF9C3 0%, #FEF3C7 100%);
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.code-label {
  font-size: 26rpx;
  color: #854D0E;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.code-value {
  flex: 1;
  font-size: 32rpx;
  font-weight: 700;
  color: #92400E;
  letter-spacing: 2rpx;
  margin-right: 16rpx;
}

.copy-btn {
  padding: 12rpx 20rpx;
  background: #fff;
  color: #92400E;
  border-radius: 20rpx;
  font-size: 24rpx;
  flex-shrink: 0;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.publisher-info {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #6b7280;
}

.publisher-icon {
  margin-right: 8rpx;
  font-size: 24rpx;
}

.expire-info {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #6b7280;
}

.expire-icon {
  margin-right: 6rpx;
}

.expire-info .urgent {
  color: #EF4444;
}

.usage-info {
  font-size: 22rpx;
  color: #9ca3af;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.container.dark .usage-info {
  border-bottom-color: #3a3a3a;
}

.use-btn {
  width: 100%;
  text-align: center;
  padding: 24rpx;
  background: linear-gradient(135deg, #4F46E5 0%, #7C3AED 100%);
  color: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  padding: 40rpx;
}

.modal-content {
  width: 100%;
  max-height: 80vh;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.container.dark .modal-content {
  background: #2a2a2a;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.container.dark .modal-header {
  border-bottom-color: #3a3a3a;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1f2937;
}

.container.dark .modal-title {
  color: #fff;
}

.modal-close {
  font-size: 36rpx;
  color: #6b7280;
  padding: 8rpx;
}

.modal-body {
  flex: 1;
  overflow-y: auto;
  padding: 32rpx;
}

.form-group {
  margin-bottom: 32rpx;
}

.form-group:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 16rpx;
}

.container.dark .form-label {
  color: #fff;
}

.form-label.required::before {
  content: '*';
  color: #EF4444;
  margin-right: 6rpx;
}

.form-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  background: #f9fafb;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
}

.container.dark .form-input {
  background: #3a3a3a;
  color: #fff;
}

.form-textarea {
  width: 100%;
  min-height: 160rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  background: #f9fafb;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  line-height: 1.6;
}

.container.dark .form-textarea {
  background: #3a3a3a;
  color: #fff;
}

.expire-options {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.expire-item {
  padding: 16rpx 32rpx;
  font-size: 26rpx;
  color: #6b7280;
  background: #f3f4f6;
  border-radius: 24rpx;
  border: 2rpx solid transparent;
}

.container.dark .expire-item {
  background: #3a3a3a;
  color: #9ca3af;
}

.expire-item.active {
  background: #EEF2FF;
  color: #4F46E5;
  border-color: #4F46E5;
}

.modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 24rpx 32rpx;
  border-top: 1rpx solid #f0f0f0;
}

.container.dark .modal-footer {
  border-top-color: #3a3a3a;
}

.btn-cancel {
  flex: 1;
  text-align: center;
  padding: 24rpx;
  font-size: 28rpx;
  color: #6b7280;
  background: #f3f4f6;
  border-radius: 12rpx;
}

.btn-confirm {
  flex: 1;
  text-align: center;
  padding: 24rpx;
  font-size: 28rpx;
  color: #fff;
  background: linear-gradient(135deg, #4F46E5 0%, #7C3AED 100%);
  border-radius: 12rpx;
}

.safe-bottom {
  height: env(safe-area-inset-bottom);
}
