<page-meta page-style="background-color: {{darkMode ? '#0F1117' : '#F8F9FA'}}; color: {{darkMode ? '#E8ECF1' : '#2C3E50'}}"/>
<view class="page {{darkMode ? 'dark' : ''}}">
  <view class="feed-tabs">
    <view class="feed-tab {{currentTab === tab.value ? 'active' : ''}}" wx:for="{{feedTabs}}" wx:for-item="tab" wx:key="value" bindtap="onTabChange" data-tab="{{tab.value}}">{{tab.label}}</view>
  </view>

  <scroll-view class="type-filter" scroll-x="{{true}}">
    <view class="type-chip {{currentType === '' ? 'active' : ''}}" bindtap="onTypeChange" data-type="">全部</view>
    <view class="type-chip {{currentType === item.value ? 'active' : ''}}" wx:for="{{postTypes}}" wx:key="value" bindtap="onTypeChange" data-type="{{item.value}}">{{item.icon}} {{item.label}}</view>
  </scroll-view>

  <view class="topic-banner" wx:if="{{currentTopicInfo}}" style="background: linear-gradient(135deg, {{currentTopicInfo.color}}20 0%, {{currentTopicInfo.color}}08 100%)">
    <view class="topic-banner-info">
      <text class="topic-banner-icon">{{currentTopicInfo.icon}}</text>
      <view class="topic-banner-text">
        <text class="topic-banner-name">#{{currentTopicInfo.label}}</text>
        <text class="topic-banner-desc">该话题下的所有帖子</text>
      </view>
    </view>
    <view class="topic-banner-clear" bindtap="onClearTopic">
      <text class="clear-icon">×</text>
      <text class="clear-text">清除筛选</text>
    </view>
  </view>

  <view class="topic-entry" bindtap="onTopicSquare" wx:if="{{!currentTopicInfo}}">
    <text class="topic-entry-text"># 话题广场</text>
    <text class="topic-entry-arrow">›</text>
  </view>

  <scroll-view class="post-scroll" scroll-y="{{true}}" refresher-enabled="{{true}}" refresher-triggered="{{refreshing}}" bindrefresherrefresh="onRefresh" bindscrolltolower="onLoadMore">
    <view class="post-list" wx:if="{{list.length > 0}}">
      <view class="post-card" wx:for="{{list}}" wx:key="id" hover-class="post-card-hover" bindtap="onItemTap" data-id="{{item.id}}">
        <view class="post-header">
          <view class="post-type-badge" style="background-color: {{item.typeInfo.color || '#999'}}20; color: {{item.typeInfo.color || '#999'}}">
            {{item.typeInfo.icon || '📝'}} {{item.typeInfo.label || '帖子'}}
          </view>
          <view class="post-meta">
            <text class="post-author">{{item.isAnonymous ? '🎭 匿名用户' : item.authorName}}</text>
            <text class="post-time">{{item.timeText}}</text>
          </view>
        </view>

        <text class="post-title">{{item.title}}</text>

        <text class="post-content" wx:if="{{item.contentPreview}}">{{item.contentPreview}}</text>

        <view class="post-images {{item.images.length === 1 ? 'img-1' : item.images.length === 2 ? 'img-2' : item.images.length === 4 ? 'img-4' : 'img-9'}}" wx:if="{{item.images && item.images.length > 0}}">
          <image class="post-img" wx:for="{{item.images}}" wx:for-item="img" wx:key="index" src="{{img}}" mode="aspectFill" />
        </view>

        <view class="post-topics" wx:if="{{item.topicLabels.length > 0}}">
          <text class="post-topic" wx:for="{{item.topicLabels}}" wx:for-item="topic" wx:key="index">#{{topic}}</text>
        </view>

        <view class="post-footer">
          <view class="post-stat"><text class="stat-icon">👍</text><text class="stat-num">{{item.likes || 0}}</text></view>
          <view class="post-stat"><text class="stat-icon">💬</text><text class="stat-num">{{item.commentCount || 0}}</text></view>
          <view class="post-stat"><text class="stat-icon">⭐</text><text class="stat-num">{{item.favorites || 0}}</text></view>
        </view>
      </view>
    </view>

    <empty wx:if="{{!loading && list.length === 0}}" text="暂无帖子" showAction="{{true}}" actionText="去发帖" bindaction="onPublish" />
  </scroll-view>

  <view class="publish-fab" hover-class="publish-fab-hover" bindtap="onPublish">
    <text class="fab-icon">✏️</text>
  </view>
</view>
