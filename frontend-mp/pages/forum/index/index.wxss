.page {
  min-height: 100vh;
  background-color: var(--color-bg-page);
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
}

.feed-tabs {
  display: flex;
  align-items: center;
  padding: var(--spacing-md) var(--spacing-lg);
  background-color: var(--color-bg-card);
  position: sticky;
  top: 0;
  z-index: 100;
  border-bottom: 1rpx solid var(--color-border-light);
}

.feed-tabs > view { margin-right: var(--spacing-sm); }

.feed-tabs > view:last-child { margin-right: 0; }

.feed-tab {
  padding: 14rpx 32rpx;
  font-size: var(--font-md);
  font-weight: 500;
  color: var(--color-text-secondary);
  background-color: var(--color-bg-input);
  border-radius: var(--radius-full);
  transition: all var(--transition-fast);
}

.feed-tab:active {
  transform: scale(0.96);
}

.feed-tab.active {
  color: #FFFFFF;
  background: linear-gradient(135deg, var(--color-primary) 0%, #FF8E8E 100%);
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 107, 0.3);
  font-weight: 600;
}

.type-filter {
  white-space: nowrap;
  background-color: var(--color-bg-card);
  padding: var(--spacing-sm) var(--spacing-lg);
  border-bottom: 1rpx solid var(--color-border-light);
}

.type-filter::-webkit-scrollbar {
  display: none;
}

.type-chip {
  display: inline-block;
  padding: 10rpx 22rpx;
  font-size: var(--font-sm);
  font-weight: 500;
  color: var(--color-text-secondary);
  background-color: var(--color-bg-input);
  border-radius: var(--radius-full);
  margin-right: var(--spacing-sm);
  transition: all var(--transition-fast);
}

.type-chip:active {
  transform: scale(0.96);
}

.type-chip.active {
  color: var(--color-primary);
  background-color: var(--color-primary-light);
  font-weight: 600;
}

.topic-banner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: var(--spacing-md) var(--spacing-lg);
  padding: var(--spacing-md) var(--spacing-lg);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-card);
  transition: all var(--transition-fast);
}

.topic-banner-info {
  display: flex;
  align-items: center;
}

.topic-banner-info > view { margin-right: var(--spacing-sm); }

.topic-banner-info > view:last-child { margin-right: 0; }

.topic-banner-icon {
  font-size: 48rpx;
}

.topic-banner-text {
  display: flex;
  flex-direction: column;
}

.topic-banner-text > view { margin-bottom: 4rpx; }

.topic-banner-text > view:last-child { margin-bottom: 0; }

.topic-banner-name {
  font-size: var(--font-md);
  font-weight: 700;
  color: var(--color-text-primary);
}

.topic-banner-desc {
  font-size: var(--font-xs);
  color: var(--color-text-secondary);
}

.topic-banner-clear {
  display: flex;
  align-items: center;
  padding: 8rpx 20rpx;
  background-color: rgba(255, 255, 255, 0.6);
  border-radius: var(--radius-full);
}

.topic-banner-clear > view { margin-right: 4rpx; }

.topic-banner-clear > view:last-child { margin-right: 0; }

.clear-icon {
  font-size: var(--font-md);
  color: var(--color-text-secondary);
  line-height: 1;
}

.clear-text {
  font-size: var(--font-xs);
  color: var(--color-text-secondary);
  font-weight: 500;
}

.topic-entry {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: var(--spacing-md) var(--spacing-lg);
  padding: var(--spacing-md) var(--spacing-lg);
  background-color: var(--color-bg-card);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-card);
  transition: all var(--transition-fast);
}

.topic-entry:active {
  transform: scale(0.98);
}

.topic-entry-text {
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--color-primary);
}

.topic-entry-arrow {
  font-size: var(--font-xl);
  color: var(--color-text-muted);
  font-weight: 300;
}

.post-scroll {
  height: calc(100vh - 260rpx);
}

.post-list {
  padding: 0 var(--spacing-lg);
}

.post-card {
  background-color: var(--color-bg-card);
  border-radius: var(--radius-2xl);
  padding: var(--spacing-lg);
  margin-bottom: var(--spacing-md);
  box-shadow: var(--shadow-card);
  transition: all var(--transition-fast);
  overflow: hidden;
}

.post-card-hover {
  transform: scale(0.99);
  box-shadow: var(--shadow-sm);
}

.post-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--spacing-sm);
}

.post-type-badge {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 16rpx;
  font-size: var(--font-xs);
  font-weight: 600;
  border-radius: var(--radius-sm);
}

.post-meta {
  display: flex;
  align-items: center;
}

.post-meta > view { margin-right: var(--spacing-sm); }

.post-meta > view:last-child { margin-right: 0; }

.post-author {
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
  font-weight: 500;
}

.post-time {
  font-size: var(--font-xs);
  color: var(--color-text-muted);
}

.post-title {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--color-text-primary);
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  margin-bottom: 8rpx;
}

.post-content {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.6;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
  overflow: hidden;
  margin-bottom: var(--spacing-sm);
}

.post-images {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: var(--spacing-sm);
}

.post-images { margin-right: -8rpx; margin-bottom: -8rpx; }

.post-images > view { margin-right: 8rpx; margin-bottom: 8rpx; }

.post-images .post-img {
  border-radius: var(--radius-lg);
  overflow: hidden;
}

.post-images.img-1 {
  flex-wrap: nowrap;
}

.post-images.img-1 .post-img {
  width: 100%;
  height: 400rpx;
}

.post-images.img-2 .post-img {
  width: calc(50% - 4rpx);
  height: 240rpx;
}

.post-images.img-4 .post-img {
  width: calc(50% - 4rpx);
  height: 200rpx;
}

.post-images.img-9 .post-img {
  width: calc(33.33% - 6rpx);
  height: 200rpx;
}

.post-topics {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: var(--spacing-sm);
}

.post-topics { margin-right: -8rpx; margin-bottom: -8rpx; }

.post-topics > view { margin-right: 8rpx; margin-bottom: 8rpx; }

.post-topic {
  font-size: var(--font-xs);
  color: var(--color-primary);
  background-color: var(--color-primary-light);
  padding: 4rpx 14rpx;
  border-radius: var(--radius-xs);
  font-weight: 500;
}

.post-footer {
  display: flex;
  align-items: center;
  padding-top: var(--spacing-sm);
  border-top: 1rpx solid var(--color-divider);
}

.post-footer > view { margin-right: var(--spacing-xl); }

.post-footer > view:last-child { margin-right: 0; }

.post-stat {
  display: flex;
  align-items: center;
}

.post-stat > view { margin-right: 6rpx; }

.post-stat > view:last-child { margin-right: 0; }

.stat-icon {
  font-size: var(--font-sm);
}

.stat-num {
  font-size: var(--font-sm);
  color: var(--color-text-muted);
  font-weight: 500;
}

.publish-fab {
  position: fixed;
  right: 32rpx;
  bottom: calc(200rpx + env(safe-area-inset-bottom));
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, var(--color-primary) 0%, #FF8E8E 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(255, 107, 107, 0.45);
  transition: all var(--transition-normal);
  z-index: 100;
}

.publish-fab::before {
  content: '';
  position: absolute;
  top: -8rpx;
  left: -8rpx;
  right: -8rpx;
  bottom: -8rpx;
  background: linear-gradient(135deg, var(--color-primary) 0%, #FF8E8E 100%);
  border-radius: 50%;
  opacity: 0.3;
  z-index: -1;
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); opacity: 0.3; }
  50% { transform: scale(1.1); opacity: 0.15; }
}

.publish-fab-hover {
  transform: scale(0.92);
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 107, 0.35);
}

.fab-icon {
  font-size: 48rpx;
  line-height: 1;
}
