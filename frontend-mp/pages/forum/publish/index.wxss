.page {
  min-height: 100vh;
  background-color: var(--color-bg-page);
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.form-section {
  padding: 24rpx 24rpx 0;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-secondary);
  margin-bottom: 16rpx;
  padding-left: 8rpx;
}

.type-scroll {
  width: 100%;
  white-space: nowrap;
}

.type-list {
  display: inline-flex;
  padding: 4rpx 0;
}

.type-list > view { margin-right: 16rpx; }

.type-list > view:last-child { margin-right: 0; }

.type-card {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 24rpx 32rpx;
  background-color: var(--color-bg-card);
  border-radius: var(--radius-xl);
  border: 3rpx solid transparent;
  box-shadow: var(--shadow-card);
  transition: all var(--transition-normal);
  flex-shrink: 0;
}

.type-card:active {
  transform: scale(0.96);
}

.type-card.active {
  border-color: var(--color-primary);
}

.type-card-icon {
  font-size: 44rpx;
  margin-bottom: 8rpx;
}

.type-card-label {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.form-card {
  background-color: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: 0 24rpx;
  box-shadow: var(--shadow-card);
}

.form-input-full {
  width: 100%;
  font-size: 28rpx;
  color: var(--color-text-primary);
  padding: 28rpx 0 8rpx;
  line-height: 40rpx;
  height: 40rpx;
}

.form-input-full::placeholder {
  color: var(--color-text-muted);
}

.input-count {
  display: block;
  text-align: right;
  font-size: 24rpx;
  color: var(--color-text-muted);
  padding-bottom: 16rpx;
}

.form-textarea {
  width: 100%;
  min-height: 240rpx;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: var(--color-text-primary);
  line-height: 1.7;
}

.form-textarea::placeholder {
  color: var(--color-text-muted);
}

.textarea-count {
  display: block;
  text-align: right;
  font-size: 24rpx;
  color: var(--color-text-muted);
  padding-bottom: 16rpx;
}

.image-list {
  display: flex;
  flex-wrap: wrap;
  padding: 24rpx 0;
}

.image-list { margin-right: -16rpx; margin-bottom: -16rpx; }

.image-list > view { margin-right: 16rpx; margin-bottom: 16rpx; }

.image-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
}

.preview-image {
  width: 100%;
  height: 100%;
  border-radius: var(--radius-lg);
}

.image-delete {
  position: absolute;
  top: -12rpx;
  right: -12rpx;
  width: 44rpx;
  height: 44rpx;
  background: linear-gradient(135deg, #E74C3C 0%, #EC7063 100%);
  color: #FFFFFF;
  font-size: 28rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(231, 76, 60, 0.4);
}

.image-add {
  width: 200rpx;
  height: 200rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: var(--color-bg-input);
  border: 2rpx dashed var(--color-border);
  border-radius: var(--radius-lg);
  transition: all var(--transition-fast);
}

.image-add:active {
  background-color: var(--color-border);
}

.add-icon {
  font-size: 48rpx;
  color: var(--color-text-muted);
  line-height: 1;
}

.add-text {
  font-size: 24rpx;
  color: var(--color-text-muted);
  margin-top: 10rpx;
}

.image-tip {
  font-size: 24rpx;
  color: var(--color-text-muted);
  padding-bottom: 16rpx;
}

.topic-area {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  min-height: 48rpx;
}

.topic-chips {
  display: flex;
  flex-wrap: wrap;
  flex: 1;
}

.topic-chips { margin-right: -12rpx; margin-bottom: -12rpx; }

.topic-chips > view { margin-right: 12rpx; margin-bottom: 12rpx; }

.topic-chip {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 20rpx;
  background-color: var(--color-primary-light);
  border-radius: var(--radius-full);
}

.topic-chip-text {
  font-size: 24rpx;
  color: var(--color-primary);
  font-weight: 500;
}

.topic-placeholder {
  flex: 1;
  font-size: 28rpx;
  color: var(--color-text-muted);
}

.topic-arrow {
  font-size: 28rpx;
  color: var(--color-text-muted);
  margin-left: 8rpx;
  flex-shrink: 0;
}

.setting-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
}

.setting-info {
  flex: 1;
}

.setting-label {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--color-text-primary);
}

.setting-desc {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-muted);
  margin-top: 4rpx;
}

.switch-track {
  width: 100rpx;
  height: 56rpx;
  border-radius: 28rpx;
  background-color: var(--color-bg-input);
  position: relative;
  transition: background-color var(--transition-normal);
  flex-shrink: 0;
  border: 2rpx solid var(--color-border);
}

.switch-track.active {
  background-color: var(--color-primary);
  border-color: var(--color-primary);
}

.switch-thumb {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background-color: #FFFFFF;
  position: absolute;
  top: 2rpx;
  left: 2rpx;
  transition: transform var(--transition-normal);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
}

.switch-track.active .switch-thumb {
  transform: translateX(44rpx);
}

.submit-section {
  padding: 40rpx 24rpx;
}

.topic-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 100;
  opacity: 0;
  visibility: hidden;
  transition: all var(--transition-normal);
}

.topic-mask.show {
  opacity: 1;
  visibility: visible;
}

.topic-picker {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: var(--color-bg-card);
  border-radius: var(--radius-2xl) var(--radius-2xl) 0 0;
  z-index: 101;
  transform: translateY(100%);
  transition: transform var(--transition-normal);
  padding-bottom: env(safe-area-inset-bottom);
}

.topic-picker.show {
  transform: translateY(0);
}

.picker-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 32rpx 16rpx;
}

.picker-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

.picker-close {
  font-size: 28rpx;
  color: var(--color-primary);
  font-weight: 600;
}

.picker-tip {
  font-size: 24rpx;
  color: var(--color-text-muted);
  padding: 0 32rpx 20rpx;
}

.picker-body {
  display: flex;
  flex-wrap: wrap;
  padding: 0 32rpx 32rpx;
  max-height: 560rpx;
  overflow-y: auto;
}

.picker-body { margin-right: -16rpx; margin-bottom: -16rpx; }

.picker-body > view { margin-right: 16rpx; margin-bottom: 16rpx; }

.picker-topic {
  display: inline-flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background-color: var(--color-bg-input);
  border-radius: var(--radius-lg);
  border: 2rpx solid transparent;
  transition: all var(--transition-fast);
}

.picker-topic.active {
  background-color: var(--color-primary-light);
  border-color: var(--color-primary);
}

.picker-topic-icon {
  font-size: 32rpx;
  margin-right: 8rpx;
}

.picker-topic-label {
  font-size: 26rpx;
  color: var(--color-text-primary);
  font-weight: 500;
}

.picker-topic-check {
  font-size: 24rpx;
  color: var(--color-primary);
  font-weight: 700;
  margin-left: 8rpx;
}
