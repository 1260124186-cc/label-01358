.exam-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #F0F5FF 0%, #F5F6F7 100%);
}

.exam-page.dark {
  background: linear-gradient(180deg, #1E293B 0%, #0F1117 100%);
}

.exam-scroll {
  height: 100vh;
}

.exam-content {
  padding: 32rpx;
  padding-bottom: 120rpx;
}

.page-header {
  margin-bottom: 32rpx;
  padding-top: 16rpx;
}

.page-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #2C3E50;
  margin-bottom: 8rpx;
  line-height: 1.2;
}

.dark .page-title {
  color: #E8ECF1;
}

.page-subtitle {
  font-size: 26rpx;
  color: #7F8C8D;
}

.dark .page-subtitle {
  color: #94A3B8;
}

.loading {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
}

.loading-text {
  font-size: 28rpx;
  color: #7F8C8D;
}

.countdown-big-card {
  width: 100%;
  background: linear-gradient(135deg, #667EEA 0%, #764BA2 50%, #F093FB 100%);
  border-radius: 32rpx;
  padding: 40rpx 32rpx;
  box-shadow: 0 12rpx 40rpx rgba(102, 126, 234, 0.35);
  margin-bottom: 32rpx;
  position: relative;
  overflow: hidden;
}

.countdown-big-card::before {
  content: '';
  position: absolute;
  top: -80rpx;
  right: -80rpx;
  width: 240rpx;
  height: 240rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.countdown-big-card::after {
  content: '';
  position: absolute;
  bottom: -60rpx;
  left: -60rpx;
  width: 180rpx;
  height: 180rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 50%;
}

.countdown-card-header {
  display: flex;
  align-items: center;
  margin-bottom: 28rpx;
  position: relative;
  z-index: 1;
}

.countdown-icon {
  font-size: 32rpx;
  margin-right: 10rpx;
}

.countdown-card-title {
  font-size: 28rpx;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.9);
}

.countdown-numbers {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 28rpx;
  position: relative;
  z-index: 1;
}

.countdown-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.countdown-num {
  font-size: 72rpx;
  font-weight: 800;
  color: #FFFFFF;
  line-height: 1;
  text-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
  min-width: 100rpx;
  text-align: center;
}

.countdown-num.num-seconds {
  font-size: 60rpx;
}

.countdown-unit {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 8rpx;
  font-weight: 500;
}

.countdown-colon {
  font-size: 56rpx;
  font-weight: 800;
  color: rgba(255, 255, 255, 0.8);
  margin: 0 8rpx;
  line-height: 1;
  padding-bottom: 30rpx;
}

.countdown-colon.colon-seconds {
  font-size: 48rpx;
}

.countdown-item.item-seconds .countdown-unit {
  color: rgba(255, 255, 255, 0.7);
}

.countdown-exam-info {
  background: rgba(255, 255, 255, 0.18);
  border-radius: 20rpx;
  padding: 20rpx 24rpx;
  position: relative;
  z-index: 1;
  backdrop-filter: blur(10rpx);
}

.countdown-course {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.countdown-detail {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

.no-exam-card {
  width: 100%;
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 80rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.dark .no-exam-card {
  background: #1E293B;
}

.no-exam-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.no-exam-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #2C3E50;
  margin-bottom: 12rpx;
}

.dark .no-exam-title {
  color: #E8ECF1;
}

.no-exam-subtitle {
  font-size: 26rpx;
  color: #7F8C8D;
}

.dark .no-exam-subtitle {
  color: #94A3B8;
}

.tab-container {
  display: flex;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 8rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.dark .tab-container {
  background: #1E293B;
}

.tab-item {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 18rpx;
  position: relative;
  transition: all 0.3s ease;
}

.tab-item.tab-active {
  background: linear-gradient(135deg, #667EEA 0%, #764BA2 100%);
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.3);
}

.tab-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #7F8C8D;
  transition: color 0.3s ease;
}

.tab-active .tab-text {
  color: #FFFFFF;
}

.dark .tab-text {
  color: #94A3B8;
}

.dark .tab-active .tab-text {
  color: #FFFFFF;
}

.tab-badge {
  min-width: 36rpx;
  height: 36rpx;
  background: #F53F3F;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 10rpx;
  padding: 0 10rpx;
}

.tab-badge-gray {
  background: #94A3B8;
}

.tab-badge-text {
  font-size: 20rpx;
  font-weight: 600;
  color: #FFFFFF;
  line-height: 1;
}

.exam-list {
  display: flex;
  flex-direction: column;
  margin-bottom: 32rpx;
}

.exam-list > * { margin-bottom: 24rpx; }

.exam-list > *:last-child { margin-bottom: 0; }

.exam-card {
  position: relative;
  background: #FFFFFF;
  border-radius: 28rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
  transition: all 0.25s ease;
  overflow: hidden;
}

.dark .exam-card {
  background: #1E293B;
}

.exam-card:active {
  transform: scale(0.98);
  opacity: 0.92;
}

.exam-card.exam-urgent {
  border: 2rpx solid rgba(245, 63, 63, 0.3);
  background: linear-gradient(135deg, #FFFFFF 0%, #FFF5F5 100%);
}

.dark .exam-card.exam-urgent {
  background: linear-gradient(135deg, #1E293B 0%, #2A1F2E 100%);
  border-color: rgba(245, 63, 63, 0.4);
}

.exam-card.exam-completed {
  background: #F8F9FA;
  opacity: 0.7;
}

.dark .exam-card.exam-completed {
  background: #172033;
  opacity: 0.6;
}

.exam-card-countdown-badge {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #F53F3F 100%);
  border-radius: 16rpx;
  padding: 8rpx 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(245, 63, 63, 0.3);
}

.exam-urgent .exam-card-countdown-badge {
  background: linear-gradient(135deg, #FF3B30 0%, #D32F2F 100%);
  animation: pulse-badge 1.5s ease-in-out infinite;
}

@keyframes pulse-badge {
  0%, 100% {
    transform: scale(1);
    box-shadow: 0 4rpx 12rpx rgba(245, 63, 63, 0.3);
  }
  50% {
    transform: scale(1.05);
    box-shadow: 0 6rpx 20rpx rgba(245, 63, 63, 0.5);
  }
}

.exam-countdown-text {
  font-size: 22rpx;
  font-weight: 600;
  color: #FFFFFF;
  line-height: 1.2;
}

.exam-completed-badge {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  background: #E5E7EB;
  border-radius: 16rpx;
  padding: 8rpx 16rpx;
}

.dark .exam-completed-badge {
  background: #374151;
}

.exam-completed-text {
  font-size: 22rpx;
  font-weight: 600;
  color: #6B7280;
  line-height: 1.2;
}

.exam-card-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  padding-right: 160rpx;
}

.exam-course-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #2C3E50;
  flex: 1;
  margin-right: 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.dark .exam-course-name {
  color: #E8ECF1;
}

.exam-completed .exam-course-name {
  color: #9CA3AF;
  text-decoration: line-through;
}

.dark .exam-completed .exam-course-name {
  color: #6B7280;
}

.exam-type-tag {
  background: linear-gradient(135deg, #3B82F6 0%, #1D4ED8 100%);
  border-radius: 12rpx;
  padding: 6rpx 14rpx;
  flex-shrink: 0;
}

.exam-type-tag-gray {
  background: #E5E7EB;
}

.dark .exam-type-tag-gray {
  background: #374151;
}

.exam-type-text {
  font-size: 20rpx;
  font-weight: 600;
  color: #FFFFFF;
  line-height: 1.2;
}

.exam-type-tag-gray .exam-type-text {
  color: #6B7280;
}

.exam-info-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  margin-bottom: 16rpx;
}

.exam-info-row { margin-right: -24rpx; margin-bottom: -24rpx; }

.exam-info-row > * { margin-right: 24rpx; margin-bottom: 24rpx; }

.exam-info-row:last-of-type {
  margin-bottom: 20rpx;
}

.exam-info-item {
  display: flex;
  align-items: center;
  min-width: 0;
}

.exam-info-icon {
  font-size: 26rpx;
  margin-right: 8rpx;
  flex-shrink: 0;
}

.exam-info-text {
  font-size: 26rpx;
  color: #5D6D7E;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.dark .exam-info-text {
  color: #94A3B8;
}

.exam-completed .exam-info-text {
  color: #9CA3AF;
}

.exam-card-footer {
  padding-top: 16rpx;
  border-top: 1rpx solid #F0F0F0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.dark .exam-card-footer {
  border-top-color: #374151;
}

.exam-tip-text {
  font-size: 22rpx;
  color: #94A3B8;
}

.empty-tip {
  background: #FFFFFF;
  border-radius: 28rpx;
  padding: 80rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.dark .empty-tip {
  background: #1E293B;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #7F8C8D;
  text-align: center;
}

.dark .empty-text {
  color: #94A3B8;
}

.tips-card {
  width: 100%;
  background: linear-gradient(135deg, #FEF3C7 0%, #FDE68A 100%);
  border-radius: 28rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(251, 191, 36, 0.15);
}

.dark .tips-card {
  background: linear-gradient(135deg, #451A03 0%, #78350F 100%);
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.2);
}

.tips-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.tips-icon {
  font-size: 32rpx;
  margin-right: 10rpx;
}

.tips-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #92400E;
}

.dark .tips-title {
  color: #FCD34D;
}

.tips-list {
  display: flex;
  flex-direction: column;
}

.tips-list > * { margin-bottom: 14rpx; }

.tips-list > *:last-child { margin-bottom: 0; }

.tips-item {
  display: flex;
  align-items: flex-start;
}

.tips-dot {
  font-size: 28rpx;
  color: #B45309;
  margin-right: 12rpx;
  line-height: 1.6;
  flex-shrink: 0;
}

.dark .tips-dot {
  color: #F59E0B;
}

.tips-text {
  font-size: 24rpx;
  color: #78350F;
  line-height: 1.6;
  flex: 1;
}

.dark .tips-text {
  color: #FDE68A;
}
