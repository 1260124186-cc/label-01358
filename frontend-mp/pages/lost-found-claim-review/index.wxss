.page {
  min-height: 100vh;
  background-color: var(--color-bg-page);
  padding: 20rpx 24rpx calc(160rpx + env(safe-area-inset-bottom));
}

.preview-card {
  background-color: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: 28rpx 24rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-card);
}

.preview-header {
  display: flex;
  align-items: center;
}

.preview-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: var(--radius-full);
  background-color: var(--color-bg-input);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  overflow: hidden;
  flex-shrink: 0;
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.avatar-default {
  font-size: 40rpx;
}

.preview-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.preview-name {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--color-text-primary);
  margin-bottom: 6rpx;
}

.preview-role {
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
}

.preview-divider {
  height: 1rpx;
  background-color: var(--color-divider);
  margin: 20rpx 0;
}

.preview-detail {
  display: flex;
  flex-direction: column;
}

.detail-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.detail-row:last-child {
  margin-bottom: 0;
}

.detail-icon {
  font-size: var(--font-sm);
  margin-right: 12rpx;
  flex-shrink: 0;
}

.detail-label {
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
  width: 140rpx;
  flex-shrink: 0;
}

.detail-value {
  font-size: var(--font-sm);
  color: var(--color-text-primary);
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.section-card {
  background-color: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: 28rpx 24rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-card);
}

.section-title {
  font-size: var(--font-md);
  font-weight: 700;
  color: var(--color-text-primary);
  display: block;
  margin-bottom: 20rpx;
}

.rating-container {
  display: flex;
  align-items: center;
}

.star-item {
  margin-right: 20rpx;
  transition: transform var(--transition-fast);
}

.star-item:active {
  transform: scale(0.9);
}

.star-icon {
  font-size: 64rpx;
  color: var(--color-border);
}

.star-item.active .star-icon {
  color: #FBBF24;
}

.rating-text {
  margin-left: auto;
  font-size: var(--font-md);
  font-weight: 700;
  color: var(--color-primary);
}

.tags-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag-item {
  display: inline-flex;
  align-items: center;
  padding: 14rpx 24rpx;
  border-radius: var(--radius-full);
  background-color: rgba(59, 130, 246, 0.08);
  border: 2rpx solid rgba(59, 130, 246, 0.3);
  transition: all var(--transition-fast);
}

.tag-item:active {
  transform: scale(0.96);
}

.tag-item.selected {
  background-color: rgba(59, 130, 246, 0.15);
  border-color: #3B82F6;
}

.tag-icon {
  font-size: var(--font-sm);
  margin-right: 8rpx;
}

.tag-label {
  font-size: var(--font-sm);
  color: var(--color-text-primary);
}

.tag-item.selected .tag-label {
  color: #2563EB;
  font-weight: 600;
}

.textarea-wrap {
  position: relative;
  background-color: var(--color-bg-input);
  border-radius: var(--radius-lg);
  padding: 20rpx;
}

.review-textarea {
  width: 100%;
  min-height: 200rpx;
  font-size: var(--font-sm);
  color: var(--color-text-primary);
  line-height: 1.6;
}

.textarea-placeholder {
  color: var(--color-text-placeholder);
}

.textarea-counter {
  position: absolute;
  right: 20rpx;
  bottom: 16rpx;
  font-size: var(--font-xs);
  color: var(--color-text-secondary);
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 100;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  background-color: var(--color-bg-card);
  border-top: 1rpx solid var(--color-border-light);
}

.submit-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  background: linear-gradient(135deg, var(--color-primary) 0%, #FF8E8E 100%);
  border-radius: var(--radius-full);
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 107, 0.3);
  transition: all var(--transition-fast);
}

.submit-btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.submit-btn.disabled {
  opacity: 0.6;
}

.submit-text {
  font-size: var(--font-md);
  font-weight: 700;
  color: #FFFFFF;
}

.page.dark .tag-item {
  background-color: rgba(59, 130, 246, 0.12);
  border-color: rgba(59, 130, 246, 0.25);
}

.page.dark .submit-btn {
  box-shadow: 0 4rpx 16rpx rgba(255, 138, 138, 0.25);
}
