.dispute-page {
  min-height: 100vh;
  background: #f8f9fa;
  padding-bottom: 140rpx;
}

.dispute-page.dark {
  background: #0F1117;
}

.order-banner {
  display: flex;
  align-items: center;
  padding: 30rpx;
  background: linear-gradient(135deg, #6366F1 0%, #8B5CF6 100%);
  margin: 20rpx;
  border-radius: 20rpx;
}

.banner-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.banner-info {
  flex: 1;
}

.banner-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 8rpx;
}

.banner-bounty {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

.warning-card {
  display: flex;
  align-items: flex-start;
  padding: 24rpx;
  margin: 20rpx;
  background: #FEF3C7;
  border-radius: 16rpx;
  border: 2rpx solid #F59E0B;
}

.dispute-page.dark .warning-card {
  background: rgba(245, 158, 11, 0.15);
  border-color: #F59E0B;
}

.warning-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.warning-content {
  flex: 1;
}

.warning-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #92400E;
  margin-bottom: 8rpx;
}

.dispute-page.dark .warning-title {
  color: #FCD34D;
}

.warning-desc {
  display: block;
  font-size: 24rpx;
  color: #B45309;
  margin-bottom: 6rpx;
}

.dispute-page.dark .warning-desc {
  color: #FDE68A;
}

.warning-time {
  font-size: 26rpx;
  font-weight: 600;
  color: #D97706;
}

.dispute-page.dark .warning-time {
  color: #FBBF24;
}

.form-section {
  margin: 20rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 10rpx 0;
}

.dispute-page.dark .form-section {
  background: #1A1D28;
}

.form-group {
  padding: 24rpx 30rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.dispute-page.dark .form-group {
  border-bottom-color: #2A2D3A;
}

.form-group:last-child {
  border-bottom: none;
}

.form-label {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.label-icon {
  font-size: 28rpx;
  margin-right: 10rpx;
}

.label-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.dispute-page.dark .label-text {
  color: #E5E7EB;
}

.label-required {
  color: #EF4444;
  margin-left: 6rpx;
  font-size: 26rpx;
}

.label-optional {
  color: #9CA3AF;
  margin-left: 8rpx;
  font-size: 24rpx;
}

.form-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 80rpx;
  padding: 0 24rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
}

.dispute-page.dark .form-picker {
  background: #252836;
}

.picker-value {
  font-size: 28rpx;
  color: #333;
}

.dispute-page.dark .picker-value {
  color: #E5E7EB;
}

.picker-value.placeholder {
  color: #9CA3AF;
}

.picker-arrow {
  font-size: 32rpx;
  color: #9CA3AF;
}

.form-textarea {
  width: 100%;
  min-height: 200rpx;
  padding: 20rpx 24rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.dispute-page.dark .form-textarea {
  background: #252836;
  color: #E5E7EB;
}

.input-placeholder {
  color: #9CA3AF;
}

.char-count {
  display: block;
  text-align: right;
  font-size: 22rpx;
  color: #9CA3AF;
  margin-top: 10rpx;
}

.evidence-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.evidence-item {
  position: relative;
  width: 180rpx;
  height: 180rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

.evidence-img {
  width: 100%;
  height: 100%;
}

.evidence-remove {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  width: 40rpx;
  height: 40rpx;
  background: #EF4444;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  line-height: 1;
}

.evidence-add {
  width: 180rpx;
  height: 180rpx;
  background: #f8f9fa;
  border: 2rpx dashed #D1D5DB;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.dispute-page.dark .evidence-add {
  background: #252836;
  border-color: #4B5563;
}

.add-icon {
  font-size: 48rpx;
  color: #9CA3AF;
  line-height: 1;
  margin-bottom: 8rpx;
}

.add-text {
  font-size: 24rpx;
  color: #9CA3AF;
}

.tips-section {
  margin: 20rpx;
  padding: 24rpx;
  background: #EFF6FF;
  border-radius: 16rpx;
}

.dispute-page.dark .tips-section {
  background: rgba(59, 130, 246, 0.1);
}

.tips-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1E40AF;
  margin-bottom: 16rpx;
}

.dispute-page.dark .tips-title {
  color: #60A5FA;
}

.tips-list {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.tips-item {
  font-size: 24rpx;
  color: #3B82F6;
  line-height: 1.6;
}

.dispute-page.dark .tips-item {
  color: #93C5FD;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.dispute-page.dark .bottom-bar {
  background: #1A1D28;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.2);
}

.submit-btn {
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: linear-gradient(135deg, #6366F1 0%, #8B5CF6 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 44rpx;
}

.submit-btn.disabled {
  background: #D1D5DB;
  color: #9CA3AF;
}

.dispute-page.dark .submit-btn.disabled {
  background: #374151;
  color: #6B7280;
}

.picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s;
  z-index: 1000;
}

.picker-mask.show {
  opacity: 1;
  visibility: visible;
}

.picker-content {
  width: 100%;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  max-height: 70vh;
  transform: translateY(100%);
  transition: transform 0.3s;
}

.picker-mask.show .picker-content {
  transform: translateY(0);
}

.dispute-page.dark .picker-content {
  background: #1A1D28;
}

.picker-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.dispute-page.dark .picker-header {
  border-bottom-color: #2A2D3A;
}

.picker-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.dispute-page.dark .picker-title {
  color: #E5E7EB;
}

.picker-close {
  font-size: 36rpx;
  color: #9CA3AF;
  padding: 10rpx;
}

.picker-body {
  padding: 10rpx 0;
  max-height: 60vh;
  overflow-y: auto;
}

.picker-item {
  display: flex;
  align-items: center;
  padding: 28rpx 30rpx;
}

.picker-item-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.picker-item-label {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.dispute-page.dark .picker-item-label {
  color: #E5E7EB;
}

.picker-item.active .picker-item-label {
  color: #6366F1;
  font-weight: 600;
}

.picker-item-check {
  font-size: 32rpx;
  color: #6366F1;
  font-weight: 600;
}
