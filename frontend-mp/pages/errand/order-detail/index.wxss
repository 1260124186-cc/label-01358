.detail-page {
  min-height: 100vh;
  background: #f8f9fa;
  padding-bottom: 140rpx;
}

.detail-page.dark {
  background: #0F1117;
}

.status-banner {
  padding: 40rpx 30rpx;
}

.status-main {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.status-icon {
  font-size: 60rpx;
}

.status-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.status-text {
  font-size: 36rpx;
  font-weight: 700;
}

.status-desc {
  font-size: 26rpx;
  color: #999;
}

.detail-page.dark .status-desc {
  color: #6B7280;
}

.progress-section {
  padding: 0 30rpx 30rpx;
}

.progress-bar {
  display: flex;
  align-items: flex-start;
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.detail-page.dark .progress-bar {
  background: #1A1D28;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.2);
}

.step-wrap {
  display: flex;
  align-items: center;
  flex: 1;
}

.step-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  flex-shrink: 0;
}

.step-dot {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #e5e7eb;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s;
}

.detail-page.dark .step-dot {
  background: #374151;
}

.step-item.active .step-dot {
  background: #FF6B6B;
  box-shadow: 0 0 16rpx rgba(255, 107, 107, 0.4);
}

.step-item.done .step-dot {
  background: #10B981;
}

.step-check {
  font-size: 22rpx;
  color: #fff;
  font-weight: 600;
}

.step-label {
  font-size: 22rpx;
  color: #9CA3AF;
}

.step-item.active .step-label {
  color: #FF6B6B;
  font-weight: 600;
}

.step-item.done .step-label {
  color: #10B981;
}

.step-line {
  flex: 1;
  height: 4rpx;
  background: #e5e7eb;
  margin: 0 8rpx;
  transform: translateY(-16rpx);
  transition: background 0.3s;
}

.detail-page.dark .step-line {
  background: #374151;
}

.step-line.done {
  background: #10B981;
}

.info-section {
  padding: 0 30rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.info-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.detail-page.dark .info-card {
  background: #1A1D28;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.2);
}

.info-card-title {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.detail-page.dark .info-card-title {
  border-bottom-color: #2E3348;
}

.card-icon {
  font-size: 28rpx;
}

.card-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.detail-page.dark .card-text {
  color: #E8ECF1;
}

.info-rows {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.row-label {
  font-size: 26rpx;
  color: #999;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.detail-page.dark .row-label {
  color: #6B7280;
}

.row-value {
  font-size: 26rpx;
  color: #333;
  text-align: right;
  flex: 1;
  word-break: break-all;
}

.detail-page.dark .row-value {
  color: #E8ECF1;
}

.row-value.highlight {
  color: #FF6B6B;
  font-weight: 600;
  font-size: 30rpx;
}

.row-value.price {
  color: #FF6B6B;
  font-weight: 600;
}

.row-value.order-id {
  font-size: 22rpx;
  color: #999;
  font-family: monospace;
}

.row-value-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
  justify-content: flex-end;
}

.copy-btn {
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  font-size: 22rpx;
  color: #FF6B6B;
  background: #FFE8E8;
  flex-shrink: 0;
}

.detail-page.dark .copy-btn {
  background: rgba(255, 138, 138, 0.15);
  color: #FF8A8A;
}

.call-btn {
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  font-size: 22rpx;
  color: #4ECDC4;
  background: #E0F7FA;
  flex-shrink: 0;
}

.detail-page.dark .call-btn {
  background: rgba(78, 205, 196, 0.15);
  color: #4ECDC4;
}

.runner-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.runner-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  flex-shrink: 0;
  background: #f0f0f0;
}

.detail-page.dark .runner-avatar {
  background: #374151;
}

.runner-detail {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.runner-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.detail-page.dark .runner-name {
  color: #E8ECF1;
}

.runner-credit {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.credit-score {
  font-size: 24rpx;
  font-weight: 600;
}

.credit-level {
  font-size: 20rpx;
  padding: 2rpx 12rpx;
  border-radius: 12rpx;
  font-weight: 500;
}

.rating-block {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.rating-role {
  font-size: 24rpx;
  color: #999;
  font-weight: 500;
}

.detail-page.dark .rating-role {
  color: #6B7280;
}

.rating-stars {
  display: flex;
  gap: 4rpx;
}

.rating-stars .star {
  font-size: 28rpx;
  color: #e5e7eb;
}

.detail-page.dark .rating-stars .star {
  color: #374151;
}

.rating-stars .star.filled {
  color: #F59E0B;
}

.rating-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.rating-tag {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 14rpx;
  background: #F3F4F6;
  color: #6B7280;
}

.detail-page.dark .rating-tag {
  background: #2E3348;
  color: #9CA3AF;
}

.rating-comment {
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
}

.detail-page.dark .rating-comment {
  color: #9CA3AF;
}

.rating-divider {
  height: 1rpx;
  background: #f0f0f0;
  margin: 8rpx 0;
}

.detail-page.dark .rating-divider {
  background: #2E3348;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.06);
  z-index: 100;
  display: flex;
  justify-content: center;
}

.detail-page.dark .bottom-bar {
  background: #1A1D28;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.3);
}

.cancel-btn {
  padding: 20rpx 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: #999;
  border: 2rpx solid #ddd;
  text-align: center;
}

.detail-page.dark .cancel-btn {
  color: #6B7280;
  border-color: #4B5563;
}

.primary-btn {
  padding: 20rpx 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
  background: linear-gradient(135deg, #FF6B6B, #FF8E8E);
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 107, 0.3);
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 200;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s;
}

.modal-mask.show {
  opacity: 1;
  visibility: visible;
}

.modal-content {
  width: 600rpx;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  transform: scale(0.9);
  transition: transform 0.3s;
}

.modal-mask.show .modal-content {
  transform: scale(1);
}

.detail-page.dark .modal-content {
  background: #1A1D28;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.detail-page.dark .modal-header {
  border-bottom-color: #2E3348;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
}

.detail-page.dark .modal-title {
  color: #E8ECF1;
}

.modal-close {
  font-size: 32rpx;
  color: #999;
  padding: 8rpx;
}

.detail-page.dark .modal-close {
  color: #6B7280;
}

.modal-body {
  padding: 30rpx;
}

.score-section {
  margin-bottom: 30rpx;
}

.score-label {
  font-size: 26rpx;
  color: #666;
  font-weight: 500;
  display: block;
  margin-bottom: 16rpx;
}

.detail-page.dark .score-label {
  color: #9CA3AF;
}

.score-stars {
  display: flex;
  gap: 16rpx;
}

.score-star {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: #e5e7eb;
  transition: all 0.2s;
}

.detail-page.dark .score-star {
  color: #374151;
}

.score-star.active {
  color: #F59E0B;
  transform: scale(1.1);
}

.tags-section {
  margin-bottom: 30rpx;
}

.tags-label {
  font-size: 26rpx;
  color: #666;
  font-weight: 500;
  display: block;
  margin-bottom: 16rpx;
}

.detail-page.dark .tags-label {
  color: #9CA3AF;
}

.tags-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag-item {
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #666;
  background: #F3F4F6;
  transition: all 0.2s;
}

.detail-page.dark .tag-item {
  color: #9CA3AF;
  background: #2E3348;
}

.tag-item.selected {
  color: #FF6B6B;
  background: #FFE8E8;
  font-weight: 500;
}

.detail-page.dark .tag-item.selected {
  color: #FF8A8A;
  background: rgba(255, 138, 138, 0.15);
}

.comment-section {
  margin-bottom: 10rpx;
}

.comment-label {
  font-size: 26rpx;
  color: #666;
  font-weight: 500;
  display: block;
  margin-bottom: 16rpx;
}

.detail-page.dark .comment-label {
  color: #9CA3AF;
}

.comment-input {
  width: 100%;
  height: 160rpx;
  padding: 16rpx;
  border-radius: 12rpx;
  border: 1rpx solid #e5e7eb;
  font-size: 26rpx;
  color: #333;
  box-sizing: border-box;
}

.detail-page.dark .comment-input {
  border-color: #374151;
  color: #E8ECF1;
  background: #0F1117;
}

.modal-footer {
  padding: 20rpx 30rpx 30rpx;
}

.submit-btn {
  width: 100%;
  padding: 22rpx 0;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
  background: linear-gradient(135deg, #FF6B6B, #FF8E8E);
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 107, 0.3);
}
