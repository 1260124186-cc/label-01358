<view class="detail-page {{darkMode ? 'dark' : ''}}" wx:if="{{order}}">
  <view class="status-banner" style="background: linear-gradient(135deg, {{order.statusColor}}20, {{order.statusColor}}05);">
    <view class="status-main">
      <text class="status-icon">{{order.statusIcon}}</text>
      <view class="status-info">
        <text class="status-text" style="color: {{order.statusColor}};">{{order.statusText}}</text>
        <text class="status-desc" wx:if="{{order.status === 'pending'}}">等待接单中，请耐心等待</text>
        <text class="status-desc" wx:elif="{{order.status === 'accepted'}}">跑手已接单，等待开始任务</text>
        <text class="status-desc" wx:elif="{{order.status === 'in_progress'}}">任务进行中，即将完成</text>
        <text class="status-desc" wx:elif="{{order.status === 'completed'}}">订单已完成</text>
        <text class="status-desc" wx:elif="{{order.status === 'cancelled'}}">订单已取消</text>
        <text class="status-desc" wx:elif="{{order.status === 'timeout'}}">订单已超时</text>
      </view>
    </view>
  </view>

  <view class="progress-section" wx:if="{{order.status !== 'cancelled' && order.status !== 'timeout'}}">
    <view class="progress-bar">
      <view
        wx:for="{{statusSteps}}"
        wx:key="value"
        class="step-wrap"
      >
        <view class="step-item {{item.done ? 'done' : ''}} {{item.active ? 'active' : ''}}">
          <view class="step-dot">
            <text wx:if="{{item.done}}" class="step-check">✓</text>
          </view>
          <text class="step-label">{{item.label}}</text>
        </view>
        <view wx:if="{{index < statusSteps.length - 1}}" class="step-line {{item.done ? 'done' : ''}}"></view>
      </view>
    </view>
  </view>

  <view class="info-section">
    <view class="info-card">
      <view class="info-card-title">
        <text class="card-icon">{{order.typeIcon}}</text>
        <text class="card-text">{{order.typeText}}信息</text>
      </view>
      <view wx:if="{{order.type === 'express'}}" class="info-rows">
        <view class="info-row">
          <text class="row-label">快递点</text>
          <text class="row-value">{{order.pickupPointText || order.pickupPoint}}</text>
        </view>
        <view class="info-row">
          <text class="row-label">取件码</text>
          <view class="row-value-wrap">
            <text class="row-value highlight">{{order.pickupCode}}</text>
            <view class="copy-btn" bindtap="onCopyPickupCode">复制</view>
          </view>
        </view>
        <view class="info-row">
          <text class="row-label">赏金</text>
          <text class="row-value price">¥{{order.bounty}}</text>
        </view>
      </view>
      <view wx:if="{{order.type === 'purchase'}}" class="info-rows">
        <view class="info-row">
          <text class="row-label">代买类别</text>
          <text class="row-value">{{order.purchaseCategoryText || order.purchaseCategory}}</text>
        </view>
        <view class="info-row">
          <text class="row-label">代买物品</text>
          <text class="row-value">{{order.purchaseItem}}</text>
        </view>
        <view class="info-row">
          <text class="row-label">赏金</text>
          <text class="row-value price">¥{{order.bounty}}</text>
        </view>
      </view>
      <view wx:if="{{order.type === 'delivery'}}" class="info-rows">
        <view class="info-row">
          <text class="row-label">代送物品</text>
          <text class="row-value">{{order.deliveryItem}}</text>
        </view>
        <view class="info-row">
          <text class="row-label">赏金</text>
          <text class="row-value price">¥{{order.bounty}}</text>
        </view>
      </view>
      <view wx:if="{{order.type === 'queue'}}" class="info-rows">
        <view class="info-row">
          <text class="row-label">排队地点</text>
          <text class="row-value">{{order.queueLocation}}</text>
        </view>
        <view class="info-row">
          <text class="row-label">排队目的</text>
          <text class="row-value">{{order.queuePurpose}}</text>
        </view>
        <view class="info-row">
          <text class="row-label">赏金</text>
          <text class="row-value price">¥{{order.bounty}}</text>
        </view>
      </view>
      <view wx:if="{{order.type === 'other'}}" class="info-rows">
        <view class="info-row">
          <text class="row-label">任务描述</text>
          <text class="row-value">{{order.otherDesc}}</text>
        </view>
        <view class="info-row">
          <text class="row-label">赏金</text>
          <text class="row-value price">¥{{order.bounty}}</text>
        </view>
      </view>
    </view>

    <view class="info-card">
      <view class="info-card-title">
        <text class="card-icon">📍</text>
        <text class="card-text">位置信息</text>
      </view>
      <view class="info-rows">
        <view class="info-row" wx:if="{{order.pickupLocation}}">
          <text class="row-label">取件地点</text>
          <text class="row-value">{{order.pickupLocation}}</text>
        </view>
        <view class="info-row" wx:if="{{order.deliveryLocation}}">
          <text class="row-label">送达地点</text>
          <text class="row-value">{{order.deliveryLocation}}</text>
        </view>
      </view>
    </view>

    <view class="info-card">
      <view class="info-card-title">
        <text class="card-icon">📞</text>
        <text class="card-text">配送信息</text>
      </view>
      <view class="info-rows">
        <view class="info-row" wx:if="{{order.contactPhone}}">
          <text class="row-label">联系电话</text>
          <view class="row-value-wrap">
            <text class="row-value">{{order.contactPhone}}</text>
            <view class="call-btn" bindtap="onCallPhone">拨打</view>
          </view>
        </view>
        <view class="info-row" wx:if="{{order.remark}}">
          <text class="row-label">备注</text>
          <text class="row-value">{{order.remark}}</text>
        </view>
      </view>
    </view>

    <view class="info-card" wx:if="{{runnerProfile}}">
      <view class="info-card-title">
        <text class="card-icon">🏃</text>
        <text class="card-text">跑手信息</text>
      </view>
      <view class="info-rows">
        <view class="runner-row">
          <image class="runner-avatar" src="{{runnerProfile.avatar || '/images/default-avatar.png'}}" mode="aspectFill"></image>
          <view class="runner-detail">
            <text class="runner-name">{{runnerProfile.name || order.runnerName}}</text>
            <view class="runner-credit">
              <text class="credit-score" style="color: {{runnerProfile.creditLevelColor}};">{{runnerProfile.creditScore}}分</text>
              <text class="credit-level" style="background: {{runnerProfile.creditLevelColor}}20; color: {{runnerProfile.creditLevelColor}};">{{runnerProfile.creditLevelText}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="info-card" wx:if="{{escrowInfo}}">
      <view class="info-card-title">
        <text class="card-icon">{{escrowInfo.icon}}</text>
        <text class="card-text">赏金托管</text>
      </view>
      <view class="info-rows">
        <view class="info-row">
          <text class="row-label">托管状态</text>
          <text class="row-value" style="color: {{escrowInfo.color}};">{{escrowInfo.label}}</text>
        </view>
        <view class="info-row">
          <text class="row-label">托管金额</text>
          <text class="row-value price">¥{{order.bounty}}</text>
        </view>
      </view>
    </view>

    <view class="info-card" wx:if="{{publisherRating || runnerRating}}">
      <view class="info-card-title">
        <text class="card-icon">⭐</text>
        <text class="card-text">评价信息</text>
      </view>
      <view class="info-rows">
        <view class="rating-block" wx:if="{{publisherRating}}">
          <text class="rating-role">发布者评价</text>
          <view class="rating-stars">
            <text wx:for="{{5}}" wx:key="*this" class="star {{item < publisherRating.score ? 'filled' : ''}}">★</text>
          </view>
          <view class="rating-tags" wx:if="{{publisherRating.tags.length > 0}}">
            <text wx:for="{{publisherRating.tags}}" wx:key="*this" class="rating-tag">{{item}}</text>
          </view>
          <text class="rating-comment" wx:if="{{publisherRating.comment}}">{{publisherRating.comment}}</text>
        </view>
        <view class="rating-divider" wx:if="{{publisherRating && runnerRating}}"></view>
        <view class="rating-block" wx:if="{{runnerRating}}">
          <text class="rating-role">跑手评价</text>
          <view class="rating-stars">
            <text wx:for="{{5}}" wx:key="*this" class="star {{item < runnerRating.score ? 'filled' : ''}}">★</text>
          </view>
          <view class="rating-tags" wx:if="{{runnerRating.tags.length > 0}}">
            <text wx:for="{{runnerRating.tags}}" wx:key="*this" class="rating-tag">{{item}}</text>
          </view>
          <text class="rating-comment" wx:if="{{runnerRating.comment}}">{{runnerRating.comment}}</text>
        </view>
      </view>
    </view>

    <view class="info-card">
      <view class="info-card-title">
        <text class="card-icon">📋</text>
        <text class="card-text">订单信息</text>
      </view>
      <view class="info-rows">
        <view class="info-row">
          <text class="row-label">订单编号</text>
          <text class="row-value order-id">{{order.id}}</text>
        </view>
        <view class="info-row">
          <text class="row-label">下单时间</text>
          <text class="row-value">{{order.timeText}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="bottom-bar" wx:if="{{isPublisher && order.status === 'pending'}}">
    <view class="cancel-btn" bindtap="onCancel">取消订单</view>
  </view>

  <view class="bottom-bar" wx:if="{{isRunner && order.status === 'pending'}}">
    <view class="primary-btn" bindtap="onAccept">接单</view>
  </view>

  <view class="bottom-bar" wx:if="{{isRunner && order.status === 'accepted'}}">
    <view class="primary-btn" bindtap="onStartTask">开始任务</view>
  </view>

  <view class="bottom-bar" wx:if="{{isRunner && order.status === 'in_progress'}}">
    <view class="primary-btn" bindtap="onComplete">确认完成</view>
  </view>

  <view class="bottom-bar" wx:if="{{canRate}}">
    <view class="primary-btn" bindtap="onRate">评价</view>
  </view>

  <view class="modal-mask {{showRatingModal ? 'show' : ''}}" bindtap="onCloseRating" wx:if="{{showRatingModal}}">
    <view class="modal-content" catchtap="preventBubble">
      <view class="modal-header">
        <text class="modal-title">评价跑手</text>
        <view class="modal-close" bindtap="onCloseRating">✕</view>
      </view>
      <view class="modal-body">
        <view class="score-section">
          <text class="score-label">评分</text>
          <view class="score-stars">
            <view
              wx:for="{{5}}"
              wx:key="*this"
              class="score-star {{item < ratingScore ? 'active' : ''}}"
              data-score="{{item + 1}}"
              bindtap="onRatingScore"
            >
              <text>★</text>
            </view>
          </view>
        </view>
        <view class="tags-section">
          <text class="tags-label">标签</text>
          <view class="tags-list">
            <view
              wx:for="{{ratingTagsList}}"
              wx:key="value"
              class="tag-item {{selectedTagsMap[item.value] ? 'selected' : ''}}"
              data-tag="{{item.value}}"
              bindtap="onTagToggle"
            >
              <text>{{item.icon}} {{item.label}}</text>
            </view>
          </view>
        </view>
        <view class="comment-section">
          <text class="comment-label">留言</text>
          <textarea
            class="comment-input"
            placeholder="对跑手说点什么..."
            value="{{ratingComment}}"
            bindinput="onRatingInput"
            maxlength="200"
          ></textarea>
        </view>
      </view>
      <view class="modal-footer">
        <view class="submit-btn" bindtap="onSubmitRating">提交评价</view>
      </view>
    </view>
  </view>
</view>
