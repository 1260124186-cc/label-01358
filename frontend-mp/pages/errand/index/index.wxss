.page {
  min-height: 100vh;
  background-color: #F8F9FA;
  padding-bottom: 140rpx;
}

.page.dark {
  background-color: #0F1117;
  color: #E8ECF1;
}

.header-section {
  padding: 20rpx 30rpx;
  background-color: #fff;
}

.page.dark .header-section {
  background-color: #1A1D29;
}

.search-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.search-box {
  flex: 1;
  display: flex;
  align-items: center;
  background-color: #F5F5F5;
  border-radius: 40rpx;
  padding: 20rpx 30rpx;
}

.page.dark .search-box {
  background-color: #2A2F3D;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 16rpx;
  color: #999;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.page.dark .search-input {
  color: #E8ECF1;
}

.publish-text-btn {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  border-radius: 36rpx;
  flex-shrink: 0;
}

.publish-text-btn-hover {
  opacity: 0.85;
  transform: scale(0.96);
}

.publish-text-btn-icon {
  font-size: 26rpx;
  margin-right: 6rpx;
}

.publish-text-btn-label {
  font-size: 26rpx;
  color: #fff;
  font-weight: 600;
}

.stats-section {
  background-color: #fff;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #EEEEEE;
}

.page.dark .stats-section {
  background-color: #1A1D29;
  border-bottom-color: #2A2F3D;
}

.stats-row {
  display: flex;
  align-items: center;
  justify-content: space-around;
  background-color: #F8F9FA;
  border-radius: 16rpx;
  padding: 24rpx 0;
}

.page.dark .stats-row {
  background-color: #22263A;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #F59E0B;
}

.stat-value-blue {
  color: #3B82F6;
}

.stat-value-green {
  color: #10B981;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
}

.page.dark .stat-label {
  color: #9AA0A6;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background-color: #E5E7EB;
}

.page.dark .stat-divider {
  background-color: #3A3F4D;
}

.type-section {
  background-color: #fff;
  border-bottom: 1rpx solid #EEEEEE;
}

.page.dark .type-section {
  background-color: #1A1D29;
  border-bottom-color: #2A2F3D;
}

.type-scroll {
  white-space: nowrap;
}

.type-tabs {
  display: inline-flex;
  padding: 0 20rpx;
  gap: 12rpx;
}

.type-tab {
  display: inline-flex;
  align-items: center;
  padding: 16rpx 28rpx;
  border-radius: 30rpx;
  background-color: #F5F5F5;
  font-size: 26rpx;
  color: #666;
  flex-shrink: 0;
}

.page.dark .type-tab {
  background-color: #2A2F3D;
  color: #9AA0A6;
}

.type-tab.active {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  color: #fff;
}

.type-tab-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.type-tab-label {
  font-weight: 500;
}

.filter-section {
  background-color: #fff;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #EEEEEE;
}

.page.dark .filter-section {
  background-color: #1A1D29;
  border-bottom-color: #2A2F3D;
}

.filter-scroll {
  white-space: nowrap;
}

.filter-row {
  display: inline-flex;
  padding: 0 20rpx;
  gap: 16rpx;
}

.filter-chip {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 24rpx;
  background-color: #F5F5F5;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #666;
  flex-shrink: 0;
}

.page.dark .filter-chip {
  background-color: #2A2F3D;
  color: #9AA0A6;
}

.filter-chip.active {
  background-color: #FFEAEA;
  color: #FF6B6B;
}

.page.dark .filter-chip.active {
  background-color: rgba(255, 107, 107, 0.2);
  color: #FF6B6B;
}

.chip-arrow {
  font-size: 20rpx;
  margin-left: 8rpx;
  color: #999;
}

.list-scroll {
  height: calc(100vh - 520rpx);
}

.list-container {
  padding: 20rpx;
}

.task-card {
  background-color: #fff;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.page.dark .task-card {
  background-color: #1A1D29;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.3);
}

.task-card-hover {
  transform: scale(0.98);
  opacity: 0.9;
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.type-badge {
  display: flex;
  align-items: center;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.type-badge-icon {
  font-size: 26rpx;
  margin-right: 8rpx;
}

.type-badge-text {
  font-weight: 600;
}

.status-tag {
  margin-left: 16rpx;
  display: flex;
  align-items: center;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.status-tag-icon {
  font-size: 22rpx;
  margin-right: 6rpx;
}

.bounty-tag {
  margin-left: auto;
  display: flex;
  align-items: baseline;
}

.bounty-currency {
  font-size: 24rpx;
  color: #FF6B6B;
  font-weight: 600;
}

.bounty-value {
  font-size: 40rpx;
  color: #FF6B6B;
  font-weight: 700;
  margin-left: 4rpx;
}

.card-desc {
  margin-bottom: 16rpx;
}

.desc-text {
  font-size: 28rpx;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.page.dark .desc-text {
  color: #C8CDD3;
}

.card-route {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  padding: 16rpx;
  background-color: #F8F9FA;
  border-radius: 12rpx;
}

.page.dark .card-route {
  background-color: #22263A;
}

.route-point {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.route-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.route-dot.from {
  background-color: #10B981;
}

.route-dot.to {
  background-color: #EF4444;
}

.route-text {
  font-size: 26rpx;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.page.dark .route-text {
  color: #C8CDD3;
}

.route-line-wrap {
  display: flex;
  align-items: center;
  padding: 0 16rpx;
  flex-shrink: 0;
}

.route-line {
  width: 40rpx;
  height: 2rpx;
  background-color: #DDD;
}

.page.dark .route-line {
  background-color: #3A3F4D;
}

.route-arrow {
  font-size: 24rpx;
  color: #999;
  margin-left: 4rpx;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid #F5F5F5;
}

.page.dark .card-footer {
  border-top-color: #2A2F3D;
}

.footer-left {
  display: flex;
  align-items: center;
}

.deadline-info {
  display: flex;
  align-items: center;
}

.footer-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
}

.deadline-text {
  font-size: 24rpx;
  color: #F59E0B;
  font-weight: 500;
}

.deadline-text.expired {
  color: #EF4444;
}

.footer-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.publisher-info {
  display: flex;
  align-items: center;
}

.publisher-avatar {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.publisher-avatar-img {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  margin-right: 8rpx;
}

.publisher-name {
  font-size: 24rpx;
  color: #666;
}

.page.dark .publisher-name {
  color: #9AA0A6;
}

.time-text {
  font-size: 22rpx;
  color: #999;
}

.fab-btn {
  position: fixed;
  right: 40rpx;
  bottom: 80rpx;
  width: 110rpx;
  height: 110rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 107, 0.4);
  z-index: 99;
}

.fab-btn-hover {
  transform: scale(0.95);
  opacity: 0.9;
}

.fab-icon {
  font-size: 60rpx;
  color: #fff;
  font-weight: 300;
  line-height: 1;
}

.picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 200;
  display: flex;
  align-items: flex-end;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.picker-mask.show {
  opacity: 1;
  visibility: visible;
}

.picker-content {
  width: 100%;
  max-height: 80vh;
  background-color: #fff;
  border-radius: 30rpx 30rpx 0 0;
  transform: translateY(100%);
  transition: transform 0.3s ease;
}

.picker-mask.show .picker-content {
  transform: translateY(0);
}

.page.dark .picker-content {
  background-color: #1A1D29;
}

.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.page.dark .picker-header {
  border-bottom-color: #2A2F3D;
}

.picker-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.page.dark .picker-title {
  color: #E8ECF1;
}

.picker-close {
  font-size: 40rpx;
  color: #999;
  padding: 10rpx;
}

.picker-options {
  padding: 20rpx;
  max-height: 60vh;
  overflow-y: auto;
}

.picker-option {
  padding: 28rpx 30rpx;
  font-size: 28rpx;
  color: #333;
  border-radius: 12rpx;
  margin-bottom: 8rpx;
}

.page.dark .picker-option {
  color: #E8ECF1;
}

.picker-option.active {
  background-color: #FFEAEA;
  color: #FF6B6B;
  font-weight: 500;
}

.page.dark .picker-option.active {
  background-color: rgba(255, 107, 107, 0.2);
  color: #FF6B6B;
}
