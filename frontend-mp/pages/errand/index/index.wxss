.errand-page {
  min-height: 100vh;
  background: #f8f9fa;
  padding-bottom: 40rpx;
}

.errand-page.dark {
  background: #0F1117;
}

.service-section {
  padding: 30rpx;
}

.section-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.title-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.errand-page.dark .title-text {
  color: #E8ECF1;
}

.title-action {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.action-text {
  font-size: 26rpx;
  color: #FF6B6B;
}

.action-arrow {
  font-size: 28rpx;
  color: #FF6B6B;
}

.service-grid {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.service-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  transition: transform 0.2s;
}

.errand-page.dark .service-card {
  background: #1A1D28;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.3);
}

.service-card:active {
  transform: scale(0.98);
}

.service-icon-wrap {
  width: 100rpx;
  height: 100rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.service-icon {
  font-size: 48rpx;
}

.service-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.service-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.errand-page.dark .service-name {
  color: #E8ECF1;
}

.service-desc {
  font-size: 24rpx;
  color: #999;
}

.errand-page.dark .service-desc {
  color: #6B7280;
}

.service-arrow {
  font-size: 36rpx;
  color: #ccc;
  margin-left: 12rpx;
}

.errand-page.dark .service-arrow {
  color: #4B5563;
}

.stats-section {
  padding: 0 30rpx 30rpx;
}

.stats-grid {
  display: flex;
  gap: 20rpx;
}

.stat-item {
  flex: 1;
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.errand-page.dark .stat-item {
  background: #1A1D28;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.2);
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #FF6B6B;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}

.errand-page.dark .stat-label {
  color: #6B7280;
}

.recent-section {
  padding: 0 30rpx 30rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.errand-page.dark .empty-text {
  color: #9CA3AF;
}

.empty-desc {
  font-size: 24rpx;
  color: #999;
}

.order-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.order-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  transition: transform 0.2s;
}

.errand-page.dark .order-card {
  background: #1A1D28;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.2);
}

.order-card:active {
  transform: scale(0.98);
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.order-type {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.order-type-icon {
  font-size: 28rpx;
}

.order-type-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.errand-page.dark .order-type-text {
  color: #E8ECF1;
}

.order-status {
  font-size: 24rpx;
  font-weight: 500;
}

.order-body {
  margin-bottom: 16rpx;
}

.order-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
}

.errand-page.dark .order-desc {
  color: #9CA3AF;
}

.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.order-price {
  font-size: 30rpx;
  font-weight: 600;
  color: #FF6B6B;
}

.order-time {
  font-size: 22rpx;
  color: #bbb;
}

.address-entry {
  display: flex;
  align-items: center;
  margin: 0 30rpx;
  padding: 24rpx 30rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  transition: transform 0.2s;
}

.errand-page.dark .address-entry {
  background: #1A1D28;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.2);
}

.address-entry:active {
  transform: scale(0.98);
}

.address-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.address-text {
  flex: 1;
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.errand-page.dark .address-text {
  color: #E8ECF1;
}

.address-arrow {
  font-size: 32rpx;
  color: #ccc;
}

.errand-page.dark .address-arrow {
  color: #4B5563;
}
