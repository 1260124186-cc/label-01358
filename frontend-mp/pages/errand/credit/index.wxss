.page {
  min-height: 100vh;
  background-color: var(--color-bg-page);
  padding-bottom: calc(60rpx + env(safe-area-inset-bottom));
}

.hero-card {
  margin: 24rpx;
  padding: 40rpx 32rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 50%, #FFB88C 100%);
  border-radius: var(--radius-2xl);
  position: relative;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(255, 107, 107, 0.3);
}

.hero-bg-circle {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
}

.hero-bg-circle-1 {
  top: -80rpx;
  right: -40rpx;
  width: 300rpx;
  height: 300rpx;
}

.hero-bg-circle-2 {
  bottom: -60rpx;
  left: -30rpx;
  width: 200rpx;
  height: 200rpx;
  background: rgba(255, 255, 255, 0.06);
}

.hero-user {
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
  position: relative;
  z-index: 1;
}

.hero-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.6);
  flex-shrink: 0;
  background: rgba(255, 255, 255, 0.2);
}

.hero-user-info {
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
}

.hero-user-info > * { margin-bottom: 10rpx; }

.hero-user-info > *:last-child { margin-bottom: 0; }

.hero-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.hero-level-badge {
  display: inline-flex;
  align-items: center;
  font-size: 22rpx;
  font-weight: 600;
  padding: 4rpx 16rpx;
  border-radius: var(--radius-sm);
  background: rgba(255, 255, 255, 0.25);
  align-self: flex-start;
}

.hero-score {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  z-index: 1;
}

.hero-score-value {
  font-size: 108rpx;
  font-weight: 800;
  line-height: 1;
  text-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.hero-score-unit {
  font-size: 26rpx;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
}

.section {
  margin: 0 24rpx 24rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.section-count {
  font-size: 24rpx;
  color: var(--color-text-muted);
}

.stats-grid {
  display: flex;
  flex-wrap: wrap;
  background-color: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: 28rpx;
  box-shadow: var(--shadow-card);
}

.stats-grid { margin-right: -16rpx; margin-bottom: -16rpx; }

.stats-grid > * { margin-right: 16rpx; margin-bottom: 16rpx; width: calc(50% - 16rpx); }

.stats-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 0;
}

.stats-num {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  line-height: 1.2;
}

.stats-label {
  font-size: 24rpx;
  color: var(--color-text-muted);
  margin-top: 6rpx;
}

.progress-card {
  background-color: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: 28rpx;
  box-shadow: var(--shadow-card);
}

.progress-track {
  height: 24rpx;
  background-color: var(--color-bg-input);
  border-radius: var(--radius-full);
  overflow: hidden;
  margin-bottom: 24rpx;
}

.progress-fill {
  height: 100%;
  border-radius: var(--radius-full);
  transition: width 0.6s ease;
  min-width: 24rpx;
}

.progress-labels {
  display: flex;
  justify-content: space-between;
}

.progress-label-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  opacity: 0.5;
}

.progress-label-item.current {
  opacity: 1;
}

.progress-label-icon {
  font-size: 28rpx;
  margin-bottom: 4rpx;
}

.progress-label-text {
  font-size: 22rpx;
  font-weight: 500;
  color: var(--color-text-secondary);
}

.progress-label-item.current .progress-label-text {
  font-weight: 700;
}

.progress-label-range {
  font-size: 18rpx;
  color: var(--color-text-muted);
  margin-top: 2rpx;
}

.violation-list {
  display: flex;
  flex-direction: column;
}

.violation-list > * { margin-bottom: 12rpx; }

.violation-list > *:last-child { margin-bottom: 0; }

.violation-card {
  display: flex;
  align-items: center;
  background-color: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: 24rpx 28rpx;
  box-shadow: var(--shadow-card);
}

.violation-icon-wrap {
  width: 64rpx;
  height: 64rpx;
  border-radius: var(--radius-lg);
  background: #FEF2F2;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.violation-icon {
  font-size: 32rpx;
}

.violation-main {
  flex: 1;
  min-width: 0;
}

.violation-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 6rpx;
}

.violation-type {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.violation-time {
  font-size: 22rpx;
  color: var(--color-text-muted);
}

.violation-desc {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.order-list {
  display: flex;
  flex-direction: column;
}

.order-list > * { margin-bottom: 12rpx; }

.order-list > *:last-child { margin-bottom: 0; }

.order-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background-color: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: 24rpx 28rpx;
  box-shadow: var(--shadow-card);
  transition: all var(--transition-fast);
}

.order-card:active {
  transform: scale(0.98);
  background-color: var(--color-bg-input);
}

.order-main {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.order-type-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.order-info {
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.order-info > * { margin-bottom: 4rpx; }

.order-info > *:last-child { margin-bottom: 0; }

.order-title {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--color-text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.order-time {
  font-size: 22rpx;
  color: var(--color-text-muted);
}

.order-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  margin-left: 20rpx;
  flex-shrink: 0;
}

.order-right > * { margin-bottom: 6rpx; }

.order-right > *:last-child { margin-bottom: 0; }

.order-rating {
  display: flex;
}

.order-rating > * { margin-right: 2rpx; }

.order-rating > *:last-child { margin-right: 0; }

.order-star {
  font-size: 22rpx;
  color: var(--color-border-light);
}

.order-star.filled {
  color: #F59E0B;
}

.order-bounty {
  font-size: 26rpx;
  font-weight: 600;
  color: #FF6B6B;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 28rpx;
  color: var(--color-text-muted);
}

.dark .hero-card {
  background: linear-gradient(135deg, #8B3A3A 0%, #9E5050 50%, #8B6B50 100%);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.4);
}

.dark .hero-level-badge {
  background: rgba(255, 255, 255, 0.15);
}

.dark .violation-icon-wrap {
  background: rgba(239, 68, 68, 0.15);
}

.dark .order-card:active {
  background-color: var(--color-bg-elevated);
}
