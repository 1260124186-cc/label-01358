.orders-page {
  min-height: 100vh;
  background: #f8f9fa;
}

.orders-page.dark {
  background: #0F1117;
}

.tabs {
  display: flex;
  background: #fff;
  padding: 0 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
  position: sticky;
  top: 0;
  z-index: 10;
}

.orders-page.dark .tabs {
  background: #1A1D28;
  border-bottom-color: #2E3348;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 28rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
  transition: all 0.3s;
}

.orders-page.dark .tab-item {
  color: #9CA3AF;
}

.tab-item.active {
  color: #FF6B6B;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 6rpx;
  background: #FF6B6B;
  border-radius: 3rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.orders-page.dark .empty-text {
  color: #9CA3AF;
}

.empty-desc {
  font-size: 24rpx;
  color: #999;
}

.order-list {
  padding: 20rpx 30rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.order-card {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.orders-page.dark .order-card {
  background: #1A1D28;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.2);
}

.order-card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 24rpx 16rpx;
}

.order-type {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.order-type-icon {
  font-size: 28rpx;
}

.order-type-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.orders-page.dark .order-type-text {
  color: #E8ECF1;
}

.order-status {
  font-size: 24rpx;
  font-weight: 500;
}

.order-card-body {
  padding: 0 24rpx 16rpx;
}

.order-detail-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 0;
}

.detail-label {
  font-size: 26rpx;
  color: #999;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.orders-page.dark .detail-label {
  color: #6B7280;
}

.detail-value {
  font-size: 26rpx;
  color: #333;
  text-align: right;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.orders-page.dark .detail-value {
  color: #E8ECF1;
}

.detail-value.highlight {
  color: #FF6B6B;
  font-weight: 600;
}

.order-card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 24rpx;
  border-top: 1rpx solid #f5f5f5;
}

.orders-page.dark .order-card-footer {
  border-top-color: #2E3348;
}

.order-time {
  font-size: 22rpx;
  color: #bbb;
}

.order-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.order-price {
  font-size: 30rpx;
  font-weight: 600;
  color: #FF6B6B;
}

.cancel-btn {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  color: #999;
  border: 1rpx solid #ddd;
}

.orders-page.dark .cancel-btn {
  color: #6B7280;
  border-color: #4B5563;
}

.view-btn {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  color: #FF6B6B;
  background: #FFE8E8;
}

.orders-page.dark .view-btn {
  background: rgba(255, 138, 138, 0.15);
  color: #FF8A8A;
}

.order-progress {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  border-top: 1rpx solid #f5f5f5;
  gap: 0;
}

.orders-page.dark .order-progress {
  border-top-color: #2E3348;
}

.progress-step {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  flex-shrink: 0;
}

.progress-step .step-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: #ddd;
}

.orders-page.dark .progress-step .step-dot {
  background: #4B5563;
}

.progress-step.active .step-dot {
  background: #FF6B6B;
  box-shadow: 0 0 12rpx rgba(255, 107, 107, 0.4);
}

.progress-step.done .step-dot {
  background: #10B981;
}

.progress-step .step-text {
  font-size: 20rpx;
  color: #999;
}

.orders-page.dark .progress-step .step-text {
  color: #6B7280;
}

.progress-step.active .step-text {
  color: #FF6B6B;
  font-weight: 500;
}

.progress-step.done .step-text {
  color: #10B981;
}

.progress-line {
  flex: 1;
  height: 4rpx;
  background: #eee;
  margin: 0 8rpx;
  transform: translateY(-12rpx);
}

.orders-page.dark .progress-line {
  background: #2E3348;
}

.progress-line.done {
  background: #10B981;
}
