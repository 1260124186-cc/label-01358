<view class="orders-page {{darkMode ? 'dark' : ''}}">
  <view class="tabs">
    <view
      wx:for="{{tabs}}"
      wx:key="value"
      class="tab-item {{currentTab === item.value ? 'active' : ''}}"
      data-tab="{{item.value}}"
      bindtap="onTabChange"
    >
      {{item.label}}
    </view>
  </view>

  <view wx:if="{{orders.length === 0 && !loading}}" class="empty-state">
    <text class="empty-icon">📋</text>
    <text class="empty-text">暂无订单</text>
    <text class="empty-desc">快去下单吧</text>
  </view>

  <view wx:else class="order-list">
    <view
      wx:for="{{orders}}"
      wx:key="id"
      class="order-card"
    >
      <view class="order-card-header" data-item="{{item}}" bindtap="onOrderTap">
        <view class="order-type">
          <text class="order-type-icon">{{item.typeIcon}}</text>
          <text class="order-type-text">{{item.typeText}}</text>
        </view>
        <view class="order-status" style="color: {{item.statusColor}};">
          {{item.statusIcon}} {{item.statusText}}
        </view>
      </view>

      <view class="order-card-body" data-item="{{item}}" bindtap="onOrderTap">
        <view wx:if="{{item.type === 'express'}}" class="order-detail-row">
          <text class="detail-label">快递点</text>
          <text class="detail-value">{{item.pickupPointText}}</text>
        </view>
        <view wx:if="{{item.type === 'express'}}" class="order-detail-row">
          <text class="detail-label">取件码</text>
          <text class="detail-value highlight">{{item.pickupCode}}</text>
        </view>
        <view wx:if="{{item.type === 'print'}}" class="order-detail-row">
          <text class="detail-label">文件</text>
          <text class="detail-value">{{item.fileName}}</text>
        </view>
        <view wx:if="{{item.type === 'print'}}" class="order-detail-row">
          <text class="detail-label">参数</text>
          <text class="detail-value">{{item.colorTypeText}} · {{item.sideTypeText}} · {{item.copies}}份</text>
        </view>
        <view class="order-detail-row">
          <text class="detail-label">送达</text>
          <text class="detail-value">{{item.deliveryAddress || '-'}}</text>
        </view>
      </view>

      <view class="order-card-footer">
        <view class="order-time">{{item.timeText}}</view>
        <view class="order-actions">
          <text class="order-price">{{item.priceText}}</text>
          <view wx:if="{{item.status === 'pending'}}" class="cancel-btn" data-id="{{item.id}}" catchtap="onCancelOrder">
            取消订单
          </view>
          <view class="view-btn" data-item="{{item}}" bindtap="onOrderTap">
            查看详情
          </view>
        </view>
      </view>

      <view wx:if="{{item.type === 'express' && item.status === 'pending'}}" class="order-progress">
        <view class="progress-step active">
          <view class="step-dot"></view>
          <text class="step-text">待接单</text>
        </view>
        <view class="progress-line"></view>
        <view class="progress-step">
          <view class="step-dot"></view>
          <text class="step-text">配送中</text>
        </view>
        <view class="progress-line"></view>
        <view class="progress-step">
          <view class="step-dot"></view>
          <text class="step-text">已送达</text>
        </view>
      </view>
      <view wx:if="{{item.type === 'express' && item.status === 'processing'}}" class="order-progress">
        <view class="progress-step done">
          <view class="step-dot"></view>
          <text class="step-text">待接单</text>
        </view>
        <view class="progress-line done"></view>
        <view class="progress-step active">
          <view class="step-dot"></view>
          <text class="step-text">配送中</text>
        </view>
        <view class="progress-line"></view>
        <view class="progress-step">
          <view class="step-dot"></view>
          <text class="step-text">已送达</text>
        </view>
      </view>
      <view wx:if="{{item.type === 'express' && item.status === 'completed'}}" class="order-progress">
        <view class="progress-step done">
          <view class="step-dot"></view>
          <text class="step-text">待接单</text>
        </view>
        <view class="progress-line done"></view>
        <view class="progress-step done">
          <view class="step-dot"></view>
          <text class="step-text">配送中</text>
        </view>
        <view class="progress-line done"></view>
        <view class="progress-step done">
          <view class="step-dot"></view>
          <text class="step-text">已送达</text>
        </view>
      </view>
    </view>
  </view>
</view>
