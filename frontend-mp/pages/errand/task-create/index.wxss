.task-create-page {
  min-height: 100vh;
  background: #f8f9fa;
  padding-bottom: 140rpx;
}

.task-create-page.dark {
  background: #0F1117;
}

.type-selector {
  padding: 30rpx 30rpx 10rpx;
}

.type-scroll {
  white-space: nowrap;
}

.type-list {
  display: flex;
}

.type-list > * { margin-right: 20rpx; }

.type-list > *:last-child { margin-right: 0; }

.type-card {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 28rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  border: 3rpx solid transparent;
  transition: all 0.2s;
  flex-shrink: 0;
}

.type-card > * { margin-bottom: 10rpx; }

.type-card > *:last-child { margin-bottom: 0; }

.task-create-page.dark .type-card {
  background: #1A1D28;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.2);
}

.type-card.active {
  border-color: #FF6B6B;
  background: #FFF5F5;
  transform: scale(1.02);
}

.task-create-page.dark .type-card.active {
  border-color: #FF8A8A;
  background: rgba(255, 138, 138, 0.1);
}

.type-card-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.type-icon-text {
  font-size: 36rpx;
}

.type-card-label {
  font-size: 24rpx;
  color: #666;
  font-weight: 500;
}

.task-create-page.dark .type-card-label {
  color: #9CA3AF;
}

.type-card.active .type-card-label {
  color: #FF6B6B;
  font-weight: 600;
}

.task-create-page.dark .type-card.active .type-card-label {
  color: #FF8A8A;
}

.form-section {
  padding: 20rpx 30rpx;
}

.type-fields {
  margin-bottom: 0;
}

.form-group {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.task-create-page.dark .form-group {
  background: #1A1D28;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.2);
}

.form-label {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.form-label > * { margin-right: 8rpx; }

.form-label > *:last-child { margin-right: 0; }

.label-icon {
  font-size: 28rpx;
}

.label-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.task-create-page.dark .label-text {
  color: #E8ECF1;
}

.label-required {
  color: #FF6B6B;
  font-size: 28rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #333;
}

.task-create-page.dark .form-input {
  background: #262A3A;
  color: #E8ECF1;
}

.input-placeholder {
  color: #bbb;
}

.form-textarea {
  width: 100%;
  min-height: 160rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  color: #333;
}

.task-create-page.dark .form-textarea {
  background: #262A3A;
  color: #E8ECF1;
}

.form-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 80rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 20rpx;
}

.task-create-page.dark .form-picker {
  background: #262A3A;
}

.picker-value {
  font-size: 28rpx;
  color: #333;
}

.task-create-page.dark .picker-value {
  color: #E8ECF1;
}

.picker-value.placeholder {
  color: #bbb;
}

.picker-arrow {
  font-size: 32rpx;
  color: #ccc;
}

.bounty-options {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 16rpx;
}

.bounty-options { margin-right: -16rpx; margin-bottom: -16rpx; }

.bounty-options > * { margin-right: 16rpx; margin-bottom: 16rpx; }

.bounty-item {
  padding: 12rpx 28rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #666;
  background: #f5f5f5;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.task-create-page.dark .bounty-item {
  background: #262A3A;
  color: #9CA3AF;
}

.bounty-item.active {
  color: #FF6B6B;
  background: #FFE8E8;
  border-color: #FF6B6B;
}

.task-create-page.dark .bounty-item.active {
  background: rgba(255, 138, 138, 0.15);
  border-color: #FF8A8A;
  color: #FF8A8A;
}

.bounty-input {
  margin-top: 0;
}

.deadline-row {
  display: flex;
}

.deadline-row > * { margin-right: 16rpx; }

.deadline-row > *:last-child { margin-right: 0; }

.deadline-picker {
  flex: 1;
}

.flex-1 {
  flex: 1;
}

.address-row {
  display: flex;
  align-items: center;
}

.address-row > * { margin-right: 16rpx; }

.address-row > *:last-child { margin-right: 0; }

.address-book-btn {
  padding: 0 24rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #FFE8E8;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.task-create-page.dark .address-book-btn {
  background: rgba(255, 138, 138, 0.15);
}

.address-book-text {
  font-size: 26rpx;
  color: #FF6B6B;
  font-weight: 500;
}

.submit-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.06);
  z-index: 100;
}

.task-create-page.dark .submit-bar {
  background: #1A1D28;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.3);
}

.submit-info {
  display: flex;
  flex-direction: column;
}

.submit-info > * { margin-bottom: 4rpx; }

.submit-info > *:last-child { margin-bottom: 0; }

.submit-escrow {
  font-size: 22rpx;
  color: #999;
}

.task-create-page.dark .submit-escrow {
  color: #6B7280;
}

.submit-price {
  font-size: 36rpx;
  font-weight: 700;
  color: #FF6B6B;
}

.submit-btn {
  padding: 20rpx 60rpx;
  background: linear-gradient(135deg, #FF6B6B, #FF8E8E);
  border-radius: 40rpx;
}

.submit-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
}

.picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 200;
  display: none;
}

.picker-mask.show {
  display: block;
}

.picker-panel {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  max-height: 70vh;
  background: #fff;
  border-radius: 30rpx 30rpx 0 0;
  padding-bottom: env(safe-area-inset-bottom);
  transform: translateY(100%);
  transition: transform 0.3s ease;
  z-index: 201;
}

.picker-panel.show {
  transform: translateY(0);
}

.task-create-page.dark .picker-panel {
  background: #1A1D28;
}

.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.task-create-page.dark .picker-header {
  border-bottom-color: #2E3348;
}

.picker-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.task-create-page.dark .picker-title {
  color: #E8ECF1;
}

.picker-close {
  font-size: 32rpx;
  color: #999;
  padding: 10rpx;
}

.picker-list {
  padding: 20rpx 30rpx;
  max-height: 60vh;
  overflow-y: auto;
}

.picker-item {
  display: flex;
  align-items: center;
  padding: 24rpx 20rpx;
  border-radius: 12rpx;
  transition: background 0.2s;
}

.picker-item > * { margin-right: 16rpx; }

.picker-item > *:last-child { margin-right: 0; }

.picker-item:active {
  background: #f5f5f5;
}

.task-create-page.dark .picker-item:active {
  background: #262A3A;
}

.picker-item.active {
  background: #FFE8E8;
}

.task-create-page.dark .picker-item.active {
  background: rgba(255, 138, 138, 0.15);
}

.picker-item-icon {
  font-size: 36rpx;
}

.picker-item-text {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.task-create-page.dark .picker-item-text {
  color: #E8ECF1;
}

.picker-item-check {
  font-size: 32rpx;
  color: #FF6B6B;
  font-weight: 600;
}
