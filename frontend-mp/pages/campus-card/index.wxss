.page {
  min-height: 100vh;
  background-color: var(--color-bg-page, #F8F9FA);
}

.content {
  padding: 24rpx;
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
}

/* ========== 未绑卡提示 ========== */
.unbind-section {
  padding: 48rpx 0;
}

.unbind-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 64rpx 48rpx;
  background: linear-gradient(135deg, #FFFFFF 0%, #FAFBFC 100%);
  border-radius: 32rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.unbind-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
}

.unbind-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--color-text-primary, #2C3E50);
  margin-bottom: 16rpx;
}

.unbind-desc {
  font-size: 28rpx;
  color: var(--color-text-muted, #86909C);
  margin-bottom: 48rpx;
}

.bind-btn {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  padding: 24rpx 96rpx;
  border-radius: 48rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 107, 0.3);
}

.bind-btn-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #FFFFFF;
}

/* ========== 卡片余额 ========== */
.card-section {
  margin-bottom: 32rpx;
}

.card-balance {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 50%, #FFA8A8 100%);
  border-radius: 32rpx;
  padding: 40rpx 32rpx;
  box-shadow: 0 12rpx 40rpx rgba(255, 107, 107, 0.25);
}

.balance-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.balance-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

.card-status {
  display: flex;
  align-items: center;
  padding: 6rpx 16rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.2);
}

.card-status.normal {
  background: rgba(72, 187, 120, 0.3);
}

.status-icon {
  font-size: 20rpx;
  color: #FFFFFF;
  margin-right: 6rpx;
}

.status-text {
  font-size: 22rpx;
  color: #FFFFFF;
  font-weight: 500;
}

.balance-amount {
  display: flex;
  align-items: baseline;
  margin-bottom: 24rpx;
}

.balance-currency {
  font-size: 36rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-right: 8rpx;
}

.balance-number {
  font-size: 72rpx;
  font-weight: 700;
  color: #FFFFFF;
  letter-spacing: 2rpx;
}

.balance-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding: 20rpx 24rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 16rpx;
  margin-bottom: 28rpx;
}

.info-item {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

.balance-actions {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 0;
  border-radius: 48rpx;
  transition: all 0.2s ease;
}

.action-btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.action-btn.primary {
  background: #FFFFFF;
}

.action-btn.secondary {
  background: rgba(255, 255, 255, 0.25);
}

.action-btn-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.action-btn.primary .action-btn-text {
  color: #FF6B6B;
  font-size: 28rpx;
  font-weight: 600;
}

.action-btn.secondary .action-btn-text {
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 500;
}

/* ========== 通用 section 标题 ========== */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--color-text-primary, #2C3E50);
}

.section-more {
  display: flex;
  align-items: center;
}

.more-text {
  font-size: 26rpx;
  color: var(--color-text-secondary, #4E5969);
}

.more-arrow {
  font-size: 28rpx;
  color: var(--color-text-muted, #86909C);
  margin-left: 4rpx;
}

/* ========== 快捷功能 ========== */
.quick-section {
  margin-bottom: 32rpx;
}

.quick-grid {
  display: flex;
  flex-wrap: wrap;
  background: linear-gradient(135deg, #FFFFFF 0%, #FAFBFC 100%);
  border-radius: 24rpx;
  padding: 32rpx 0;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.quick-item {
  width: 33.33%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
  transition: all 0.2s ease;
}

.quick-item-hover {
  transform: scale(0.95);
  opacity: 0.85;
}

.quick-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}

.quick-icon-text {
  font-size: 40rpx;
}

.quick-name {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--color-text-primary, #2C3E50);
}

/* ========== 最近消费 ========== */
.recent-section {
  margin-bottom: 32rpx;
}

.recent-list {
  background: linear-gradient(135deg, #FFFFFF 0%, #FAFBFC 100%);
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.recent-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  transition: all 0.2s ease;
}

.recent-item:not(:last-child) {
  border-bottom: 1rpx solid var(--color-border-light, #F2F3F5);
}

.recent-item-hover {
  background-color: var(--color-bg-page, #F8F9FA);
}

.recent-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
  font-size: 32rpx;
}

.recent-icon.category-canteen {
  background: linear-gradient(135deg, #FEF3C7 0%, #FDE68A 100%);
}

.recent-icon.category-supermarket {
  background: linear-gradient(135deg, #DBEAFE 0%, #BFDBFE 100%);
}

.recent-icon.category-bathroom {
  background: linear-gradient(135deg, #CFFAFE 0%, #A5F3FC 100%);
}

.recent-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.recent-merchant {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--color-text-primary, #2C3E50);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.recent-category {
  font-size: 24rpx;
  color: var(--color-text-muted, #86909C);
}

.recent-amount {
  margin-left: 16rpx;
  flex-shrink: 0;
}

.amount-text.consume {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary, #2C3E50);
}

.amount-text.recharge {
  font-size: 30rpx;
  font-weight: 600;
  color: #48BB78;
}

/* ========== 温馨提示 ========== */
.tips-section {
  margin-bottom: 32rpx;
}

.tips-card {
  display: flex;
  align-items: flex-start;
  padding: 24rpx;
  background: linear-gradient(135deg, #FFF7ED 0%, #FFEDD5 100%);
  border-radius: 20rpx;
}

.tips-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.tips-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.tips-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #C2410C;
}

.tips-text {
  font-size: 24rpx;
  color: #9A3412;
  line-height: 1.5;
}

.bottom-space {
  height: 48rpx;
}

/* ========== 暗色模式 ========== */
.dark .unbind-card {
  background: linear-gradient(135deg, #1F2937 0%, #111827 100%);
}

.dark .quick-grid,
.dark .recent-list {
  background: linear-gradient(135deg, #1F2937 0%, #111827 100%);
}

.dark .recent-item:not(:last-child) {
  border-bottom-color: #374151;
}

.dark .recent-item-hover {
  background-color: #374151;
}
