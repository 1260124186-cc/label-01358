.page {
  min-height: 100vh;
  background-color: var(--color-bg-page, #F8F9FA);
  display: flex;
  flex-direction: column;
}

/* ========== 搜索框 ========== */
.search-section {
  padding: 20rpx 24rpx;
  background: var(--color-bg-card, #FFFFFF);
  border-bottom: 1rpx solid var(--color-border-light, #F2F3F5);
}

.search-box {
  display: flex;
  align-items: center;
  background: var(--color-bg-input, #F7F8FA);
  border-radius: 40rpx;
  padding: 0 24rpx;
  height: 72rpx;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--color-text-primary, #2C3E50);
}

.search-placeholder {
  color: var(--color-text-muted, #C9CDD4);
}

/* ========== 筛选标签 ========== */
.filter-section {
  padding: 16rpx 0;
  background: var(--color-bg-card, #FFFFFF);
  border-bottom: 1rpx solid var(--color-border-light, #F2F3F5);
}

.filter-scroll {
  white-space: nowrap;
}

.filter-list {
  display: inline-flex;
  padding: 0 24rpx;
  gap: 16rpx;
}

.filter-item {
  display: inline-flex;
  align-items: center;
  padding: 14rpx 24rpx;
  background: var(--color-bg-input, #F7F8FA);
  border-radius: 32rpx;
  transition: all 0.2s ease;
}

.filter-item-hover {
  opacity: 0.8;
}

.filter-item.active {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
}

.filter-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
}

.filter-text {
  font-size: 26rpx;
  color: var(--color-text-secondary, #4E5969);
  font-weight: 500;
}

.filter-item.active .filter-text {
  color: #FFFFFF;
}

/* ========== 地图 ========== */
.map-section {
  width: 100%;
  height: 420rpx;
  flex-shrink: 0;
}

.map-view {
  width: 100%;
  height: 100%;
}

/* ========== 列表 ========== */
.list-section {
  flex: 1;
  padding: 24rpx;
  overflow-y: auto;
}

.section-header {
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text-primary, #2C3E50);
}

.point-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.point-card {
  display: flex;
  background: linear-gradient(135deg, #FFFFFF 0%, #FAFBFC 100%);
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
  transition: all 0.2s ease;
}

.point-card-hover {
  transform: translateY(-2rpx);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
}

.point-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.point-icon.type-service {
  background: linear-gradient(135deg, #FEF3C7 0%, #FDE68A 100%);
}

.point-icon.type-cash {
  background: linear-gradient(135deg, #DCFCE7 0%, #BBF7D0 100%);
}

.point-icon.type-self {
  background: linear-gradient(135deg, #DBEAFE 0%, #BFDBFE 100%);
}

.point-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  min-width: 0;
}

.point-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.point-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary, #2C3E50);
}

.point-type-tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 12rpx;
  background: linear-gradient(135deg, #FEE2E2 0%, #FECACA 100%);
  border-radius: 12rpx;
}

.tag-text {
  font-size: 20rpx;
  color: #DC2626;
  font-weight: 500;
}

.point-address {
  font-size: 24rpx;
  color: var(--color-text-secondary, #4E5969);
}

.point-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.point-time {
  font-size: 22rpx;
  color: var(--color-text-muted, #86909C);
}

.point-services {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 4rpx;
}

.service-tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  background: var(--color-bg-input, #F7F8FA);
  color: var(--color-text-secondary, #4E5969);
  border-radius: 8rpx;
}

/* ========== 详情弹窗 ========== */
.detail-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  animation: fadeIn 0.2s ease;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.detail-content {
  width: 100%;
  max-height: 80vh;
  background: var(--color-bg-card, #FFFFFF);
  border-radius: 32rpx 32rpx 0 0;
  display: flex;
  flex-direction: column;
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.detail-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 32rpx 24rpx;
  border-bottom: 1rpx solid var(--color-border-light, #F2F3F5);
}

.detail-title-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
}

.detail-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}

.detail-icon.type-service {
  background: linear-gradient(135deg, #FEF3C7 0%, #FDE68A 100%);
}

.detail-icon.type-cash {
  background: linear-gradient(135deg, #DCFCE7 0%, #BBF7D0 100%);
}

.detail-icon.type-self {
  background: linear-gradient(135deg, #DBEAFE 0%, #BFDBFE 100%);
}

.detail-title-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.detail-name {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--color-text-primary, #2C3E50);
}

.detail-type {
  font-size: 24rpx;
  color: var(--color-text-secondary, #4E5969);
}

.detail-close {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: var(--color-bg-input, #F7F8FA);
  display: flex;
  align-items: center;
  justify-content: center;
}

.close-icon {
  font-size: 28rpx;
  color: var(--color-text-muted, #86909C);
}

.detail-body {
  flex: 1;
  overflow-y: auto;
  padding: 24rpx 32rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.detail-item {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.detail-item-label {
  font-size: 26rpx;
  color: var(--color-text-muted, #86909C);
  font-weight: 500;
}

.detail-item-value {
  font-size: 28rpx;
  color: var(--color-text-primary, #2C3E50);
  line-height: 1.5;
}

.detail-item-value.link {
  color: #FF6B6B;
  text-decoration: underline;
}

.detail-services {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.detail-service-tag {
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  background: linear-gradient(135deg, #FEE2E2 0%, #FECACA 100%);
  color: #DC2626;
  border-radius: 12rpx;
  font-weight: 500;
}

.detail-actions {
  display: flex;
  gap: 16rpx;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid var(--color-border-light, #F2F3F5);
}

.detail-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  transition: all 0.2s ease;
}

.detail-btn.secondary {
  background: var(--color-bg-input, #F7F8FA);
}

.detail-btn.primary {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
}

.btn-icon {
  font-size: 28rpx;
}

.btn-text {
  font-size: 28rpx;
  font-weight: 600;
}

.detail-btn.secondary .btn-text {
  color: var(--color-text-primary, #2C3E50);
}

.detail-btn.primary .btn-text {
  color: #FFFFFF;
}

.bottom-space {
  height: 24rpx;
}

/* ========== 暗色模式 ========== */
.dark .search-section,
.dark .filter-section,
.dark .detail-content {
  background: #1F2937;
}

.dark .filter-section {
  border-bottom-color: #374151;
}

.dark .search-section {
  border-bottom-color: #374151;
}

.dark .filter-item {
  background: #374151;
}

.dark .filter-text {
  color: #E5E7EB;
}

.dark .point-card {
  background: linear-gradient(135deg, #1F2937 0%, #111827 100%);
}

.dark .service-tag {
  background: #374151;
}

.dark .detail-header,
.dark .detail-actions {
  border-bottom-color: #374151;
  border-top-color: #374151;
}

.dark .detail-close,
.dark .detail-btn.secondary {
  background: #374151;
}

.dark .detail-service-tag {
  background: linear-gradient(135deg, #7F1D1D 0%, #991B1B 100%);
  color: #FCA5A5;
}

.dark .point-type-tag {
  background: linear-gradient(135deg, #7F1D1D 0%, #991B1B 100%);
}

.dark .tag-text {
  color: #FCA5A5;
}
