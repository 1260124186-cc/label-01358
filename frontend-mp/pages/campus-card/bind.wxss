.page {
  min-height: 100vh;
  background-color: var(--color-bg-page, #F8F9FA);
}

.content {
  padding: 32rpx 24rpx;
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
}

/* ========== 头部 ========== */
.header-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 0 64rpx;
}

.header-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-text-primary, #2C3E50);
  margin-bottom: 12rpx;
}

.header-desc {
  font-size: 26rpx;
  color: var(--color-text-muted, #86909C);
}

/* ========== 表单 ========== */
.form-section {
  margin-bottom: 32rpx;
}

.form-card {
  background: linear-gradient(135deg, #FFFFFF 0%, #FAFBFC 100%);
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.form-item {
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid var(--color-border-light, #F2F3F5);
}

.form-item:last-child {
  border-bottom: none;
}

.form-label {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.required {
  color: #FF6B6B;
  font-size: 28rpx;
  margin-right: 6rpx;
}

.label-text {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--color-text-primary, #2C3E50);
}

.form-input-wrap {
  display: flex;
  align-items: center;
}

.form-input {
  flex: 1;
  height: 72rpx;
  font-size: 28rpx;
  color: var(--color-text-primary, #2C3E50);
  background-color: var(--color-bg-input, #F7F8FA);
  border-radius: 12rpx;
  padding: 0 24rpx;
}

.input-placeholder {
  color: var(--color-text-muted, #C9CDD4);
}

.scan-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 16rpx;
  background-color: var(--color-bg-input, #F7F8FA);
  border-radius: 12rpx;
}

.scan-icon {
  font-size: 32rpx;
}

/* ========== 协议勾选 ========== */
.terms-section {
  margin-bottom: 40rpx;
  padding: 0 8rpx;
}

.terms-check {
  display: flex;
  align-items: flex-start;
}

.check-box {
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid var(--color-border, #C9CDD4);
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12rpx;
  margin-top: 4rpx;
  flex-shrink: 0;
  transition: all 0.2s ease;
}

.check-box.checked {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  border-color: #FF6B6B;
}

.check-icon {
  font-size: 22rpx;
  color: #FFFFFF;
  font-weight: 700;
}

.terms-text {
  font-size: 24rpx;
  color: var(--color-text-secondary, #4E5969);
  line-height: 1.6;
}

.terms-link {
  color: #FF6B6B;
}

/* ========== 提交按钮 ========== */
.submit-section {
  margin-bottom: 32rpx;
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  border-radius: 48rpx;
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 107, 0.3);
  border: none;
}

.submit-btn::after {
  border: none;
}

.submit-btn.disabled {
  opacity: 0.6;
  box-shadow: none;
}

/* ========== 提示信息 ========== */
.tips-section {
  margin-bottom: 32rpx;
}

.tips-card {
  display: flex;
  flex-direction: column;
  padding: 24rpx;
  background: linear-gradient(135deg, #EFF6FF 0%, #DBEAFE 100%);
  border-radius: 20rpx;
}

.tips-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #1E40AF;
  margin-bottom: 8rpx;
}

.tips-text {
  font-size: 24rpx;
  color: #1E3A8A;
  line-height: 1.5;
}

.bottom-space {
  height: 48rpx;
}

/* ========== 暗色模式 ========== */
.dark .form-card {
  background: linear-gradient(135deg, #1F2937 0%, #111827 100%);
}

.dark .form-item {
  border-bottom-color: #374151;
}

.dark .form-input {
  background-color: #374151;
}

.dark .scan-btn {
  background-color: #374151;
}

.dark .tips-card {
  background: linear-gradient(135deg, #1E3A8A 0%, #1E40AF 100%);
}

.dark .tips-title {
  color: #BFDBFE;
}

.dark .tips-text {
  color: #93C5FD;
}
