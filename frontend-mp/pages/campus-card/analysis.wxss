.page {
  min-height: 100vh;
  background-color: var(--color-bg-page, #F8F9FA);
}

.content {
  padding: 24rpx;
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
}

/* ========== 头部 ========== */
.header-section {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 50%, #FFA8A8 100%);
  border-radius: 28rpx;
  padding: 40rpx 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 12rpx 40rpx rgba(255, 107, 107, 0.25);
}

.header-title {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  display: block;
  margin-bottom: 16rpx;
}

.header-amount-wrap {
  display: flex;
  flex-direction: column;
}

.amount-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 8rpx;
}

.amount-value-wrap {
  display: flex;
  align-items: baseline;
}

.amount-currency {
  font-size: 36rpx;
  color: #FFFFFF;
  font-weight: 600;
  margin-right: 8rpx;
}

.amount-value {
  font-size: 72rpx;
  color: #FFFFFF;
  font-weight: 700;
  letter-spacing: 2rpx;
}

/* ========== 分类统计 ========== */
.stats-section {
  margin-bottom: 24rpx;
}

.stats-card {
  background: linear-gradient(135deg, #FFFFFF 0%, #FAFBFC 100%);
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.stats-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
}

.stats-item:not(:last-child) {
  border-bottom: 1rpx solid var(--color-border-light, #F2F3F5);
}

.stats-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  font-size: 32rpx;
}

.stats-icon.canteen {
  background: linear-gradient(135deg, #FEF3C7 0%, #FDE68A 100%);
}

.stats-icon.supermarket {
  background: linear-gradient(135deg, #DBEAFE 0%, #BFDBFE 100%);
}

.stats-icon.bathroom {
  background: linear-gradient(135deg, #CFFAFE 0%, #A5F3FC 100%);
}

.stats-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.stats-label {
  font-size: 26rpx;
  color: var(--color-text-secondary, #4E5969);
}

.stats-value-wrap {
  display: flex;
  align-items: baseline;
}

.stats-currency {
  font-size: 24rpx;
  color: var(--color-text-primary, #2C3E50);
  font-weight: 500;
  margin-right: 4rpx;
}

.stats-value {
  font-size: 36rpx;
  color: var(--color-text-primary, #2C3E50);
  font-weight: 700;
}

/* ========== 通用 section 标题 ========== */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--color-text-primary, #2C3E50);
}

/* ========== 饼图区域 ========== */
.pie-section {
  margin-bottom: 24rpx;
}

.pie-card {
  background: linear-gradient(135deg, #FFFFFF 0%, #FAFBFC 100%);
  border-radius: 24rpx;
  padding: 32rpx 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.pie-container {
  display: flex;
  justify-content: center;
  margin-bottom: 32rpx;
}

.pie-chart {
  width: 360rpx;
  height: 360rpx;
  border-radius: 50%;
  position: relative;
  overflow: hidden;
}

.pie-slice {
  position: absolute;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  top: 0;
  left: 0;
}

.pie-cover {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FFFFFF 0%, #FAFBFC 100%);
}

.pie-center {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.pie-center-value {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-text-primary, #2C3E50);
}

.pie-center-label {
  font-size: 22rpx;
  color: var(--color-text-muted, #86909C);
  margin-top: 4rpx;
}

.pie-legend {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  border-radius: 16rpx;
  background: var(--color-bg-input, #F7F8FA);
  transition: all 0.2s ease;
}

.legend-item-hover {
  background: var(--color-bg-page, #F8F9FA);
  opacity: 0.8;
}

.legend-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 6rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.legend-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.legend-name-row {
  display: flex;
  align-items: center;
}

.legend-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
}

.legend-name {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--color-text-primary, #2C3E50);
}

.legend-percent {
  font-size: 22rpx;
  color: var(--color-text-muted, #86909C);
}

.legend-amount {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary, #2C3E50);
}

/* ========== 趋势图 ========== */
.trend-section {
  margin-bottom: 24rpx;
}

.trend-card {
  background: linear-gradient(135deg, #FFFFFF 0%, #FAFBFC 100%);
  border-radius: 24rpx;
  padding: 32rpx 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.trend-chart {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  height: 280rpx;
  padding-top: 40rpx;
}

.trend-bar-wrap {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  height: 100%;
  padding: 0 6rpx;
}

.trend-bar {
  width: 100%;
  min-height: 20rpx;
  max-width: 60rpx;
  background: linear-gradient(180deg, #FF6B6B 0%, #FF8E8E 100%);
  border-radius: 12rpx 12rpx 4rpx 4rpx;
  position: relative;
  transition: height 0.3s ease;
  margin-top: auto;
}

.trend-bar-value {
  position: absolute;
  top: -36rpx;
  left: 50%;
  transform: translateX(-50%);
  font-size: 20rpx;
  color: var(--color-text-muted, #86909C);
  white-space: nowrap;
}

.trend-date {
  font-size: 20rpx;
  color: var(--color-text-muted, #86909C);
  margin-top: 12rpx;
}

/* ========== 周统计 ========== */
.week-section {
  margin-bottom: 24rpx;
}

.week-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.week-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  background: linear-gradient(135deg, #FFFFFF 0%, #FAFBFC 100%);
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.week-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.week-label {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--color-text-primary, #2C3E50);
}

.week-count {
  font-size: 22rpx;
  color: var(--color-text-muted, #86909C);
}

.week-amount {
  display: flex;
  align-items: baseline;
}

.week-amount-currency {
  font-size: 24rpx;
  color: var(--color-text-primary, #2C3E50);
  font-weight: 500;
  margin-right: 4rpx;
}

.week-amount-value {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-text-primary, #2C3E50);
}

/* ========== 提示 ========== */
.tips-section {
  margin-bottom: 32rpx;
}

.tips-card {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  background: linear-gradient(135deg, #F3F4F6 0%, #E5E7EB 100%);
  border-radius: 16rpx;
}

.tips-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.tips-text {
  font-size: 24rpx;
  color: var(--color-text-secondary, #4E5969);
}

.bottom-space {
  height: 48rpx;
}

/* ========== 暗色模式 ========== */
.dark .stats-card,
.dark .pie-card,
.dark .trend-card,
.dark .week-card {
  background: linear-gradient(135deg, #1F2937 0%, #111827 100%);
}

.dark .stats-item:not(:last-child) {
  border-bottom-color: #374151;
}

.dark .legend-item {
  background: #374151;
}

.dark .legend-item-hover {
  background: #4B5563;
}

.dark .pie-cover {
  background: linear-gradient(135deg, #1F2937 0%, #111827 100%);
}

.dark .tips-card {
  background: linear-gradient(135deg, #374151 0%, #1F2937 100%);
}
