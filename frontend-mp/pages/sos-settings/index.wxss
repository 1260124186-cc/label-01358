.page {
  min-height: 100vh;
  padding: 30rpx;
}

.settings-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  margin-bottom: 30rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #2C3E50;
  padding: 24rpx;
  border-bottom: 1rpx solid #F3F4F6;
}

.setting-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid #F3F4F6;
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-info {
  display: flex;
  align-items: center;
  flex: 1;
}

.setting-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.setting-text {
  flex: 1;
}

.setting-name {
  font-size: 28rpx;
  color: #2C3E50;
  display: block;
  margin-bottom: 4rpx;
}

.setting-desc {
  font-size: 24rpx;
  color: #6B7280;
}

.link-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid #F3F4F6;
}

.link-item:last-child {
  border-bottom: none;
}

.link-info {
  display: flex;
  align-items: center;
}

.link-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.link-name {
  font-size: 28rpx;
  color: #2C3E50;
}

.link-arrow {
  font-size: 32rpx;
  color: #9CA3AF;
}

.history-item {
  display: flex;
  align-items: flex-start;
  padding: 24rpx;
  border-bottom: 1rpx solid #F3F4F6;
}

.history-status {
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.history-status text {
  font-size: 22rpx;
  font-weight: 500;
}

.history-info {
  flex: 1;
}

.history-location {
  font-size: 26rpx;
  margin-bottom: 8rpx;
}

.history-label {
  color: #6B7280;
}

.history-value {
  color: #2C3E50;
}

.history-time {
  font-size: 24rpx;
  color: #9CA3AF;
}

.view-all {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  border-top: 1rpx solid #F3F4F6;
}

.view-all text {
  font-size: 26rpx;
  color: #FF6B6B;
}

.view-arrow {
  margin-left: 8rpx;
}

.danger-zone {
  background: #FEF2F2;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-top: 20rpx;
}

.danger-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #DC2626;
  margin-bottom: 12rpx;
}

.danger-text {
  font-size: 24rpx;
  color: #B91C1C;
  line-height: 1.6;
}

.page.dark .settings-card {
  background: #1F2937;
}

.page.dark .card-title,
.page.dark .setting-name,
.page.dark .link-name,
.page.dark .history-value {
  color: #E8ECF1;
}

.page.dark .setting-item,
.page.dark .link-item,
.page.dark .history-item,
.page.dark .view-all {
  border-bottom-color: #374151;
  border-top-color: #374151;
}

.page.dark .card-title {
  border-bottom-color: #374151;
}

.page.dark .danger-zone {
  background: rgba(220, 38, 38, 0.1);
}

.page.dark .danger-title {
  color: #FCA5A5;
}

.page.dark .danger-text {
  color: #FECACA;
}
