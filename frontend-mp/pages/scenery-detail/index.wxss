.page {
  min-height: 100vh;
  background-color: var(--color-bg-page);
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.image-section {
  position: relative;
  width: 100%;
  height: 600rpx;
}

.main-image {
  width: 100%;
  height: 100%;
}

.image-overlay {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 70%;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.8) 0%, rgba(0, 0, 0, 0.4) 50%, transparent 100%);
  pointer-events: none;
}

.image-info {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 120rpx;
  padding: 0 32rpx;
}

.title-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.title {
  font-size: 44rpx;
  font-weight: 700;
  color: #FFFFFF;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
  flex: 1;
}

.category-tag {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 16rpx;
  background: rgba(255, 255, 255, 0.25);
  backdrop-filter: blur(10rpx);
  border-radius: var(--radius-full);
}

.tag-icon {
  font-size: 24rpx;
}

.tag-text {
  font-size: 24rpx;
  color: #FFFFFF;
  font-weight: 500;
}

.meta-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
  flex-wrap: wrap;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.meta-icon {
  font-size: 24rpx;
}

.meta-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

.uploader-info {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx 32rpx;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.6) 0%, transparent 100%);
}

.uploader-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
}

.uploader-text {
  display: flex;
  flex-direction: column;
}

.uploader-name {
  font-size: 28rpx;
  color: #FFFFFF;
  font-weight: 500;
}

.upload-time {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
}

.description-section {
  padding: 32rpx;
  background-color: var(--color-bg-card);
  margin: 24rpx;
  border-radius: var(--radius-2xl);
  box-shadow: var(--shadow-card);
}

.description {
  font-size: 30rpx;
  color: var(--color-text-primary);
  line-height: 1.8;
}

.stats-section {
  display: flex;
  align-items: center;
  justify-content: space-around;
  margin: 0 24rpx;
  padding: 32rpx 0;
  background-color: var(--color-bg-card);
  border-radius: var(--radius-2xl);
  box-shadow: var(--shadow-card);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  transition: transform 0.2s ease;
}

.stat-item:active {
  transform: scale(0.95);
}

.stat-item.liked .stat-icon {
  animation: heartBeat 0.3s ease;
}

@keyframes heartBeat {
  0% { transform: scale(1); }
  50% { transform: scale(1.3); }
  100% { transform: scale(1); }
}

.stat-icon {
  font-size: 40rpx;
}

.stat-value {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

.stat-label {
  font-size: 24rpx;
  color: var(--color-text-muted);
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background-color: var(--color-border);
}

.comments-section {
  margin: 24rpx;
  padding: 32rpx;
  background-color: var(--color-bg-card);
  border-radius: var(--radius-2xl);
  box-shadow: var(--shadow-card);
}

.section-header {
  margin-bottom: 24rpx;
}

.section-title-wrap {
  display: flex;
  align-items: center;
}

.section-icon {
  width: 8rpx;
  height: 32rpx;
  background: linear-gradient(180deg, var(--color-primary) 0%, #FF8E8E 100%);
  border-radius: 4rpx;
  margin-right: 12rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

.comment-input-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 32rpx;
  padding: 16rpx;
  background-color: var(--color-bg-page);
  border-radius: var(--radius-xl);
}

.comment-input {
  flex: 1;
  height: 72rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: var(--color-text-primary);
}

.send-btn {
  padding: 16rpx 32rpx;
  background-color: var(--color-border);
  border-radius: var(--radius-lg);
  font-size: 28rpx;
  color: var(--color-text-muted);
  transition: all 0.2s ease;
}

.send-btn.active {
  background: linear-gradient(135deg, var(--color-primary) 0%, #FF8E8E 100%);
  color: #FFFFFF;
}

.send-btn:active {
  transform: scale(0.96);
}

.comments-list {
  max-height: 800rpx;
  overflow-y: auto;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: var(--color-text-muted);
}

.comment-item {
  display: flex;
  gap: 20rpx;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--color-border);
}

.comment-item:last-child {
  border-bottom: none;
}

.comment-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.comment-content {
  flex: 1;
  min-width: 0;
}

.comment-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.comment-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.comment-time {
  font-size: 22rpx;
  color: var(--color-text-muted);
}

.comment-text {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  line-height: 1.6;
  margin-bottom: 16rpx;
  word-break: break-all;
}

.comment-actions {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.comment-like {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 6rpx 12rpx;
  border-radius: var(--radius-sm);
  transition: background-color 0.2s ease;
}

.comment-like:active {
  background-color: var(--color-bg-page);
}

.like-icon {
  font-size: 24rpx;
}

.like-count {
  font-size: 24rpx;
  color: var(--color-text-muted);
}

.map-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.map-content {
  width: 90%;
  max-width: 680rpx;
  background-color: var(--color-bg-card);
  border-radius: var(--radius-2xl);
  overflow: hidden;
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from { transform: translateY(100rpx); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

.map-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid var(--color-border);
}

.map-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.close-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: var(--color-bg-page);
  border-radius: 50%;
  font-size: 28rpx;
  color: var(--color-text-muted);
}

.map-container {
  width: 100%;
  height: 500rpx;
}

.map-actions {
  padding: 24rpx 32rpx;
  border-top: 1rpx solid var(--color-border);
}

.map-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, var(--color-primary) 0%, #FF8E8E 100%);
  border-radius: var(--radius-xl);
  transition: transform 0.2s ease;
}

.map-btn:active {
  transform: scale(0.98);
}

.btn-icon {
  font-size: 32rpx;
}

.btn-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.bottom-spacing {
  height: 40rpx;
}

.page.dark .send-btn {
  background-color: rgba(255, 255, 255, 0.1);
}

.page.dark .send-btn.active {
  background: linear-gradient(135deg, var(--color-primary) 0%, #FF8E8E 100%);
}

.page.dark .comment-input {
  color: #FFFFFF;
}

.page.dark .close-btn {
  background-color: rgba(255, 255, 255, 0.1);
}
