<page-meta page-style="background-color: {{darkMode ? '#0F1117' : '#F8F9FA'}}; color: {{darkMode ? '#E8ECF1' : '#2C3E50'}}"/>
<view class="page {{darkMode ? 'dark' : ''}}">
  <scroll-view class="main-scroll" scroll-y="{{true}}">
    <view class="header">
      <view class="header-bg"></view>
      <view class="header-content">
        <text class="page-title">办事指南大全</text>
        <text class="page-subtitle">分类查找、一键收藏，办事不迷路</text>
      </view>
    </view>

    <view class="search-bar">
      <view class="search-input-wrap">
        <text class="search-icon">🔍</text>
        <input
          class="search-input"
          placeholder="搜索指南标题..."
          placeholder-class="search-placeholder"
          value="{{searchKeyword}}"
          bindfocus="onSearchFocus"
          bindblur="onSearchBlur"
          bindinput="onSearchInput"
          confirm-type="search"
        />
        <text
          class="search-clear"
          wx:if="{{searchKeyword}}"
          bindtap="onSearchClear"
        >✕</text>
      </view>
    </view>

    <view class="search-results" wx:if="{{isSearching && searchResults.length > 0}}">
      <view
        class="search-result-item"
        wx:for="{{searchResults}}"
        wx:key="id"
        bindtap="onSearchResultTap"
        data-id="{{item.id}}"
        hover-class="guide-card-hover"
      >
        <text class="result-icon">{{item.icon}}</text>
        <view class="result-info">
          <text class="result-title">{{item.title}}</text>
          <text class="result-summary">{{item.summary}}</text>
        </view>
      </view>
    </view>

    <view class="search-empty" wx:if="{{isSearching && searchKeyword && searchResults.length === 0}}">
      <text class="search-empty-text">未找到相关指南</text>
    </view>

    <view wx:if="{{!isSearching || !searchKeyword}}">
      <view class="category-section">
        <scroll-view class="category-scroll" scroll-x="{{true}}" enhanced="{{true}}" show-scrollbar="{{false}}">
          <view
            class="category-item {{currentCategory === item.key ? 'category-active' : ''}}"
            wx:for="{{categories}}"
            wx:key="key"
            bindtap="onCategoryTap"
            data-key="{{item.key}}"
            hover-class="category-item-hover"
          >
            <view class="category-icon-wrap" style="background: {{currentCategory === item.key ? item.color : (darkMode ? '#2A2D3A' : '#F1F3F4')}};">
              <text class="category-icon">{{item.icon}}</text>
            </view>
            <text class="category-name">{{item.name}}</text>
          </view>
        </scroll-view>
      </view>

      <view class="toolbar">
        <text class="guide-count">共 {{displayList.length}} 篇指南</text>
        <view
          class="fav-filter-btn {{showFavoritesOnly ? 'fav-filter-active' : ''}}"
          bindtap="onShowFavorites"
          hover-class="btn-hover"
        >
          <text class="fav-filter-icon">{{showFavoritesOnly ? '★' : '☆'}}</text>
          <text class="fav-filter-text">只看收藏</text>
        </view>
      </view>

      <view class="guide-list">
        <view
          class="guide-card"
          wx:for="{{displayList}}"
          wx:key="id"
          bindtap="onGuideTap"
          data-id="{{item.id}}"
          hover-class="guide-card-hover"
        >
          <view class="guide-card-header">
            <view class="guide-icon-wrap" style="background: {{categories[categories.map(c=>c.key).indexOf(item.category)+1].color || '#FF6B6B'}}20;">
              <text class="guide-card-icon">{{item.icon}}</text>
            </view>
            <view class="guide-card-info">
              <text class="guide-card-title">{{item.title}}</text>
              <text class="guide-card-summary">{{item.summary}}</text>
            </view>
            <view
              class="guide-fav-btn"
              catchtap="onToggleFavoriteFromList"
              data-id="{{item.id}}"
            >
              <text class="guide-fav-icon {{favoriteIds.indexOf(item.id) > -1 ? 'fav-active' : ''}}">{{favoriteIds.indexOf(item.id) > -1 ? '★' : '☆'}}</text>
            </view>
          </view>
          <view class="guide-card-meta">
            <view class="meta-item">
              <text class="meta-icon">⏱</text>
              <text class="meta-text">{{item.estimatedTime}}</text>
            </view>
            <view class="meta-item">
              <text class="meta-icon">📍</text>
              <text class="meta-text truncate">{{item.location}}</text>
            </view>
          </view>
        </view>
      </view>

      <empty
        wx:if="{{displayList.length === 0 && showFavoritesOnly}}"
        text="暂无收藏的指南"
      />
    </view>

    <view class="bottom-space"></view>
  </scroll-view>

  <view class="detail-overlay {{showDetail ? 'detail-show' : ''}}" wx:if="{{showDetail}}">
    <scroll-view class="detail-scroll" scroll-y="{{true}}">
      <view class="detail-header">
        <view class="detail-back" bindtap="onCloseDetail" hover-class="btn-hover">
          <text class="back-icon">←</text>
        </view>
        <view class="detail-header-title-wrap">
          <text class="detail-header-title">{{currentGuide.title}}</text>
        </view>
        <view class="detail-fav-btn" bindtap="onToggleFavorite" hover-class="btn-hover">
          <text class="detail-fav-icon {{isFavorited ? 'fav-active' : ''}}">{{isFavorited ? '★' : '☆'}}</text>
        </view>
      </view>

      <view class="detail-content" wx:if="{{currentGuide}}">
        <view class="detail-hero">
          <view class="detail-hero-bg"></view>
          <view class="detail-hero-content">
            <text class="detail-hero-icon">{{currentGuide.icon}}</text>
            <text class="detail-hero-title">{{currentGuide.title}}</text>
            <text class="detail-hero-summary">{{currentGuide.summary}}</text>
          </view>
        </view>

        <view class="detail-section">
          <view class="section-label">
            <text class="section-label-icon">📋</text>
            <text class="section-label-text">分步流程</text>
          </view>
          <view class="steps-list">
            <view class="step-item" wx:for="{{currentGuide.steps}}" wx:key="step">
              <view class="step-left">
                <view class="step-number">{{item.step}}</view>
                <view class="step-line" wx:if="{{index < currentGuide.steps.length - 1}}"></view>
              </view>
              <view class="step-content">
                <text class="step-title">{{item.title}}</text>
                <text class="step-desc">{{item.desc}}</text>
              </view>
            </view>
          </view>
        </view>

        <view class="detail-section">
          <view class="section-label">
            <text class="section-label-icon">📂</text>
            <text class="section-label-text">所需材料</text>
          </view>
          <view class="materials-list">
            <view class="material-item" wx:for="{{currentGuide.materials}}" wx:key="index">
              <text class="material-dot">•</text>
              <text class="material-text">{{item}}</text>
            </view>
          </view>
        </view>

        <view class="detail-info-grid">
          <view class="info-card info-location" bindtap="onCopyLocation" data-location="{{currentGuide.location}}" hover-class="btn-hover">
            <text class="info-card-icon">📍</text>
            <text class="info-card-label">办理地点</text>
            <text class="info-card-value">{{currentGuide.location}}</text>
            <text class="info-card-action">复制</text>
          </view>
          <view class="info-card info-phone" bindtap="onCallPhone" data-phone="{{currentGuide.phone}}" hover-class="btn-hover">
            <text class="info-card-icon">📞</text>
            <text class="info-card-label">联系电话</text>
            <text class="info-card-value">{{currentGuide.phone}}</text>
            <text class="info-card-action">拨打</text>
          </view>
          <view class="info-card info-time">
            <text class="info-card-icon">⏱</text>
            <text class="info-card-label">预计耗时</text>
            <text class="info-card-value">{{currentGuide.estimatedTime}}</text>
          </view>
          <view class="info-card info-category">
            <text class="info-card-icon">🏷</text>
            <text class="info-card-label">所属分类</text>
            <text class="info-card-value">{{categories[categories.map(c=>c.key).indexOf(currentGuide.category)+1].name || '其他'}}</text>
          </view>
        </view>

        <view class="detail-section">
          <view class="section-label">
            <text class="section-label-icon">📖</text>
            <text class="section-label-text">详细说明</text>
          </view>
          <view class="markdown-body">
            <rich-text nodes="{{currentGuideHtml}}"></rich-text>
          </view>
        </view>

        <view class="detail-bottom-space"></view>
      </view>
    </scroll-view>
  </view>
</view>
