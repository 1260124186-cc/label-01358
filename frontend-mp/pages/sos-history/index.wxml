<page-meta page-style="background-color: {{darkMode ? '#0F1117' : '#F8F9FA'}}; color: {{darkMode ? '#E8ECF1' : '#2C3E50'}}"/>
<view class="page {{darkMode ? 'dark' : ''}}">
  <view class="history-list" wx:if="{{history.length > 0}}">
    <view 
      class="history-card" 
      wx:for="{{history}}" 
      wx:key="id"
    >
      <view class="card-header">
        <view class="status-badge" style="background: {{item.statusBg}};">
          <text style="color: {{item.statusColor}};">{{item.statusText}}</text>
        </view>
        <text class="time-text">{{item.timeText}}</text>
      </view>
      
      <view class="card-content">
        <view class="info-row" wx:if="{{item.location}}">
          <text class="info-icon">📍</text>
          <view class="info-content">
            <text class="info-label">位置坐标</text>
            <text class="info-value">{{item.locationText}}</text>
          </view>
        </view>
        
        <view class="info-row" wx:if="{{item.nearestPOI}}">
          <text class="info-icon">🏢</text>
          <view class="info-content">
            <text class="info-label">附近地点</text>
            <text class="info-value">{{item.nearestPOI.name}}</text>
          </view>
        </view>
        
        <view class="info-row" wx:if="{{item.emergencyContacts.length > 0}}">
          <text class="info-icon">👥</text>
          <view class="info-content">
            <text class="info-label">通知联系人</text>
            <view class="contacts-list">
              <text 
                class="contact-tag" wx:for="{{item.emergencyContacts}}" wx:for-item="contact" wx:key="id">
                {{contact.name}}
              </text>
            </view>
          </view>
        </view>
        
        <view class="info-row">
          <text class="info-icon">👮</text>
          <view class="info-content">
            <text class="info-label">通知保卫处</text>
            <text class="info-value">{{item.notifiedAdmin ? '已通知' : '未通知'}}</text>
          </view>
        </view>
        
        <view class="info-row" wx:if="{{item.remark}}">
          <text class="info-icon">📝</text>
          <view class="info-content">
            <text class="info-label">备注</text>
            <text class="info-value">{{item.remark}}</text>
          </view>
        </view>
      </view>
      
      <view class="card-actions">
        <view class="action-btn" bindtap="onCallSecurity" wx:if="{{item.status === 'sent'}}">
          <text class="action-icon">📞</text>
          <text class="action-text">拨打保卫处</text>
        </view>
        <view class="action-btn primary" bindtap="onCallContact" wx:if="{{item.emergencyContacts.length > 0}}">
          <text class="action-icon">📱</text>
          <text class="action-text">联系紧急联系人</text>
        </view>
      </view>
    </view>
  </view>

  <view class="empty-state" wx:if="{{history.length === 0}}">
    <text class="empty-icon">📋</text>
    <text class="empty-title">暂无 SOS 记录</text>
    <text class="empty-desc">平安是福，希望您永远不需要使用这个功能</text>
  </view>
</view>
