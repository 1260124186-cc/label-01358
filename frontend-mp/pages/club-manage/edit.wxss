.page {
  min-height: 100vh;
  background-color: var(--color-bg-page);
  padding: 24rpx;
}

.form-section {
  background-color: var(--color-bg-card);
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-card);
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 20rpx;
}

.cover-upload {
  width: 100%;
  height: 320rpx;
  border-radius: 16rpx;
  overflow: hidden;
  border: 2rpx dashed var(--color-border);
  display: flex;
  align-items: center;
  justify-content: center;
}

.cover-image {
  width: 100%;
  height: 100%;
}

.cover-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  color: var(--color-text-muted);
}

.upload-icon {
  font-size: 64rpx;
}

.upload-text {
  font-size: 26rpx;
}

.input-wrapper {
  background-color: var(--color-bg-page);
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
}

.input {
  font-size: 30rpx;
  color: var(--color-text-primary);
  width: 100%;
}

.textarea-wrapper {
  background-color: var(--color-bg-page);
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  position: relative;
}

.textarea {
  font-size: 30rpx;
  color: var(--color-text-primary);
  width: 100%;
  min-height: 200rpx;
}

.char-count {
  text-align: right;
  font-size: 24rpx;
  color: var(--color-text-muted);
  margin-top: 12rpx;
}

.submit-section {
  margin-top: 48rpx;
  padding: 0 8rpx;
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  border: none;
}

.submit-btn::after {
  border: none;
}

.submit-btn.disabled {
  opacity: 0.6;
}
