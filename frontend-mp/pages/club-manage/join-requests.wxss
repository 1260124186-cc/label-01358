.page {
  min-height: 100vh;
  background-color: var(--color-bg-page);
}

.tabs {
  display: flex;
  background-color: var(--color-bg-card);
  padding: 8rpx;
  margin: 24rpx;
  border-radius: 16rpx;
  box-shadow: var(--shadow-card);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: var(--color-text-secondary);
  border-radius: 12rpx;
  transition: all 0.2s ease;
}

.tab-item.active {
  background-color: var(--color-primary);
  color: #FFFFFF;
  font-weight: 600;
}

.list {
  padding: 0 24rpx 24rpx;
}

.request-card {
  background-color: var(--color-bg-card);
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-card);
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.user-info {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.user-detail {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.user-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.request-time {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.status-tag {
  padding: 8rpx 16rpx;
  font-size: 24rpx;
  font-weight: 500;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.card-body {
  padding-top: 20rpx;
  border-top: 1rpx solid var(--color-border);
}

.label {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-bottom: 12rpx;
}

.reason-text {
  font-size: 28rpx;
  color: var(--color-text-primary);
  line-height: 1.6;
}

.card-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--color-border);
}

.btn {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 28rpx;
  font-weight: 500;
  border-radius: 12rpx;
  border: none;
}

.btn::after {
  border: none;
}

.btn-reject {
  background-color: #FEF2F2;
  color: #EF4444;
}

.btn-approve {
  background-color: #10B981;
  color: #FFFFFF;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: var(--color-text-secondary);
}
