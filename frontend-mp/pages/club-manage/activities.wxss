.page {
  min-height: 100vh;
  background-color: var(--color-bg-page);
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  background-color: var(--color-bg-card);
  position: sticky;
  top: 0;
  z-index: 100;
}

.back-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 36rpx;
  color: var(--color-text-primary);
}

.title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.publish-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #10B981;
  border-radius: 50%;
}

.publish-icon {
  font-size: 36rpx;
  color: #FFFFFF;
  font-weight: 600;
}

.tabs {
  display: flex;
  background-color: var(--color-bg-card);
  padding: 0 16rpx;
  border-bottom: 1rpx solid var(--color-border);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: var(--color-text-secondary);
  position: relative;
}

.tab-item.active {
  color: #10B981;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 4rpx;
  background-color: #10B981;
  border-radius: 2rpx;
}

.activity-list {
  padding: 24rpx;
}

.activity-card {
  display: flex;
  background-color: var(--color-bg-card);
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-card);
}

.activity-card-hover {
  opacity: 0.85;
}

.activity-cover {
  width: 180rpx;
  height: 180rpx;
  flex-shrink: 0;
  background-color: var(--color-bg-secondary);
  display: flex;
  align-items: center;
  justify-content: center;
}

.cover-img {
  width: 100%;
  height: 100%;
}

.cover-icon {
  font-size: 48rpx;
}

.activity-info {
  flex: 1;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
}

.activity-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
}

.activity-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.status-tag {
  flex-shrink: 0;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.activity-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 8rpx;
}

.meta-item {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.activity-stats {
  display: flex;
  gap: 24rpx;
  margin-top: 12rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.stat-value {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.stat-value.rate {
  color: #10B981;
}

.stat-label {
  font-size: 22rpx;
  color: var(--color-text-muted);
  margin-top: 4rpx;
}

.activity-arrow {
  display: flex;
  align-items: center;
  padding-right: 24rpx;
  font-size: 40rpx;
  color: var(--color-text-muted);
}

.empty-state {
  padding: 120rpx 48rpx;
  text-align: center;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 30rpx;
  color: var(--color-text-secondary);
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: var(--color-text-muted);
}
