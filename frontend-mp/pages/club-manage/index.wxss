.page {
  min-height: 100vh;
  background-color: var(--color-bg-page);
  padding: 24rpx;
}

.header {
  margin-bottom: 32rpx;
}

.club-info {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 24rpx;
  background: var(--color-bg-card);
  border-radius: 24rpx;
  box-shadow: var(--shadow-card);
}

.club-cover {
  width: 120rpx;
  height: 120rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
}

.club-cover.placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  font-size: 48rpx;
}

.club-detail {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.club-name {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

.club-role {
  display: flex;
  align-items: center;
}

.role-tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  font-size: 22rpx;
  font-weight: 500;
  background: linear-gradient(135deg, #FEF3C7 0%, #FDE68A 100%);
  color: #B45309;
  border-radius: 8rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.stats-item {
  border-radius: 24rpx;
  padding: 32rpx;
  display: flex;
  flex-direction: column;
}

.stats-count {
  font-size: 56rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.stats-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

.module-section {
  margin-top: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin: 0 8rpx 20rpx;
}

.module-list {
  background-color: var(--color-bg-card);
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: var(--shadow-card);
}

.module-card {
  display: flex;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid var(--color-border);
  transition: background-color 0.2s ease;
}

.module-card:last-child {
  border-bottom: none;
}

.module-card-hover {
  background-color: var(--color-bg-page);
}

.module-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.icon-text {
  font-size: 44rpx;
}

.module-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.module-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 6rpx;
}

.module-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.badge {
  min-width: 36rpx;
  height: 36rpx;
  padding: 0 10rpx;
  font-size: 22rpx;
  font-weight: 600;
  color: #FFFFFF;
  background: #EF4444;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.module-desc {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.module-arrow {
  font-size: 40rpx;
  color: var(--color-text-muted);
  font-weight: 300;
}
