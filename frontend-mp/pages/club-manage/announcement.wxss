.page {
  min-height: 100vh;
  background-color: var(--color-bg-page);
  padding: 24rpx;
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32rpx;
  padding: 0 8rpx;
}

.header-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

.header-desc {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.publish-btn {
  padding: 16rpx 32rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: #FFFFFF;
  background: linear-gradient(135deg, #EF4444 0%, #F87171 100%);
  border-radius: 32rpx;
  border: none;
}

.publish-btn::after {
  border: none;
}

.announcement-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.announcement-card {
  background-color: var(--color-bg-card);
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: var(--shadow-card);
}

.card-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 1;
}

.important-tag {
  padding: 4rpx 12rpx;
  font-size: 22rpx;
  font-weight: 500;
  color: #EF4444;
  background-color: #FEF2F2;
  border-radius: 6rpx;
  flex-shrink: 0;
}

.title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  flex: 1;
}

.delete-btn {
  font-size: 24rpx;
  color: #EF4444;
  flex-shrink: 0;
  padding: 8rpx 16rpx;
  background-color: #FEF2F2;
  border-radius: 8rpx;
}

.content {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  line-height: 1.6;
  margin-bottom: 16rpx;
}

.card-footer {
  display: flex;
  justify-content: flex-end;
}

.time {
  font-size: 24rpx;
  color: var(--color-text-muted);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 8rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.publish-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  padding: 48rpx;
}

.modal-content {
  width: 100%;
  background-color: var(--color-bg-card);
  border-radius: 24rpx;
  overflow: hidden;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid var(--color-border);
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.modal-close {
  font-size: 48rpx;
  color: var(--color-text-muted);
  line-height: 1;
}

.modal-body {
  padding: 32rpx;
}

.form-item {
  margin-bottom: 32rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--color-text-primary);
  margin-bottom: 16rpx;
}

.form-input {
  width: 100%;
  padding: 20rpx 24rpx;
  font-size: 30rpx;
  color: var(--color-text-primary);
  background-color: var(--color-bg-page);
  border-radius: 12rpx;
  box-sizing: border-box;
}

.form-textarea {
  width: 100%;
  min-height: 200rpx;
  padding: 20rpx 24rpx;
  font-size: 30rpx;
  color: var(--color-text-primary);
  background-color: var(--color-bg-page);
  border-radius: 12rpx;
  box-sizing: border-box;
}

.switch-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  background-color: var(--color-bg-page);
  border-radius: 12rpx;
}

.switch-label {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.switch-label text:first-child {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--color-text-primary);
}

.switch-desc {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 24rpx 32rpx 32rpx;
}

.cancel-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 30rpx;
  font-weight: 500;
  color: var(--color-text-secondary);
  background-color: var(--color-bg-page);
  border-radius: 44rpx;
  border: none;
}

.cancel-btn::after {
  border: none;
}

.confirm-btn {
  flex: 2;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #FFFFFF;
  background: linear-gradient(135deg, #EF4444 0%, #F87171 100%);
  border-radius: 44rpx;
  border: none;
}

.confirm-btn::after {
  border: none;
}
