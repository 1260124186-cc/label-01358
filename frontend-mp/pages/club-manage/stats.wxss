.page {
  min-height: 100vh;
  background-color: var(--color-bg-page);
  padding: 24rpx;
}

.stats-section {
  margin-bottom: 32rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin: 0 8rpx 20rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.stat-card {
  border-radius: 24rpx;
  padding: 32rpx;
  display: flex;
  flex-direction: column;
}

.stat-value {
  font-size: 52rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

.more-stats {
  background-color: var(--color-bg-card);
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: var(--shadow-card);
  display: flex;
  gap: 32rpx;
}

.more-stat-item {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.more-stat-icon {
  font-size: 48rpx;
  flex-shrink: 0;
}

.more-stat-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.more-stat-value {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

.more-stat-label {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.activity-list {
  background-color: var(--color-bg-card);
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: var(--shadow-card);
}

.activity-item {
  display: flex;
  justify-content: space-between;
  padding: 28rpx;
  border-bottom: 1rpx solid var(--color-border);
}

.activity-item:last-child {
  border-bottom: none;
}

.activity-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  flex: 1;
}

.activity-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.activity-time {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.activity-stats {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  align-items: flex-end;
}

.stat-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.stat-row .stat-label {
  font-size: 24rpx;
  color: var(--color-text-muted);
}

.stat-row .stat-value {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.stat-row .stat-value.rate {
  color: #10B981;
}

.empty-state {
  padding: 48rpx;
  text-align: center;
  background-color: var(--color-bg-card);
  border-radius: 20rpx;
  box-shadow: var(--shadow-card);
}

.empty-text {
  font-size: 28rpx;
  color: var(--color-text-secondary);
}
