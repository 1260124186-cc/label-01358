.page {
  min-height: 100vh;
  background-color: var(--color-bg-page);
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
}

.header {
  padding: 24rpx;
  background-color: var(--color-bg-card);
  border-bottom: 1rpx solid var(--color-border-light);
}

.header-actions {
  display: flex;
  align-items: center;
}

.header-actions > * { margin-right: 20rpx; }

.header-actions > *:last-child { margin-right: 0; }

.view-mode-switch {
  display: flex;
  background-color: var(--color-bg-input);
  border-radius: var(--radius-lg);
  padding: 4rpx;
  margin-right: auto;
}

.view-mode-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 56rpx;
  border-radius: var(--radius-md);
  transition: all var(--transition-fast);
}

.view-mode-btn.active {
  background-color: var(--color-bg-card);
  box-shadow: var(--shadow-sm);
}

.view-mode-icon {
  font-size: 28rpx;
  color: var(--color-text-secondary);
}

.view-mode-btn.active .view-mode-icon {
  color: var(--color-primary);
}

.header-action {
  display: flex;
  align-items: center;
  padding: 12rpx 24rpx;
  background-color: var(--color-bg-input);
  border-radius: var(--radius-full);
  transition: all var(--transition-fast);
}

.header-action > * { margin-right: 8rpx; }

.header-action > *:last-child { margin-right: 0; }

.header-action:active {
  transform: scale(0.96);
  opacity: 0.8;
}

.action-icon {
  font-size: 28rpx;
  color: var(--color-text-secondary);
}

.action-text {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  font-weight: 500;
}

.tabs-scroll {
  background-color: var(--color-bg-card);
  white-space: nowrap;
  border-bottom: 1rpx solid var(--color-border-light);
}

.tabs {
  display: inline-flex;
  padding: 16rpx 24rpx;
}

.tabs > * { margin-right: 16rpx; }

.tabs > *:last-child { margin-right: 0; }

.tab-item {
  display: inline-flex;
  align-items: center;
  padding: 16rpx 28rpx;
  background-color: var(--color-bg-input);
  border-radius: var(--radius-full);
  position: relative;
  transition: all var(--transition-fast);
}

.tab-item > * { margin-right: 8rpx; }

.tab-item > *:last-child { margin-right: 0; }

.tab-item.active {
  background-color: var(--color-primary);
}

.tab-item.active .tab-icon,
.tab-item.active .tab-text {
  color: #FFFFFF;
}

.tab-icon {
  font-size: 28rpx;
  color: var(--color-text-secondary);
}

.tab-text {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--color-text-secondary);
  white-space: nowrap;
}

.tab-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  min-width: 36rpx;
  height: 36rpx;
  padding: 0 10rpx;
  background-color: #FF4D4F;
  color: #FFFFFF;
  font-size: 22rpx;
  font-weight: 600;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(255, 77, 79, 0.4);
}

.tab-item.active .tab-badge {
  background-color: #FFFFFF;
  color: var(--color-primary);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}

.content {
  padding: 24rpx;
}

.notification-group {
  margin-bottom: 32rpx;
}

.group-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  padding: 0 8rpx;
}

.group-header > * { margin-right: 12rpx; }

.group-header > *:last-child { margin-right: 0; }

.group-icon {
  font-size: 32rpx;
}

.group-label {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  flex: 1;
}

.group-count {
  font-size: 24rpx;
  color: var(--color-text-muted);
  padding: 4rpx 16rpx;
  background-color: var(--color-bg-input);
  border-radius: var(--radius-full);
}

.notification-item {
  display: flex;
  align-items: flex-start;
  padding: 28rpx 24rpx;
  background-color: var(--color-bg-card);
  border-radius: var(--radius-2xl);
  margin-bottom: 16rpx;
  position: relative;
  transition: all var(--transition-fast);
  box-shadow: var(--shadow-card);
}

.notification-item:active {
  transform: scale(0.98);
}

.notification-item.read {
  opacity: 0.7;
}

.notification-unread-dot {
  position: absolute;
  top: 32rpx;
  left: 16rpx;
  width: 16rpx;
  height: 16rpx;
  background-color: #FF4D4F;
  border-radius: 50%;
  box-shadow: 0 0 0 4rpx var(--color-bg-card);
}

.notification-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: var(--radius-lg);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.notification-content {
  flex: 1;
  min-width: 0;
}

.notification-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.notification-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-right: 16rpx;
}

.notification-time {
  font-size: 24rpx;
  color: var(--color-text-muted);
  flex-shrink: 0;
}

.notification-desc {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.notification-footer {
  margin-top: 12rpx;
}

.notification-preview {
  font-size: 24rpx;
  color: var(--color-text-muted);
  padding: 8rpx 16rpx;
  background-color: var(--color-bg-input);
  border-radius: var(--radius-md);
  display: inline-block;
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.notification-delete {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 12rpx;
  flex-shrink: 0;
}

.delete-icon {
  font-size: 36rpx;
  color: var(--color-text-muted);
  line-height: 1;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 48rpx;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 32rpx;
  opacity: 0.6;
}

.empty-text {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-secondary);
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: var(--color-text-muted);
}

.dark .notification-unread-dot {
  box-shadow: 0 0 0 4rpx var(--color-bg-card);
}
