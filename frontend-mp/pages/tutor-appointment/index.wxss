.page {
  min-height: 100vh;
  background-color: var(--color-bg-page);
}

.tab-section {
  padding: 0 24rpx;
  background-color: var(--color-bg-card);
  border-bottom: 1rpx solid var(--color-border-light);
  position: sticky;
  top: 0;
  z-index: 100;
}

.tab-scroll {
  white-space: nowrap;
}

.tab-bar {
  display: inline-flex;
  height: 88rpx;
  align-items: center;
}

.tab-bar > view { margin-right: 48rpx; }
.tab-bar > view:last-child { margin-right: 0; }

.tab-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  height: 88rpx;
  transition: all var(--transition-fast);
}

.tab-text {
  font-size: var(--font-md);
  font-weight: 500;
  color: var(--color-text-secondary);
  transition: all var(--transition-fast);
}

.tab-item.active .tab-text {
  color: var(--color-primary);
  font-weight: 700;
}

.tab-underline {
  position: absolute;
  bottom: 8rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 6rpx;
  background: linear-gradient(135deg, var(--color-primary) 0%, #FF8E8E 100%);
  border-radius: var(--radius-full);
}

.list-scroll {
  height: calc(100vh - 180rpx);
}

.list-container {
  padding: 16rpx 24rpx;
}

.appointment-card {
  background-color: var(--color-bg-card);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-card);
  margin-bottom: 20rpx;
  overflow: hidden;
  transition: all var(--transition-fast);
}

.appointment-card:active {
  transform: scale(0.98);
  box-shadow: var(--shadow-sm);
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  border-bottom: 1rpx solid var(--color-divider);
}

.user-section {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.avatar-wrapper {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  overflow: hidden;
  background-color: var(--color-bg-input);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.avatar {
  width: 100%;
  height: 100%;
}

.avatar-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, var(--color-primary) 0%, #FF8E8E 100%);
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 700;
}

.user-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.user-name {
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--color-text-primary);
}

.user-role {
  font-size: var(--font-xs);
  color: var(--color-text-tertiary);
}

.status-tag {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 16rpx;
  border-radius: var(--radius-full);
  font-size: var(--font-xs);
  font-weight: 600;
}

.status-icon {
  font-size: var(--font-xs);
}

.status-label {
  font-size: var(--font-xs);
}

.card-body {
  padding: 20rpx 24rpx;
}

.info-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
  flex-wrap: wrap;
}

.info-tag {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 16rpx;
  border-radius: var(--radius-sm);
  font-size: var(--font-xs);
}

.subject-tag {
  background-color: var(--color-bg-input);
}

.tag-icon {
  font-size: var(--font-xs);
  margin-right: 6rpx;
}

.tag-text {
  color: var(--color-text-secondary);
  font-weight: 500;
}

.method-tag {
  background-color: rgba(59, 130, 246, 0.1);
}

.method-tag .tag-text {
  color: #3B82F6;
}

.detail-row {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  margin-bottom: 10rpx;
}

.detail-row:last-child {
  margin-bottom: 0;
}

.detail-icon {
  font-size: var(--font-sm);
  flex-shrink: 0;
  margin-top: 2rpx;
}

.detail-text {
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
  line-height: 1.5;
  flex: 1;
  min-width: 0;
}

.detail-text.remark {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.card-footer {
  padding: 0 24rpx;
}

.footer-divider {
  height: 1rpx;
  background-color: var(--color-divider);
}

.view-detail {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  padding: 16rpx 0;
  gap: 4rpx;
}

.view-detail-text {
  font-size: var(--font-sm);
  color: var(--color-primary);
  font-weight: 500;
}

.view-detail-arrow {
  font-size: var(--font-lg);
  color: var(--color-primary);
  font-weight: 600;
}
