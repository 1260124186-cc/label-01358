.page {
  min-height: 100vh;
  background-color: #F8F9FA;
}

.page.dark {
  background-color: #0F1117;
  color: #E8ECF1;
}

.tab-section {
  background-color: #fff;
  border-bottom: 1rpx solid #EEEEEE;
}

.page.dark .tab-section {
  background-color: #1A1D29;
  border-bottom-color: #2A2F3D;
}

.tab-scroll {
  white-space: nowrap;
}

.tabs {
  display: inline-flex;
  padding: 0 20rpx;
}

.tab-item {
  padding: 24rpx 30rpx;
  font-size: 30rpx;
  color: #666;
  position: relative;
}

.page.dark .tab-item {
  color: #9AA0A6;
}

.tab-item.active {
  color: #FF6B6B;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 6rpx;
  background-color: #FF6B6B;
  border-radius: 3rpx;
}

.points-section {
  padding: 20rpx;
}

.points-card {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  border-radius: 20rpx;
  padding: 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  color: #fff;
}

.points-info {
  flex: 1;
}

.points-label {
  font-size: 26rpx;
  opacity: 0.9;
  display: block;
  margin-bottom: 8rpx;
}

.points-value-wrap {
  display: flex;
  align-items: baseline;
}

.points-value {
  font-size: 52rpx;
  font-weight: 700;
}

.points-unit {
  font-size: 24rpx;
  margin-left: 8rpx;
  opacity: 0.9;
}

.points-btn {
  display: flex;
  align-items: center;
  background-color: rgba(255, 255, 255, 0.2);
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
}

.btn-arrow {
  margin-left: 6rpx;
  font-size: 28rpx;
}

.list-scroll {
  height: calc(100vh - 260rpx);
}

.list-container {
  padding: 20rpx;
}

.groupbuy-card {
  background-color: #fff;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.page.dark .groupbuy-card {
  background-color: #1A1D29;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.3);
}

.groupbuy-card-hover {
  transform: scale(0.98);
  opacity: 0.9;
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.role-tag {
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.role-tag.publisher {
  background-color: #FFF4E5;
  color: #FF8C19;
}

.role-tag.member {
  background-color: #E8F8EF;
  color: #10B981;
}

.status-badge {
  margin-left: 16rpx;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.product-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #111;
  margin-bottom: 20rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.page.dark .product-name {
  color: #E8ECF1;
}

.progress-section {
  margin-bottom: 20rpx;
}

.progress-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.progress-count {
  font-size: 26rpx;
  font-weight: 600;
  color: #FF6B6B;
}

.progress-hint {
  font-size: 24rpx;
  color: #FF8C19;
}

.progress-bar-wrap {
  width: 100%;
  height: 12rpx;
  background-color: #F0F0F0;
  border-radius: 6rpx;
  overflow: hidden;
}

.page.dark .progress-bar-wrap {
  background-color: #2A2F3D;
}

.progress-bar {
  height: 100%;
  background: linear-gradient(90deg, #FF6B6B 0%, #FF8E8E 100%);
  border-radius: 6rpx;
}

.my-order-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background-color: #FFF9F9;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  font-size: 26rpx;
  color: #666;
}

.page.dark .my-order-info {
  background-color: rgba(255, 107, 107, 0.08);
  color: #9AA0A6;
}

.order-amount {
  color: #FF6B6B;
  font-weight: 600;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  padding-top: 20rpx;
  border-top: 1rpx solid #F5F5F5;
}

.page.dark .card-footer {
  border-top-color: #2A2F3D;
}

.price-info {
  display: flex;
  align-items: baseline;
}

.price-currency {
  font-size: 26rpx;
  color: #FF6B6B;
  font-weight: 600;
}

.price-value {
  font-size: 40rpx;
  color: #FF6B6B;
  font-weight: 700;
  margin: 0 4rpx;
}

.price-unit {
  font-size: 22rpx;
  color: #999;
}

.card-meta {
  display: flex;
  align-items: center;
}

.meta-text {
  font-size: 22rpx;
  color: #999;
}
