.page {
  min-height: 100vh;
  background-color: var(--color-bg-page);
  padding-bottom: calc(180rpx + env(safe-area-inset-bottom));
}

.header-section {
  position: relative;
  padding: 40rpx 32rpx 48rpx;
  margin-bottom: -24rpx;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 360rpx;
  background: linear-gradient(135deg, var(--color-primary) 0%, #FF8E8E 60%, #FFB3B3 100%);
  z-index: 0;
}

.header-content {
  position: relative;
  z-index: 1;
  color: #FFFFFF;
}

.status-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.status-tag {
  display: flex;
  align-items: center;
  padding: 8rpx 20rpx;
  border-radius: var(--radius-full);
  font-size: 24rpx;
  font-weight: 600;
  background-color: rgba(255, 255, 255, 0.25);
}

.status-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin-right: 10rpx;
  background-color: #FFFFFF;
}

.visibility-tag {
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: var(--radius-full);
}

.voting-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.4;
  margin-bottom: 16rpx;
  color: #FFFFFF;
}

.voting-desc {
  display: block;
  font-size: 26rpx;
  line-height: 1.7;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 28rpx;
}

.header-info {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 24rpx;
}

.info-item {
  display: flex;
  align-items: center;
}

.info-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.info-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.95);
}

.info-text.highlight {
  font-weight: 600;
  color: #FFFFFF;
}

.time-section {
  margin: 0 24rpx 20rpx;
  position: relative;
  z-index: 2;
}

.time-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.time-item {
  flex: 1;
  text-align: center;
}

.time-label {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-bottom: 8rpx;
}

.time-value {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.time-arrow {
  font-size: 32rpx;
  color: var(--color-text-secondary);
  padding: 0 16rpx;
}

.type-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--color-border-light);
}

.type-label {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.type-value {
  font-size: 26rpx;
  color: var(--color-text-primary);
  font-weight: 500;
}

.warning-section {
  margin: 0 24rpx 20rpx;
}

.warning-content {
  display: flex;
  align-items: flex-start;
}

.warning-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.warning-text {
  font-size: 26rpx;
  color: var(--color-warning);
  line-height: 1.6;
  flex: 1;
  font-weight: 500;
}

.voted-section {
  margin: 0 24rpx 20rpx;
}

.voted-content {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.voted-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.voted-text {
  font-size: 28rpx;
  color: var(--color-success);
  font-weight: 600;
}

.voted-time {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  padding-left: 48rpx;
}

.candidates-section {
  padding: 0 24rpx;
}

.section-title-row {
  display: flex;
  align-items: baseline;
  margin: 32rpx 8rpx 20rpx;
}

.section-title-text {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

.section-sub {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-left: 12rpx;
}

.candidate-list {
  display: flex;
  flex-direction: column;
}

.candidate-card {
  margin-bottom: 20rpx;
  border: 3rpx solid transparent;
  transition: all var(--transition-fast);
}

.candidate-card.selectable {
  cursor: pointer;
}

.candidate-card.selected {
  border-color: var(--color-primary);
  background-color: var(--color-primary-light);
  box-shadow: 0 4rpx 20rpx rgba(255, 107, 107, 0.15);
}

.candidate-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.candidate-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--color-primary) 0%, #FF8E8E 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.avatar-text {
  font-size: 40rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.candidate-info {
  flex: 1;
  min-width: 0;
}

.candidate-name-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.candidate-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.check-box {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 3rpx solid var(--color-border);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 16rpx;
  flex-shrink: 0;
  transition: all var(--transition-fast);
}

.check-box.checked {
  background-color: var(--color-primary);
  border-color: var(--color-primary);
}

.check-icon {
  font-size: 28rpx;
  color: #FFFFFF;
  font-weight: 700;
}

.candidate-tags {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
}

.c-tag {
  padding: 4rpx 14rpx;
  font-size: 22rpx;
  color: var(--color-info);
  background-color: rgba(52, 152, 219, 0.1);
  border-radius: var(--radius-sm);
}

.vote-count-badge {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 8rpx 16rpx;
  background-color: var(--color-bg-input);
  border-radius: var(--radius-md);
  margin-left: 16rpx;
  flex-shrink: 0;
}

.count-num {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-primary);
  line-height: 1;
}

.count-label {
  font-size: 20rpx;
  color: var(--color-text-secondary);
  margin-top: 4rpx;
}

.candidate-desc {
  display: block;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.7;
  padding-left: 116rpx;
}

.action-space {
  height: 40rpx;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 32rpx calc(20rpx + env(safe-area-inset-bottom));
  background-color: var(--color-bg-card);
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  z-index: 100;
}

.selected-info {
  display: flex;
  align-items: baseline;
}

.selected-count {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--color-primary);
  line-height: 1;
}

.selected-text {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  margin-left: 6rpx;
}

.submit-btn {
  flex: 1;
  height: 96rpx;
  line-height: 96rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
  background: linear-gradient(135deg, var(--color-primary) 0%, #FF8E8E 100%);
  border-radius: var(--radius-full);
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 107, 0.35);
}

.submit-btn.result-btn {
  background: linear-gradient(135deg, #3B82F6 0%, #60A5FA 100%);
  box-shadow: 0 8rpx 24rpx rgba(59, 130, 246, 0.35);
}

.submit-btn.publish-btn {
  background: linear-gradient(135deg, #8B5CF6 0%, #A78BFA 100%);
  box-shadow: 0 8rpx 24rpx rgba(139, 92, 246, 0.35);
  flex: 0 0 240rpx;
}

.submit-btn.disabled {
  opacity: 0.5;
}

.submit-btn::after {
  border: none;
}

.loading-wrap,
.empty-wrap {
  min-height: 60vh;
  display: flex;
  align-items: center;
  justify-content: center;
}

.loading-text,
.empty-wrap text {
  font-size: 28rpx;
  color: var(--color-text-secondary);
}
