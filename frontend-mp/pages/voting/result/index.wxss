.page {
  min-height: 100vh;
  background-color: var(--color-bg-page);
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
}

.header-section {
  position: relative;
  padding: 40rpx 32rpx 56rpx;
  margin-bottom: -24rpx;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 520rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 50%, #f093fb 100%);
  z-index: 0;
}

.header-content {
  position: relative;
  z-index: 1;
  color: #FFFFFF;
}

.status-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.status-tag {
  display: flex;
  align-items: center;
  padding: 8rpx 20rpx;
  border-radius: var(--radius-full);
  font-size: 24rpx;
  font-weight: 600;
  background-color: rgba(255, 255, 255, 0.25);
}

.status-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin-right: 10rpx;
}

.visibility-tag {
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: var(--radius-full);
}

.voting-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.4;
  margin-bottom: 28rpx;
}

.winner-section {
  display: flex;
  align-items: flex-start;
  margin-bottom: 32rpx;
  padding: 24rpx;
  background-color: rgba(255, 255, 255, 0.18);
  border-radius: var(--radius-lg);
  backdrop-filter: blur(10px);
}

.winner-badge {
  display: flex;
  align-items: center;
  padding: 8rpx 20rpx;
  background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
  border-radius: var(--radius-full);
  margin-right: 16rpx;
  flex-shrink: 0;
}

.winner-icon {
  font-size: 24rpx;
  margin-right: 6rpx;
}

.winner-label {
  font-size: 22rpx;
  font-weight: 700;
  color: #8B4513;
}

.winner-names {
  flex: 1;
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 12rpx;
}

.winner-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #FFFFFF;
  padding: 6rpx 18rpx;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: var(--radius-sm);
}

.stats-row {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  background-color: rgba(255, 255, 255, 0.15);
  border-radius: var(--radius-lg);
  backdrop-filter: blur(10px);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 44rpx;
  font-weight: 700;
  color: #FFFFFF;
  line-height: 1.2;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 8rpx;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background-color: rgba(255, 255, 255, 0.25);
}

.info-section {
  margin: 0 24rpx 20rpx;
  position: relative;
  z-index: 2;
}

.info-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
}

.info-row + .info-row {
  border-top: 1rpx solid var(--color-border-light);
}

.info-label {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.info-value {
  font-size: 26rpx;
  color: var(--color-text-primary);
  font-weight: 500;
}

.filter-section {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background-color: var(--color-bg-card);
  position: sticky;
  top: 0;
  z-index: 100;
}

.filter-scroll {
  flex: 1;
  white-space: nowrap;
}

.filter-tabs {
  display: inline-flex;
}

.filter-tabs > view { margin-right: 12rpx; }
.filter-tabs > view:last-child { margin-right: 0; }

.filter-tab {
  display: inline-block;
  padding: 14rpx 32rpx;
  font-size: 26rpx;
  font-weight: 500;
  color: var(--color-text-secondary);
  background-color: var(--color-bg-input);
  border-radius: var(--radius-full);
  transition: all var(--transition-fast);
}

.filter-tab.active {
  color: #FFFFFF;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
}

.ranking-section {
  padding: 16rpx 24rpx;
}

.rank-card {
  margin-bottom: 20rpx;
  border-left: 8rpx solid var(--color-border);
  transition: all var(--transition-fast);
}

.rank-card.rank-gold {
  border-left-color: #FFD700;
  box-shadow: 0 8rpx 32rpx rgba(255, 215, 0, 0.2);
}

.rank-card.rank-silver {
  border-left-color: #C0C0C0;
  box-shadow: 0 6rpx 24rpx rgba(192, 192, 192, 0.18);
}

.rank-card.rank-bronze {
  border-left-color: #CD7F32;
  box-shadow: 0 6rpx 24rpx rgba(205, 127, 50, 0.18);
}

.rank-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.rank-no-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 80rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.rank-no {
  display: flex;
  align-items: center;
  justify-content: center;
}

.rank-trophy {
  font-size: 48rpx;
  line-height: 1;
}

.rank-num {
  font-size: 40rpx;
  font-weight: 800;
  color: var(--color-text-secondary);
}

.winner-tag-mini {
  margin-top: 6rpx;
  padding: 2rpx 10rpx;
  background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
  border-radius: 6rpx;
}

.winner-tag-mini text {
  font-size: 18rpx;
  font-weight: 700;
  color: #8B4513;
}

.rank-candidate {
  flex: 1;
  display: flex;
  align-items: center;
  min-width: 0;
}

.candidate-avatar-sm {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--color-primary) 0%, #FF8E8E 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.avatar-text-sm {
  font-size: 30rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.candidate-main {
  flex: 1;
  min-width: 0;
}

.candidate-name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 6rpx;
}

.candidate-desc-sm {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-secondary);
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  overflow: hidden;
}

.rank-votes {
  display: flex;
  align-items: baseline;
  margin-left: 16rpx;
  flex-shrink: 0;
}

.votes-num {
  font-size: 36rpx;
  font-weight: 800;
  color: var(--color-primary);
}

.votes-unit {
  font-size: 20rpx;
  color: var(--color-text-secondary);
  margin: 0 4rpx 0 2rpx;
}

.votes-percent {
  font-size: 20rpx;
  color: var(--color-text-secondary);
  font-weight: 500;
}

.progress-bar-wrap {
  padding-left: 100rpx;
}

.progress-bar-bg {
  height: 16rpx;
  background-color: var(--color-bg-input);
  border-radius: var(--radius-full);
  overflow: hidden;
}

.progress-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--color-primary) 0%, #FF8E8E 100%);
  border-radius: var(--radius-full);
  transition: width 0.6s ease;
}

.progress-bar-fill.fill-gold {
  background: linear-gradient(90deg, #FFD700 0%, #FFA500 100%);
}

.progress-bar-fill.fill-silver {
  background: linear-gradient(90deg, #C0C0C0 0%, #A8A8A8 100%);
}

.progress-bar-fill.fill-bronze {
  background: linear-gradient(90deg, #CD7F32 0%, #B87333 100%);
}

.voters-section {
  padding: 16rpx 24rpx;
}

.voter-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
}

.voter-item + .voter-item {
  border-top: 1rpx solid var(--color-border-light);
}

.voter-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.voter-avatar-text {
  font-size: 30rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.voter-info {
  flex: 1;
  min-width: 0;
}

.voter-name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 6rpx;
}

.voter-id {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

.voter-time {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  flex-shrink: 0;
}

.empty-voters {
  padding: 80rpx 0;
  text-align: center;
}

.empty-text {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.no-permission-section {
  margin: 24rpx;
}

.no-permission-content {
  padding: 40rpx 20rpx;
  text-align: center;
}

.no-permission-icon {
  display: block;
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.no-permission-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  margin-bottom: 16rpx;
}

.no-permission-desc {
  display: block;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.7;
  max-width: 520rpx;
  margin: 0 auto;
}

.go-vote-btn {
  margin-top: 32rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #FFFFFF;
  background: linear-gradient(135deg, var(--color-primary) 0%, #FF8E8E 100%);
  border-radius: var(--radius-full);
  border: none;
}

.go-vote-btn::after {
  border: none;
}

.action-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 32rpx calc(20rpx + env(safe-area-inset-bottom));
  background-color: var(--color-bg-card);
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
  display: flex;
  align-items: center;
  gap: 20rpx;
  z-index: 100;
}

.action-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  background-color: var(--color-bg-input);
  border-radius: var(--radius-full);
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.share-btn {
  color: var(--color-info);
  background-color: rgba(52, 152, 219, 0.1);
}

.publish-btn {
  color: #FFFFFF;
  background: linear-gradient(135deg, #8B5CF6 0%, #A78BFA 100%);
  box-shadow: 0 6rpx 20rpx rgba(139, 92, 246, 0.35);
}

.action-btn::after {
  border: none;
}

.btn-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.loading-wrap,
.empty-wrap {
  min-height: 60vh;
  display: flex;
  align-items: center;
  justify-content: center;
}

.loading-text,
.empty-wrap text {
  font-size: 28rpx;
  color: var(--color-text-secondary);
}
