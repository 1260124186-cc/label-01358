.page {
  min-height: 100vh;
  background-color: var(--color-bg-page);
  padding-bottom: calc(180rpx + env(safe-area-inset-bottom));
}

.form-scroll {
  height: 100vh;
}

.form-container {
  padding: 20rpx 24rpx;
}

.form-section {
  margin-bottom: 24rpx;
}

.section-header {
  display: flex;
  align-items: center;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid var(--color-border-light);
}

.section-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  flex: 1;
}

.section-count {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  font-weight: 400;
}

.form-item {
  padding: 20rpx 0;
}

.form-item + .form-item {
  border-top: 1rpx solid var(--color-border-light);
}

.form-label {
  display: block;
  font-size: 26rpx;
  font-weight: 500;
  color: var(--color-text-primary);
  margin-bottom: 16rpx;
}

.form-label.required::before {
  content: '*';
  color: #FF6B6B;
  margin-right: 4rpx;
}

.form-input {
  width: 100%;
  box-sizing: border-box;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: var(--color-text-primary);
  background-color: var(--color-bg-input);
  border-radius: var(--radius-md);
  border: none;
}

.number-input {
  width: 240rpx;
}

.form-textarea {
  width: 100%;
  box-sizing: border-box;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: var(--color-text-primary);
  background-color: var(--color-bg-input);
  border-radius: var(--radius-md);
  line-height: 1.6;
  min-height: 120rpx;
  border: none;
}

.form-hint {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  line-height: 1.5;
}

.option-group {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.option-item {
  padding: 16rpx 32rpx;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  background-color: var(--color-bg-input);
  border-radius: var(--radius-md);
  border: 2rpx solid transparent;
  transition: all var(--transition-fast);
}

.option-item.active {
  color: var(--color-primary);
  background-color: var(--color-primary-light);
  border-color: var(--color-primary);
  font-weight: 500;
}

.option-text {
  font-size: 26rpx;
}

.tag-group {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag-item {
  padding: 14rpx 28rpx;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  background-color: var(--color-bg-input);
  border-radius: var(--radius-full);
  border: 2rpx solid transparent;
  transition: all var(--transition-fast);
}

.tag-item.active {
  color: #FFFFFF;
  background: linear-gradient(135deg, var(--color-primary) 0%, #FF8E8E 100%);
  font-weight: 500;
}

.switch-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.switch-item .form-label {
  margin-bottom: 0;
}

.row-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.row-item .form-label {
  margin-bottom: 0;
  flex-shrink: 0;
}

.datetime-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.datetime-picker {
  flex-shrink: 0;
}

.picker-value {
  padding: 14rpx 24rpx;
  font-size: 26rpx;
  color: var(--color-text-primary);
  background-color: var(--color-bg-input);
  border-radius: var(--radius-md);
}

.candidate-item {
  padding: 20rpx;
  margin-bottom: 20rpx;
  background-color: var(--color-bg-input);
  border-radius: var(--radius-md);
}

.candidate-item:last-child {
  margin-bottom: 0;
}

.candidate-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.candidate-index {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-primary);
}

.remove-btn {
  padding: 8rpx 20rpx;
  font-size: 24rpx;
  color: var(--color-danger);
  background-color: rgba(231, 76, 60, 0.1);
  border-radius: var(--radius-sm);
}

.candidate-item .form-input {
  margin-bottom: 16rpx;
  background-color: var(--color-bg-card);
}

.candidate-item .form-textarea {
  background-color: var(--color-bg-card);
  min-height: 100rpx;
}

.add-candidate-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 28rpx;
  margin-top: 20rpx;
  background-color: var(--color-bg-input);
  border: 2rpx dashed var(--color-border);
  border-radius: var(--radius-md);
  transition: all var(--transition-fast);
}

.add-icon {
  font-size: 36rpx;
  color: var(--color-primary);
  margin-right: 12rpx;
  font-weight: 300;
}

.add-text {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  font-weight: 500;
}

.form-tips {
  display: flex;
  align-items: flex-start;
  padding: 24rpx;
  margin-bottom: 24rpx;
  background-color: rgba(243, 156, 18, 0.1);
  border-radius: var(--radius-md);
}

.tips-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.tips-text {
  font-size: 24rpx;
  color: var(--color-warning);
  line-height: 1.6;
  flex: 1;
}

.submit-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 32rpx calc(20rpx + env(safe-area-inset-bottom));
  background-color: var(--color-bg-card);
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
  z-index: 100;
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
  background: linear-gradient(135deg, var(--color-primary) 0%, #FF8E8E 100%);
  border-radius: var(--radius-full);
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 107, 0.35);
}

.submit-btn.disabled {
  opacity: 0.6;
}

.submit-btn::after {
  border: none;
}

.hover-scale {
  transform: scale(0.98);
}
