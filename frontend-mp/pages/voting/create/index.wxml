<page-meta page-style="background-color: {{darkMode ? '#0F1117' : '#F8F9FA'}}; color: {{darkMode ? '#E8ECF1' : '#2C3E50'}}"/>
<view class="page {{darkMode ? 'dark' : ''}}">
  <scroll-view class="form-scroll" scroll-y="{{true}}" enhanced="{{true}}" show-scrollbar="{{false}}">
    <view class="form-container">
      <view class="form-section card">
        <view class="section-header">
          <text class="section-icon">📋</text>
          <text class="section-title">基本信息</text>
        </view>
        <view class="card-body">
          <view class="form-item">
            <text class="form-label required">投票标题</text>
            <input
              class="form-input"
              placeholder="请输入投票标题，如：学生会主席选举"
              value="{{formData.title}}"
              bindinput="onTitleInput"
              maxlength="50"
            />
          </view>
          <view class="form-item">
            <text class="form-label">投票说明</text>
            <textarea
              class="form-textarea"
              placeholder="请输入投票的详细说明，帮助投票人了解投票内容"
              value="{{formData.description}}"
              bindinput="onDescInput"
              maxlength="500"
              auto-height
            />
          </view>
        </view>
      </view>

      <view class="form-section card">
        <view class="section-header">
          <text class="section-icon">⚙️</text>
          <text class="section-title">投票设置</text>
        </view>
        <view class="card-body">
          <view class="form-item">
            <text class="form-label">投票类型</text>
            <view class="option-group">
              <view
                wx:for="{{votingTypes}}"
                wx:key="value"
                class="option-item {{formData.type === item.value ? 'active' : ''}}"
                bindtap="onTypeChange"
                data-value="{{item.value}}"
              >
                <text class="option-text">{{item.label}}</text>
              </view>
            </view>
          </view>
          <view class="form-item" wx:if="{{formData.type === 'multiple'}}">
            <text class="form-label">最多可选人数</text>
            <input
              class="form-input number-input"
              type="number"
              placeholder="请输入最多可选人数"
              value="{{formData.maxChoices}}"
              bindinput="onMaxChoicesInput"
            />
          </view>
          <view class="form-item">
            <text class="form-label">投票方式</text>
            <view class="option-group">
              <view
                wx:for="{{visibilityOptions}}"
                wx:key="value"
                class="option-item {{formData.visibility === item.value ? 'active' : ''}}"
                bindtap="onVisibilityChange"
                data-value="{{item.value}}"
              >
                <text class="option-text">{{item.label}}</text>
              </view>
            </view>
            <text class="form-hint">
              {{formData.visibility === 'anonymous' ? '🔒 匿名投票：投票结果中不会显示投票人信息' : '📛 实名投票：投票结果中会显示投票人姓名'}}
            </text>
          </view>
          <view class="form-item switch-item">
            <text class="form-label">投票中实时显示票数</text>
            <switch
              checked="{{formData.showRealTimeResult}}"
              bindchange="onShowRealTimeToggle"
              color="#FF6B6B"
            />
          </view>
        </view>
      </view>

      <view class="form-section card">
        <view class="section-header">
          <text class="section-icon">🎯</text>
          <text class="section-title">投票资格</text>
        </view>
        <view class="card-body">
          <view class="form-item">
            <text class="form-label">参与范围</text>
            <view class="option-group">
              <view
                wx:for="{{eligibilityTypes}}"
                wx:key="value"
                class="option-item {{formData.eligibilityType === item.value ? 'active' : ''}}"
                bindtap="onEligibilityTypeChange"
                data-value="{{item.value}}"
              >
                <text class="option-text">{{item.label}}</text>
              </view>
            </view>
          </view>
          <view class="form-item" wx:if="{{formData.eligibilityType === 'college'}}">
            <text class="form-label required">选择学院</text>
            <view class="tag-group">
              <view
                wx:for="{{colleges}}"
                wx:key="value"
                class="tag-item {{formData.selectedColleges.indexOf(item.value) > -1 ? 'active' : ''}}"
                bindtap="onCollegeToggle"
                data-value="{{item.value}}"
              >
                <text class="tag-text">{{item.label}}</text>
              </view>
            </view>
          </view>
          <view class="form-item" wx:if="{{formData.eligibilityType === 'grade'}}">
            <text class="form-label required">选择年级</text>
            <view class="tag-group">
              <view
                wx:for="{{grades}}"
                wx:key="value"
                class="tag-item {{formData.selectedGrades.indexOf(item.value) > -1 ? 'active' : ''}}"
                bindtap="onGradeToggle"
                data-value="{{item.value}}"
              >
                <text class="tag-text">{{item.label}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>

      <view class="form-section card">
        <view class="section-header">
          <text class="section-icon">📅</text>
          <text class="section-title">投票时间</text>
        </view>
        <view class="card-body">
          <view class="form-item row-item">
            <text class="form-label">开始时间</text>
            <view class="datetime-row">
              <picker mode="date" value="{{formData.startDate}}" bindchange="onStartDateChange" class="datetime-picker">
                <view class="picker-value">{{formData.startDate}}</view>
              </picker>
              <picker mode="time" value="{{formData.startTime}}" bindchange="onStartTimeChange" class="datetime-picker">
                <view class="picker-value">{{formData.startTime}}</view>
              </picker>
            </view>
          </view>
          <view class="form-item row-item">
            <text class="form-label">结束时间</text>
            <view class="datetime-row">
              <picker mode="date" value="{{formData.endDate}}" bindchange="onEndDateChange" class="datetime-picker">
                <view class="picker-value">{{formData.endDate}}</view>
              </picker>
              <picker mode="time" value="{{formData.endTime}}" bindchange="onEndTimeChange" class="datetime-picker">
                <view class="picker-value">{{formData.endTime}}</view>
              </picker>
            </view>
          </view>
        </view>
      </view>

      <view class="form-section card">
        <view class="section-header">
          <text class="section-icon">👥</text>
          <text class="section-title">候选人 / 选项</text>
          <text class="section-count">({{formData.candidates.length}}位)</text>
        </view>
        <view class="card-body">
          <view
            class="candidate-item"
            wx:for="{{formData.candidates}}"
            wx:key="index"
            wx:for-index="cIndex"
          >
            <view class="candidate-header">
              <text class="candidate-index">候选人 {{cIndex + 1}}</text>
              <view
                class="remove-btn"
                bindtap="onRemoveCandidate"
                data-index="{{cIndex}}"
                wx:if="{{formData.candidates.length > 2}}"
              >
                <text>删除</text>
              </view>
            </view>
            <input
              class="form-input"
              placeholder="请输入候选人姓名 / 选项名称"
              value="{{item.name}}"
              bindinput="onCandidateNameInput"
              data-index="{{cIndex}}"
              maxlength="30"
            />
            <textarea
              class="form-textarea"
              placeholder="候选人简介 / 选项说明（选填）"
              value="{{item.description}}"
              bindinput="onCandidateDescInput"
              data-index="{{cIndex}}"
              maxlength="200"
              auto-height
            />
          </view>
          <view class="add-candidate-btn" bindtap="onAddCandidate" hover-class="hover-scale">
            <text class="add-icon">+</text>
            <text class="add-text">添加候选人</text>
          </view>
        </view>
      </view>

      <view class="form-tips">
        <text class="tips-icon">💡</text>
        <text class="tips-text">提交后投票将按照设定的时间自动开始和结束，请仔细核对信息。</text>
      </view>
    </view>
  </scroll-view>

  <view class="submit-bar">
    <button
      class="submit-btn {{submitting ? 'disabled' : ''}}"
      bindtap="onSubmit"
      disabled="{{submitting}}"
      loading="{{submitting}}"
    >
      {{submitting ? '提交中...' : '发布投票'}}
    </button>
  </view>
</view>
