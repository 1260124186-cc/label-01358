.page {
  min-height: 100vh;
  background-color: var(--color-bg-page);
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
}

/* ==================== Hero 统计卡片 ==================== */
.hero-card {
  margin: 24rpx;
  padding: 48rpx 32rpx 40rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 50%, #FFB88C 100%);
  border-radius: var(--radius-2xl);
  position: relative;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(255, 107, 107, 0.3);
}

.hero-bg-circle {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
}

.hero-bg-circle-1 {
  top: -80rpx;
  right: -40rpx;
  width: 300rpx;
  height: 300rpx;
}

.hero-bg-circle-2 {
  bottom: -60rpx;
  left: -30rpx;
  width: 200rpx;
  height: 200rpx;
  background: rgba(255, 255, 255, 0.06);
}

.hero-stats {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 32rpx;
  position: relative;
  z-index: 1;
}

.hero-stat-main {
  display: flex;
  align-items: baseline;
}

.hero-stat-value {
  font-size: 96rpx;
  font-weight: 800;
  color: #FFFFFF;
  line-height: 1;
  text-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.hero-stat-unit {
  font-size: 32rpx;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.85);
  margin-left: 8rpx;
}

.hero-stat-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
}

.hero-stats-row {
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  z-index: 1;
}

.hero-stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.hero-stat-num {
  font-size: 44rpx;
  font-weight: 700;
  color: #FFFFFF;
  line-height: 1.2;
}

.hero-stat-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.75);
  margin-top: 4rpx;
}

.hero-stat-divider {
  width: 1rpx;
  height: 60rpx;
  background-color: rgba(255, 255, 255, 0.3);
}

/* ==================== 学期筛选 ==================== */
.section {
  margin: 0 24rpx 24rpx;
}

.picker-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background-color: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: 24rpx 28rpx;
  box-shadow: var(--shadow-card);
}

.picker-label {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--color-text-primary);
}

.picker-value {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: var(--color-primary);
  font-weight: 500;
}

.picker-arrow {
  margin-left: 8rpx;
  font-size: 24rpx;
}

/* ==================== Section 通用 ==================== */
.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.section-count {
  font-size: 24rpx;
  color: var(--color-text-muted);
}

/* ==================== 分类工时 ==================== */
.category-card {
  background-color: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: 24rpx 28rpx;
  box-shadow: var(--shadow-card);
}

.category-item {
  padding: 16rpx 0;
}

.category-item:not(:last-child) {
  border-bottom: 1rpx solid var(--color-border-light);
}

.category-info {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.category-icon {
  font-size: 30rpx;
  margin-right: 12rpx;
}

.category-label {
  font-size: 26rpx;
  color: var(--color-text-primary);
  font-weight: 500;
  flex: 1;
}

.category-hours {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text-secondary);
}

.bar-track {
  height: 16rpx;
  background-color: var(--color-bg-input);
  border-radius: var(--radius-full);
  overflow: hidden;
}

.bar-fill {
  height: 100%;
  border-radius: var(--radius-full);
  transition: width 0.5s ease;
  min-width: 24rpx;
}

/* ==================== 工时记录 ==================== */
.record-list {
  display: flex;
  flex-direction: column;
}

.record-list > view { margin-bottom: 16rpx; }

.record-list > view:last-child { margin-bottom: 0; }

.record-card {
  display: flex;
  align-items: center;
  background-color: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: 24rpx 28rpx;
  box-shadow: var(--shadow-card);
  transition: all var(--transition-fast);
}

.record-card:active {
  transform: scale(0.98);
  background-color: var(--color-bg-input);
}

.record-main {
  flex: 1;
  min-width: 0;
}

.record-title {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: var(--color-text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 8rpx;
}

.record-meta {
  display: flex;
  align-items: center;
}

.record-meta > view { margin-right: 12rpx; }

.record-meta > view:last-child { margin-right: 0; }

.record-tag {
  font-size: 22rpx;
  font-weight: 500;
  padding: 4rpx 14rpx;
  border-radius: var(--radius-sm);
}

.record-date {
  font-size: 22rpx;
  color: var(--color-text-muted);
}

.record-hours-badge {
  display: flex;
  align-items: baseline;
  justify-content: center;
  padding: 10rpx 20rpx;
  border-radius: var(--radius-lg);
  margin-left: 20rpx;
  flex-shrink: 0;
}

.record-hours-num {
  font-size: 32rpx;
  font-weight: 700;
  color: #FFFFFF;
  line-height: 1;
}

.record-hours-unit {
  font-size: 20rpx;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.85);
  margin-left: 2rpx;
}

/* ==================== 空状态 ==================== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 28rpx;
  color: var(--color-text-muted);
}

/* ==================== 底部按钮 ==================== */
.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background-color: var(--color-bg-card);
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.06);
  z-index: 50;
}

.bottom-actions > view { margin-right: 20rpx; }

.bottom-actions > view:last-child { margin-right: 0; }

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: var(--radius-xl);
  font-size: 28rpx;
  font-weight: 600;
  transition: all var(--transition-fast);
}

.action-btn-icon {
  margin-right: 8rpx;
  font-size: 30rpx;
}

.action-btn-outline {
  background-color: var(--color-bg-card);
  color: var(--color-primary);
  border: 2rpx solid var(--color-primary);
}

.action-btn-primary {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  color: #FFFFFF;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 107, 0.3);
}

.action-btn-hover {
  transform: scale(0.97);
  opacity: 0.9;
}

/* ==================== 暗色模式适配 ==================== */
.dark .hero-card {
  background: linear-gradient(135deg, #8B3A3A 0%, #9E5050 50%, #8B6B50 100%);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.4);
}

.dark .action-btn-primary {
  background: linear-gradient(135deg, #C04040 0%, #D06060 100%);
  box-shadow: 0 4rpx 16rpx rgba(192, 64, 64, 0.3);
}

.dark .action-btn-outline {
  background-color: var(--color-bg-elevated);
  border-color: var(--color-primary);
}

.dark .bottom-actions {
  background-color: var(--color-bg-card);
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.3);
}

.dark .record-card:active {
  background-color: var(--color-bg-elevated);
}
