<page-meta page-style="background-color: {{darkMode ? '#0F1117' : '#F8F9FA'}}; color: {{darkMode ? '#E8ECF1' : '#2C3E50'}}"/>
<view class="page {{darkMode ? 'dark' : ''}}">

  <view class="tab-section">
    <scroll-view class="tab-scroll" scroll-x="{{true}}" enhanced="{{true}}" show-scrollbar="{{false}}">
      <view class="tab-bar">
        <view
          class="tab-item {{currentTab === item.value ? 'active' : ''}}"
          wx:for="{{tabs}}"
          wx:key="value"
          bindtap="onTabTap"
          data-value="{{item.value}}"
        >
          <text class="tab-text">{{item.label}}</text>
          <view class="tab-underline" wx:if="{{currentTab === item.value}}"></view>
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="category-section">
    <scroll-view class="category-scroll" scroll-x="{{true}}" enhanced="{{true}}" show-scrollbar="{{false}}">
      <view class="category-chips">
        <view
          class="category-chip {{currentCategory === item.value ? 'active' : ''}}"
          wx:for="{{categories}}"
          wx:key="value"
          bindtap="onCategoryTap"
          data-value="{{item.value}}"
        >
          <text class="chip-icon">{{item.icon}}</text>
          <text class="chip-label">{{item.label}}</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <scroll-view
    class="list-scroll"
    scroll-y="{{true}}"
    refresher-enabled="{{true}}"
    refresher-triggered="{{refreshing}}"
    bindrefresherrefresh="onRefresh"
  >
    <view class="list-container" wx:if="{{activityList.length > 0}}">
      <view
        class="activity-card"
        wx:for="{{activityList}}"
        wx:key="id"
        hover-class="activity-card-hover"
        bindtap="onNavToDetail"
        data-id="{{item.id}}"
      >
        <view class="card-top">
          <view class="category-tag" style="background-color: {{item.categoryColor}}20; color: {{item.categoryColor}}">
            <text class="category-tag-icon">{{item.categoryIcon}}</text>
            <text class="category-tag-text">{{item.categoryLabel}}</text>
          </view>
          <view class="status-tag status-{{item.status}}" style="color: {{item.statusColor}}; background-color: {{item.statusColor}}15;">
            {{item.statusLabel}}
          </view>
        </view>

        <text class="card-title">{{item.title}}</text>

        <view class="card-info">
          <view class="info-row">
            <text class="info-icon">🕐</text>
            <text class="info-text">{{item.timeText}}</text>
          </view>
          <view class="info-row" wx:if="{{item.location}}">
            <text class="info-icon">📍</text>
            <text class="info-text">{{item.location}}</text>
          </view>
          <view class="info-row" wx:if="{{item.hours}}">
            <text class="info-icon">⏱️</text>
            <text class="info-text">{{item.hours}}小时</text>
          </view>
          <view class="info-row">
            <text class="info-icon">👥</text>
            <text class="info-text">{{item.registrationCount}}/{{item.requiredCount}}人</text>
          </view>
        </view>

        <view class="card-bottom" wx:if="{{item.canRegister}}">
          <view class="register-btn" catchtap="onNavToDetail" data-id="{{item.id}}">
            立即报名
          </view>
        </view>
      </view>
    </view>

    <empty
      wx:if="{{activityList.length === 0}}"
      text="暂无志愿活动"
    />
  </scroll-view>

  <view class="bottom-bar">
    <view class="bottom-bar-inner">
      <view class="bottom-btn" bindtap="onMyHours">
        <text class="bottom-btn-icon">⏱️</text>
        <text class="bottom-btn-text">我的工时</text>
      </view>
      <view class="bottom-divider"></view>
      <view class="bottom-btn" bindtap="onLeaderboard">
        <text class="bottom-btn-icon">🏆</text>
        <text class="bottom-btn-text">排行榜</text>
      </view>
      <view class="bottom-divider"></view>
      <view class="bottom-btn bottom-btn-primary" bindtap="onPublish">
        <text class="bottom-btn-icon">➕</text>
        <text class="bottom-btn-text">发布活动</text>
      </view>
    </view>
  </view>

</view>
