<page-meta page-style="{{darkMode ? '--dark-mode: 1;' : ''}}" />

<view class="publish-page {{darkMode ? 'dark' : ''}}">
  <scroll-view class="form-scroll" scroll-y>
    <view class="form-section">
      <view class="section-header">
        <text class="section-icon">📋</text>
        <text class="section-title">基本信息</text>
      </view>

      <view class="form-item">
        <view class="form-label required">活动标题</view>
        <input
          class="form-input"
          placeholder="请输入志愿活动标题"
          placeholder-class="input-placeholder"
          value="{{formData.title}}"
          data-field="title"
          bindinput="onInputChange"
          maxlength="50"
        />
      </view>

      <view class="form-item">
        <view class="form-label required">活动分类</view>
        <picker
          mode="selector"
          range="{{categories}}"
          range-key="label"
          value="{{categoryIndex}}"
          bindchange="onCategoryChange"
        >
          <view class="picker-view">
            <text wx:if="{{categoryIndex >= 0}}" class="picker-value">
              {{categories[categoryIndex].icon}} {{categories[categoryIndex].label}}
            </text>
            <text wx:else class="picker-placeholder">请选择分类</text>
            <text class="picker-arrow">›</text>
          </view>
        </picker>
      </view>

      <view class="form-item">
        <view class="form-label">活动描述</view>
        <textarea
          class="form-textarea"
          placeholder="请详细描述志愿活动内容、要求等"
          placeholder-class="input-placeholder"
          value="{{formData.description}}"
          data-field="description"
          bindinput="onInputChange"
          maxlength="500"
          auto-height
        />
        <view class="char-count">{{formData.description.length || 0}}/500</view>
      </view>
    </view>

    <view class="form-section">
      <view class="section-header">
        <text class="section-icon">📅</text>
        <text class="section-title">时间地点</text>
      </view>

      <view class="form-item">
        <view class="form-label required">开始时间</view>
        <view class="datetime-row">
          <picker mode="date" value="{{formData.startDate}}" bindchange="onStartDateChange">
            <view class="picker-view datetime-picker">
              <text wx:if="{{formData.startDate}}" class="picker-value">{{formData.startDate}}</text>
              <text wx:else class="picker-placeholder">选择日期</text>
              <text class="picker-arrow">›</text>
            </view>
          </picker>
          <picker mode="time" value="{{formData.startTime}}" bindchange="onStartTimeChange">
            <view class="picker-view datetime-picker">
              <text wx:if="{{formData.startTime}}" class="picker-value">{{formData.startTime}}</text>
              <text wx:else class="picker-placeholder">选择时间</text>
              <text class="picker-arrow">›</text>
            </view>
          </picker>
        </view>
      </view>

      <view class="form-item">
        <view class="form-label required">结束时间</view>
        <view class="datetime-row">
          <picker mode="date" value="{{formData.endDate}}" bindchange="onEndDateChange">
            <view class="picker-view datetime-picker">
              <text wx:if="{{formData.endDate}}" class="picker-value">{{formData.endDate}}</text>
              <text wx:else class="picker-placeholder">选择日期</text>
              <text class="picker-arrow">›</text>
            </view>
          </picker>
          <picker mode="time" value="{{formData.endTime}}" bindchange="onEndTimeChange">
            <view class="picker-view datetime-picker">
              <text wx:if="{{formData.endTime}}" class="picker-value">{{formData.endTime}}</text>
              <text wx:else class="picker-placeholder">选择时间</text>
              <text class="picker-arrow">›</text>
            </view>
          </picker>
        </view>
      </view>

      <view class="form-item">
        <view class="form-label required">活动地点</view>
        <input
          class="form-input"
          placeholder="请输入活动地点"
          placeholder-class="input-placeholder"
          value="{{formData.location}}"
          data-field="location"
          bindinput="onInputChange"
          maxlength="100"
        />
      </view>
    </view>

    <view class="form-section">
      <view class="section-header">
        <text class="section-icon">👥</text>
        <text class="section-title">人数时长</text>
      </view>

      <view class="form-item">
        <view class="form-label required">招募人数</view>
        <input
          class="form-input"
          type="number"
          placeholder="请输入需要招募的志愿者人数"
          placeholder-class="input-placeholder"
          value="{{formData.requiredCount}}"
          data-field="requiredCount"
          bindinput="onInputChange"
        />
      </view>

      <view class="form-item">
        <view class="form-label required">志愿时长（小时）</view>
        <input
          class="form-input"
          type="digit"
          placeholder="请输入每位志愿者可获得的小时数"
          placeholder-class="input-placeholder"
          value="{{formData.hours}}"
          data-field="hours"
          bindinput="onInputChange"
        />
      </view>
    </view>

    <view class="form-section">
      <view class="section-header">
        <text class="section-icon">📞</text>
        <text class="section-title">联系方式</text>
      </view>

      <view class="form-item">
        <view class="form-label">联系人</view>
        <input
          class="form-input"
          placeholder="请输入联系人姓名"
          placeholder-class="input-placeholder"
          value="{{formData.contactName}}"
          data-field="contactName"
          bindinput="onInputChange"
          maxlength="20"
        />
      </view>

      <view class="form-item">
        <view class="form-label">联系电话</view>
        <input
          class="form-input"
          type="number"
          placeholder="请输入联系电话"
          placeholder-class="input-placeholder"
          value="{{formData.contactPhone}}"
          data-field="contactPhone"
          bindinput="onInputChange"
          maxlength="11"
        />
      </view>
    </view>

    <view class="bottom-spacer"></view>
  </scroll-view>

  <view class="submit-bar">
    <button
      class="submit-btn {{submitting ? 'disabled' : ''}}"
      bindtap="onSubmit"
      disabled="{{submitting}}"
    >
      {{submitting ? '发布中...' : '发布活动'}}
    </button>
  </view>
</view>
