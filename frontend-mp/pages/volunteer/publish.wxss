.publish-page {
  min-height: 100vh;
  background: #f8f9fa;
  display: flex;
  flex-direction: column;
}

.publish-page.dark {
  background: #1a1a2e;
}

.form-scroll {
  flex: 1;
  height: calc(100vh - 140rpx);
}

.form-section {
  margin: 20rpx 30rpx 0;
  padding: 30rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.publish-page.dark .form-section {
  background: #16213e;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.2);
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.section-header > view { margin-right: 10rpx; }

.section-header > view:last-child { margin-right: 0; }

.publish-page.dark .section-header {
  border-bottom-color: #0f3460;
}

.section-icon {
  font-size: 30rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
}

.publish-page.dark .section-title {
  color: #e0e0e0;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 15rpx;
}

.publish-page.dark .form-label {
  color: #e0e0e0;
}

.form-label.required::before {
  content: '*';
  color: #FF6B6B;
  margin-right: 6rpx;
}

.form-input {
  width: 100%;
  height: 88rpx;
  padding: 0 25rpx;
  background: #f8f9fa;
  border: 2rpx solid #eee;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.publish-page.dark .form-input {
  background: #1a1a2e;
  border-color: #0f3460;
  color: #e0e0e0;
}

.form-input:focus {
  border-color: #10B981;
}

.input-placeholder {
  color: #bbb;
}

.picker-view {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 25rpx;
  background: #f8f9fa;
  border: 2rpx solid #eee;
  border-radius: 12rpx;
}

.publish-page.dark .picker-view {
  background: #1a1a2e;
  border-color: #0f3460;
}

.picker-value {
  font-size: 28rpx;
  color: #333;
}

.publish-page.dark .picker-value {
  color: #e0e0e0;
}

.picker-placeholder {
  font-size: 28rpx;
  color: #bbb;
}

.picker-arrow {
  font-size: 32rpx;
  color: #999;
  font-weight: 300;
}

.datetime-row {
  display: flex;
}

.datetime-row > view { margin-right: 15rpx; }

.datetime-row > view:last-child { margin-right: 0; }

.datetime-picker {
  flex: 1;
}

.form-textarea {
  width: 100%;
  min-height: 200rpx;
  padding: 20rpx 25rpx;
  background: #f8f9fa;
  border: 2rpx solid #eee;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  box-sizing: border-box;
}

.publish-page.dark .form-textarea {
  background: #1a1a2e;
  border-color: #0f3460;
  color: #e0e0e0;
}

.char-count {
  text-align: right;
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}

.bottom-spacer {
  height: 40rpx;
}

.submit-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  background: #fff;
  border-top: 1rpx solid #eee;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}

.publish-page.dark .submit-bar {
  background: #16213e;
  border-top-color: #0f3460;
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #10B981 0%, #059669 100%);
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
  border: none;
  box-shadow: 0 6rpx 20rpx rgba(16, 185, 129, 0.35);
}

.submit-btn::after {
  border: none;
}

.submit-btn.disabled {
  opacity: 0.6;
}
