.page {
  min-height: 100vh;
  background-color: var(--color-bg-page);
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.header-section {
  padding: 32rpx;
  background: linear-gradient(135deg, var(--color-primary) 0%, #FF8E8E 100%);
}

.header-title {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.header-title > * { margin-right: 12rpx; }

.header-title > *:last-child { margin-right: 0; }

.title-icon {
  font-size: 48rpx;
}

.title-text {
  font-size: 40rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.header-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-left: 60rpx;
}

.tabs-section {
  background-color: var(--color-bg-card);
  position: sticky;
  top: 0;
  z-index: 10;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.tabs-scroll {
  white-space: nowrap;
}

.tabs-wrap {
  display: inline-flex;
  padding: 20rpx 24rpx;
}

.tabs-wrap > * { margin-right: 16rpx; }

.tabs-wrap > *:last-child { margin-right: 0; }

.tab-item {
  display: inline-flex;
  align-items: center;
  padding: 16rpx 32rpx;
  background-color: var(--color-bg-page);
  border-radius: var(--radius-full);
  transition: all 0.2s ease;
}

.tab-item > * { margin-right: 8rpx; }

.tab-item > *:last-child { margin-right: 0; }

.tab-item:active {
  transform: scale(0.96);
}

.tab-item.active {
  background: linear-gradient(135deg, var(--color-primary) 0%, #FF8E8E 100%);
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 107, 0.3);
}

.tab-icon {
  font-size: 28rpx;
}

.tab-text {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--color-text-secondary);
}

.tab-item.active .tab-text {
  color: #FFFFFF;
}

.collections-section {
  padding: 24rpx;
}

.collection-card {
  margin-bottom: 24rpx;
  background-color: var(--color-bg-card);
  border-radius: var(--radius-2xl);
  overflow: hidden;
  box-shadow: var(--shadow-card);
  transition: all 0.2s ease;
}

.collection-card:active {
  transform: scale(0.98);
}

.card-image-wrap {
  position: relative;
  width: 100%;
  height: 320rpx;
}

.card-image {
  width: 100%;
  height: 100%;
}

.card-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
}

.card-badge {
  position: absolute;
  top: 20rpx;
  left: 20rpx;
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: rgba(255, 255, 255, 0.95);
  border-radius: 50%;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}

.badge-icon {
  font-size: 32rpx;
}

.card-stats {
  position: absolute;
  bottom: 16rpx;
  right: 16rpx;
  display: flex;
}

.card-stats > * { margin-right: 16rpx; }

.card-stats > *:last-child { margin-right: 0; }

.stat-item {
  padding: 8rpx 16rpx;
  background-color: rgba(0, 0, 0, 0.5);
  border-radius: var(--radius-full);
  font-size: 22rpx;
  color: #FFFFFF;
  backdrop-filter: blur(10rpx);
}

.card-content {
  padding: 24rpx;
}

.card-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  margin-bottom: 12rpx;
}

.card-desc {
  display: block;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.5;
  margin-bottom: 20rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.card-preview {
  display: flex;
}

.card-preview > * { margin-right: 8rpx; }

.card-preview > *:last-child { margin-right: 0; }

.preview-image {
  width: calc((100% - 24rpx) / 4);
  height: 120rpx;
  border-radius: var(--radius-md);
}

.preview-more {
  width: calc((100% - 24rpx) / 4);
  height: 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: var(--color-bg-page);
  border-radius: var(--radius-md);
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-muted);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 16rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: var(--color-text-muted);
}

.detail-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: flex-end;
  z-index: 1000;
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.detail-content {
  width: 100%;
  height: 85vh;
  background-color: var(--color-bg-card);
  border-radius: var(--radius-2xl) var(--radius-2xl) 0 0;
  display: flex;
  flex-direction: column;
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.detail-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid var(--color-border);
}

.detail-title-wrap {
  display: flex;
  align-items: flex-start;
  flex: 1;
}

.detail-title-wrap > * { margin-right: 16rpx; }

.detail-title-wrap > *:last-child { margin-right: 0; }

.detail-icon {
  font-size: 56rpx;
  flex-shrink: 0;
}

.detail-title-content {
  display: flex;
  flex-direction: column;
  flex: 1;
  min-width: 0;
}

.detail-title-content > * { margin-bottom: 8rpx; }

.detail-title-content > *:last-child { margin-bottom: 0; }

.detail-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

.detail-desc {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.5;
}

.close-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: var(--color-bg-page);
  border-radius: 50%;
  font-size: 28rpx;
  color: var(--color-text-muted);
  flex-shrink: 0;
  margin-left: 16rpx;
}

.detail-stats {
  display: flex;
  justify-content: space-around;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--color-border);
}

.detail-stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.detail-stat-item > * { margin-bottom: 8rpx; }

.detail-stat-item > *:last-child { margin-bottom: 0; }

.stat-value {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

.stat-label {
  font-size: 24rpx;
  color: var(--color-text-muted);
}

.detail-list {
  flex: 1;
  overflow-y: auto;
  padding: 24rpx;
}

.list-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.list-header > * { margin-right: 12rpx; }

.list-header > *:last-child { margin-right: 0; }

.section-icon {
  width: 8rpx;
  height: 32rpx;
  border-radius: 4rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

.list-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.list-grid {
  display: flex;
  flex-wrap: wrap;
}

.list-grid { margin-right: -16rpx; margin-bottom: -16rpx; }

.list-grid > * { margin-right: 16rpx; margin-bottom: 16rpx; }

.list-item {
  width: calc((100% - 16rpx) / 2);
  background-color: var(--color-bg-page);
  border-radius: var(--radius-xl);
  overflow: hidden;
  transition: transform 0.2s ease;
}

.list-item:active {
  transform: scale(0.96);
}

.item-image {
  width: 100%;
  height: 240rpx;
}

.item-info {
  padding: 16rpx;
}

.item-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-meta {
  display: flex;
}

.item-meta > * { margin-right: 16rpx; }

.item-meta > *:last-child { margin-right: 0; }

.meta-item {
  font-size: 22rpx;
  color: var(--color-text-muted);
}

.bottom-spacing {
  height: 40rpx;
}

.page.dark .tab-item {
  background-color: rgba(255, 255, 255, 0.08);
}

.page.dark .tab-item.active {
  background: linear-gradient(135deg, var(--color-primary) 0%, #FF8E8E 100%);
}

.page.dark .tab-text {
  color: rgba(255, 255, 255, 0.7);
}

.page.dark .tab-item.active .tab-text {
  color: #FFFFFF;
}

.page.dark .close-btn {
  background-color: rgba(255, 255, 255, 0.1);
}

.page.dark .preview-more {
  background-color: rgba(255, 255, 255, 0.08);
}
