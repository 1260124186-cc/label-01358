.page {
  min-height: 100vh;
  background-color: var(--color-bg-page);
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

/* 头像区域 */
.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 24rpx;
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
  margin-bottom: 20rpx;
}

.avatar-wrap {
  position: relative;
  width: 160rpx;
  height: 160rpx;
}

.avatar-btn {
  padding: 0;
  margin: 0;
  background: transparent;
  border: none;
  line-height: normal;
  width: 160rpx;
  height: 160rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-btn::after {
  border: none;
}

.avatar-image {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 6rpx solid rgba(255, 255, 255, 0.9);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
}

.avatar-edit {
  position: absolute;
  right: 0;
  bottom: 0;
  width: 48rpx;
  height: 48rpx;
  background-color: #FFFFFF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}

.edit-icon {
  font-size: 24rpx;
  color: var(--color-primary);
}

.avatar-tip {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 16rpx;
}

/* 表单区域 */
.form-section {
  padding: 0 24rpx;
  margin-top: -20rpx;
}

.form-card {
  background-color: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: 0 24rpx;
  box-shadow: var(--shadow-card);
}

.form-item {
  display: flex;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 1rpx solid var(--color-border);
}

.form-item.no-border {
  border-bottom: none;
}

.form-label {
  width: 160rpx;
  font-size: 28rpx;
  color: var(--color-text-primary);
  flex-shrink: 0;
  line-height: 40rpx;
}

.form-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--color-text-primary);
  text-align: right;
  line-height: 40rpx;
  height: 40rpx;
}

.form-input::placeholder {
  color: var(--color-text-tertiary);
}

/* picker组件需要占满剩余空间 */
.form-picker-wrap {
  flex: 1;
}

.form-picker {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  height: 40rpx;
}

.picker-text {
  font-size: 28rpx;
  color: var(--color-text-primary);
  line-height: 40rpx;
}

.picker-text.placeholder {
  color: var(--color-text-tertiary);
}

.picker-arrow {
  font-size: 28rpx;
  color: var(--color-text-tertiary);
  margin-left: 8rpx;
  line-height: 40rpx;
}

/* 保存按钮 */
.submit-section {
  padding: 40rpx 24rpx;
}
