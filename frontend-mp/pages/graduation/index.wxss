.page {
  min-height: 100vh;
  padding-bottom: 180rpx;
  background: #F8F9FA;
}

.page.dark {
  background: #0F1117;
}

.header-banner {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  padding: 48rpx 32rpx 40rpx;
  margin-bottom: 24rpx;
}

.banner-content {
  margin-bottom: 32rpx;
}

.banner-title {
  display: block;
  font-size: 44rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.banner-subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

.student-info {
  background: rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
  padding: 24rpx;
  backdrop-filter: blur(10rpx);
}

.info-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.info-row:last-child {
  margin-bottom: 0;
}

.info-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  width: 100rpx;
}

.info-value {
  font-size: 26rpx;
  color: #FFFFFF;
  font-weight: 500;
}

.progress-section {
  margin: 0 32rpx 24rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.page.dark .progress-section {
  background: #1A1D26;
}

.progress-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.progress-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #2C3E50;
}

.page.dark .progress-title {
  color: #E8ECF1;
}

.progress-percent {
  font-size: 36rpx;
  font-weight: 700;
  color: #FF6B6B;
}

.progress-bar {
  width: 100%;
  height: 16rpx;
  background: #E5E7EB;
  border-radius: 8rpx;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.page.dark .progress-bar {
  background: #2D3139;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #FF6B6B 0%, #FF8E8E 100%);
  border-radius: 8rpx;
  transition: width 0.3s ease;
}

.progress-stats {
  text-align: right;
}

.stats-text {
  font-size: 24rpx;
  color: #6B7280;
}

.page.dark .stats-text {
  color: #9CA3AF;
}

.checklist-section {
  margin: 0 32rpx;
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #2C3E50;
}

.page.dark .section-title {
  color: #E8ECF1;
}

.checklist-container {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.check-item {
  display: flex;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  transition: all 0.2s ease;
}

.page.dark .check-item {
  background: #1A1D26;
}

.check-item:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.check-item.completed {
  opacity: 0.85;
}

.item-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.item-icon text {
  font-size: 40rpx;
}

.item-content {
  flex: 1;
  min-width: 0;
}

.item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.item-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #2C3E50;
}

.page.dark .item-name {
  color: #E8ECF1;
}

.item-status {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  flex-shrink: 0;
}

.status-text {
  font-size: 22rpx;
}

.item-desc {
  display: block;
  font-size: 24rpx;
  color: #6B7280;
  margin-bottom: 12rpx;
  line-height: 1.5;
}

.page.dark .item-desc {
  color: #9CA3AF;
}

.item-meta {
  display: flex;
  gap: 24rpx;
  margin-bottom: 12rpx;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.meta-icon {
  font-size: 24rpx;
}

.meta-text {
  font-size: 22rpx;
  color: #6B7280;
}

.page.dark .meta-text {
  color: #9CA3AF;
}

.item-department {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 16rpx;
  background: #ECFDF5;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
}

.page.dark .item-department {
  background: rgba(16, 185, 129, 0.1);
}

.dept-icon {
  font-size: 24rpx;
}

.dept-text {
  font-size: 22rpx;
  color: #10B981;
  font-weight: 500;
  flex: 1;
}

.sign-time {
  font-size: 20rpx;
  color: #6B7280;
}

.item-action {
  padding-top: 12rpx;
  border-top: 1rpx solid #F3F4F6;
}

.page.dark .item-action {
  border-top-color: #2D3139;
}

.action-text {
  font-size: 24rpx;
  color: #FF6B6B;
  font-weight: 500;
}

.item-action.processing .action-text {
  color: #3B82F6;
}

.item-action.completed .action-text {
  color: #10B981;
}

.bottom-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  background: #FFFFFF;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.08);
  z-index: 100;
}

.page.dark .bottom-section {
  background: #1A1D26;
}

.action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  height: 96rpx;
  border-radius: 48rpx;
  transition: all 0.2s ease;
}

.action-btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.action-btn.primary {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
}

.action-btn.success {
  background: linear-gradient(135deg, #10B981 0%, #34D399 100%);
}

.action-btn.disabled {
  background: #E5E7EB;
}

.page.dark .action-btn.disabled {
  background: #2D3139;
}

.btn-icon {
  font-size: 36rpx;
}

.action-btn .btn-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.action-btn.disabled .btn-text {
  color: #9CA3AF;
}

.certificate-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  visibility: hidden;
  opacity: 0;
  transition: all 0.3s ease;
}

.certificate-modal.show {
  visibility: visible;
  opacity: 1;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
}

.modal-content {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%) scale(0.9);
  width: 650rpx;
  max-height: 85vh;
  transition: all 0.3s ease;
}

.certificate-modal.show .modal-content {
  transform: translate(-50%, -50%) scale(1);
}

.certificate-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  overflow: hidden;
}

.page.dark .certificate-card {
  background: #1A1D26;
}

.cert-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
}

.cert-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.cert-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(255, 255, 255, 0.9);
  font-size: 28rpx;
}

.cert-body {
  padding: 32rpx;
  max-height: 60vh;
  overflow-y: auto;
}

.cert-info {
  display: flex;
  margin-bottom: 16rpx;
}

.cert-label {
  font-size: 26rpx;
  color: #6B7280;
  width: 140rpx;
}

.page.dark .cert-label {
  color: #9CA3AF;
}

.cert-value {
  font-size: 26rpx;
  color: #2C3E50;
  font-weight: 500;
  flex: 1;
}

.page.dark .cert-value {
  color: #E8ECF1;
}

.cert-divider {
  height: 1rpx;
  background: #E5E7EB;
  margin: 24rpx 0;
}

.page.dark .cert-divider {
  background: #2D3139;
}

.cert-items-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2C3E50;
  margin-bottom: 16rpx;
}

.page.dark .cert-items-title {
  color: #E8ECF1;
}

.cert-items {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.cert-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx;
  background: #F9FAFB;
  border-radius: 12rpx;
}

.page.dark .cert-item {
  background: #2D3139;
}

.cert-item-left {
  flex: 1;
}

.cert-item-name {
  display: block;
  font-size: 26rpx;
  color: #2C3E50;
  font-weight: 500;
  margin-bottom: 4rpx;
}

.page.dark .cert-item-name {
  color: #E8ECF1;
}

.cert-item-dept {
  font-size: 22rpx;
  color: #6B7280;
}

.page.dark .cert-item-dept {
  color: #9CA3AF;
}

.cert-item-sign {
  font-size: 24rpx;
  color: #10B981;
  font-weight: 500;
}

.cert-qrcode {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx;
  background: #F9FAFB;
  border-radius: 16rpx;
}

.page.dark .cert-qrcode {
  background: #2D3139;
}

.qrcode-img {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 12rpx;
}

.qrcode-text {
  font-size: 22rpx;
  color: #6B7280;
}

.page.dark .qrcode-text {
  color: #9CA3AF;
}

.cert-footer {
  padding: 24rpx 32rpx 32rpx;
}

.cert-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  background: linear-gradient(135deg, #10B981 0%, #34D399 100%);
  border-radius: 44rpx;
}

.cert-btn .btn-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #FFFFFF;
}
