<page-meta page-style="background-color: {{darkMode ? '#0F1117' : '#F8F9FA'}}; color: {{darkMode ? '#E8ECF1' : '#2C3E50'}}"/>
<view class="page {{darkMode ? 'dark' : ''}}">
  <view class="tabs-section">
    <view
      class="tab-item {{currentTab === item.value ? 'active' : ''}}"
      wx:for="{{tabs}}"
      wx:key="value"
      bindtap="onTabChange"
      data-tab="{{item.value}}"
    >{{item.label}}</view>
  </view>

  <scroll-view class="list-scroll" scroll-y="{{true}}">
    <view class="list-container" wx:if="{{list.length > 0}}">
      <view
        class="item-card"
        wx:for="{{list}}"
        wx:key="id"
        hover-class="item-card-hover"
        bindtap="onItemTap"
        data-item="{{item}}"
      >
        <image
          class="item-image"
          src="{{item.images[0] || '/assets/images/default-goods.png'}}"
          mode="aspectFill"
        />
        <view class="item-info">
          <view class="item-header">
            <view class="item-type-tag {{item.type}}">
              {{item.typeText}}
            </view>
            <view class="item-status-tag status-{{item.status}}">
              {{item.statusText}}
            </view>
            <view class="claim-manage-badge" wx:if="{{item.pendingClaimCount > 0}}">
              <text>{{item.pendingClaimCount}}待审核</text>
            </view>
          </view>
          <text class="item-title">{{item.title}}</text>
          <text class="item-desc">{{item.description}}</text>
          <view class="item-claim-info" wx:if="{{item.status === 'claim_pending' || item.status === 'verifying' || item.status === 'resolved'}}">
            <text class="claim-info-icon">🔔</text>
            <text class="claim-info-text" wx:if="{{item.status === 'claim_pending'}}">有认领申请待处理</text>
            <text class="claim-info-text" wx:elif="{{item.status === 'verifying'}}">核验中，请联系认领人</text>
            <text class="claim-info-text" wx:elif="{{item.status === 'resolved'}}">已完成，感谢您的参与</text>
          </view>
          <view class="item-meta">
            <text class="item-meta-text">{{item.itemTypeText}}</text>
            <text class="item-meta-dot">·</text>
            <text class="item-meta-text">{{item.timeText}}</text>
          </view>
        </view>
        <view class="item-actions">
          <view class="action-btn action-claim-manage" catchtap="onManageClaims" data-item="{{item}}" wx:if="{{item.status !== 'closed'}}">
            <text>认领管理</text>
            <view class="claim-dot" wx:if="{{item.pendingClaimCount > 0}}"></view>
          </view>
          <view class="action-btn action-edit" catchtap="onEdit" data-item="{{item}}">
            <text>编辑</text>
          </view>
          <view class="action-btn action-status" catchtap="onToggleStatus" data-item="{{item}}">
            <text>{{item.status === 'active' ? '关闭' : '开启'}}</text>
          </view>
          <view class="action-btn action-delete" catchtap="onDelete" data-item="{{item}}">
            <text>删除</text>
          </view>
        </view>
      </view>
    </view>

    <empty
      wx:if="{{list.length === 0}}"
      text="暂无发布记录"
    />
  </scroll-view>
</view>
