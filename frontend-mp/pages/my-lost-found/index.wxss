.page {
  min-height: 100vh;
  background-color: var(--color-bg-page);
}

.tabs-section {
  display: flex;
  background-color: var(--color-bg-card);
  padding: 0 24rpx;
  border-bottom: 1rpx solid var(--color-border);
  box-shadow: var(--shadow-sm);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 28rpx 0;
  font-size: 28rpx;
  color: var(--color-text-secondary);
  position: relative;
  transition: all 0.2s ease;
}

.tab-item.active {
  color: var(--color-primary);
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  left: 50%;
  bottom: 0;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  background: linear-gradient(90deg, var(--color-primary), var(--color-primary-dark));
  border-radius: 3rpx;
}

.list-scroll {
  height: calc(100vh - 90rpx);
}

.list-container {
  padding: 24rpx;
}

.item-card {
  display: flex;
  background-color: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-card);
  transition: all 0.2s ease;
}

.item-card-hover {
  transform: scale(0.98);
  box-shadow: var(--shadow-sm);
}

.item-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: var(--radius-lg);
  flex-shrink: 0;
}

.item-info {
  flex: 1;
  margin-left: 20rpx;
  margin-right: 16rpx;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.item-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.item-type-tag {
  display: inline-block;
  padding: 4rpx 12rpx;
  font-size: 22rpx;
  border-radius: 6rpx;
}

.item-type-tag.lost {
  color: var(--color-primary);
  background-color: var(--color-primary-light);
}

.item-type-tag.found {
  color: #0891B2;
  background-color: #CFFAFE;
}

.item-status-tag {
  display: inline-block;
  padding: 4rpx 12rpx;
  font-size: 22rpx;
  border-radius: 6rpx;
}

.item-status-tag.status-active {
  color: #059669;
  background-color: #D1FAE5;
}

.item-status-tag.status-closed {
  color: #6B7280;
  background-color: #F3F4F6;
}

.item-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 8rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  overflow: hidden;
}

.item-desc {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-bottom: 8rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  overflow: hidden;
}

.item-meta {
  display: flex;
  align-items: center;
  margin-top: auto;
}

.item-meta-text {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
}

.item-meta-dot {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
  margin: 0 8rpx;
}

.item-actions {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  flex-shrink: 0;
}

.action-btn {
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  font-size: 22rpx;
  text-align: center;
  transition: all 0.2s ease;
}

.action-btn:active {
  opacity: 0.8;
  transform: scale(0.95);
}

.action-edit {
  background-color: var(--color-primary-light);
  color: var(--color-primary);
}

.action-status {
  background-color: #FEF3C7;
  color: #D97706;
}

.action-delete {
  background-color: #FEE2E2;
  color: #DC2626;
}

.action-claim-manage {
  position: relative;
  background: linear-gradient(135deg, #FEF3C7 0%, #FDE68A 100%);
  color: #B45309;
  font-weight: 600;
}

.claim-dot {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  width: 16rpx;
  height: 16rpx;
  background: #EF4444;
  border-radius: 50%;
  border: 2rpx solid #FFFFFF;
}

.claim-manage-badge {
  padding: 4rpx 12rpx;
  background: linear-gradient(135deg, #F59E0B 0%, #D97706 100%);
  color: #FFFFFF;
  font-size: 20rpx;
  font-weight: 600;
  border-radius: 20rpx;
  margin-left: auto;
  box-shadow: 0 4rpx 8rpx rgba(245, 158, 11, 0.3);
}

.item-claim-info {
  display: flex;
  align-items: center;
  margin-top: 8rpx;
  margin-bottom: 8rpx;
  padding: 8rpx 12rpx;
  background: linear-gradient(135deg, rgba(99, 102, 241, 0.06) 0%, rgba(139, 92, 246, 0.06) 100%);
  border-radius: 8rpx;
  border-left: 4rpx solid #6366F1;
}

.claim-info-icon {
  font-size: 22rpx;
  margin-right: 8rpx;
}

.claim-info-text {
  font-size: 22rpx;
  color: #4F46E5;
  font-weight: 500;
}

.item-status-tag.status-claim_pending {
  color: #B45309;
  background: linear-gradient(135deg, #FEF3C7 0%, #FDE68A 100%);
}

.item-status-tag.status-verifying {
  color: #6D28D9;
  background: linear-gradient(135deg, #EDE9FE 0%, #DDD6FE 100%);
}

.item-status-tag.status-resolved,
.item-status-tag.status-claimed,
.item-status-tag.status-returned {
  color: #047857;
  background: linear-gradient(135deg, #D1FAE5 0%, #A7F3D0 100%);
}

.dark .item-type-tag.found {
  background-color: rgba(8, 145, 178, 0.15);
  color: #22D3EE;
}

.dark .item-status-tag.status-active {
  background-color: rgba(5, 150, 105, 0.15);
  color: #10B981;
}

.dark .item-status-tag.status-closed {
  background-color: rgba(107, 114, 128, 0.15);
  color: #9CA3AF;
}

.dark .item-status-tag.status-claim_pending {
  background: rgba(251, 191, 36, 0.15);
  color: #FBBF24;
}

.dark .item-status-tag.status-verifying {
  background: rgba(167, 139, 250, 0.15);
  color: #A78BFA;
}

.dark .item-status-tag.status-resolved,
.dark .item-status-tag.status-claimed,
.dark .item-status-tag.status-returned {
  background: rgba(52, 211, 153, 0.15);
  color: #34D399;
}

.dark .action-edit {
  background-color: rgba(255, 107, 107, 0.15);
  color: #F87171;
}

.dark .action-status {
  background-color: rgba(251, 191, 36, 0.15);
  color: #FBBF24;
}

.dark .action-delete {
  background-color: rgba(239, 68, 68, 0.15);
  color: #F87171;
}

.dark .action-claim-manage {
  background: rgba(251, 191, 36, 0.15);
  color: #FBBF24;
}

.dark .claim-dot {
  border-color: #1a1d23;
}

.dark .item-claim-info {
  background: rgba(99, 102, 241, 0.1);
  border-left-color: #818CF8;
}

.dark .claim-info-text {
  color: #A5B4FC;
}
