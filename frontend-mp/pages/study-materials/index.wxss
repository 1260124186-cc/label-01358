.study-page {
  min-height: 100vh;
  background: #f8f9fa;
  padding-bottom: 120rpx;
}

.study-page.dark {
  background: #1a1a2e;
}

.search-section {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  background: #fff;
  gap: 20rpx;
}

.study-page.dark .search-section {
  background: #16213e;
}

.search-box {
  flex: 1;
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 40rpx;
  padding: 15rpx 25rpx;
  gap: 15rpx;
}

.study-page.dark .search-box {
  background: #0f3460;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.study-page.dark .search-input {
  color: #e0e0e0;
}

.search-placeholder {
  color: #999;
}

.search-icon {
  font-size: 28rpx;
}

.points-badge {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: linear-gradient(135deg, #FFEAA7, #FDCB6E);
  padding: 12rpx 20rpx;
  border-radius: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(253, 203, 110, 0.3);
}

.points-icon {
  font-size: 24rpx;
}

.points-text {
  font-size: 26rpx;
  font-weight: 600;
  color: #e17055;
}

.tabs {
  display: flex;
  background: #fff;
  padding: 0 30rpx;
  border-bottom: 1rpx solid #eee;
}

.study-page.dark .tabs {
  background: #16213e;
  border-bottom-color: #0f3460;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 25rpx 0;
  font-size: 30rpx;
  color: #666;
  position: relative;
  transition: all 0.3s;
}

.study-page.dark .tab-item {
  color: #888;
}

.tab-item.active {
  color: #FF6B6B;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 6rpx;
  background: #FF6B6B;
  border-radius: 3rpx;
}

.category-scroll {
  white-space: nowrap;
  padding: 20rpx 30rpx;
  background: #fff;
  margin-bottom: 20rpx;
}

.study-page.dark .category-scroll {
  background: #16213e;
}

.category-item {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 15rpx 25rpx;
  margin-right: 15rpx;
  border-radius: 30rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.category-icon {
  font-size: 28rpx;
}

.category-label {
  font-size: 26rpx;
  color: #666;
}

.category-item.active {
  font-weight: 500;
}

.content-section {
  padding: 0 30rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.study-page.dark .empty-text {
  color: #888;
}

.empty-desc {
  font-size: 26rpx;
  color: #999;
}

.materials-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.material-card {
  width: calc(50% - 10rpx);
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  transition: transform 0.2s;
}

.study-page.dark .material-card {
  background: #16213e;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.2);
}

.material-card:active {
  transform: scale(0.98);
}

.card-cover {
  position: relative;
  width: 100%;
  height: 240rpx;
  background: #f0f0f0;
}

.study-page.dark .card-cover {
  background: #0f3460;
}

.cover-image {
  width: 100%;
  height: 100%;
}

.cover-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.placeholder-icon {
  font-size: 60rpx;
  opacity: 0.5;
}

.file-type-badge {
  position: absolute;
  top: 15rpx;
  right: 15rpx;
  background: rgba(0, 0, 0, 0.6);
  color: #fff;
  padding: 6rpx 15rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.card-content {
  padding: 20rpx;
}

.card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.4;
  margin-bottom: 12rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.study-page.dark .card-title {
  color: #e0e0e0;
}

.card-meta {
  margin-bottom: 10rpx;
}

.meta-tag {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 15rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  margin-right: 10rpx;
}

.card-course {
  margin-bottom: 12rpx;
}

.course-label {
  font-size: 24rpx;
  color: #888;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.uploader-name {
  font-size: 22rpx;
  color: #999;
}

.stats {
  display: flex;
  gap: 15rpx;
}

.stat-item {
  font-size: 22rpx;
  color: #999;
}

.card-time {
  font-size: 20rpx;
  color: #bbb;
}

.rewards-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.reward-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 25rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  transition: transform 0.2s;
}

.study-page.dark .reward-card {
  background: #16213e;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.2);
}

.reward-card:active {
  transform: scale(0.98);
}

.reward-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 15rpx;
}

.reward-title {
  flex: 1;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.4;
  padding-right: 20rpx;
}

.study-page.dark .reward-title {
  color: #e0e0e0;
}

.reward-points {
  display: flex;
  align-items: center;
  gap: 6rpx;
  background: linear-gradient(135deg, #FFEAA7, #FDCB6E);
  padding: 10rpx 18rpx;
  border-radius: 25rpx;
  flex-shrink: 0;
}

.reward-points .points-icon {
  font-size: 24rpx;
}

.reward-points .points-value {
  font-size: 28rpx;
  font-weight: 700;
  color: #e17055;
}

.reward-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 18rpx;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.study-page.dark .reward-content {
  color: #aaa;
}

.reward-meta {
  display: flex;
  gap: 12rpx;
  margin-bottom: 15rpx;
  flex-wrap: wrap;
}

.status-tag {
  font-weight: 500;
}

.reward-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.publisher-name {
  font-size: 24rpx;
  color: #999;
}

.reward-stats {
  display: flex;
  gap: 20rpx;
}

.reward-stats .stat-item {
  font-size: 24rpx;
  color: #999;
}

.reward-time {
  font-size: 22rpx;
  color: #bbb;
}

.publish-btn {
  position: fixed;
  right: 40rpx;
  bottom: 140rpx;
  width: 110rpx;
  height: 110rpx;
  background: linear-gradient(135deg, #FF6B6B, #FF8E8E);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 107, 0.4);
  z-index: 100;
  transition: transform 0.2s;
}

.publish-btn:active {
  transform: scale(0.95);
}

.publish-icon {
  font-size: 50rpx;
  color: #fff;
  font-weight: 300;
}

.copyright-tip {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 15rpx 30rpx;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(10rpx);
  border-top: 1rpx solid #eee;
  z-index: 50;
}

.study-page.dark .copyright-tip {
  background: rgba(22, 33, 62, 0.95);
  border-top-color: #0f3460;
}

.tip-icon {
  font-size: 24rpx;
}

.tip-text {
  font-size: 22rpx;
  color: #999;
}

.study-page.dark .tip-text {
  color: #666;
}
