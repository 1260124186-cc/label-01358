.page {
  min-height: 100vh;
  background-color: #F8F9FA;
  padding-bottom: 40rpx;
}

.page.dark {
  background-color: #0F1117;
}

.header-card {
  position: relative;
  margin: 0;
  border-radius: 0 0 32rpx 32rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 50%, #FFA726 100%);
}

.header-content {
  position: relative;
  padding: 32rpx;
  padding-top: 48rpx;
}

.points-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.points-info {
  display: flex;
  flex-direction: column;
}

.points-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-bottom: 8rpx;
}

.points-value {
  font-size: 72rpx;
  font-weight: 700;
  color: #FFFFFF;
  line-height: 1;
}

.header-actions {
  display: flex;
  gap: 16rpx;
}

.header-action {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 20rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
  min-width: 100rpx;
}

.action-icon {
  font-size: 32rpx;
  margin-bottom: 4rpx;
}

.action-text {
  font-size: 22rpx;
  color: #FFFFFF;
}

.validity-card {
  background: rgba(255, 255, 255, 0.15);
  border-radius: 24rpx;
  padding: 24rpx;
}

.validity-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.validity-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.validity-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.validity-content {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
  margin-bottom: 16rpx;
}

.validity-item {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.validity-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
}

.validity-value {
  font-size: 26rpx;
  font-weight: 600;
  color: #FFD700;
}

.validity-desc {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  line-height: 1.6;
}

.tabs-section {
  margin: 24rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 8rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.page.dark .tabs-section {
  background: #1E2128;
}

.tabs-row {
  display: flex;
}

.tab-item {
  flex: 1;
  padding: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  transition: all 0.3s ease;
}

.tab-item.active {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
}

.tab-text {
  font-size: 28rpx;
  color: #666666;
  font-weight: 500;
}

.page.dark .tab-text {
  color: #8B95A7;
}

.tab-item.active .tab-text {
  color: #FFFFFF;
  font-weight: 600;
}

.rules-container {
  padding: 0 24rpx;
}

.rules-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.rule-item {
  display: flex;
  padding: 24rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.page.dark .rule-item {
  background: #1E2128;
}

.rule-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.rule-info {
  flex: 1;
  min-width: 0;
}

.rule-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.rule-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
}

.page.dark .rule-name {
  color: #E8ECF1;
}

.rule-points {
  font-size: 28rpx;
  font-weight: 700;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.rule-desc {
  font-size: 24rpx;
  color: #999999;
  line-height: 1.5;
  margin-bottom: 8rpx;
}

.page.dark .rule-desc {
  color: #8B95A7;
}

.rule-footer {
  display: flex;
  align-items: center;
}

.rule-limit {
  font-size: 22rpx;
  color: #FF6B6B;
  padding: 4rpx 12rpx;
  background: #FFF0F0;
  border-radius: 16rpx;
}

.page.dark .rule-limit {
  background: #2A1F1F;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
}

.page.dark .empty-text {
  color: #8B95A7;
}

.faq-section {
  margin: 24rpx;
  margin-top: 32rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.page.dark .faq-section {
  background: #1E2128;
}

.section-header {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
}

.page.dark .section-title {
  color: #E8ECF1;
}

.faq-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.faq-item {
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.page.dark .faq-item {
  border-bottom-color: #2A2E37;
}

.faq-item:last-child {
  padding-bottom: 0;
  border-bottom: none;
}

.faq-q {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 8rpx;
}

.page.dark .faq-q {
  color: #E8ECF1;
}

.faq-a {
  display: block;
  font-size: 24rpx;
  color: #666666;
  line-height: 1.6;
}

.page.dark .faq-a {
  color: #8B95A7;
}

.contact-section {
  display: flex;
  justify-content: center;
  margin-top: 32rpx;
  padding: 0 24rpx;
}

.contact-text {
  font-size: 24rpx;
  color: #999999;
}

.page.dark .contact-text {
  color: #8B95A7;
}

.bottom-space {
  height: 40rpx;
}
