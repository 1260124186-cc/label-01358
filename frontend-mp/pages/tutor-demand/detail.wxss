.demand-detail-page {
  min-height: 100vh;
  background: var(--color-bg-page);
  display: flex;
  flex-direction: column;
}

.detail-scroll {
  flex: 1;
  height: calc(100vh - 140rpx);
}

.header-section {
  padding: var(--spacing-xl);
  padding-bottom: var(--spacing-lg);
  background: var(--color-bg-card);
  border-radius: 0 0 var(--radius-2xl) var(--radius-2xl);
  box-shadow: var(--shadow-sm);
}

.category-row {
  display: flex;
  align-items: center;
  margin-bottom: var(--spacing-md);
}

.category-row > view { margin-right: var(--spacing-sm); }

.category-row > view:last-child { margin-right: 0; }

.subject-tag {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 20rpx;
  border-radius: var(--radius-full);
  background: rgba(16, 185, 129, 0.1);
  font-size: var(--font-sm);
  font-weight: 500;
  color: #10B981;
}

.subject-icon {
  font-size: var(--font-md);
  margin-right: 6rpx;
}

.status-tag {
  padding: 8rpx 20rpx;
  border-radius: var(--radius-full);
  font-size: var(--font-sm);
  font-weight: 600;
}

.demand-title {
  font-size: var(--font-2xl);
  font-weight: 700;
  color: var(--color-text-primary);
  line-height: 1.4;
  margin-bottom: var(--spacing-lg);
}

.publisher-row {
  display: flex;
  align-items: center;
  padding-top: var(--spacing-md);
  border-top: 1rpx solid var(--color-divider);
}

.publisher-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #4ECDC4 0%, #44A08D 100%);
  flex-shrink: 0;
}

.publisher-info {
  flex: 1;
  margin-left: var(--spacing-md);
  display: flex;
  flex-direction: column;
}

.publisher-name {
  font-size: var(--font-base);
  font-weight: 500;
  color: var(--color-text-primary);
}

.publish-time {
  font-size: var(--font-xs);
  color: var(--color-text-muted);
  margin-top: 4rpx;
}

.views-count {
  display: flex;
  align-items: center;
  flex-shrink: 0;
}

.views-icon {
  font-size: var(--font-sm);
  margin-right: 4rpx;
}

.views-text {
  font-size: var(--font-xs);
  color: var(--color-text-muted);
}

.card {
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: var(--spacing-lg);
  margin: var(--spacing-lg) var(--spacing-lg) 0;
  box-shadow: var(--shadow-card);
}

.section-title {
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: var(--spacing-md);
}

.info-row {
  display: flex;
  align-items: flex-start;
  padding: 14rpx 0;
  border-bottom: 1rpx solid var(--color-divider);
}

.info-row:last-child {
  border-bottom: none;
}

.info-icon {
  width: 48rpx;
  font-size: var(--font-lg);
  flex-shrink: 0;
  text-align: center;
  padding-top: 2rpx;
}

.info-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.info-label {
  font-size: var(--font-sm);
  color: var(--color-text-muted);
}

.info-value {
  font-size: var(--font-base);
  color: var(--color-text-primary);
  font-weight: 500;
}

.info-value.highlight {
  color: var(--color-primary);
}

.info-value.price {
  color: #EF4444;
  font-size: var(--font-lg);
  font-weight: 700;
}

.multi-tags {
  display: flex;
  flex-wrap: wrap;
  margin: -6rpx;
}

.inline-tag {
  padding: 8rpx 16rpx;
  margin: 6rpx;
  background: var(--color-bg-input);
  border-radius: var(--radius-md);
  font-size: var(--font-xs);
  color: var(--color-text-secondary);
  font-weight: 500;
}

.description-text {
  font-size: var(--font-base);
  color: var(--color-text-secondary);
  line-height: 1.8;
  white-space: pre-wrap;
}

.phone-row {
  display: flex;
  align-items: center;
}

.call-btn {
  margin-left: var(--spacing-md);
  padding: 6rpx 20rpx;
  background: rgba(16, 185, 129, 0.1);
  color: #10B981;
  font-size: var(--font-sm);
  font-weight: 500;
  border-radius: var(--radius-full);
}

.stats-row {
  display: flex;
  align-items: center;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--color-text-primary);
  margin-bottom: 4rpx;
}

.stat-label {
  font-size: var(--font-xs);
  color: var(--color-text-muted);
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: var(--color-divider);
}

.bottom-spacer {
  height: 40rpx;
}

.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  padding: 20rpx var(--spacing-xl);
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: var(--color-bg-card);
  border-top: 1rpx solid var(--color-border);
  z-index: 100;
}

.action-bar > view { margin-right: var(--spacing-md); }

.action-bar > view:last-child { margin-right: 0; }

.action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: var(--radius-2xl);
  font-size: var(--font-md);
  font-weight: 600;
  transition: all var(--transition-fast);
}

.action-btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.action-btn.primary {
  flex: 1;
  background: linear-gradient(135deg, #10B981 0%, #059669 100%);
  color: #fff;
  box-shadow: 0 6rpx 20rpx rgba(16, 185, 129, 0.35);
}

.action-btn.outline {
  width: 260rpx;
  flex-shrink: 0;
  background: var(--color-bg-card);
  color: #10B981;
  border: 2rpx solid #10B981;
  box-shadow: none;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  background: var(--color-bg-page);
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: var(--spacing-lg);
  opacity: 0.4;
}

.empty-text {
  font-size: var(--font-base);
  color: var(--color-text-muted);
}
