<page-meta page-style="background-color: {{darkMode ? '#0F1117' : '#F8F9FA'}}; color: {{darkMode ? '#E8ECF1' : '#2C3E50'}}"/>
<view class="page {{darkMode ? 'dark' : ''}}">
  <view class="tabs-section">
    <view
      class="tab-item {{currentTab === item.value ? 'active' : ''}}"
      wx:for="{{tabs}}"
      wx:key="value"
      bindtap="onTabChange"
      data-tab="{{item.value}}"
    >{{item.label}}</view>
  </view>

  <scroll-view class="list-scroll" scroll-y="{{true}}">
    <view class="list-container" wx:if="{{list.length > 0}}">
      <view
        class="item-card"
        wx:for="{{list}}"
        wx:key="id"
        hover-class="item-card-hover"
        bindtap="onItemTap"
        data-item="{{item}}"
      >
        <image
          class="item-image"
          src="{{item.images[0] || '/assets/images/default-goods.png'}}"
          mode="aspectFill"
        />
        <view class="item-info">
          <view class="item-header">
            <view class="item-price">¥{{item.priceText}}</view>
            <view class="item-status-tag status-{{item.status}}">
              {{item.statusText}}
            </view>
          </view>
          <text class="item-title">{{item.title}}</text>
          <text class="item-desc">{{item.description}}</text>
          <view class="item-meta">
            <text class="item-meta-text">{{item.categoryText}}</text>
            <text class="item-meta-dot">·</text>
            <text class="item-meta-text">{{item.timeText}}</text>
          </view>
        </view>
        <view class="item-actions">
          <view class="action-btn action-edit" catchtap="onEdit" data-item="{{item}}">
            <text>编辑</text>
          </view>
          <block wx:if="{{item.status === 'selling'}}">
            <view class="action-btn action-reserve" catchtap="onMarkReserved" data-item="{{item}}">
              <text>预订</text>
            </view>
            <view class="action-btn action-sold" catchtap="onMarkSold" data-item="{{item}}">
              <text>售出</text>
            </view>
          </block>
          <block wx:elif="{{item.status === 'reserved'}}">
            <view class="action-btn action-sold" catchtap="onMarkSold" data-item="{{item}}">
              <text>售出</text>
            </view>
            <view class="action-btn action-relist" catchtap="onRelist" data-item="{{item}}">
              <text>上架</text>
            </view>
          </block>
          <block wx:else>
            <view class="action-btn action-relist" catchtap="onRelist" data-item="{{item}}">
              <text>上架</text>
            </view>
          </block>
          <view class="action-btn action-delete" catchtap="onDelete" data-item="{{item}}">
            <text>删除</text>
          </view>
        </view>
      </view>
    </view>

    <empty
      wx:if="{{list.length === 0}}"
      text="暂无发布记录"
    />
  </scroll-view>
</view>
