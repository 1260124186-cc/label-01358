<page-meta page-style="background-color: {{darkMode ? '#0F1117' : '#F8F9FA'}}; color: {{darkMode ? '#E8ECF1' : '#2C3E50'}}"/>
<view class="page {{darkMode ? 'dark' : ''}}">
  <!-- 顶部标签栏 -->
  <view class="top-tabs">
    <view
      class="tab-item {{currentTab === item.value ? 'active' : ''}}"
      wx:for="{{tabs}}"
      wx:key="value"
      bindtap="onTabTap"
      data-value="{{item.value}}"
    >
      <text class="tab-label">{{item.label}}</text>
    </view>
  </view>

  <!-- 预约列表 -->
  <scroll-view class="appointment-list" scroll-y="{{true}}" enhanced="{{true}}" show-scrollbar="{{false}}">
    <view class="list-inner" wx:if="{{filteredAppointments.length > 0}}">
      <view
        class="appointment-card"
        wx:for="{{filteredAppointments}}"
        wx:key="id"
        bindtap="onAppointmentTap"
        data-id="{{item.id}}"
      >
        <!-- 卡片头部 -->
        <view class="card-header">
          <view class="user-info">
            <image class="user-avatar" src="{{item.userAvatar || '/assets/images/default-avatar.png'}}" mode="aspectFill" />
            <view class="user-detail">
              <text class="user-name">{{item.userName}}</text>
              <text class="apply-time">申请时间：{{item.createTimeText}}</text>
            </view>
          </view>
          <view class="status-tag" style="background: {{item.statusColor}}15; color: {{item.statusColor}};">
            <text class="status-icon">{{item.statusIcon}}</text>
            <text class="status-text">{{item.statusLabel}}</text>
          </view>
        </view>

        <!-- 预约信息 -->
        <view class="card-body">
          <view class="lab-title">
            <text class="lab-icon">🔬</text>
            <text class="lab-name">{{item.labName || '实验室'}}</text>
          </view>
          <view class="info-grid">
            <view class="info-item">
              <text class="info-label">预约日期</text>
              <text class="info-value">{{item.appointmentDate}}</text>
            </view>
            <view class="info-item">
              <text class="info-label">预约时段</text>
              <text class="info-value">{{item.timeSlot}}</text>
            </view>
            <view class="info-item">
              <text class="info-label">使用人数</text>
              <text class="info-value">{{item.participantCount}} 人</text>
            </view>
          </view>
          <view class="purpose-box" wx:if="{{item.purpose}}">
            <text class="purpose-label">使用目的</text>
            <text class="purpose-text">{{item.purpose}}</text>
          </view>
        </view>

        <!-- 审批备注 -->
        <view class="approval-remark" wx:if="{{item.approvalRemark}}">
          <text class="remark-label">审批备注</text>
          <text class="remark-text">{{item.approvalRemark}}</text>
        </view>

        <!-- 操作按钮 -->
        <view class="card-footer" wx:if="{{item.status === 'pending'}}">
          <view class="action-buttons">
            <view class="action-btn reject-btn" catchtap="onReject" data-id="{{item.id}}">
              <text class="btn-text">拒绝</text>
            </view>
            <view class="action-btn approve-btn" catchtap="onApprove" data-id="{{item.id}}">
              <text class="btn-text">通过</text>
            </view>
          </view>
        </view>

        <view class="card-footer approved-footer" wx:else>
          <text class="approval-time">审批时间：{{item.approvalTimeText}}</text>
        </view>
      </view>
    </view>

    <empty wx:else text="暂无预约申请" icon="📋" />
  </scroll-view>

  <!-- 拒绝弹窗 -->
  <view class="modal-mask {{showRejectModal ? 'show' : ''}}" bindtap="onCancelReject">
    <view class="modal-content" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">拒绝预约</text>
        <text class="modal-close" bindtap="onCancelReject">✕</text>
      </view>
      <view class="modal-body">
        <view class="form-item">
          <text class="form-label">拒绝原因</text>
          <textarea
            class="form-textarea"
            placeholder="请输入拒绝原因"
            placeholder-class="form-placeholder"
            value="{{rejectRemark}}"
            bindinput="onRejectRemarkInput"
            maxlength="200"
            auto-height
          />
        </view>
      </view>
      <view class="modal-footer">
        <view class="modal-btn cancel-btn" bindtap="onCancelReject">
          <text class="btn-text">取消</text>
        </view>
        <view class="modal-btn confirm-btn" bindtap="onConfirmReject">
          <text class="btn-text">确认拒绝</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 加载状态 -->
  <view class="loading-overlay" wx:if="{{loading}}">
    <view class="loading-content">
      <view class="loading-spinner"></view>
      <text class="loading-text">加载中...</text>
    </view>
  </view>
</view>
