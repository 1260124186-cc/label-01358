<page-meta page-style="background-color: {{darkMode ? '#0F1117' : '#F8F9FA'}}; color: {{darkMode ? '#E8ECF1' : '#2C3E50'}}"/>
<view class="page {{darkMode ? 'dark' : ''}}">
  <view class="list-container">
    <view class="list-header">
      <text class="list-count">共 {{list.length}} 条动态</text>
      <view class="add-btn" bindtap="onAdd">
        <text class="add-icon">+</text>
        <text>新增</text>
      </view>
    </view>

    <view class="empty-state" wx:if="{{list.length === 0}}">
      <text class="empty-icon">📰</text>
      <text class="empty-text">暂无动态，点击右上角新增</text>
    </view>

    <view class="item-list" wx:else>
      <view class="item-card" wx:for="{{list}}" wx:key="id">
        <view class="item-top">
          <view class="item-tags">
            <view class="tag tag-top" wx:if="{{item.isTop}}">
              <text>置顶</text>
            </view>
            <view class="tag tag-category" style="background-color: #E0F2FE; color: #0369A1;">
              <text>{{item.categoryInfo.icon}} {{item.categoryInfo.label}}</text>
            </view>
            <view class="tag tag-status" style="background-color: {{item.statusInfo.color}}20; color: {{item.statusInfo.color}};">
              <text>{{item.statusInfo.label}}</text>
            </view>
          </view>
          <text class="item-time">{{item.timeText}}</text>
        </view>

        <view class="item-body">
          <view class="item-cover" wx:if="{{item.cover}}">
            <image src="{{item.cover}}" mode="aspectFill" />
          </view>
          <view class="item-main">
            <view class="item-title">{{item.title}}</view>
            <view class="item-summary">{{item.summary}}</view>
          </view>
        </view>

        <view class="item-tags-inline" wx:if="{{item.tags && item.tags.length > 0}}">
          <text class="inline-tag" wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this">#{{tag}}</text>
        </view>

        <view class="item-actions">
          <view class="action-btn action-top" data-id="{{item.id}}" bindtap="onToggleTop">
            <text>{{item.isTop ? '取消置顶' : '置顶'}}</text>
          </view>
          <view class="action-btn action-edit" data-id="{{item.id}}" bindtap="onEdit">
            <text>编辑</text>
          </view>
          <view class="action-btn action-delete" data-id="{{item.id}}" bindtap="onDelete">
            <text>删除</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="bottom-spacing"></view>
</view>
