@import "/pages/admin/announcement-list/index.wxss";

.item-body {
  display: flex;
  gap: 20rpx;
  margin-bottom: 16rpx;
}

.item-body .item-cover {
  width: 200rpx;
  height: 150rpx;
  border-radius: 12rpx;
  overflow: hidden;
  flex-shrink: 0;
  margin-bottom: 0;
}

.item-body .item-cover image {
  width: 100%;
  height: 100%;
}

.item-main {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.item-main .item-title {
  margin-bottom: 8rpx;
  font-size: 30rpx;
  -webkit-line-clamp: 2;
}

.item-summary {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  line-height: 1.5;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.tag-category {
  background-color: #E0F2FE;
  color: #0369A1;
}

.item-tags-inline {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.inline-tag {
  font-size: 22rpx;
  color: var(--color-primary);
  background-color: rgba(255, 107, 107, 0.1);
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}
