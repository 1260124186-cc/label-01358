.page {
  min-height: 100vh;
  background-color: var(--color-bg-page);
  padding: 24rpx;
}

.header {
  padding: 32rpx 24rpx 48rpx;
}

.header-title {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  margin-bottom: 12rpx;
}

.header-desc {
  font-size: 28rpx;
  color: var(--color-text-secondary);
}

/* 管理员校区切换 */
.admin-campus-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 32rpx;
  padding: 24rpx 28rpx;
  background: linear-gradient(135deg, #FEF3C7 0%, #FDE68A 100%);
  border-radius: 24rpx;
  box-shadow: 0 6rpx 20rpx rgba(245, 158, 11, 0.15);
  transition: all 0.2s ease;
}

.admin-campus-bar-hover {
  transform: scale(0.99);
  box-shadow: 0 3rpx 10rpx rgba(245, 158, 11, 0.12);
}

.campus-bar-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex: 1;
}

.campus-bar-icon {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.6);
  border-radius: 20rpx;
  font-size: 36rpx;
}

.campus-bar-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.campus-bar-tag {
  display: inline-block;
  padding: 2rpx 16rpx;
  font-size: 22rpx;
  font-weight: 500;
  background: rgba(255, 255, 255, 0.7);
  color: #B45309;
  border-radius: 8rpx;
  width: fit-content;
}

.campus-bar-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #92400E;
}

.campus-bar-arrow {
  font-size: 40rpx;
  color: #B45309;
  font-weight: 300;
  line-height: 1;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.stats-item {
  border-radius: 24rpx;
  padding: 32rpx;
  display: flex;
  flex-direction: column;
}

.stats-count {
  font-size: 56rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.stats-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

.module-section {
  margin-top: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin: 0 8rpx 20rpx;
}

.module-list {
  background-color: var(--color-bg-card);
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: var(--shadow-card);
}

.module-card {
  display: flex;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid var(--color-border);
  transition: background-color 0.2s ease;
}

.module-card:last-child {
  border-bottom: none;
}

.module-card-hover {
  background-color: var(--color-bg-page);
}

.module-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.icon-text {
  font-size: 44rpx;
}

.module-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.module-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 6rpx;
}

.module-desc {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.module-arrow {
  font-size: 40rpx;
  color: var(--color-text-muted);
  font-weight: 300;
}
