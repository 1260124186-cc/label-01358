@import "/pages/admin/announcement-edit/index.wxss";

.file-row {
  margin-bottom: 16rpx;
}

.file-name {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx 24rpx;
  background-color: #FEF3C7;
  border-radius: 12rpx;
  border-left: 6rpx solid #F59E0B;
}

.file-icon {
  font-size: 36rpx;
}

.file-text {
  flex: 1;
  font-size: 24rpx;
  color: #92400E;
  word-break: break-all;
}

.file-placeholder {
  padding: 20rpx 24rpx;
  background-color: var(--color-bg-page);
  border-radius: 12rpx;
  font-size: 26rpx;
  color: var(--color-text-muted);
}

.upload-audio-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  height: 88rpx;
  background: linear-gradient(135deg, #F59E0B 0%, #FBBF24 100%);
  color: #FFFFFF;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.upload-audio-icon {
  font-size: 32rpx;
}

.upload-audio-btn:active {
  opacity: 0.85;
}

.page.dark .file-placeholder {
  background-color: rgba(255, 255, 255, 0.06);
}
