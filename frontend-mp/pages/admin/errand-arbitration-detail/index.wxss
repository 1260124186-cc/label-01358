.detail-page {
  min-height: 100vh;
  background: #f8f9fa;
  padding-bottom: 140rpx;
}

.detail-page.dark {
  background: #0F1117;
}

.status-banner {
  padding: 40rpx 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.status-main {
  display: flex;
  align-items: center;
  flex: 1;
}

.status-icon {
  font-size: 56rpx;
  margin-right: 20rpx;
}

.status-info {
  flex: 1;
}

.status-text {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.status-desc {
  font-size: 26rpx;
  color: #6B7280;
}

.bounty-tag {
  text-align: center;
  padding: 16rpx 24rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 16rpx;
}

.detail-page.dark .bounty-tag {
  background: rgba(26, 29, 40, 0.9);
}

.bounty-amount {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #F59E0B;
}

.bounty-label {
  font-size: 22rpx;
  color: #9CA3AF;
}

.info-section {
  margin: 20rpx;
}

.section-title {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  padding: 0 10rpx;
}

.title-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.title-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.detail-page.dark .title-text {
  color: #E5E7EB;
}

.info-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 10rpx 0;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.detail-page.dark .info-card {
  background: #1A1D28;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.2);
}

.info-row {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.detail-page.dark .info-row {
  border-bottom-color: #2A2D3A;
}

.info-row:last-child {
  border-bottom: none;
}

.row-label {
  width: 140rpx;
  flex-shrink: 0;
  font-size: 26rpx;
  color: #9CA3AF;
}

.detail-page.dark .row-label {
  color: #6B7280;
}

.row-value {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.detail-page.dark .row-value {
  color: #E5E7EB;
}

.row-value.reason {
  color: #EF4444;
  font-weight: 500;
}

.user-info {
  display: flex;
  align-items: center;
}

.user-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}

.user-detail {
  display: flex;
  flex-direction: column;
}

.user-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 4rpx;
}

.detail-page.dark .user-name {
  color: #E5E7EB;
}

.user-role {
  font-size: 22rpx;
  color: #9CA3AF;
}

.desc-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.detail-page.dark .desc-card {
  background: #1A1D28;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.2);
}

.desc-text {
  font-size: 28rpx;
  line-height: 1.8;
  color: #333;
}

.detail-page.dark .desc-text {
  color: #E5E7EB;
}

.evidence-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.detail-page.dark .evidence-grid {
  background: #1A1D28;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.2);
}

.evidence-img {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
}

.order-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.detail-page.dark .order-card {
  background: #1A1D28;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.2);
}

.order-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.order-type {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.detail-page.dark .order-type {
  color: #E5E7EB;
}

.order-arrow {
  font-size: 36rpx;
  color: #D1D5DB;
}

.detail-page.dark .order-arrow {
  color: #4B5563;
}

.order-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.order-id,
.order-time {
  font-size: 24rpx;
  color: #9CA3AF;
}

.credit-compare {
  display: flex;
  align-items: stretch;
  gap: 20rpx;
}

.credit-card {
  flex: 1;
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.detail-page.dark .credit-card {
  background: #1A1D28;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.2);
}

.credit-role {
  font-size: 26rpx;
  color: #6B7280;
  margin-bottom: 12rpx;
}

.credit-score {
  display: flex;
  align-items: baseline;
  justify-content: center;
  margin-bottom: 16rpx;
}

.score-number {
  font-size: 48rpx;
  font-weight: 700;
  color: #10B981;
}

.score-unit {
  font-size: 24rpx;
  color: #9CA3AF;
  margin-left: 4rpx;
}

.credit-stats {
  display: flex;
  justify-content: space-around;
  margin-bottom: 12rpx;
}

.stat-item {
  text-align: center;
}

.stat-value {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 4rpx;
}

.detail-page.dark .stat-value {
  color: #E5E7EB;
}

.stat-label {
  font-size: 20rpx;
  color: #9CA3AF;
}

.violation-badge {
  display: inline-block;
  padding: 6rpx 16rpx;
  background: #FEF3C7;
  color: #D97706;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.violation-badge.warning {
  background: #FEE2E2;
  color: #DC2626;
}

.vs-divider {
  display: flex;
  align-items: center;
  justify-content: center;
}

.vs-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #8B5CF6;
  background: #F3E8FF;
  padding: 12rpx 16rpx;
  border-radius: 50%;
}

.detail-page.dark .vs-text {
  background: rgba(139, 92, 246, 0.2);
}

.timeline {
  background: #fff;
  border-radius: 20rpx;
  padding: 20rpx 0;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.detail-page.dark .timeline {
  background: #1A1D28;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.2);
}

.timeline-item {
  display: flex;
  padding: 20rpx 30rpx;
  position: relative;
}

.timeline-item:not(:last-child)::after {
  content: '';
  position: absolute;
  left: 45rpx;
  top: 50rpx;
  bottom: 0;
  width: 2rpx;
  background: #E5E7EB;
}

.detail-page.dark .timeline-item:not(:last-child)::after {
  background: #374151;
}

.timeline-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #8B5CF6;
  margin-right: 24rpx;
  margin-top: 8rpx;
  flex-shrink: 0;
}

.timeline-content {
  flex: 1;
}

.timeline-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.timeline-action {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.detail-page.dark .timeline-action {
  color: #E5E7EB;
}

.timeline-amount {
  font-size: 28rpx;
  font-weight: 600;
  color: #F59E0B;
}

.timeline-time {
  font-size: 24rpx;
  color: #9CA3AF;
}

.arbitration-result {
  background: #fff;
  border-radius: 20rpx;
  padding: 10rpx 0;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.detail-page.dark .arbitration-result {
  background: #1A1D28;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.2);
}

.result-row {
  display: flex;
  padding: 20rpx 30rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.detail-page.dark .result-row {
  border-bottom-color: #2A2D3A;
}

.result-row:last-child {
  border-bottom: none;
}

.result-label {
  width: 140rpx;
  flex-shrink: 0;
  font-size: 26rpx;
  color: #9CA3AF;
}

.result-value {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  word-break: break-all;
}

.detail-page.dark .result-value {
  color: #E5E7EB;
}

.result-value.remark {
  line-height: 1.6;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.detail-page.dark .bottom-bar {
  background: #1A1D28;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.2);
}

.arbitrate-btn {
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: linear-gradient(135deg, #6366F1 0%, #8B5CF6 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 44rpx;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s;
  z-index: 1000;
  padding: 40rpx;
}

.modal-mask.show {
  opacity: 1;
  visibility: visible;
}

.modal-content {
  width: 100%;
  max-height: 85vh;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.detail-page.dark .modal-content {
  background: #1A1D28;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 2rpx solid #f0f0f0;
  flex-shrink: 0;
}

.detail-page.dark .modal-header {
  border-bottom-color: #2A2D3A;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

.detail-page.dark .modal-title {
  color: #E5E7EB;
}

.modal-close {
  font-size: 36rpx;
  color: #9CA3AF;
  padding: 10rpx;
}

.modal-body {
  flex: 1;
  overflow-y: auto;
  padding: 30rpx;
}

.form-group {
  margin-bottom: 30rpx;
}

.form-group:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 16rpx;
}

.detail-page.dark .form-label {
  color: #E5E7EB;
}

.result-options {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.result-option {
  padding: 24rpx 20rpx;
  border: 3rpx solid #E5E7EB;
  border-radius: 16rpx;
  text-align: center;
  transition: all 0.2s;
}

.detail-page.dark .result-option {
  border-color: #374151;
}

.result-option.active {
  border-color: #6366F1;
  background: #F3E8FF;
}

.detail-page.dark .result-option.active {
  background: rgba(99, 102, 241, 0.15);
}

.result-option.malicious.active {
  border-color: #EF4444;
  background: #FEE2E2;
}

.detail-page.dark .result-option.malicious.active {
  background: rgba(239, 68, 68, 0.15);
}

.option-icon {
  display: block;
  font-size: 40rpx;
  margin-bottom: 10rpx;
}

.option-label {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 6rpx;
}

.detail-page.dark .option-label {
  color: #E5E7EB;
}

.option-desc {
  display: block;
  font-size: 22rpx;
  color: #9CA3AF;
}

.split-inputs {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.split-item {
  flex: 1;
  display: flex;
  align-items: center;
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
}

.detail-page.dark .split-item {
  background: #252836;
}

.split-label {
  font-size: 24rpx;
  color: #6B7280;
  margin-right: 12rpx;
}

.split-input {
  flex: 1;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  text-align: center;
}

.detail-page.dark .split-input {
  color: #E5E7EB;
}

.split-unit {
  font-size: 24rpx;
  color: #9CA3AF;
  margin-left: 8rpx;
}

.split-plus {
  font-size: 32rpx;
  color: #9CA3AF;
}

.form-textarea {
  width: 100%;
  min-height: 160rpx;
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.detail-page.dark .form-textarea {
  background: #252836;
  color: #E5E7EB;
}

.input-placeholder {
  color: #9CA3AF;
}

.modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 24rpx 30rpx;
  border-top: 2rpx solid #f0f0f0;
  flex-shrink: 0;
}

.detail-page.dark .modal-footer {
  border-top-color: #2A2D3A;
}

.cancel-btn,
.confirm-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.cancel-btn {
  background: #f3f4f6;
  color: #6B7280;
}

.detail-page.dark .cancel-btn {
  background: #252836;
  color: #9CA3AF;
}

.confirm-btn {
  background: linear-gradient(135deg, #6366F1 0%, #8B5CF6 100%);
  color: #fff;
}
