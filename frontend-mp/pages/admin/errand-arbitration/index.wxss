.page {
  min-height: 100vh;
  background: #f8f9fa;
  padding-bottom: 40rpx;
}

.page.dark {
  background: #0F1117;
}

.header {
  padding: 30rpx;
  background: linear-gradient(135deg, #6366F1 0%, #8B5CF6 100%);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.header-info {
  flex: 1;
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
}

.header-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

.total-count {
  font-weight: 600;
  color: #FDE68A;
}

.stats-cards {
  display: flex;
  gap: 20rpx;
  padding: 20rpx;
  margin-top: -30rpx;
  position: relative;
  z-index: 1;
}

.stat-card {
  flex: 1;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 16rpx;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.page.dark .stat-card {
  background: #1A1D28;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.2);
}

.stat-count {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 6rpx;
}

.stat-card.pending .stat-count {
  color: #F59E0B;
}

.stat-card.processing .stat-count {
  color: #3B82F6;
}

.stat-card.resolved .stat-count {
  color: #10B981;
}

.stat-label {
  font-size: 24rpx;
  color: #6B7280;
}

.page.dark .stat-label {
  color: #9CA3AF;
}

.tabs-bar {
  padding: 0 20rpx;
  margin-bottom: 10rpx;
}

.tabs-scroll {
  white-space: nowrap;
}

.tabs-list {
  display: inline-flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 8rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.page.dark .tabs-list {
  background: #1A1D28;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

.tab-item {
  padding: 16rpx 32rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #6B7280;
  transition: all 0.2s;
}

.page.dark .tab-item {
  color: #9CA3AF;
}

.tab-item.active {
  background: linear-gradient(135deg, #6366F1 0%, #8B5CF6 100%);
  color: #fff;
  font-weight: 600;
}

.list-section {
  padding: 20rpx;
}

.empty-state {
  padding: 120rpx 40rpx;
  text-align: center;
}

.empty-icon {
  display: block;
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #9CA3AF;
}

.dispute-card {
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.page.dark .dispute-card {
  background: #1A1D28;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.2);
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.page.dark .card-header {
  border-bottom-color: #2A2D3A;
}

.card-type {
  display: flex;
  align-items: center;
}

.type-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.type-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.page.dark .type-text {
  color: #E5E7EB;
}

.card-status {
  display: flex;
  align-items: center;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.status-icon {
  margin-right: 6rpx;
  font-size: 24rpx;
}

.status-text {
  font-size: 24rpx;
}

.card-body {
  padding: 20rpx 24rpx;
}

.card-row {
  display: flex;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.card-row:last-child {
  margin-bottom: 0;
}

.row-label {
  width: 140rpx;
  flex-shrink: 0;
  font-size: 26rpx;
  color: #9CA3AF;
}

.page.dark .row-label {
  color: #6B7280;
}

.row-value {
  flex: 1;
  font-size: 26rpx;
  color: #333;
  word-break: break-all;
}

.page.dark .row-value {
  color: #E5E7EB;
}

.row-value .user-name {
  color: #333;
  font-weight: 500;
}

.page.dark .row-value .user-name {
  color: #E5E7EB;
}

.row-value .user-role {
  color: #9CA3AF;
  font-size: 24rpx;
  margin-left: 8rpx;
}

.row-value.reason {
  color: #EF4444;
  font-weight: 500;
}

.row-value.bounty {
  color: #F59E0B;
  font-weight: 600;
}

.row-value.time {
  color: #6B7280;
}

.card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  background: #f8f9fa;
}

.page.dark .card-footer {
  background: #252836;
}

.footer-tip {
  font-size: 24rpx;
  color: #9CA3AF;
}

.footer-arrow {
  font-size: 32rpx;
  color: #D1D5DB;
}

.page.dark .footer-arrow {
  color: #4B5563;
}
