@import "/pages/admin/announcement-edit/index.wxss";

.images-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.image-item {
  position: relative;
  width: 100%;
  padding-top: 100%;
  border-radius: 16rpx;
  overflow: hidden;
}

.image-item image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.image-add {
  width: 100%;
  padding-top: 100%;
  position: relative;
  border: 2rpx dashed var(--color-border);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: var(--color-bg-page);
}

.image-add > * {
  position: absolute;
}

.add-icon {
  top: 30%;
  left: 50%;
  transform: translateX(-50%);
  font-size: 48rpx;
  color: var(--color-text-muted);
  font-weight: 300;
}

.add-text {
  top: 58%;
  left: 50%;
  transform: translateX(-50%);
  font-size: 24rpx;
  color: var(--color-text-muted);
}

.tag-input-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.tag-input {
  flex: 1;
  height: 72rpx;
  padding: 0 24rpx;
  background-color: var(--color-bg-page);
  border-radius: 12rpx;
  font-size: 28rpx;
  color: var(--color-text-primary);
}

.tag-add-btn {
  height: 72rpx;
  padding: 0 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: var(--color-primary);
  color: #FFFFFF;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.tags-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag-chip {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 20rpx;
  background-color: rgba(255, 107, 107, 0.1);
  border-radius: 24rpx;
  font-size: 26rpx;
  color: var(--color-primary);
}

.tag-close {
  font-size: 24rpx;
  opacity: 0.7;
}

.title-hint {
  font-size: 24rpx;
  color: var(--color-text-muted);
  font-weight: 400;
  margin-left: 8rpx;
}

.page.dark .tag-input {
  background-color: rgba(255, 255, 255, 0.06);
}

.page.dark .image-add {
  background-color: rgba(255, 255, 255, 0.05);
  border-color: rgba(255, 255, 255, 0.15);
}
