.page {
  min-height: 100vh;
  background-color: var(--color-bg-page);
}

.list-container {
  padding: 24rpx;
}

.list-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.list-count {
  font-size: 28rpx;
  color: var(--color-text-secondary);
}

.add-btn {
  display: flex;
  align-items: center;
  padding: 16rpx 28rpx;
  background: linear-gradient(135deg, var(--color-primary) 0%, #FF8E8E 100%);
  border-radius: 40rpx;
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 500;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 107, 0.3);
}

.add-icon {
  font-size: 32rpx;
  margin-right: 8rpx;
  font-weight: 300;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: var(--color-text-secondary);
}

.item-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.item-card {
  background-color: var(--color-bg-card);
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: var(--shadow-card);
}

.item-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.item-tags {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.tag {
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.tag-top {
  background-color: #FEF3C7;
  color: #D97706;
}

.item-time {
  font-size: 24rpx;
  color: var(--color-text-muted);
}

.item-cover {
  width: 100%;
  height: 280rpx;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
}

.item-cover image {
  width: 100%;
  height: 100%;
}

.item-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 12rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.item-content {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.6;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.item-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--color-border);
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 72rpx;
  border-radius: 36rpx;
  font-size: 26rpx;
  font-weight: 500;
  transition: opacity 0.2s ease;
}

.action-btn:active {
  opacity: 0.7;
}

.action-top {
  background-color: #FEF3C7;
  color: #D97706;
}

.action-edit {
  background-color: #DBEAFE;
  color: #2563EB;
}

.action-delete {
  background-color: #FEE2E2;
  color: #DC2626;
}

.bottom-spacing {
  height: 60rpx;
}
