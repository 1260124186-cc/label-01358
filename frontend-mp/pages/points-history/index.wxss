.page {
  min-height: 100vh;
  background-color: #F8F9FA;
  padding-bottom: 40rpx;
}

.page.dark {
  background-color: #0F1117;
}

.header-card {
  position: relative;
  margin: 0;
  border-radius: 0 0 32rpx 32rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 50%, #FFA726 100%);
}

.header-content {
  position: relative;
  padding: 32rpx;
  padding-top: 48rpx;
}

.points-header {
  text-align: center;
  margin-bottom: 32rpx;
}

.points-label-row {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.points-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
}

.expiring-badge {
  display: flex;
  align-items: center;
  margin-left: 16rpx;
  padding: 6rpx 16rpx;
  background: rgba(255, 255, 255, 0.25);
  border-radius: 24rpx;
}

.expiring-icon {
  font-size: 24rpx;
  margin-right: 6rpx;
}

.expiring-text {
  font-size: 22rpx;
  color: #FFFFFF;
  font-weight: 500;
}

.points-main {
  display: flex;
  align-items: baseline;
  justify-content: center;
}

.points-value {
  font-size: 96rpx;
  font-weight: 700;
  line-height: 1;
  color: #FFFFFF;
  letter-spacing: 2rpx;
}

.expiring-tip {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.75);
}

.stats-row {
  display: flex;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 20rpx;
  padding: 24rpx 0;
  margin-bottom: 24rpx;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 6rpx;
}

.stat-value.positive {
  color: #A5D6A7;
}

.stat-value.negative {
  color: #FFCDD2;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.75);
}

.stat-divider {
  width: 1rpx;
  background: rgba(255, 255, 255, 0.2);
  margin: 8rpx 0;
}

.action-row {
  display: flex;
  justify-content: space-around;
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 32rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
  min-width: 140rpx;
}

.action-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.action-text {
  font-size: 24rpx;
  color: #FFFFFF;
  font-weight: 500;
}

.tab-section {
  background: #FFFFFF;
  margin: 24rpx 24rpx 0;
  border-radius: 20rpx;
  padding: 0 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.page.dark .tab-section {
  background: #1E2128;
}

.tab-row {
  display: flex;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 0;
  position: relative;
}

.tab-text {
  font-size: 28rpx;
  color: #666666;
  font-weight: 500;
  transition: all 0.3s ease;
}

.page.dark .tab-text {
  color: #8B95A7;
}

.tab-item.active .tab-text {
  color: #FF6B6B;
  font-weight: 600;
}

.tab-underline {
  position: absolute;
  bottom: 0;
  width: 48rpx;
  height: 6rpx;
  background: linear-gradient(90deg, #FF6B6B 0%, #FF8E53 100%);
  border-radius: 3rpx;
}

.list-section {
  background: #FFFFFF;
  margin: 24rpx;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.page.dark .list-section {
  background: #1E2128;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
  opacity: 0.4;
}

.empty-text {
  font-size: 30rpx;
  color: #333333;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.page.dark .empty-text {
  color: #E8ECF1;
}

.empty-desc {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 32rpx;
}

.page.dark .empty-desc {
  color: #8B95A7;
}

.empty-btn {
  padding: 16rpx 48rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  border-radius: 40rpx;
}

.empty-btn text {
  font-size: 26rpx;
  color: #FFFFFF;
  font-weight: 500;
}

.transaction-list {
  position: relative;
}

.transaction-item {
  display: flex;
  position: relative;
  padding-bottom: 28rpx;
}

.transaction-item:last-child {
  padding-bottom: 0;
}

.item-left {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-right: 20rpx;
  width: 72rpx;
  flex-shrink: 0;
}

.item-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  flex-shrink: 0;
  z-index: 1;
}

.timeline-line {
  position: absolute;
  top: 72rpx;
  bottom: -28rpx;
  width: 2rpx;
  background: #EEEEEE;
}

.page.dark .timeline-line {
  background: #2A2E37;
}

.item-content {
  flex: 1;
  padding-top: 8rpx;
  min-width: 0;
}

.item-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.item-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #333333;
}

.page.dark .item-title {
  color: #E8ECF1;
}

.item-points {
  font-size: 32rpx;
  font-weight: 700;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.item-points.positive {
  color: #10B981;
}

.item-points.negative {
  color: #EF4444;
}

.item-desc {
  font-size: 24rpx;
  color: #666666;
  margin-bottom: 10rpx;
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.page.dark .item-desc {
  color: #8B95A7;
}

.item-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.item-time {
  font-size: 22rpx;
  color: #999999;
}

.page.dark .item-time {
  color: #6B7280;
}

.item-balance {
  font-size: 22rpx;
  color: #999999;
}

.page.dark .item-balance {
  color: #6B7280;
}

.bottom-space {
  height: 40rpx;
}

.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}

.loading-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #999999;
}

.page.dark .loading-text {
  color: #8B95A7;
}
