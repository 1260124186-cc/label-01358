<page-meta page-style="background-color: {{darkMode ? '#0F1117' : '#FFFFFF'}}; color: {{darkMode ? '#E8ECF1' : '#2C3E50'}}"/>
<view class="page {{darkMode ? 'dark' : ''}}" wx:if="{{article}}">
  <view class="article-header">
    <image class="article-cover" src="{{article.cover}}" mode="aspectFill" />
    <view class="header-overlay"></view>
    <view class="header-content">
      <view class="category-tag" style="background: {{article.categoryBg}}; color: {{article.categoryColor}};">
        {{article.categoryLabel}}
      </view>
      <text class="article-title">{{article.title}}</text>
      <view class="article-meta">
        <text class="meta-item">👁️ {{article.views}} 阅读</text>
        <text class="meta-item">⏰ {{article.timeText}}</text>
      </view>
    </view>
  </view>

  <view class="article-content">
    <view class="content-section">
      <text class="content-text">{{article.summary}}</text>
    </view>
    
    <view class="content-divider"></view>
    
    <view class="content-section">
      <block wx:for="{{articleContent}}" wx:key="index">
        <block wx:if="{{item.type === 'title'}}">
          <text class="content-title">{{item.text}}</text>
        </block>
        <block wx:if="{{item.type === 'text'}}">
          <text class="content-paragraph">{{item.text}}</text>
        </block>
        <block wx:if="{{item.type === 'list'}}">
          <view class="content-list">
            <view class="list-item" wx:for="{{item.items}}" wx:for-item="listItem" wx:key="*this">
              <text class="list-bullet">•</text>
              <text class="list-text">{{listItem}}</text>
            </view>
          </view>
        </block>
      </block>
    </view>
  </view>

  <view class="article-footer">
    <view class="emergency-tip">
      <text class="tip-icon">🚨</text>
      <view class="tip-content">
        <text class="tip-title">遇到紧急情况？</text>
        <text class="tip-desc">立即使用 SOS 一键求助功能</text>
      </view>
      <view class="tip-action" bindtap="onSOS">
        <text>一键求助</text>
      </view>
    </view>
    
    <view class="share-section">
      <view class="share-item" bindtap="onShare">
        <text class="share-icon">📤</text>
        <text class="share-text">分享给同学</text>
      </view>
    </view>
  </view>
</view>

<view class="empty-state" wx:if="{{!article && !loading}}">
  <text class="empty-icon">📄</text>
  <text class="empty-title">文章不存在</text>
</view>
