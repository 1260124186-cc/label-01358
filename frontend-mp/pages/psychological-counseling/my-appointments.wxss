.page {
  min-height: 100vh;
  background: var(--color-bg-page);
  display: flex;
  flex-direction: column;
}

.page.dark {
  --color-bg-page: #0F1117;
  --color-bg-card: #1A1D29;
  --color-bg-secondary: #252936;
  --color-text-primary: #E8ECF1;
  --color-text-secondary: #9CA3AF;
  --color-text-placeholder: #6B7280;
  --color-border: #2D3142;
  --color-primary: #FF6B6B;
  --color-primary-dark: #E55555;
}

.top-tabs {
  white-space: nowrap;
  background: var(--color-bg-card, #FFFFFF);
  border-bottom: 1rpx solid var(--color-border, #E5E7EB);
}

.tabs-inner {
  display: inline-flex;
  padding: 0 16rpx;
}

.tab-item {
  padding: 24rpx 28rpx;
  position: relative;
}

.tab-label {
  font-size: 28rpx;
  color: var(--color-text-secondary, #6B7280);
  font-weight: 500;
}

.tab-item.active .tab-label {
  color: var(--color-primary, #FF6B6B);
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  left: 50%;
  bottom: 0;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  background: var(--color-primary, #FF6B6B);
  border-radius: 3rpx;
}

.appointment-list {
  flex: 1;
  padding: 24rpx 32rpx 40rpx;
}

.list-inner {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.appointment-card {
  background: var(--color-bg-card, #FFFFFF);
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.card-header {
  padding: 24rpx;
  border-bottom: 1rpx solid var(--color-border, #F3F4F6);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.counselor-info {
  display: flex;
  align-items: center;
  flex: 1;
  margin-right: 16rpx;
}

.counselor-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: var(--color-bg-secondary, #F3F4F6);
  flex-shrink: 0;
}

.counselor-meta {
  display: flex;
  flex-direction: column;
  margin-left: 20rpx;
  flex: 1;
  min-width: 0;
}

.counselor-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary, #2C3E50);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.counselor-title {
  font-size: 24rpx;
  color: var(--color-text-secondary, #6B7280);
  margin-top: 6rpx;
}

.status-tag {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
}

.status-icon {
  font-size: 24rpx;
}

.status-text {
  font-size: 24rpx;
  font-weight: 500;
}

.card-body {
  padding: 20rpx 24rpx;
}

.info-row {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
}

.info-icon {
  font-size: 28rpx;
  width: 40rpx;
  flex-shrink: 0;
}

.info-label {
  font-size: 26rpx;
  color: var(--color-text-secondary, #6B7280);
  width: 140rpx;
  flex-shrink: 0;
}

.info-value {
  flex: 1;
  font-size: 26rpx;
  color: var(--color-text-primary, #2C3E50);
  text-align: right;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  border-top: 1rpx solid var(--color-border, #F3F4F6);
  background: var(--color-bg-secondary, #FAFAFA);
}

.page.dark .card-footer {
  background: rgba(255, 255, 255, 0.02);
}

.create-time {
  font-size: 22rpx;
  color: var(--color-text-secondary, #9CA3AF);
}

.action-buttons {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  padding: 12rpx 24rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.action-btn.primary {
  background: linear-gradient(135deg, var(--color-primary, #FF6B6B), var(--color-primary-dark, #E55555));
  color: #FFFFFF;
}

.action-btn.secondary {
  background: var(--color-bg-card, #FFFFFF);
  color: var(--color-text-secondary, #6B7280);
  border: 1rpx solid var(--color-border, #D9D9D9);
}

.page.dark .action-btn.secondary {
  background: transparent;
  border-color: var(--color-border, #2D3142);
}

.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 255, 255, 0.8);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.page.dark .loading-overlay {
  background: rgba(15, 17, 23, 0.8);
}

.loading-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid var(--color-bg-secondary, #E5E7EB);
  border-top-color: var(--color-primary, #FF6B6B);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: 26rpx;
  color: var(--color-text-secondary, #6B7280);
}
