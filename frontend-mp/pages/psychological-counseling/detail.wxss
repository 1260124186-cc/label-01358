.page {
  min-height: 100vh;
  background: var(--color-bg-page);
  display: flex;
  flex-direction: column;
  padding-bottom: 140rpx;
}

.page.dark {
  --color-bg-page: #0F1117;
  --color-bg-card: #1A1D29;
  --color-bg-secondary: #252936;
  --color-text-primary: #E8ECF1;
  --color-text-secondary: #9CA3AF;
  --color-text-placeholder: #6B7280;
  --color-border: #2D3142;
  --color-primary: #FF6B6B;
  --color-primary-dark: #E55555;
}

.page-scroll {
  flex: 1;
  height: calc(100vh - 140rpx);
}

.counselor-hero {
  position: relative;
  width: 100%;
  padding: 48rpx 32rpx 40rpx;
  overflow: hidden;
}

.hero-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #667EEA 0%, #764BA2 100%);
}

.page.dark .hero-bg {
  background: linear-gradient(135deg, #4C51BF 0%, #553C9A 100%);
}

.hero-content {
  position: relative;
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  background: #FFFFFF;
}

.counselor-info {
  flex: 1;
}

.name-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.name {
  font-size: 40rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.title-tag {
  padding: 6rpx 16rpx;
  background: rgba(255, 255, 255, 0.25);
  border-radius: 20rpx;
  font-size: 22rpx;
  color: #FFFFFF;
  backdrop-filter: blur(10rpx);
}

.meta-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.meta-item {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
}

.meta-dot {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

.info-section {
  margin: 24rpx 32rpx;
  background: var(--color-bg-card, #FFFFFF);
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary, #2C3E50);
  margin-bottom: 20rpx;
}

.info-grid {
  display: flex;
  flex-wrap: wrap;
}

.info-item {
  width: 50%;
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.info-item:nth-child(odd) {
  padding-right: 16rpx;
}

.info-item:nth-child(even) {
  padding-left: 16rpx;
}

.info-icon {
  font-size: 32rpx;
  flex-shrink: 0;
}

.info-content {
  flex: 1;
}

.info-label {
  font-size: 24rpx;
  color: var(--color-text-secondary, #9CA3AF);
  display: block;
  margin-bottom: 4rpx;
}

.info-value {
  font-size: 28rpx;
  color: var(--color-text-primary, #2C3E50);
  font-weight: 500;
}

.desc-box {
  background: var(--color-bg-secondary, #F9FAFB);
  border-radius: 16rpx;
  padding: 20rpx;
}

.desc-text {
  font-size: 26rpx;
  color: var(--color-text-secondary, #6B7280);
  line-height: 1.7;
}

.specialty-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.specialty-tag {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 20rpx;
  border-radius: 20rpx;
}

.tag-icon {
  font-size: 26rpx;
}

.tag-label {
  font-size: 24rpx;
  font-weight: 500;
}

.consult-methods {
  display: flex;
  gap: 20rpx;
}

.method-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 16rpx;
  border-radius: 16rpx;
  background: var(--color-bg-secondary, #F9FAFB);
  border: 2rpx solid transparent;
}

.method-item.active {
  background: rgba(102, 126, 234, 0.1);
  border-color: #667EEA;
}

.method-item.disabled {
  opacity: 0.4;
}

.method-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.method-label {
  font-size: 24rpx;
  color: var(--color-text-primary, #2C3E50);
  font-weight: 500;
}

.form-section {
  margin: 24rpx 32rpx;
  background: var(--color-bg-card, #FFFFFF);
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.form-item {
  margin-bottom: 28rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.label-text {
  font-size: 28rpx;
  color: var(--color-text-primary, #2C3E50);
  font-weight: 500;
}

.required {
  color: #F5222D;
  margin-left: 6rpx;
  font-size: 28rpx;
}

.optional {
  color: var(--color-text-secondary, #9CA3AF);
  margin-left: 6rpx;
  font-size: 24rpx;
}

.form-picker-wrap {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 24rpx;
  background: var(--color-bg-secondary, #F9FAFB);
  border-radius: 16rpx;
  border: 2rpx solid transparent;
}

.form-picker-text {
  font-size: 28rpx;
  color: var(--color-text-primary, #2C3E50);
}

.form-picker-text.placeholder {
  color: var(--color-text-placeholder, #9CA3AF);
}

.picker-arrow {
  font-size: 32rpx;
  color: var(--color-text-secondary, #9CA3AF);
}

.time-slot-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.time-slot-item {
  width: calc(33.333% - 11rpx);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 12rpx;
  background: var(--color-bg-secondary, #F9FAFB);
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.time-slot-item.active {
  background: rgba(102, 126, 234, 0.1);
  border-color: #667EEA;
}

.time-slot-item.disabled {
  opacity: 0.5;
}

.slot-text {
  font-size: 26rpx;
  color: var(--color-text-primary, #2C3E50);
  font-weight: 500;
  margin-bottom: 6rpx;
}

.time-slot-item.active .slot-text {
  color: #667EEA;
}

.slot-status {
  font-size: 20rpx;
}

.slot-status.available {
  color: #10B981;
}

.slot-status.full {
  color: #EF4444;
}

.empty-tip {
  padding: 32rpx 0;
  text-align: center;
}

.empty-text {
  font-size: 26rpx;
  color: var(--color-text-placeholder, #9CA3AF);
}

.form-textarea-wrap {
  padding: 20rpx 24rpx;
  background: var(--color-bg-secondary, #F9FAFB);
  border-radius: 16rpx;
  min-height: 160rpx;
}

.form-textarea {
  width: 100%;
  font-size: 28rpx;
  color: var(--color-text-primary, #2C3E50);
  line-height: 1.5;
}

.form-placeholder {
  color: var(--color-text-placeholder, #9CA3AF);
}

.word-count {
  text-align: right;
  font-size: 22rpx;
  color: var(--color-text-secondary, #9CA3AF);
  margin-top: 8rpx;
}

.privacy-section {
  margin: 24rpx 32rpx;
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, #EBF4FF 0%, #E0E7FF 100%);
  border-radius: 16rpx;
}

.page.dark .privacy-section {
  background: linear-gradient(135deg, rgba(59, 130, 246, 0.15) 0%, rgba(102, 126, 234, 0.15) 100%);
}

.privacy-icon {
  font-size: 36rpx;
  flex-shrink: 0;
}

.privacy-content {
  flex: 1;
}

.privacy-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #1E40AF;
  display: block;
  margin-bottom: 8rpx;
}

.page.dark .privacy-title {
  color: #93C5FD;
}

.privacy-text {
  font-size: 24rpx;
  color: #3B82F6;
  line-height: 1.6;
}

.page.dark .privacy-text {
  color: #BFDBFE;
}

.rules-section {
  margin: 24rpx 32rpx;
  background: var(--color-bg-card, #FFFFFF);
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.rules-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.rule-item {
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
}

.rule-dot {
  font-size: 24rpx;
  color: var(--color-primary, #FF6B6B);
  flex-shrink: 0;
  line-height: 1.6;
}

.rule-text {
  font-size: 24rpx;
  color: var(--color-text-secondary, #6B7280);
  line-height: 1.6;
}

.bottom-space {
  height: 40rpx;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: var(--color-bg-card, #FFFFFF);
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.06);
  z-index: 100;
}

.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 255, 255, 0.8);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.page.dark .loading-overlay {
  background: rgba(15, 17, 23, 0.8);
}

.loading-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid var(--color-bg-secondary, #E5E7EB);
  border-top-color: #667EEA;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: 26rpx;
  color: var(--color-text-secondary, #6B7280);
}
