.page {
  min-height: 100vh;
  background: var(--color-bg-page, #F8F9FA);
  display: flex;
  flex-direction: column;
  padding-bottom: 140rpx;
}

.page.dark {
  --color-bg-page: #0F1117;
  --color-bg-card: #1A1D29;
  --color-bg-secondary: #252936;
  --color-text-primary: #E8ECF1;
  --color-text-secondary: #9CA3AF;
  --color-text-placeholder: #6B7280;
  --color-border: #2D3142;
  --color-primary: #FF6B6B;
  --color-primary-dark: #E55555;
  --color-success: #10B981;
}

.privacy-tip {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx;
  background: linear-gradient(135deg, #6366F1 0%, #8B5CF6 100%);
  margin: 20rpx 32rpx 0;
  border-radius: 16rpx;
}

.privacy-content {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 1;
}

.privacy-icon {
  font-size: 28rpx;
}

.privacy-text {
  font-size: 24rpx;
  color: #FFFFFF;
  flex: 1;
}

.privacy-close {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  padding: 8rpx;
}

.top-actions {
  display: flex;
  gap: 20rpx;
  padding: 24rpx 32rpx;
}

.emergency-btn,
.article-btn {
  flex: 1;
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-radius: 20rpx;
  gap: 16rpx;
}

.emergency-btn {
  background: linear-gradient(135deg, #EF4444 0%, #DC2626 100%);
  box-shadow: 0 8rpx 24rpx rgba(239, 68, 68, 0.3);
}

.article-btn {
  background: linear-gradient(135deg, #3B82F6 0%, #2563EB 100%);
  box-shadow: 0 8rpx 24rpx rgba(59, 130, 246, 0.3);
}

.emergency-icon-wrap,
.article-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.emergency-icon,
.article-icon {
  font-size: 36rpx;
}

.emergency-info,
.article-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  flex: 1;
}

.emergency-title,
.article-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.emergency-phone,
.article-desc {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
}

.emergency-arrow,
.article-arrow {
  font-size: 36rpx;
  color: rgba(255, 255, 255, 0.7);
  flex-shrink: 0;
}

.filter-section {
  background: var(--color-bg-card, #FFFFFF);
  padding: 24rpx 32rpx;
  margin: 0 0 20rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.search-box {
  display: flex;
  align-items: center;
  background: var(--color-bg-secondary, #F3F4F6);
  border-radius: 40rpx;
  padding: 16rpx 24rpx;
  gap: 12rpx;
}

.search-icon {
  font-size: 28rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--color-text-primary, #2C3E50);
}

.search-placeholder {
  color: var(--color-text-placeholder, #9CA3AF);
}

.search-clear {
  font-size: 24rpx;
  color: var(--color-text-secondary, #9CA3AF);
  padding: 4rpx 8rpx;
}

.specialty-tabs {
  white-space: nowrap;
}

.specialty-tabs-inner {
  display: inline-flex;
  gap: 16rpx;
}

.specialty-tab-item {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 14rpx 24rpx;
  background: var(--color-bg-secondary, #F3F4F6);
  border-radius: 32rpx;
  transition: all 0.3s ease;
}

.specialty-tab-item.active {
  background: linear-gradient(135deg, var(--color-primary, #FF6B6B), var(--color-primary-dark, #E55555));
}

.specialty-tab-item .tab-icon {
  font-size: 24rpx;
}

.specialty-tab-item .tab-label {
  font-size: 24rpx;
  color: var(--color-text-secondary, #6B7280);
}

.specialty-tab-item.active .tab-label {
  color: #FFFFFF;
  font-weight: 500;
}

.filter-row {
  display: flex;
  gap: 32rpx;
}

.filter-group {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.filter-label {
  font-size: 24rpx;
  color: var(--color-text-secondary, #6B7280);
  font-weight: 500;
}

.filter-options {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.filter-option {
  padding: 10rpx 20rpx;
  background: var(--color-bg-secondary, #F3F4F6);
  border-radius: 16rpx;
  transition: all 0.3s ease;
}

.filter-option.active {
  background: linear-gradient(135deg, var(--color-primary, #FF6B6B) 0%, var(--color-primary-dark, #E55555) 100%);
}

.filter-option .option-text {
  font-size: 22rpx;
  color: var(--color-text-secondary, #6B7280);
}

.filter-option.active .option-text {
  color: #FFFFFF;
  font-weight: 500;
}

.counselor-list {
  flex: 1;
  padding: 0 32rpx;
}

.counselor-list-inner {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.counselor-card {
  display: flex;
  align-items: flex-start;
  padding: 28rpx;
  background: var(--color-bg-card, #FFFFFF);
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  gap: 20rpx;
}

.counselor-avatar-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
  border: 4rpx solid var(--color-bg-secondary, #F3F4F6);
}

.counselor-avatar {
  width: 100%;
  height: 100%;
}

.counselor-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  min-width: 0;
}

.counselor-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.counselor-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-primary, #2C3E50);
}

.counselor-title {
  font-size: 22rpx;
  color: var(--color-primary, #FF6B6B);
  background: rgba(255, 107, 107, 0.1);
  padding: 4rpx 14rpx;
  border-radius: 12rpx;
}

.counselor-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.meta-icon {
  font-size: 22rpx;
}

.meta-text {
  font-size: 22rpx;
  color: var(--color-text-secondary, #6B7280);
}

.specialty-tags {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 12rpx;
}

.specialty-tag {
  font-size: 20rpx;
  padding: 6rpx 14rpx;
  border-radius: 12rpx;
}

.specialty-more {
  font-size: 20rpx;
  color: var(--color-text-secondary, #9CA3AF);
}

.counselor-brief {
  margin-top: 4rpx;
}

.brief-text {
  font-size: 24rpx;
  color: var(--color-text-secondary, #6B7280);
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.card-arrow {
  font-size: 36rpx;
  color: var(--color-text-secondary, #9CA3AF);
  align-self: center;
  flex-shrink: 0;
}

.list-footer-space {
  height: 40rpx;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 32rpx calc(20rpx + env(safe-area-inset-bottom));
  background: var(--color-bg-card, #FFFFFF);
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.my-appointments-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 24rpx 32rpx;
  background: linear-gradient(135deg, var(--color-primary, #FF6B6B), var(--color-primary-dark, #E55555));
  border-radius: 48rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 107, 0.3);
}

.my-appointments-btn .btn-icon {
  font-size: 32rpx;
}

.my-appointments-btn .btn-text {
  font-size: 30rpx;
  color: #FFFFFF;
  font-weight: 600;
}

.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 255, 255, 0.8);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.page.dark .loading-overlay {
  background: rgba(15, 17, 23, 0.8);
}

.loading-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid var(--color-bg-secondary, #E5E7EB);
  border-top-color: var(--color-primary, #FF6B6B);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: 26rpx;
  color: var(--color-text-secondary, #6B7280);
}
