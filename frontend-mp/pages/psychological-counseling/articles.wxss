.page {
  min-height: 100vh;
  background: var(--color-bg-page, #F8F9FA);
  display: flex;
  flex-direction: column;
}

.page.dark {
  --color-bg-page: #0F1117;
  --color-bg-card: #1A1D29;
  --color-bg-secondary: #252936;
  --color-text-primary: #E8ECF1;
  --color-text-secondary: #9CA3AF;
  --color-text-placeholder: #6B7280;
  --color-border: #2D3142;
  --color-primary: #FF6B6B;
  --color-primary-dark: #E55555;
}

.hotline-section {
  display: flex;
  align-items: center;
  margin: 24rpx 32rpx;
  padding: 28rpx;
  background: linear-gradient(135deg, #EF4444 0%, #DC2626 100%);
  border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(239, 68, 68, 0.3);
  gap: 20rpx;
}

.hotline-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.hotline-icon {
  font-size: 40rpx;
}

.hotline-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.hotline-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.hotline-phone {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

.hotline-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 14rpx 24rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 32rpx;
  flex-shrink: 0;
}

.hotline-btn-icon {
  font-size: 28rpx;
}

.hotline-btn-text {
  font-size: 26rpx;
  font-weight: 500;
  color: #FFFFFF;
}

.search-section {
  padding: 0 32rpx 20rpx;
}

.search-box {
  display: flex;
  align-items: center;
  background: var(--color-bg-card, #FFFFFF);
  border-radius: 40rpx;
  padding: 18rpx 28rpx;
  gap: 14rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.search-icon {
  font-size: 28rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--color-text-primary, #2C3E50);
}

.search-placeholder {
  color: var(--color-text-placeholder, #9CA3AF);
}

.search-clear {
  font-size: 26rpx;
  color: var(--color-text-secondary, #9CA3AF);
  padding: 6rpx 10rpx;
}

.category-tabs {
  background: var(--color-bg-card, #FFFFFF);
  border-bottom: 1rpx solid var(--color-border, #F3F4F6);
}

.tabs-container {
  display: flex;
  padding: 20rpx 24rpx;
  gap: 16rpx;
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 28rpx;
  background: var(--color-bg-secondary, #F3F4F6);
  border-radius: 16rpx;
  flex-shrink: 0;
  transition: all 0.2s ease;
}

.tab-item.active {
  background: linear-gradient(135deg, var(--color-primary, #FF6B6B) 0%, var(--color-primary-dark, #E55555) 100%);
}

.tab-icon {
  font-size: 32rpx;
  margin-bottom: 6rpx;
}

.tab-text {
  font-size: 24rpx;
  color: var(--color-text-secondary, #6B7280);
}

.tab-item.active .tab-text {
  color: #FFFFFF;
  font-weight: 500;
}

.articles-list {
  flex: 1;
  padding: 24rpx 32rpx;
}

.article-card {
  display: flex;
  background: var(--color-bg-card, #FFFFFF);
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.article-cover {
  width: 220rpx;
  height: 220rpx;
  flex-shrink: 0;
}

.article-content {
  flex: 1;
  padding: 20rpx 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
}

.article-category {
  margin-bottom: 8rpx;
}

.category-tag {
  font-size: 20rpx;
  padding: 6rpx 14rpx;
  border-radius: 10rpx;
}

.article-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary, #2C3E50);
  line-height: 1.4;
  margin-bottom: 8rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.article-summary {
  font-size: 24rpx;
  color: var(--color-text-secondary, #6B7280);
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.article-meta {
  display: flex;
  gap: 28rpx;
}

.meta-item {
  font-size: 22rpx;
  color: var(--color-text-secondary, #9CA3AF);
}

.list-footer-space {
  height: 60rpx;
}

.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 255, 255, 0.8);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.page.dark .loading-overlay {
  background: rgba(15, 17, 23, 0.8);
}

.loading-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid var(--color-bg-secondary, #E5E7EB);
  border-top-color: var(--color-primary, #FF6B6B);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: 26rpx;
  color: var(--color-text-secondary, #6B7280);
}
