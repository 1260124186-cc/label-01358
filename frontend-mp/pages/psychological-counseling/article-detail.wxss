.page {
  min-height: 100vh;
  background: var(--color-bg-page, #F8F9FA);
  display: flex;
  flex-direction: column;
  padding-bottom: 160rpx;
}

.page.dark {
  --color-bg-page: #0F1117;
  --color-bg-card: #1A1D29;
  --color-bg-secondary: #252936;
  --color-text-primary: #E8ECF1;
  --color-text-secondary: #9CA3AF;
  --color-text-placeholder: #6B7280;
  --color-border: #2D3142;
  --color-primary: #FF6B6B;
  --color-primary-dark: #E55555;
}

.page-scroll {
  flex: 1;
  height: calc(100vh - 160rpx);
}

.cover-wrap {
  position: relative;
  width: 100%;
  height: 420rpx;
  overflow: hidden;
}

.cover-image {
  width: 100%;
  height: 100%;
}

.cover-gradient {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 120rpx;
  background: linear-gradient(to top, var(--color-bg-page, #F8F9FA), transparent);
}

.article-header {
  padding: 32rpx;
  padding-top: 24rpx;
}

.category-tag {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
}

.tag-icon {
  font-size: 24rpx;
}

.tag-label {
  font-size: 24rpx;
  font-weight: 500;
}

.article-title {
  font-size: 40rpx;
  font-weight: 600;
  color: var(--color-text-primary, #2C3E50);
  line-height: 1.4;
  margin-bottom: 20rpx;
}

.article-meta {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.meta-icon {
  font-size: 24rpx;
}

.meta-text {
  font-size: 24rpx;
  color: var(--color-text-secondary, #6B7280);
}

.meta-dot {
  font-size: 24rpx;
  color: var(--color-text-placeholder, #9CA3AF);
}

.article-content {
  padding: 0 32rpx 32rpx;
}

.content-h2 {
  margin: 40rpx 0 20rpx;
  padding-left: 20rpx;
  border-left: 6rpx solid var(--color-primary, #FF6B6B);
}

.h2-text {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--color-text-primary, #2C3E50);
  line-height: 1.4;
}

.content-h3 {
  margin: 32rpx 0 16rpx;
}

.h3-text {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary, #2C3E50);
  line-height: 1.4;
}

.content-list {
  margin: 16rpx 0;
  padding-left: 16rpx;
}

.list-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.list-bullet {
  font-size: 24rpx;
  color: var(--color-primary, #FF6B6B);
  line-height: 1.7;
  flex-shrink: 0;
}

.list-text {
  font-size: 28rpx;
  color: var(--color-text-secondary, #4B5563);
  line-height: 1.7;
  flex: 1;
}

.content-text {
  margin: 16rpx 0;
}

.paragraph-text {
  font-size: 28rpx;
  color: var(--color-text-secondary, #4B5563);
  line-height: 1.8;
  white-space: pre-wrap;
}

.related-section {
  margin: 24rpx 32rpx;
  background: var(--color-bg-card, #FFFFFF);
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary, #2C3E50);
  margin-bottom: 20rpx;
}

.related-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.related-card {
  display: flex;
  gap: 20rpx;
  padding: 16rpx;
  background: var(--color-bg-secondary, #F9FAFB);
  border-radius: 16rpx;
}

.related-cover {
  width: 180rpx;
  height: 120rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  background: #E5E7EB;
}

.related-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
}

.related-title {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--color-text-primary, #2C3E50);
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.related-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.related-tag {
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  font-size: 20rpx;
}

.related-views {
  font-size: 22rpx;
  color: var(--color-text-secondary, #9CA3AF);
  flex-shrink: 0;
}

.bottom-space {
  height: 40rpx;
}

.floating-hotline {
  position: fixed;
  right: 32rpx;
  bottom: 200rpx;
  width: 100rpx;
  height: 100rpx;
  z-index: 90;
  display: flex;
  align-items: center;
  justify-content: center;
}

.hotline-pulse {
  position: absolute;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: rgba(239, 68, 68, 0.4);
  animation: pulse 2s ease-out infinite;
}

@keyframes pulse {
  0% {
    transform: scale(1);
    opacity: 0.6;
  }
  50% {
    transform: scale(1.3);
    opacity: 0.3;
  }
  100% {
    transform: scale(1.6);
    opacity: 0;
  }
}

.hotline-inner {
  position: relative;
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #EF4444 0%, #DC2626 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(239, 68, 68, 0.4);
}

.page.dark .hotline-inner {
  background: linear-gradient(135deg, #F87171 0%, #EF4444 100%);
  box-shadow: 0 4rpx 16rpx rgba(239, 68, 68, 0.5);
}

.hotline-icon {
  font-size: 36rpx;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: var(--color-bg-card, #FFFFFF);
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.06);
  z-index: 100;
  display: flex;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  background: var(--color-bg-secondary, #F9FAFB);
  border-radius: 44rpx;
  border: none;
  padding: 0;
  margin: 0;
  line-height: 1.5;
  font-size: 28rpx;
}

.action-btn::after {
  border: none;
}

.action-icon {
  font-size: 32rpx;
}

.action-text {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--color-text-primary, #2C3E50);
}

.share-btn {
  background: linear-gradient(135deg, var(--color-primary, #FF6B6B) 0%, var(--color-primary-dark, #E55555) 100%);
}

.share-btn .action-text,
.share-btn .action-icon {
  color: #FFFFFF;
}

.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 255, 255, 0.8);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.page.dark .loading-overlay {
  background: rgba(15, 17, 23, 0.8);
}

.loading-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid var(--color-bg-secondary, #E5E7EB);
  border-top-color: var(--color-primary, #FF6B6B);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: 26rpx;
  color: var(--color-text-secondary, #6B7280);
}
