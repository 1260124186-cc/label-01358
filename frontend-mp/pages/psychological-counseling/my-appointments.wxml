<page-meta page-style="background-color: {{darkMode ? '#0F1117' : '#F8F9FA'}}; color: {{darkMode ? '#E8ECF1' : '#2C3E50'}}"/>
<view class="page {{darkMode ? 'dark' : ''}}">
  <scroll-view class="top-tabs" scroll-x="{{true}}" enhanced="{{true}}" show-scrollbar="{{false}}">
    <view class="tabs-inner">
      <view
        class="tab-item {{currentTab === item.value ? 'active' : ''}}"
        wx:for="{{tabs}}"
        wx:key="value"
        bindtap="onTabTap"
        data-value="{{item.value}}"
      >
        <text class="tab-label">{{item.label}}</text>
      </view>
    </view>
  </scroll-view>

  <scroll-view class="appointment-list" scroll-y="{{true}}" enhanced="{{true}}" show-scrollbar="{{false}}">
    <view class="list-inner" wx:if="{{filteredAppointments.length > 0}}">
      <view
        class="appointment-card"
        wx:for="{{filteredAppointments}}"
        wx:key="id"
        bindtap="onAppointmentTap"
        data-id="{{item.id}}"
      >
        <view class="card-header">
          <view class="counselor-info">
            <image class="counselor-avatar" src="{{item.counselorAvatar || '/images/default-avatar.png'}}" mode="aspectFill"/>
            <view class="counselor-meta">
              <text class="counselor-name">{{item.counselorName || '未知咨询师'}}</text>
              <text class="counselor-title">{{item.counselorTitle || ''}}</text>
            </view>
          </view>
          <view class="status-tag" style="background: {{item.statusColor}}15; color: {{item.statusColor}};">
            <text class="status-icon">{{item.statusIcon}}</text>
            <text class="status-text">{{item.statusLabel}}</text>
          </view>
        </view>

        <view class="card-body">
          <view class="info-row">
            <text class="info-icon">📅</text>
            <text class="info-label">预约日期</text>
            <text class="info-value">{{item.appointmentDate}}</text>
          </view>
          <view class="info-row">
            <text class="info-icon">⏰</text>
            <text class="info-label">预约时段</text>
            <text class="info-value">{{item.timeSlot}}</text>
          </view>
          <view class="info-row">
            <text class="info-icon">🆔</text>
            <text class="info-label">匿名ID</text>
            <text class="info-value">{{item.displayName}}</text>
          </view>
        </view>

        <view class="card-footer">
          <text class="create-time">申请时间：{{item.createTimeText}}</text>
          <view class="action-buttons">
            <view
              class="action-btn secondary"
              wx:if="{{item.status === 'pending' || item.status === 'confirmed'}}"
              catchtap="onCancel"
              data-id="{{item.id}}"
            >
              取消预约
            </view>
            <view
              class="action-btn primary"
              wx:if="{{item.status === 'pending' || item.status === 'confirmed'}}"
              catchtap="onReschedule"
              data-id="{{item.id}}"
            >
              改期
            </view>
            <view
              class="action-btn primary"
              wx:if="{{item.status === 'completed'}}"
              catchtap="onViewDetail"
              data-id="{{item.id}}"
            >
              查看详情
            </view>
          </view>
        </view>
      </view>
    </view>

    <empty wx:else text="暂无预约记录" icon="📋" />
  </scroll-view>

  <view class="loading-overlay" wx:if="{{loading}}">
    <view class="loading-content">
      <view class="loading-spinner"></view>
      <text class="loading-text">加载中...</text>
    </view>
  </view>
</view>
