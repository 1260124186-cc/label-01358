.page {
  min-height: 100vh;
  background-color: #F8F9FA;
  padding: 24rpx 32rpx;
  padding-bottom: 60rpx;
}

.page.dark {
  background-color: #0F1117;
}

/* 状态卡片 */
.status-card {
  display: flex;
  align-items: center;
  padding: 28rpx;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
}

.status-card.approved {
  background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%);
}

.status-card.pending {
  background: linear-gradient(135deg, #FFF8E1 0%, #FFECB3 100%);
}

.status-card.rejected {
  background: linear-gradient(135deg, #FFEBEE 0%, #FFCDD2 100%);
}

.status-icon {
  font-size: 56rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.status-info {
  flex: 1;
}

.status-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2E7D32;
  display: block;
  margin-bottom: 8rpx;
}

.status-card.pending .status-title {
  color: #F57C00;
}

.status-card.rejected .status-title {
  color: #C62828;
}

.status-desc {
  font-size: 24rpx;
  color: #388E3C;
  line-height: 1.5;
}

.status-card.pending .status-desc {
  color: #F57C00;
}

.status-card.rejected .status-desc {
  color: #C62828;
}

/* 认证说明卡片 */
.intro-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.intro-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.intro-icon {
  font-size: 40rpx;
  margin-right: 12rpx;
}

.intro-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
}

.intro-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.intro-item {
  display: flex;
  align-items: center;
}

.intro-item-icon {
  width: 36rpx;
  height: 36rpx;
  background: #E8F5E9;
  color: #4CAF50;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: bold;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.intro-item-text {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.4;
}

/* 表单区域 */
.form-section {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.form-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 24rpx;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-label {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.label-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
}

.required {
  color: #F44336;
  font-size: 28rpx;
  margin-left: 4rpx;
}

.optional {
  color: #999999;
  font-size: 24rpx;
  margin-left: 8rpx;
}

.form-input-wrap {
  background: #F8F9FA;
  border: 2rpx solid #EEEEEE;
  border-radius: 12rpx;
  padding: 0 20rpx;
}

.form-input {
  height: 88rpx;
  font-size: 28rpx;
  color: #333333;
}

.form-picker-wrap {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #F8F9FA;
  border: 2rpx solid #EEEEEE;
  border-radius: 12rpx;
  padding: 0 20rpx;
  height: 88rpx;
}

.form-picker-text {
  font-size: 28rpx;
  color: #333333;
}

.form-picker-text.placeholder {
  color: #999999;
}

.picker-arrow {
  font-size: 32rpx;
  color: #CCCCCC;
}

/* 协议区域 */
.terms-section {
  margin-top: 32rpx;
  margin-bottom: 32rpx;
}

.terms-row {
  display: flex;
  align-items: flex-start;
}

.terms-checkbox {
  margin-right: 12rpx;
  margin-top: 4rpx;
  flex-shrink: 0;
}

.terms-text {
  font-size: 24rpx;
  color: #666666;
  line-height: 1.6;
}

.terms-link {
  color: #FF6B6B;
}

/* 提交按钮 */
.submit-section {
  margin-top: 8rpx;
}

/* 信息展示区域 */
.info-section {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.info-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 24rpx;
}

.info-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.info-item {
  display: flex;
  align-items: center;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.info-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.info-label {
  font-size: 26rpx;
  color: #999999;
  width: 120rpx;
  flex-shrink: 0;
}

.info-value {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
}

.info-tip {
  display: flex;
  align-items: flex-start;
  margin-top: 24rpx;
  padding: 20rpx;
  background: #FFF8E1;
  border-radius: 12rpx;
}

.tip-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.tip-text {
  font-size: 24rpx;
  color: #FF8F00;
  line-height: 1.5;
  flex: 1;
}

/* 加载状态 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 60vh;
}

.loading-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #999999;
}

/* 深色模式 */
.page.dark .intro-card,
.page.dark .form-section,
.page.dark .info-section {
  background-color: #1E2128;
}

.page.dark .intro-title,
.page.dark .form-title,
.page.dark .label-text,
.page.dark .form-picker-text,
.page.dark .info-title,
.page.dark .info-value {
  color: #E8ECF1;
}

.page.dark .intro-item-text,
.page.dark .form-picker-text.placeholder,
.page.dark .terms-text,
.page.dark .info-label,
.page.dark .loading-text {
  color: #8B95A7;
}

.page.dark .form-input-wrap,
.page.dark .form-picker-wrap {
  background: #2A2E37;
  border-color: #2A2E37;
  color: #E8ECF1;
}

.page.dark .form-input {
  color: #E8ECF1;
}

.page.dark .info-item {
  border-bottom-color: #2A2E37;
}

.page.dark .info-tip {
  background: rgba(255, 143, 0, 0.1);
}
