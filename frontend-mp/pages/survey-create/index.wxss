.page {
  min-height: 100vh;
  background-color: var(--color-bg-page);
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.form-section {
  padding: 24rpx 24rpx 0;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-secondary);
  margin-bottom: 16rpx;
  padding-left: 8rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
  padding: 0 8rpx;
}

.add-q-btn {
  padding: 10rpx 24rpx;
  font-size: 26rpx;
  font-weight: 500;
  color: var(--color-primary);
  background-color: var(--color-primary-light);
  border-radius: var(--radius-full);
  transition: all var(--transition-fast);
}

.add-q-btn:active {
  transform: scale(0.95);
}

.form-card {
  background-color: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: 0 24rpx;
  box-shadow: var(--shadow-card);
}

.form-item {
  display: flex;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 1rpx solid var(--color-border-light);
}

.form-item.no-border {
  border-bottom: none;
  padding-bottom: 0;
}

.form-label {
  min-width: 140rpx;
  max-width: 180rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: var(--color-text-primary);
  flex-shrink: 0;
  white-space: nowrap;
  line-height: 40rpx;
}

.form-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--color-text-primary);
  text-align: right;
  line-height: 40rpx;
  height: 40rpx;
}

.form-input::placeholder {
  color: var(--color-text-muted);
}

.form-textarea {
  width: 100%;
  min-height: 120rpx;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: var(--color-text-primary);
  line-height: 1.7;
}

.form-textarea::placeholder {
  color: var(--color-text-muted);
}

.question-card {
  margin-bottom: 20rpx;
}

.question-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.question-header > view { margin-right: 12rpx; }
.question-header > view:last-child { margin-right: 0; }

.question-index {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, var(--color-primary) 0%, #FF8E8E 100%);
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: 700;
  border-radius: 50%;
  flex-shrink: 0;
}

.question-type-tag {
  padding: 6rpx 16rpx;
  font-size: 22rpx;
  font-weight: 600;
  border-radius: var(--radius-sm);
}

.question-type-tag.single { color: var(--color-info); background-color: rgba(52, 152, 219, 0.1); }
.question-type-tag.multiple { color: var(--color-secondary); background-color: rgba(78, 205, 196, 0.1); }
.question-type-tag.fill { color: var(--color-warning); background-color: rgba(243, 156, 18, 0.1); }
.question-type-tag.nps { color: #8B5CF6; background-color: rgba(139, 92, 246, 0.1); }
.question-type-tag.likert { color: #0EA5E9; background-color: rgba(14, 165, 233, 0.1); }
.question-type-tag.date { color: #10B981; background-color: rgba(16, 185, 129, 0.1); }

.question-actions {
  margin-left: auto;
  display: flex;
  align-items: center;
}

.question-actions > view { margin-right: 8rpx; }
.question-actions > view:last-child { margin-right: 0; }

.q-action {
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: var(--color-text-secondary);
  background-color: var(--color-bg-input);
  border-radius: var(--radius-sm);
  transition: all var(--transition-fast);
}

.q-action:active { background-color: var(--color-border); }
.q-action.disabled { opacity: 0.3; pointer-events: none; }
.q-action.delete { color: var(--color-danger); }

.question-title-input {
  width: 100%;
  font-size: 30rpx;
  font-weight: 500;
  color: var(--color-text-primary);
  line-height: 44rpx;
  height: 44rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--color-border-light);
  margin-bottom: 16rpx;
  overflow: visible;
}

.question-title-input::placeholder {
  color: var(--color-text-muted);
  font-weight: 400;
}

.option-list {
  display: flex;
  flex-direction: column;
}

.option-list > view { margin-bottom: 12rpx; }
.option-list > view:last-child { margin-bottom: 0; }

.option-item {
  display: flex;
  align-items: center;
  padding: 12rpx 16rpx;
  background-color: var(--color-bg-input);
  border-radius: var(--radius-md);
}

.option-item > view { margin-right: 12rpx; }
.option-item > view:last-child { margin-right: 0; }

.option-radio {
  font-size: 28rpx;
  color: var(--color-text-muted);
  flex-shrink: 0;
  width: 40rpx;
  text-align: center;
}

.option-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--color-text-primary);
  height: 40rpx;
  line-height: 40rpx;
}

.option-input::placeholder { color: var(--color-text-muted); }

.option-delete {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: var(--color-text-muted);
  border-radius: 50%;
  flex-shrink: 0;
  transition: all var(--transition-fast);
}

.option-delete:active { color: var(--color-danger); background-color: rgba(231, 76, 60, 0.1); }

.add-option-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx;
  margin-top: 12rpx;
  font-size: 26rpx;
  color: var(--color-primary);
  border: 2rpx dashed var(--color-primary-light);
  border-radius: var(--radius-md);
  transition: all var(--transition-fast);
}

.add-option-btn:active { background-color: var(--color-primary-light); }

.fill-hint {
  padding: 24rpx;
  background-color: var(--color-bg-input);
  border-radius: var(--radius-md);
  border: 2rpx dashed var(--color-border);
}

.fill-hint text { font-size: 26rpx; color: var(--color-text-muted); }

.nps-preview {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  background-color: var(--color-bg-input);
  border-radius: var(--radius-md);
}

.nps-label-left, .nps-label-right {
  font-size: 22rpx;
  color: var(--color-text-muted);
  margin: 8rpx 0;
}

.nps-scale-preview {
  display: flex;
  justify-content: space-between;
  width: 100%;
}

.nps-num {
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 600;
  color: var(--color-text-secondary);
  background-color: var(--color-bg-card);
  border-radius: var(--radius-sm);
  border: 2rpx solid var(--color-border-light);
}

.likert-preview {
  display: flex;
  justify-content: space-between;
  padding: 20rpx;
  background-color: var(--color-bg-input);
  border-radius: var(--radius-md);
}

.likert-option {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.likert-num {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 600;
  color: var(--color-text-secondary);
  background-color: var(--color-bg-card);
  border-radius: 50%;
  border: 2rpx solid var(--color-border-light);
  margin-bottom: 8rpx;
}

.likert-text {
  font-size: 18rpx;
  color: var(--color-text-muted);
  text-align: center;
}

.settings-card, .logic-card {
  margin-bottom: 20rpx;
}

.setting-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--color-border-light);
}

.setting-item:last-child { border-bottom: none; }

.setting-label {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--color-text-primary);
}

.setting-value {
  font-size: 28rpx;
  color: var(--color-text-primary);
}

.setting-value.placeholder { color: var(--color-text-muted); }

.setting-input {
  width: 200rpx;
  text-align: right;
  font-size: 28rpx;
  color: var(--color-text-primary);
}

.toggle-arrow {
  font-size: 24rpx;
  color: var(--color-text-muted);
  transition: transform 0.3s;
}

.toggle-arrow.open { transform: rotate(90deg); }

.logic-rules { margin-bottom: 20rpx; }

.logic-rule-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx;
  background-color: var(--color-bg-input);
  border-radius: var(--radius-md);
  margin-bottom: 12rpx;
}

.logic-rule-text {
  flex: 1;
  font-size: 24rpx;
  color: var(--color-text-primary);
  line-height: 1.5;
}

.logic-rule-delete {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: var(--color-danger);
  flex-shrink: 0;
}

.no-rules {
  padding: 20rpx;
  text-align: center;
}

.no-rules text { font-size: 24rpx; color: var(--color-text-muted); }

.logic-form {
  padding-top: 16rpx;
  border-top: 1rpx solid var(--color-border-light);
}

.logic-form-row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.logic-form-label {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  margin-right: 12rpx;
  flex-shrink: 0;
}

.logic-picker {
  padding: 12rpx 20rpx;
  background-color: var(--color-bg-input);
  border-radius: var(--radius-md);
  font-size: 26rpx;
  color: var(--color-text-primary);
  margin-right: 12rpx;
  max-width: 240rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.logic-value-input {
  flex: 1;
  padding: 12rpx 20rpx;
  background-color: var(--color-bg-input);
  border-radius: var(--radius-md);
  font-size: 26rpx;
  color: var(--color-text-primary);
}

.logic-add-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx;
  margin-top: 8rpx;
  font-size: 26rpx;
  color: var(--color-primary);
  border: 2rpx dashed var(--color-primary-light);
  border-radius: var(--radius-md);
}

.submit-section {
  padding: 40rpx 24rpx;
}

.picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.picker-mask.show { opacity: 1; visibility: visible; }

.picker-content {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: var(--color-bg-card);
  border-radius: var(--radius-2xl) var(--radius-2xl) 0 0;
  padding-bottom: env(safe-area-inset-bottom);
  transform: translateY(100%);
  transition: transform 0.35s cubic-bezier(0.32, 0.72, 0, 1);
}

.picker-mask.show .picker-content { transform: translateY(0); }

.picker-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid var(--color-border-light);
}

.picker-title { font-size: 34rpx; font-weight: 700; color: var(--color-text-primary); }

.picker-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: var(--color-text-muted);
  background-color: var(--color-bg-input);
  border-radius: 50%;
}

.picker-options { padding: 16rpx 32rpx 32rpx; }

.picker-option {
  display: flex;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 1rpx solid var(--color-border-light);
  transition: all var(--transition-fast);
}

.picker-option:last-child { border-bottom: none; }
.picker-option:active { background-color: var(--color-bg-page); }

.type-icon {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  background-color: var(--color-primary-light);
  border-radius: var(--radius-lg);
  margin-right: 20rpx;
  flex-shrink: 0;
}

.type-info { display: flex; flex-direction: column; }
.type-info > view { margin-bottom: 4rpx; }
.type-info > view:last-child { margin-bottom: 0; }

.type-name { font-size: 30rpx; font-weight: 600; color: var(--color-text-primary); }
.type-desc { font-size: 24rpx; color: var(--color-text-secondary); }
