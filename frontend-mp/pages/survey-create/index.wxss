.page {
  min-height: 100vh;
  background-color: var(--color-bg-page);
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.form-section {
  padding: 24rpx 24rpx 0;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-secondary);
  margin-bottom: 16rpx;
  padding-left: 8rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
  padding: 0 8rpx;
}

.add-q-btn {
  padding: 10rpx 24rpx;
  font-size: 26rpx;
  font-weight: 500;
  color: var(--color-primary);
  background-color: var(--color-primary-light);
  border-radius: var(--radius-full);
  transition: all var(--transition-fast);
}

.add-q-btn:active {
  transform: scale(0.95);
}

.form-card {
  background-color: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: 0 24rpx;
  box-shadow: var(--shadow-card);
}

.form-item {
  display: flex;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 1rpx solid var(--color-border-light);
}

.form-item.no-border {
  border-bottom: none;
  padding-bottom: 0;
}

.form-label {
  min-width: 140rpx;
  max-width: 180rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: var(--color-text-primary);
  flex-shrink: 0;
  white-space: nowrap;
  line-height: 40rpx;
}

.form-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--color-text-primary);
  text-align: right;
  line-height: 40rpx;
  height: 40rpx;
}

.form-input::placeholder {
  color: var(--color-text-muted);
}

.form-textarea {
  width: 100%;
  min-height: 120rpx;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: var(--color-text-primary);
  line-height: 1.7;
}

.form-textarea::placeholder {
  color: var(--color-text-muted);
}

.question-card {
  margin-bottom: 20rpx;
}

.question-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.question-index {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, var(--color-primary) 0%, #FF8E8E 100%);
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: 700;
  border-radius: 50%;
  flex-shrink: 0;
}

.question-type-tag {
  padding: 6rpx 16rpx;
  font-size: 22rpx;
  font-weight: 600;
  border-radius: var(--radius-sm);
}

.question-type-tag.single {
  color: var(--color-info);
  background-color: rgba(52, 152, 219, 0.1);
}

.question-type-tag.multiple {
  color: var(--color-secondary);
  background-color: rgba(78, 205, 196, 0.1);
}

.question-type-tag.fill {
  color: var(--color-warning);
  background-color: rgba(243, 156, 18, 0.1);
}

.question-actions {
  margin-left: auto;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.q-action {
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: var(--color-text-secondary);
  background-color: var(--color-bg-input);
  border-radius: var(--radius-sm);
  transition: all var(--transition-fast);
}

.q-action:active {
  background-color: var(--color-border);
}

.q-action.disabled {
  opacity: 0.3;
  pointer-events: none;
}

.q-action.delete {
  color: var(--color-danger);
}

.question-title-input {
  width: 100%;
  font-size: 30rpx;
  font-weight: 500;
  color: var(--color-text-primary);
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--color-border-light);
  margin-bottom: 16rpx;
}

.question-title-input::placeholder {
  color: var(--color-text-muted);
  font-weight: 400;
}

.option-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.option-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 16rpx;
  background-color: var(--color-bg-input);
  border-radius: var(--radius-md);
}

.option-radio {
  font-size: 28rpx;
  color: var(--color-text-muted);
  flex-shrink: 0;
  width: 40rpx;
  text-align: center;
}

.option-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--color-text-primary);
  height: 40rpx;
}

.option-input::placeholder {
  color: var(--color-text-muted);
}

.option-delete {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: var(--color-text-muted);
  border-radius: 50%;
  flex-shrink: 0;
  transition: all var(--transition-fast);
}

.option-delete:active {
  color: var(--color-danger);
  background-color: rgba(231, 76, 60, 0.1);
}

.add-option-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx;
  margin-top: 12rpx;
  font-size: 26rpx;
  color: var(--color-primary);
  border: 2rpx dashed var(--color-primary-light);
  border-radius: var(--radius-md);
  transition: all var(--transition-fast);
}

.add-option-btn:active {
  background-color: var(--color-primary-light);
}

.fill-hint {
  padding: 24rpx;
  background-color: var(--color-bg-input);
  border-radius: var(--radius-md);
  border: 2rpx dashed var(--color-border);
}

.fill-hint text {
  font-size: 26rpx;
  color: var(--color-text-muted);
}

.submit-section {
  padding: 40rpx 24rpx;
}

.picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.picker-mask.show {
  opacity: 1;
  visibility: visible;
}

.picker-content {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: var(--color-bg-card);
  border-radius: var(--radius-2xl) var(--radius-2xl) 0 0;
  padding-bottom: env(safe-area-inset-bottom);
  transform: translateY(100%);
  transition: transform 0.35s cubic-bezier(0.32, 0.72, 0, 1);
}

.picker-mask.show .picker-content {
  transform: translateY(0);
}

.picker-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid var(--color-border-light);
}

.picker-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

.picker-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: var(--color-text-muted);
  background-color: var(--color-bg-input);
  border-radius: 50%;
}

.picker-options {
  padding: 16rpx 32rpx 32rpx;
}

.picker-option {
  display: flex;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 1rpx solid var(--color-border-light);
  transition: all var(--transition-fast);
}

.picker-option:last-child {
  border-bottom: none;
}

.picker-option:active {
  background-color: var(--color-bg-page);
}

.type-icon {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  background-color: var(--color-primary-light);
  border-radius: var(--radius-lg);
  margin-right: 20rpx;
  flex-shrink: 0;
}

.type-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.type-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.type-desc {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}
