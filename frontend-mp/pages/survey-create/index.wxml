<page-meta page-style="background-color: {{darkMode ? '#0F1117' : '#F8F9FA'}}; color: {{darkMode ? '#E8ECF1' : '#2C3E50'}}"/>
<view class="page {{darkMode ? 'dark' : ''}}">
  <view class="form-section">
    <view class="section-title">基本信息</view>
    <view class="form-card">
      <view class="form-item">
        <text class="form-label">问卷标题</text>
        <input
          class="form-input"
          placeholder="请输入问卷标题"
          value="{{formData.title}}"
          bindinput="onTitleInput"
          maxlength="50"
        />
      </view>
      <view class="form-item no-border">
        <text class="form-label">问卷描述</text>
      </view>
      <textarea
        class="form-textarea"
        placeholder="请输入问卷描述（选填）"
        value="{{formData.description}}"
        bindinput="onDescInput"
        maxlength="200"
      />
    </view>
  </view>

  <view class="form-section">
    <view class="section-header">
      <text class="section-title">题目列表</text>
      <view class="add-q-btn" bindtap="onAddQuestion">
        <text>+ 添加题目</text>
      </view>
    </view>

    <view
      class="question-card card"
      wx:for="{{formData.questions}}"
      wx:key="id"
    >
      <view class="card-body">
        <view class="question-header">
          <view class="question-index">{{index + 1}}</view>
          <view class="question-type-tag {{item.type}}">
            {{questionTypeLabels[item.type] || item.type}}
          </view>
          <view class="question-actions">
            <view
              class="q-action {{index === 0 ? 'disabled' : ''}}"
              catchtap="onMoveUp"
              data-index="{{index}}"
            >↑</view>
            <view
              class="q-action {{index === formData.questions.length - 1 ? 'disabled' : ''}}"
              catchtap="onMoveDown"
              data-index="{{index}}"
            >↓</view>
            <view
              class="q-action delete"
              catchtap="onDeleteQuestion"
              data-index="{{index}}"
            >✕</view>
          </view>
        </view>

        <input
          class="question-title-input"
          placeholder="请输入题目标题"
          value="{{item.title}}"
          bindinput="onQuestionTitleInput"
          data-index="{{index}}"
          maxlength="100"
        />

        <block wx:if="{{item.type === 'single' || item.type === 'multiple'}}">
          <view class="option-list">
            <view
              class="option-item"
              wx:for="{{item.options}}"
              wx:for-item="opt"
              wx:for-index="oIndex"
              wx:key="oIndex"
            >
              <view class="option-radio {{item.type === 'multiple' ? 'checkbox' : ''}}">
                <text wx:if="{{item.type === 'single'}}">○</text>
                <text wx:else>☐</text>
              </view>
              <input
                class="option-input"
                value="{{opt}}"
                bindinput="onOptionInput"
                data-q-index="{{index}}"
                data-o-index="{{oIndex}}"
                maxlength="50"
              />
              <view
                class="option-delete"
                catchtap="onDeleteOption"
                data-q-index="{{index}}"
                data-o-index="{{oIndex}}"
              >✕</view>
            </view>
          </view>
          <view
            class="add-option-btn"
            catchtap="onAddOption"
            data-index="{{index}}"
          >
            <text>+ 添加选项</text>
          </view>
        </block>

        <block wx:if="{{item.type === 'fill'}}">
          <view class="fill-hint">
            <text>答题者将在此处输入文字</text>
          </view>
        </block>

        <block wx:if="{{item.type === 'nps'}}">
          <view class="nps-preview">
            <view class="nps-label-left">完全不可能</view>
            <view class="nps-scale-preview">
              <view class="nps-num" wx:for="{{11}}" wx:key="*this" wx:for-index="n">
                {{n}}
              </view>
            </view>
            <view class="nps-label-right">非常可能</view>
          </view>
        </block>

        <block wx:if="{{item.type === 'likert'}}">
          <view class="likert-preview">
            <view class="likert-option" wx:for="{{5}}" wx:key="*this" wx:for-index="li">
              <view class="likert-num">{{li + 1}}</view>
              <text class="likert-text">{{li === 0 ? '非常不同意' : li === 1 ? '不同意' : li === 2 ? '一般' : li === 3 ? '同意' : '非常同意'}}</text>
            </view>
          </view>
        </block>

        <block wx:if="{{item.type === 'date'}}">
          <view class="fill-hint">
            <text>答题者将选择日期和时间</text>
          </view>
        </block>
      </view>
    </view>
  </view>

  <view class="form-section">
    <view class="section-header" bindtap="onToggleSettings">
      <text class="section-title">问卷设置</text>
      <text class="toggle-arrow {{showSettings ? 'open' : ''}}">▶</text>
    </view>

    <view class="settings-card card" wx:if="{{showSettings}}">
      <view class="card-body">
        <view class="setting-item">
          <text class="setting-label">截止时间</text>
          <picker mode="date" value="{{deadlineDisplay}}" bindchange="onDeadlineChange">
            <view class="setting-value {{deadlineDisplay ? '' : 'placeholder'}}">
              {{deadlineDisplay || '不限制'}}
            </view>
          </picker>
        </view>
        <view class="setting-item">
          <text class="setting-label">答题次数限制</text>
          <input
            class="setting-input"
            type="number"
            placeholder="0 表示不限"
            value="{{formData.settings.maxResponses || ''}}"
            bindinput="onMaxResponsesInput"
          />
        </view>
        <view class="setting-item">
          <text class="setting-label">公开结果</text>
          <switch
            checked="{{formData.settings.publicResults}}"
            bindchange="onPublicResultsChange"
            color="#FF6B6B"
          />
        </view>
        <view class="setting-item">
          <text class="setting-label">匿名展示</text>
          <switch
            checked="{{formData.settings.anonymousDisplay}}"
            bindchange="onAnonymousDisplayChange"
            color="#FF6B6B"
          />
        </view>
      </view>
    </view>
  </view>

  <view class="form-section">
    <view class="section-header" bindtap="onToggleLogicEditor">
      <text class="section-title">逻辑跳转</text>
      <text class="toggle-arrow {{showLogicEditor ? 'open' : ''}}">▶</text>
    </view>

    <view class="logic-card card" wx:if="{{showLogicEditor}}">
      <view class="card-body">
        <view class="logic-rules" wx:if="{{formData.logicRules.length > 0}}">
          <view class="logic-rule-item" wx:for="{{formData.logicRules}}" wx:key="id">
            <view class="logic-rule-text">
              第{{index + 1}}条：当「{{formData.questions.find(q => q.id === item.sourceQuestionId).title || '未知题目'}}」
              {{item.operator === 'eq' ? '等于' : item.operator === 'neq' ? '不等于' : item.operator === 'contains' ? '包含' : item.operator === 'gt' ? '大于' : item.operator === 'lt' ? '小于' : item.operator === 'gte' ? '大于等于' : '小于等于'}}
              「{{item.value}}」时，{{item.action === 'show' ? '显示' : '跳过'}}「{{formData.questions.find(q => q.id === item.targetQuestionId).title || '未知题目'}}」
            </view>
            <view class="logic-rule-delete" catchtap="onDeleteLogicRule" data-index="{{index}}">✕</view>
          </view>
        </view>

        <view class="no-rules" wx:if="{{formData.logicRules.length === 0}}">
          <text>暂无逻辑规则，添加规则可控制题目显示/跳过</text>
        </view>

        <view class="logic-form">
          <view class="logic-form-row">
            <text class="logic-form-label">当</text>
            <picker
              range="{{formData.questions}}"
              range-key="title"
              value="{{logicForm.sourceQuestionIndex}}"
              bindchange="onLogicFieldChange"
              data-field="sourceQuestionId"
            >
              <view class="logic-picker">
                {{logicForm.sourceQuestionId ? (formData.questions.find(q => q.id === logicForm.sourceQuestionId).title || '选择题目') : '选择题目'}}
              </view>
            </picker>
          </view>
          <view class="logic-form-row">
            <picker
              range="{{['等于','不等于','包含','大于','小于','大于等于','小于等于']}}"
              range-key="label"
              value="{{['eq','neq','contains','gt','lt','gte','lte'].indexOf(logicForm.operator)}}"
              bindchange="onLogicFieldChange"
              data-field="operator"
            >
              <view class="logic-picker">{{['等于','不等于','包含','大于','小于','大于等于','小于等于'][['eq','neq','contains','gt','lt','gte','lte'].indexOf(logicForm.operator)]}}</view>
            </picker>
            <input
              class="logic-value-input"
              placeholder="条件值"
              value="{{logicForm.value}}"
              bindinput="onLogicFieldChange"
              data-field="value"
            />
          </view>
          <view class="logic-form-row">
            <text class="logic-form-label">时</text>
            <picker
              range="{{['显示','跳过']}}"
              value="{{logicForm.action === 'show' ? 0 : 1}}"
              bindchange="onLogicFieldChange"
              data-field="action"
            >
              <view class="logic-picker">{{logicForm.action === 'show' ? '显示' : '跳过'}}</view>
            </picker>
            <picker
              range="{{formData.questions}}"
              range-key="title"
              value="{{logicForm.targetQuestionIndex}}"
              bindchange="onLogicFieldChange"
              data-field="targetQuestionId"
            >
              <view class="logic-picker">
                {{logicForm.targetQuestionId ? (formData.questions.find(q => q.id === logicForm.targetQuestionId).title || '目标题目') : '目标题目'}}
              </view>
            </picker>
          </view>
          <view class="logic-add-btn" bindtap="onAddLogicRule">
            <text>+ 添加规则</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="submit-section">
    <btn type="primary" size="large" block="{{true}}" loading="{{submitting}}" bind:click="onSubmit">
      发布问卷
    </btn>
  </view>

  <view
    class="picker-mask {{showTypePicker ? 'show' : ''}}"
    bindtap="onHideTypePicker"
  >
    <view class="picker-content" catchtap="stopPropagation">
      <view class="picker-header">
        <text class="picker-title">选择题目类型</text>
        <text class="picker-close" bindtap="onHideTypePicker">×</text>
      </view>
      <view class="picker-options">
        <view
          class="picker-option"
          bindtap="onTypeSelect"
          data-type="single"
        >
          <view class="type-icon">○</view>
          <view class="type-info">
            <text class="type-name">单选题</text>
            <text class="type-desc">从多个选项中选择一个</text>
          </view>
        </view>
        <view
          class="picker-option"
          bindtap="onTypeSelect"
          data-type="multiple"
        >
          <view class="type-icon">☐</view>
          <view class="type-info">
            <text class="type-name">多选题</text>
            <text class="type-desc">从多个选项中选择多个</text>
          </view>
        </view>
        <view
          class="picker-option"
          bindtap="onTypeSelect"
          data-type="fill"
        >
          <view class="type-icon">✎</view>
          <view class="type-info">
            <text class="type-name">填空题</text>
            <text class="type-desc">自由输入文字回答</text>
          </view>
        </view>
        <view
          class="picker-option"
          bindtap="onTypeSelect"
          data-type="nps"
        >
          <view class="type-icon">★</view>
          <view class="type-info">
            <text class="type-name">NPS评分</text>
            <text class="type-desc">0-10推荐度评分</text>
          </view>
        </view>
        <view
          class="picker-option"
          bindtap="onTypeSelect"
          data-type="likert"
        >
          <view class="type-icon">☰</view>
          <view class="type-info">
            <text class="type-name">量表题</text>
            <text class="type-desc">1-5 Likert量表</text>
          </view>
        </view>
        <view
          class="picker-option"
          bindtap="onTypeSelect"
          data-type="date"
        >
          <view class="type-icon">📅</view>
          <view class="type-info">
            <text class="type-name">日期时间</text>
            <text class="type-desc">选择日期和时间</text>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>
