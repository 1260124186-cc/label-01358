.page {
  min-height: 100vh;
  background-color: var(--color-bg-page);
}

.cover-image {
  width: 100%;
  height: 400rpx;
  border-radius: 0 0 var(--radius-xl) var(--radius-xl);
}

.content-section {
  padding: 32rpx;
  margin: -40rpx 24rpx 24rpx;
  background-color: var(--color-bg-card);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-card);
  position: relative;
}

.content-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  line-height: 1.4;
  margin-bottom: 16rpx;
}

.content-time {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: var(--color-text-tertiary);
  margin-bottom: 24rpx;
}

.content-time::before {
  content: '';
  display: inline-block;
  width: 8rpx;
  height: 8rpx;
  background-color: var(--color-primary);
  border-radius: 50%;
  margin-right: 12rpx;
}

.content-divider {
  height: 1rpx;
  background: linear-gradient(90deg, var(--color-primary-light), transparent);
  margin-bottom: 24rpx;
}

.content-text {
  font-size: 30rpx;
  color: var(--color-text-secondary);
  line-height: 1.8;
}

.empty-page {
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-text {
  font-size: 28rpx;
  color: var(--color-text-tertiary);
}
