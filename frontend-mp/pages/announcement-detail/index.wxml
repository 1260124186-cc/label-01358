<page-meta page-style="background-color: {{darkMode ? '#0F1117' : '#F8F9FA'}}; color: {{darkMode ? '#E8ECF1' : '#2C3E50'}}"/>
<view class="page {{darkMode ? 'dark' : ''}}" wx:if="{{detail}}">
  <!-- 封面图 -->
  <image class="cover-image" src="{{detail.image}}" mode="aspectFill" wx:if="{{detail.image}}" />

  <!-- 内容 -->
  <view class="content-section">
    <text class="content-title">{{detail.title}}</text>
    <text class="content-time">{{detail.timeText}}</text>
    <view class="content-divider"></view>
    <text class="content-text">{{detail.content}}</text>
  </view>
</view>

<view class="page empty-page {{darkMode ? 'dark' : ''}}" wx:else>
  <text class="empty-text">公告不存在</text>
</view>
