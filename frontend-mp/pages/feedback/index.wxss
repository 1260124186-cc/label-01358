.page {
  min-height: 100vh;
  background-color: var(--color-bg-page);
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.form-section {
  padding: 24rpx 24rpx 0;
}

.section-title {
  font-size: calc(var(--font-md) * var(--font-scale));
  font-weight: 600;
  color: var(--color-text-secondary);
  margin-bottom: 16rpx;
  padding-left: 8rpx;
}

/* ==================== 类型选择药丸 ==================== */
.type-scroll {
  white-space: nowrap;
}

.type-pills {
  display: inline-flex;
  padding-bottom: 4rpx;
}

.type-pills > * { margin-right: 16rpx; }

.type-pills > *:last-child { margin-right: 0; }

.type-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 36rpx;
  background-color: var(--color-bg-card);
  border-radius: var(--radius-full);
  border: 2rpx solid var(--color-border);
  transition: all var(--transition-fast);
  flex-shrink: 0;
}

.type-pill:active {
  transform: scale(0.96);
}

.type-pill.active {
  background: linear-gradient(135deg, var(--color-primary) 0%, #FF8E8E 100%);
  border-color: var(--color-primary);
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 107, 0.3);
}

.pill-text {
  font-size: calc(var(--font-base) * var(--font-scale));
  font-weight: 500;
  color: var(--color-text-primary);
  white-space: nowrap;
}

.type-pill.active .pill-text {
  color: #FFFFFF;
  font-weight: 600;
}

/* ==================== 表单卡片 ==================== */
.form-card {
  background-color: var(--color-bg-card);
  border-radius: var(--radius-2xl);
  padding: 0 24rpx;
  box-shadow: var(--shadow-card);
}

/* ==================== 文本域 ==================== */
.feedback-textarea {
  width: 100%;
  min-height: 240rpx;
  padding: 24rpx 0 8rpx;
  font-size: calc(var(--font-base) * var(--font-scale));
  color: var(--color-text-primary);
  line-height: 1.7;
}

.feedback-textarea::placeholder {
  color: var(--color-text-muted);
}

.textarea-count {
  display: block;
  text-align: right;
  font-size: calc(var(--font-sm) * var(--font-scale));
  color: var(--color-text-muted);
  padding-bottom: 20rpx;
}

/* ==================== 图片网格 ==================== */
.image-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 24rpx 0;
}

.image-grid { margin-right: -16rpx; margin-bottom: -16rpx; }

.image-grid > * { margin-right: 16rpx; margin-bottom: 16rpx; }

.image-item {
  position: relative;
  width: calc(50% - 16rpx);
  padding-bottom: 100%;
}

.image-thumb {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  border-radius: var(--radius-lg);
}

.image-delete {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 40rpx;
  height: 40rpx;
  background: linear-gradient(135deg, #E74C3C 0%, #EC7063 100%);
  color: #FFFFFF;
  font-size: 26rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(231, 76, 60, 0.4);
  z-index: 2;
  line-height: 1;
}

.image-add {
  width: calc(50% - 16rpx);
  padding-bottom: 100%;
  position: relative;
  background-color: var(--color-bg-input);
  border: 2rpx dashed var(--color-border);
  border-radius: var(--radius-lg);
  transition: all var(--transition-fast);
}

.image-add:active {
  background-color: var(--color-border);
}

.add-icon {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 56rpx;
  color: var(--color-text-muted);
  line-height: 1;
}

.image-tip {
  font-size: calc(var(--font-sm) * var(--font-scale));
  color: var(--color-text-muted);
  padding-bottom: 16rpx;
}

/* ==================== 联系方式输入 ==================== */
.contact-input {
  width: 100%;
  height: 80rpx;
  font-size: calc(var(--font-base) * var(--font-scale));
  color: var(--color-text-primary);
  line-height: 80rpx;
}

.contact-input::placeholder {
  color: var(--color-text-muted);
}

/* ==================== 提交按钮 ==================== */
.submit-section {
  padding: 48rpx 24rpx 0;
}

.submit-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, var(--color-primary) 0%, #FF8E8E 100%);
  border-radius: var(--radius-2xl);
  font-size: calc(var(--font-lg) * var(--font-scale));
  font-weight: 600;
  color: #FFFFFF;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 107, 0.3);
  transition: all var(--transition-fast);
}

.submit-btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.submit-btn.disabled {
  opacity: 0.6;
  pointer-events: none;
}

.submit-loading {
  margin-right: 12rpx;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

/* ==================== 暗色模式适配 ==================== */
.dark .type-pill {
  border-color: var(--color-border);
}

.dark .type-pill.active {
  box-shadow: 0 4rpx 16rpx rgba(255, 138, 138, 0.2);
}

.dark .image-add {
  border-color: var(--color-border);
  background-color: var(--color-bg-input);
}

.dark .image-add:active {
  background-color: var(--color-bg-elevated);
}

.dark .submit-btn {
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.3);
}

.dark .submit-btn:active {
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.3);
}

/* ==================== 主题色适配 ==================== */
.dark.color-scheme-coral .submit-btn,
.color-scheme-coral .submit-btn {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
}

.dark.color-scheme-coral .submit-btn {
  background: linear-gradient(135deg, #C04040 0%, #D06060 100%);
}

.color-scheme-blue .submit-btn {
  background: linear-gradient(135deg, #4A90D9 0%, #6BA8E8 100%);
}

.dark.color-scheme-blue .submit-btn {
  background: linear-gradient(135deg, #2A5080 0%, #3A6A9E 100%);
}

.color-scheme-green .submit-btn {
  background: linear-gradient(135deg, #2ECC71 0%, #4ADE80 100%);
}

.dark.color-scheme-green .submit-btn {
  background: linear-gradient(135deg, #1A7A42 0%, #2A9A5A 100%);
}

.color-scheme-purple .submit-btn {
  background: linear-gradient(135deg, #8B5CF6 0%, #A78BFA 100%);
}

.dark.color-scheme-purple .submit-btn {
  background: linear-gradient(135deg, #5B2F9E 0%, #7B4FBE 100%);
}

/* ==================== 字体缩放支持 ==================== */
.font-size-standard {
  --font-scale: 1;
}

.font-size-large {
  --font-scale: 1.15;
}

.font-size-xl {
  --font-scale: 1.3;
}
