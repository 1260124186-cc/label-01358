.page {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

.hero-banner {
  padding: 48rpx 32rpx 40rpx;
  background: linear-gradient(135deg, #667EEA 0%, #764BA2 100%);
}

.hero-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 12rpx;
}

.hero-subtitle {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-bottom: 32rpx;
}

.hero-stats {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 20rpx;
  padding: 24rpx 16rpx;
  backdrop-filter: blur(10px);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 36rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 6rpx;
}

.stat-label {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.75);
}

.stat-divider {
  width: 2rpx;
  height: 56rpx;
  background: rgba(255, 255, 255, 0.2);
}

.auto-match-section {
  padding: 24rpx 32rpx;
  margin-top: -20rpx;
}

.auto-match-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #10B981 0%, #059669 100%);
  border-radius: 48rpx;
  padding: 28rpx;
  box-shadow: 0 8rpx 24rpx rgba(16, 185, 129, 0.3);
}

.auto-match-btn text {
  margin-right: 12rpx;
}

.auto-match-btn text:last-child {
  margin-right: 0;
}

.btn-icon {
  font-size: 36rpx;
}

.btn-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.my-buddy-section {
  padding: 24rpx 32rpx 0;
  margin-top: -20rpx;
}

.my-buddy-section .section-header {
  margin-bottom: 20rpx;
}

.section-header {
  display: flex;
  align-items: center;
  padding: 0 8rpx;
  margin-bottom: 24rpx;
}

.section-header text {
  margin-right: 12rpx;
}

.section-header text:last-child {
  margin-right: 0;
}

.section-icon {
  font-size: 32rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.my-buddy-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.page.dark .my-buddy-card {
  background: #1E2230;
}

.my-buddy-info {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.my-buddy-info text,
.my-buddy-info view {
  margin-right: 20rpx;
}

.my-buddy-info text:last-child,
.my-buddy-info view:last-child {
  margin-right: 0;
}

.my-buddy-avatar {
  font-size: 64rpx;
}

.my-buddy-detail {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.my-buddy-detail text {
  margin-right: 0;
}

.my-buddy-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #2C3E50;
  margin-bottom: 6rpx;
}

.page.dark .my-buddy-name {
  color: #E8ECF1;
}

.my-buddy-status {
  font-size: 22rpx;
  color: #10B981;
  background: #D1FAE5;
  padding: 4rpx 16rpx;
  border-radius: 12rpx;
  display: inline-block;
  align-self: flex-start;
}

.my-buddy-actions {
  display: flex;
}

.my-buddy-actions view {
  margin-right: 16rpx;
}

.my-buddy-actions view:last-child {
  margin-right: 0;
}

.action-btn-outline {
  flex: 1;
  padding: 20rpx;
  border: 2rpx solid #667EEA;
  border-radius: 32rpx;
  text-align: center;
}

.action-btn-outline text {
  font-size: 26rpx;
  color: #667EEA;
  font-weight: 500;
}

.action-btn-danger {
  flex: 1;
  padding: 20rpx;
  background: #FEF2F2;
  border-radius: 32rpx;
  text-align: center;
}

.action-btn-danger text {
  font-size: 26rpx;
  color: #EF4444;
  font-weight: 500;
}

.section {
  margin: 32rpx 24rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.page.dark .section {
  background: #1E2230;
}

.section .section-title {
  color: #2C3E50;
}

.page.dark .section .section-title {
  color: #E8ECF1;
}

.buddy-list {
  display: flex;
  flex-direction: column;
}

.buddy-list view {
  margin-bottom: 20rpx;
}

.buddy-list view:last-child {
  margin-bottom: 0;
}

.buddy-card {
  background: #FAFAFA;
  border-radius: 16rpx;
  padding: 24rpx;
}

.page.dark .buddy-card {
  background: #2D3142;
}

.buddy-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.buddy-header text,
.buddy-header view {
  margin-right: 16rpx;
}

.buddy-header text:last-child,
.buddy-header view:last-child {
  margin-right: 0;
}

.buddy-avatar {
  font-size: 56rpx;
}

.buddy-main {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.buddy-main text {
  margin-right: 0;
}

.buddy-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #2C3E50;
  margin-bottom: 6rpx;
}

.page.dark .buddy-name {
  color: #E8ECF1;
}

.buddy-meta {
  display: flex;
  align-items: center;
}

.buddy-meta text {
  margin-right: 0;
}

.buddy-major,
.buddy-grade {
  font-size: 22rpx;
  color: #95A5A6;
}

.buddy-dot {
  margin: 0 10rpx !important;
  color: #95A5A6;
  font-size: 22rpx;
}

.buddy-status {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
  font-weight: 500;
}

.buddy-status.available {
  background: #D1FAE5;
  color: #10B981;
}

.buddy-status.matched {
  background: #DBEAFE;
  color: #3B82F6;
}

.buddy-status text {
  margin-right: 0;
}

.buddy-bio {
  display: block;
  font-size: 24rpx;
  color: #6B7280;
  line-height: 1.6;
  margin-bottom: 16rpx;
}

.page.dark .buddy-bio {
  color: #9CA3AF;
}

.buddy-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.buddy-hobbies text {
  margin-right: 12rpx;
}

.buddy-hobbies text:last-child {
  margin-right: 0;
}

.hobby-icon {
  font-size: 28rpx;
}

.buddy-rating {
  display: flex;
  align-items: center;
}

.buddy-rating text {
  margin-right: 6rpx;
}

.buddy-rating text:last-child {
  margin-right: 0;
}

.rating-star {
  font-size: 24rpx;
}

.rating-score {
  font-size: 24rpx;
  font-weight: 600;
  color: #F59E0B;
}

.rating-count {
  font-size: 22rpx;
  color: #95A5A6;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
}

.detail-modal {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  z-index: 101;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  max-height: 85vh;
  overflow-y: auto;
}

.page.dark .detail-modal {
  background: #1E2230;
}

.detail-modal.show {
  transform: translateY(0);
}

.modal-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 32rpx 24rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.page.dark .modal-header {
  border-bottom-color: #2D3142;
}

.modal-avatar {
  font-size: 96rpx;
  margin-bottom: 16rpx;
}

.modal-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #2C3E50;
  margin-bottom: 16rpx;
}

.page.dark .modal-name {
  color: #E8ECF1;
}

.modal-tags {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
}

.modal-tags text {
  margin-right: 12rpx;
  margin-bottom: 8rpx;
}

.modal-tag {
  padding: 8rpx 20rpx;
  background: linear-gradient(135deg, #667EEA 0%, #764BA2 100%);
  color: #FFFFFF;
  font-size: 22rpx;
  border-radius: 16rpx;
}

.modal-body {
  padding: 24rpx 32rpx;
}

.info-row {
  display: flex;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.page.dark .info-row {
  border-bottom-color: #2D3142;
}

.info-row text {
  margin-right: 24rpx;
}

.info-row text:last-child {
  margin-right: 0;
}

.info-label {
  width: 160rpx;
  font-size: 26rpx;
  color: #95A5A6;
  flex-shrink: 0;
}

.info-value {
  flex: 1;
  font-size: 26rpx;
  color: #2C3E50;
  line-height: 1.6;
}

.page.dark .info-value {
  color: #E8ECF1;
}

.bio-text {
  line-height: 1.8;
}

.modal-footer {
  display: flex;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #F0F0F0;
}

.page.dark .modal-footer {
  border-top-color: #2D3142;
}

.modal-footer view {
  margin-right: 16rpx;
}

.modal-footer view:last-child {
  margin-right: 0;
}

.modal-btn {
  flex: 1;
  padding: 24rpx;
  border-radius: 40rpx;
  text-align: center;
}

.modal-btn.secondary {
  background: #F0F2F5;
}

.page.dark .modal-btn.secondary {
  background: #2D3142;
}

.modal-btn.secondary text {
  font-size: 28rpx;
  color: #2C3E50;
  font-weight: 500;
}

.page.dark .modal-btn.secondary text {
  color: #E8ECF1;
}

.modal-btn.primary {
  flex: 1.5;
  background: linear-gradient(135deg, #667EEA 0%, #764BA2 100%);
}

.modal-btn.primary text {
  font-size: 28rpx;
  color: #FFFFFF;
  font-weight: 600;
}

.bottom-spacer {
  height: 40rpx;
}
