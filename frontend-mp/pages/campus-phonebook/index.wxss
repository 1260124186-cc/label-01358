.page {
  min-height: 100vh;
  background-color: var(--color-bg-page);
}

/* ==================== 搜索区域 ==================== */
.search-section {
  padding: 20rpx 24rpx;
  background-color: var(--color-bg-card);
  border-bottom: 1rpx solid var(--color-border-light);
  position: sticky;
  top: 0;
  z-index: 100;
}

.search-box {
  display: flex;
  align-items: center;
  background-color: var(--color-bg-input);
  border-radius: var(--radius-full);
  padding: 20rpx 28rpx;
  transition: all var(--transition-fast);
}

.search-box:focus-within {
  background-color: var(--color-bg-page);
  box-shadow: 0 0 0 4rpx rgba(255, 107, 107, 0.15);
}

.search-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--color-text-primary);
  background: transparent;
}

.search-placeholder {
  color: var(--color-text-muted);
  font-size: 28rpx;
}

.search-clear {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: var(--color-text-muted);
  background-color: var(--color-border-light);
  border-radius: 50%;
  flex-shrink: 0;
  margin-left: 16rpx;
  transition: all var(--transition-fast);
}

.search-clear:active {
  background-color: var(--color-border);
  transform: scale(0.9);
}

/* ==================== 滚动区域 ==================== */
.list-scroll {
  height: calc(100vh - 120rpx);
}

.bottom-space {
  height: 60rpx;
}

/* ==================== 通用section ==================== */
.section {
  padding: 24rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

.section-title.emergency {
  color: #E74C3C;
}

.section-desc {
  font-size: 24rpx;
  color: var(--color-text-muted);
  background-color: rgba(231, 76, 60, 0.1);
  padding: 6rpx 16rpx;
  border-radius: var(--radius-full);
}

.section-more {
  font-size: 26rpx;
  color: var(--color-primary);
  display: flex;
  align-items: center;
}

.result-count {
  font-size: 24rpx;
  color: var(--color-text-muted);
}

/* ==================== 紧急电话 ==================== */
.emergency-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.emergency-item {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #FFF5F5 0%, #FFE8E8 100%);
  border-radius: var(--radius-2xl);
  padding: 24rpx;
  border: 2rpx solid rgba(231, 76, 60, 0.2);
  transition: all var(--transition-fast);
}

.page.dark .emergency-item {
  background: linear-gradient(135deg, #3D1E1E 0%, #4A2323 100%);
  border-color: rgba(231, 76, 60, 0.3);
}

.emergency-item:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(231, 76, 60, 0.2);
}

.emergency-icon-wrapper {
  width: 96rpx;
  height: 96rpx;
  border-radius: var(--radius-xl);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.emergency-icon-wrapper.emergency-0 {
  background: linear-gradient(135deg, #FF6B6B 0%, #EE5A5A 100%);
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 107, 0.4);
}

.emergency-icon-wrapper.emergency-1 {
  background: linear-gradient(135deg, #FF8E53 0%, #FF6F3C 100%);
  box-shadow: 0 4rpx 16rpx rgba(255, 142, 83, 0.4);
}

.emergency-icon-wrapper.emergency-2 {
  background: linear-gradient(135deg, #E74C3C 0%, #C0392B 100%);
  box-shadow: 0 4rpx 16rpx rgba(231, 76, 60, 0.4);
}

.emergency-icon {
  font-size: 48rpx;
}

.emergency-info {
  flex: 1;
  min-width: 0;
}

.emergency-name {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  margin-bottom: 8rpx;
}

.emergency-desc {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.emergency-call-btn {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background-color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.page.dark .emergency-call-btn {
  background-color: var(--color-bg-card);
}

.call-icon {
  font-size: 36rpx;
}

/* ==================== 分类标签 ==================== */
.category-tabs {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.category-tab {
  padding: 16rpx 32rpx;
  background-color: var(--color-bg-input);
  border-radius: var(--radius-full);
  transition: all var(--transition-fast);
}

.category-tab:active {
  transform: scale(0.96);
}

.category-tab.active {
  background: linear-gradient(135deg, var(--color-primary) 0%, #FF8E8E 100%);
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 107, 0.3);
}

.tab-text {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--color-text-secondary);
  transition: all var(--transition-fast);
}

.category-tab.active .tab-text {
  color: #FFFFFF;
}

/* ==================== 电话列表 ==================== */
.phone-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.phone-card {
  display: flex;
  align-items: center;
  background-color: var(--color-bg-card);
  border-radius: var(--radius-2xl);
  padding: 24rpx;
  box-shadow: var(--shadow-card);
  transition: all var(--transition-fast);
}

.phone-card:active {
  transform: scale(0.99);
  box-shadow: var(--shadow-sm);
}

.phone-left {
  flex: 1;
  display: flex;
  align-items: flex-start;
  min-width: 0;
}

.phone-icon-wrapper {
  width: 88rpx;
  height: 88rpx;
  border-radius: var(--radius-xl);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.phone-icon {
  font-size: 40rpx;
}

.phone-info {
  flex: 1;
  min-width: 0;
}

.phone-name {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  margin-bottom: 8rpx;
}

.phone-tag {
  display: inline-block;
  padding: 4rpx 12rpx;
  font-size: 20rpx;
  color: var(--color-text-secondary);
  background-color: var(--color-bg-input);
  border-radius: var(--radius-xs);
  margin-bottom: 8rpx;
}

.phone-number {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-primary);
  margin-bottom: 8rpx;
}

.phone-address,
.phone-worktime {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-muted);
  line-height: 1.5;
}

.phone-right {
  flex-shrink: 0;
  margin-left: 16rpx;
}

.call-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 16rpx 24rpx;
  background: linear-gradient(135deg, var(--color-primary) 0%, #FF8E8E 100%);
  border-radius: var(--radius-xl);
  min-width: 100rpx;
  transition: all var(--transition-fast);
}

.call-btn:active {
  transform: scale(0.94);
  box-shadow: 0 2rpx 8rpx rgba(255, 107, 107, 0.3);
}

.call-btn-icon {
  font-size: 32rpx;
  margin-bottom: 4rpx;
}

.call-btn-text {
  font-size: 22rpx;
  color: #FFFFFF;
  font-weight: 600;
}

/* ==================== 办事指南 ==================== */
.guide-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.guide-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 16rpx;
  background-color: var(--color-bg-card);
  border-radius: var(--radius-xl);
  transition: all var(--transition-fast);
  text-align: center;
}

.guide-item:active {
  transform: scale(0.96);
  background-color: var(--color-bg-input);
}

.guide-icon-wrapper {
  width: 88rpx;
  height: 88rpx;
  border-radius: var(--radius-xl);
  background: linear-gradient(135deg, #FEF3C7 0%, #FDE68A 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.guide-icon {
  font-size: 40rpx;
}

.guide-title {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 8rpx;
  line-height: 1.3;
}

.guide-desc {
  display: block;
  font-size: 20rpx;
  color: var(--color-text-muted);
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}
