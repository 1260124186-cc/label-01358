.page {
  min-height: 100vh;
  background-color: var(--color-bg-page);
}

.content-scroll {
  height: 100vh;
}

/* ==================== 头部 ==================== */
.header {
  position: relative;
  padding: 40rpx 32rpx 48rpx;
  overflow: hidden;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 320rpx;
  background: linear-gradient(135deg, var(--color-primary) 0%, #FF8E8E 50%, #FFB4B4 100%);
  border-radius: 0 0 48rpx 48rpx;
}

.page.dark .header-bg {
  background: linear-gradient(135deg, #8B2C2C 0%, #A63A3A 50%, #C04A4A 100%);
}

.header-content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 20rpx;
}

.icon-wrapper {
  width: 120rpx;
  height: 120rpx;
  background-color: rgba(255, 255, 255, 0.25);
  backdrop-filter: blur(10px);
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
}

.guide-icon {
  font-size: 56rpx;
}

.guide-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 16rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.guide-summary {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  text-align: center;
  line-height: 1.6;
  padding: 0 20rpx;
}

/* ==================== 内容区域 ==================== */
.content {
  padding: 0 24rpx;
  margin-top: -24rpx;
  position: relative;
  z-index: 2;
}

.section-item {
  background-color: var(--color-bg-card);
  border-radius: var(--radius-2xl);
  margin-bottom: 20rpx;
  padding: 28rpx;
  box-shadow: var(--shadow-card);
  transition: all var(--transition-fast);
}

.section-item:active {
  transform: scale(0.995);
}

.section-header {
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid var(--color-border-light);
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

.section-body {
  padding-top: 8rpx;
}

.section-content {
  font-size: 28rpx;
  line-height: 1.8;
  color: var(--color-text-secondary);
  white-space: pre-wrap;
  word-break: break-all;
}

/* ==================== 相关电话 ==================== */
.phones-list {
  display: flex;
  flex-direction: column;
}

.phones-list > view { margin-bottom: 16rpx; }

.phones-list > view:last-child { margin-bottom: 0; }

.phone-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  background: linear-gradient(135deg, #FEF3C7 0%, #FDE68A 100%);
  border-radius: var(--radius-xl);
  transition: all var(--transition-fast);
}

.page.dark .phone-item {
  background: linear-gradient(135deg, #4A3F20 0%, #5C4D28 100%);
}

.phone-item:active {
  transform: scale(0.98);
}

.phone-info {
  flex: 1;
  min-width: 0;
}

.phone-name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 8rpx;
}

.phone-number {
  display: block;
  font-size: 26rpx;
  color: var(--color-primary);
  font-weight: 600;
}

.phone-call-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background-color: var(--color-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 107, 0.3);
  transition: all var(--transition-fast);
}

.phone-call-btn:active {
  transform: scale(0.9);
  box-shadow: 0 2rpx 8rpx rgba(255, 107, 107, 0.2);
}

.call-icon {
  font-size: 32rpx;
}

.bottom-space {
  height: 60rpx;
}

/* ==================== 加载状态 ==================== */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 200rpx;
}

.loading-text {
  font-size: 28rpx;
  color: var(--color-text-muted);
}
