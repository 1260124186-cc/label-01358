.page {
  min-height: 100vh;
  background-color: var(--color-bg-page);
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.points-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 24rpx;
  padding: 28rpx 24rpx;
  background: linear-gradient(135deg, #22C55E 0%, #4ADE80 100%);
  border-radius: var(--radius-2xl);
  box-shadow: 0 8rpx 32rpx rgba(34, 197, 94, 0.3);
}

.points-info {
  display: flex;
  align-items: center;
}

.points-icon {
  font-size: 48rpx;
  margin-right: 16rpx;
}

.points-text-wrap {
  display: flex;
  flex-direction: column;
}

.points-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.points-value {
  font-size: 48rpx;
  font-weight: 800;
  color: #FFFFFF;
  line-height: 1.2;
}

.points-shop-link {
  display: flex;
  align-items: center;
  padding: 12rpx 24rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: var(--radius-full);
}

.points-shop-link-hover { transform: scale(0.96); }

.shop-link-text {
  font-size: 26rpx;
  font-weight: 500;
  color: #FFFFFF;
}

.shop-link-arrow {
  font-size: 32rpx;
  color: #FFFFFF;
  margin-left: 4rpx;
}

.category-section {
  padding: 0 24rpx 16rpx;
}

.category-scroll { white-space: nowrap; }

.category-tabs {
  display: inline-flex;
}

.category-tabs > view { margin-right: 16rpx; }
.category-tabs > view:last-child { margin-right: 0; }

.category-tab {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 24rpx;
  background-color: var(--color-bg-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
  transition: all var(--transition-fast);
}

.category-tab:active { transform: scale(0.96); }

.category-tab.active {
  background: linear-gradient(135deg, #22C55E 0%, #4ADE80 100%);
  box-shadow: 0 4rpx 12rpx rgba(34, 197, 94, 0.3);
}

.category-tab.active .category-icon,
.category-tab.active .category-label { color: #FFFFFF; }

.category-icon { font-size: 28rpx; margin-bottom: 4rpx; }

.category-label {
  font-size: 22rpx;
  font-weight: 500;
  color: var(--color-text-secondary);
}

.list-scroll {
  height: auto;
}

.reward-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  padding: 0 24rpx;
}

.reward-card {
  background-color: var(--color-bg-card);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-card);
  overflow: hidden;
}

.reward-image {
  height: 160rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, rgba(34, 197, 94, 0.08) 0%, rgba(74, 222, 128, 0.08) 100%);
  position: relative;
}

.reward-emoji { font-size: 56rpx; }

.reward-stock {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  padding: 4rpx 12rpx;
  background: rgba(239, 68, 68, 0.9);
  border-radius: var(--radius-full);
}

.stock-text {
  font-size: 20rpx;
  color: #FFFFFF;
  font-weight: 500;
}

.reward-info { padding: 16rpx 20rpx 20rpx; }

.reward-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.reward-desc {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-muted);
  margin-bottom: 12rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  overflow: hidden;
}

.reward-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.reward-points-wrap {
  display: flex;
  align-items: baseline;
}

.reward-points-icon { font-size: 22rpx; margin-right: 4rpx; }

.reward-points {
  font-size: 30rpx;
  font-weight: 700;
  color: #22C55E;
}

.reward-points-unit {
  font-size: 20rpx;
  color: var(--color-text-muted);
  margin-left: 4rpx;
}

.redeem-btn {
  padding: 8rpx 20rpx;
  background: linear-gradient(135deg, #22C55E 0%, #4ADE80 100%);
  color: #FFFFFF;
  font-size: 22rpx;
  font-weight: 600;
  border-radius: var(--radius-full);
  transition: all var(--transition-fast);
}

.redeem-btn-hover { transform: scale(0.96); }

.btn-disabled {
  background: var(--color-bg-input);
  color: var(--color-text-muted);
}

.orders-section {
  margin: 24rpx;
  background-color: var(--color-bg-card);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-card);
  padding: 24rpx;
}

.orders-header { margin-bottom: 16rpx; }

.orders-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.orders-list {
  display: flex;
  flex-direction: column;
}

.order-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 0;
  border-bottom: 1rpx solid var(--color-border-light);
}

.order-item:last-child { border-bottom: none; }

.order-left {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.order-icon { font-size: 28rpx; margin-right: 10rpx; }

.order-title {
  font-size: 26rpx;
  color: var(--color-text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.order-points {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text-secondary);
  margin-left: 16rpx;
}

.dark .points-bar {
  background: linear-gradient(135deg, #166534 0%, #15803D 100%);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.4);
}

.dark .reward-image {
  background: linear-gradient(135deg, rgba(34, 197, 94, 0.15) 0%, rgba(74, 222, 128, 0.15) 100%);
}
