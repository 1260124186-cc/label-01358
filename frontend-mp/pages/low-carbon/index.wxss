.page {
  min-height: 100vh;
  background-color: var(--color-bg-page);
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.hero-card {
  margin: 24rpx;
  padding: 48rpx 32rpx 40rpx;
  background: linear-gradient(135deg, #22C55E 0%, #4ADE80 50%, #86EFAC 100%);
  border-radius: var(--radius-2xl);
  position: relative;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(34, 197, 94, 0.3);
}

.hero-bg-circle {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
}

.hero-bg-circle-1 {
  top: -80rpx;
  right: -40rpx;
  width: 300rpx;
  height: 300rpx;
}

.hero-bg-circle-2 {
  bottom: -60rpx;
  left: -30rpx;
  width: 200rpx;
  height: 200rpx;
  background: rgba(255, 255, 255, 0.06);
}

.hero-stats {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 32rpx;
  position: relative;
  z-index: 1;
}

.hero-stat-main {
  display: flex;
  align-items: baseline;
}

.hero-stat-value {
  font-size: 96rpx;
  font-weight: 800;
  color: #FFFFFF;
  line-height: 1;
  text-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.hero-stat-unit {
  font-size: 32rpx;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.85);
  margin-left: 8rpx;
}

.hero-stat-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
}

.hero-stats-row {
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  z-index: 1;
}

.hero-stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.hero-stat-num {
  font-size: 44rpx;
  font-weight: 700;
  color: #FFFFFF;
  line-height: 1.2;
}

.hero-stat-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.75);
  margin-top: 4rpx;
}

.hero-stat-divider {
  width: 1rpx;
  height: 60rpx;
  background-color: rgba(255, 255, 255, 0.3);
}

.tip-bar {
  display: flex;
  align-items: center;
  margin: 0 24rpx 24rpx;
  padding: 20rpx 24rpx;
  background-color: var(--color-bg-card);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-card);
}

.tip-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.tip-text {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.5;
}

.section {
  margin: 0 24rpx 24rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.checkin-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.checkin-card {
  background-color: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: 28rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  box-shadow: var(--shadow-card);
  transition: all var(--transition-fast);
  overflow: hidden;
}

.checkin-card-hover {
  transform: scale(0.97);
}

.checkin-card.checked {
  background: linear-gradient(135deg, rgba(34, 197, 94, 0.08) 0%, rgba(74, 222, 128, 0.08) 100%);
  border: 2rpx solid rgba(34, 197, 94, 0.3);
}

.checkin-icon-wrap {
  width: 88rpx;
  height: 88rpx;
  border-radius: var(--radius-lg);
  background: var(--color-bg-input);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.checkin-icon-wrap.checked-icon {
  background: linear-gradient(135deg, #22C55E 0%, #4ADE80 100%);
}

.checkin-icon {
  font-size: 40rpx;
}

.checkin-label {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 4rpx;
}

.checkin-points {
  font-size: 22rpx;
  color: #22C55E;
  font-weight: 500;
}

.checkin-done {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: #22C55E;
  display: flex;
  align-items: center;
  justify-content: center;
}

.checkin-done-icon {
  font-size: 22rpx;
  color: #FFFFFF;
  font-weight: 700;
}

.quick-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.quick-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
  transition: all var(--transition-fast);
}

.quick-item-hover {
  transform: scale(0.95);
}

.quick-icon-wrap {
  width: 88rpx;
  height: 88rpx;
  border-radius: var(--radius-xl);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 10rpx;
}

.quick-icon {
  font-size: 36rpx;
}

.quick-label {
  font-size: 24rpx;
  font-weight: 500;
  color: var(--color-text-secondary);
}

.record-list {
  background-color: var(--color-bg-card);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-card);
  overflow: hidden;
}

.record-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid var(--color-border-light);
}

.record-item:last-child {
  border-bottom: none;
}

.record-left {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.record-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.record-info {
  display: flex;
  flex-direction: column;
}

.record-label {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--color-text-primary);
}

.record-time {
  font-size: 22rpx;
  color: var(--color-text-muted);
  margin-top: 4rpx;
}

.record-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  margin-left: 16rpx;
}

.record-points {
  font-size: 28rpx;
  font-weight: 700;
  color: #22C55E;
}

.record-carbon {
  font-size: 22rpx;
  color: var(--color-text-muted);
  margin-top: 2rpx;
}

.checkin-success-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

.checkin-success-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-2xl);
  padding: 56rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: var(--shadow-float);
  animation: successPopIn 0.3s ease;
}

@keyframes successPopIn {
  0% { transform: scale(0.8); opacity: 0; }
  100% { transform: scale(1); opacity: 1; }
}

.success-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.success-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  margin-bottom: 24rpx;
}

.success-rewards {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.success-reward-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 32rpx;
}

.success-reward-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #22C55E;
}

.success-reward-label {
  font-size: 22rpx;
  color: var(--color-text-muted);
  margin-top: 4rpx;
}

.success-reward-divider {
  width: 1rpx;
  height: 60rpx;
  background-color: var(--color-border);
}

.success-total {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.dark .hero-card {
  background: linear-gradient(135deg, #166534 0%, #15803D 50%, #22C55E 100%);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.4);
}

.dark .checkin-card.checked {
  background: linear-gradient(135deg, rgba(34, 197, 94, 0.15) 0%, rgba(74, 222, 128, 0.15) 100%);
  border-color: rgba(34, 197, 94, 0.4);
}
