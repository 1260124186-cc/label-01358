.page {
  min-height: 100vh;
  background-color: var(--color-bg-page);
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.report-header {
  position: relative;
  height: 200rpx;
  overflow: hidden;
}

.report-header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #22C55E 0%, #4ADE80 100%);
}

.report-header-content {
  position: relative;
  z-index: 1;
  padding: 48rpx 32rpx;
  display: flex;
  flex-direction: column;
}

.report-title {
  font-size: 40rpx;
  font-weight: 800;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.report-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

.stats-row {
  display: flex;
  margin: -40rpx 24rpx 24rpx;
  position: relative;
  z-index: 2;
}

.stat-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  background-color: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: 28rpx 16rpx;
  margin: 0 8rpx;
  box-shadow: var(--shadow-card);
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #22C55E;
  line-height: 1.2;
}

.stat-label {
  font-size: 22rpx;
  color: var(--color-text-muted);
  margin-top: 8rpx;
}

.section {
  margin: 0 24rpx 24rpx;
}

.section-header {
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.chart-card {
  background-color: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: 28rpx 24rpx;
  box-shadow: var(--shadow-card);
}

.chart-container {
  display: flex;
  align-items: flex-end;
  justify-content: space-around;
  height: 300rpx;
}

.chart-bar-group {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.chart-bar-wrap {
  width: 40rpx;
  height: 200rpx;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.chart-bar {
  width: 100%;
  background: linear-gradient(180deg, #22C55E 0%, #86EFAC 100%);
  border-radius: var(--radius-sm) var(--radius-sm) 0 0;
  transition: height 0.5s ease;
  min-height: 4rpx;
}

.chart-label {
  font-size: 22rpx;
  color: var(--color-text-muted);
  margin-top: 12rpx;
}

.chart-value {
  font-size: 20rpx;
  font-weight: 600;
  color: #22C55E;
  margin-top: 4rpx;
}

.category-card {
  background-color: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: 8rpx 28rpx;
  box-shadow: var(--shadow-card);
}

.category-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--color-border-light);
}

.category-item:last-child {
  border-bottom: none;
}

.category-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.category-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.category-info {
  display: flex;
  flex-direction: column;
}

.category-label {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--color-text-primary);
}

.category-sub {
  font-size: 22rpx;
  color: var(--color-text-muted);
  margin-top: 4rpx;
}

.category-points {
  font-size: 28rpx;
  font-weight: 700;
  color: #22C55E;
}

.rank-overview-card {
  background-color: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: 32rpx 28rpx;
  box-shadow: var(--shadow-card);
  display: flex;
  align-items: center;
}

.rank-main {
  display: flex;
  align-items: baseline;
  margin-right: 24rpx;
}

.rank-number {
  font-size: 64rpx;
  font-weight: 800;
  color: #22C55E;
  line-height: 1;
}

.rank-suffix {
  font-size: 28rpx;
  font-weight: 500;
  color: #22C55E;
  margin-left: 4rpx;
}

.rank-desc {
  display: flex;
  flex-direction: column;
}

.rank-percent {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--color-text-primary);
}

.rank-total-points {
  font-size: 22rpx;
  color: var(--color-text-muted);
  margin-top: 4rpx;
}

.tip-card {
  display: flex;
  align-items: center;
  margin: 0 24rpx 24rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, rgba(34, 197, 94, 0.08) 0%, rgba(74, 222, 128, 0.08) 100%);
  border-radius: var(--radius-xl);
  border: 1rpx solid rgba(34, 197, 94, 0.2);
}

.tip-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.tip-text {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.5;
}

.share-btn {
  margin: 0 24rpx 24rpx;
}

.share-button {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  background: linear-gradient(135deg, #22C55E 0%, #4ADE80 100%);
  border-radius: var(--radius-xl);
  box-shadow: 0 4rpx 16rpx rgba(34, 197, 94, 0.3);
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 600;
}

.share-btn-hover .share-button {
  transform: scale(0.98);
  opacity: 0.9;
}

.share-icon {
  font-size: 32rpx;
  margin-right: 8rpx;
}

.share-text {
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 600;
}

.dark .report-header-bg {
  background: linear-gradient(135deg, #166534 0%, #15803D 100%);
}

.dark .share-button {
  background: linear-gradient(135deg, #166534 0%, #22C55E 100%);
  box-shadow: 0 4rpx 16rpx rgba(34, 197, 94, 0.2);
}
