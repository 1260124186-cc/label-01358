<page-meta page-style="background-color: {{darkMode ? '#0F1117' : '#F8F9FA'}}; color: {{darkMode ? '#E8ECF1' : '#2C3E50'}}"/>
<view class="page {{darkMode ? 'dark' : ''}}">

  <view class="filter-section">
    <scroll-view class="filter-scroll" scroll-x="{{true}}" enhanced="{{true}}" show-scrollbar="{{false}}">
      <view class="filter-chips">
        <view
          class="filter-chip {{currentType === item.value ? 'active' : ''}}"
          wx:for="{{activityTypes}}"
          wx:key="value"
          bindtap="onTypeTap"
          data-value="{{item.value}}"
        >
          <text class="chip-icon">{{item.icon}}</text>
          <text class="chip-label">{{item.label}}</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <scroll-view
    class="list-scroll"
    scroll-y="{{true}}"
    refresher-enabled="{{true}}"
    refresher-triggered="{{refreshing}}"
    bindrefresherrefresh="onRefresh"
  >
    <view class="list-container" wx:if="{{activityList.length > 0}}">
      <view class="activity-card" wx:for="{{activityList}}" wx:key="id">
        <view class="card-top">
          <view class="type-tag" style="background-color: {{item.typeColor}}20; color: {{item.typeColor}};">
            <text class="type-tag-icon">{{item.typeIcon}}</text>
            <text class="type-tag-text">{{item.typeLabel}}</text>
          </view>
          <view class="status-tag" style="color: {{item.statusColor}}; background-color: {{item.statusColor}}15;">
            {{item.statusLabel}}
          </view>
        </view>

        <text class="card-title">{{item.title}}</text>
        <text class="card-desc">{{item.description}}</text>

        <view class="card-info">
          <view class="info-row">
            <text class="info-icon">🕐</text>
            <text class="info-text">{{item.timeText}}</text>
          </view>
          <view class="info-row" wx:if="{{item.location}}">
            <text class="info-icon">📍</text>
            <text class="info-text">{{item.location}}</text>
          </view>
          <view class="info-row">
            <text class="info-icon">👥</text>
            <text class="info-text">{{item.registrationCount}}/{{item.maxParticipants}}人</text>
          </view>
          <view class="info-row">
            <text class="info-icon">💚</text>
            <text class="info-text">+{{item.points}}积分 · -{{item.carbon}}kg碳排放</text>
          </view>
        </view>

        <view class="card-bottom">
          <view class="organizer">
            <text class="organizer-text">主办方: {{item.organizer}}</text>
          </view>
          <view
            class="action-btn {{item.isRegistered ? 'btn-cancel' : ''}} {{!item.canRegister && !item.isRegistered ? 'btn-disabled' : ''}}"
            wx:if="{{item.status === 'registering'}}"
            bindtap="{{item.isRegistered ? 'onCancel' : 'onRegister'}}"
            data-id="{{item.id}}"
            hover-class="action-btn-hover"
          >
            <text wx:if="{{item.isRegistered}}">取消报名</text>
            <text wx:elif="{{item.isFull}}">名额已满</text>
            <text wx:else>立即报名</text>
          </view>
          <view class="action-btn btn-registered" wx:if="{{item.isRegistered && item.status !== 'registering'}}">
            <text>已报名</text>
          </view>
        </view>
      </view>
    </view>

    <empty wx:if="{{activityList.length === 0}}" text="暂无环保活动" />
  </scroll-view>

</view>
