.page {
  min-height: 100vh;
  background-color: #F8F9FA;
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
}

.page.dark {
  background-color: #0F1117;
  color: #E8ECF1;
}

.image-swiper-wrap {
  position: relative;
  background-color: #1F2937;
}

.image-swiper {
  height: 560rpx;
}

.swiper-image {
  width: 100%;
  height: 100%;
}

.image-counter {
  position: absolute;
  right: 24rpx;
  bottom: 24rpx;
  padding: 10rpx 24rpx;
  background-color: rgba(0, 0, 0, 0.5);
  backdrop-filter: blur(10rpx);
  -webkit-backdrop-filter: blur(10rpx);
  border-radius: 30rpx;
  font-size: 24rpx;
  font-weight: 500;
  color: #fff;
}

.publisher-badge {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
  backdrop-filter: blur(10rpx);
  -webkit-backdrop-filter: blur(10rpx);
}

.detail-scroll {
  height: calc(100vh - 560rpx);
}

.detail-header {
  background-color: #fff;
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.page.dark .detail-header {
  background-color: #1A1D29;
}

.price-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.price-info {
  display: flex;
  align-items: baseline;
}

.price-currency {
  font-size: 32rpx;
  color: #FF6B6B;
  font-weight: 600;
}

.price-value {
  font-size: 56rpx;
  color: #FF6B6B;
  font-weight: 700;
  margin: 0 4rpx;
  line-height: 1;
}

.price-unit {
  font-size: 26rpx;
  color: #999;
}

.header-actions {
  display: flex;
  gap: 24rpx;
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 8rpx 16rpx;
  transition: all 0.2s ease;
}

.action-btn:active {
  transform: scale(0.92);
}

.action-btn.active .action-icon {
  color: #FF6B6B;
}

.action-icon {
  font-size: 40rpx;
  color: #999;
  line-height: 1;
}

.action-text {
  font-size: 22rpx;
  color: #999;
  margin-top: 6rpx;
}

.action-btn.active .action-text {
  color: #FF6B6B;
}

.house-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #111;
  line-height: 1.4;
  margin-bottom: 16rpx;
}

.page.dark .house-title {
  color: #E8ECF1;
}

.house-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.house-tag {
  padding: 8rpx 20rpx;
  font-size: 24rpx;
  font-weight: 500;
  color: #666;
  background-color: #F5F5F5;
  border-radius: 8rpx;
}

.page.dark .house-tag {
  background-color: #2A2F3D;
  color: #9AA0A6;
}

.house-tag.location-tag {
  color: #0D9488;
  background-color: #CCFBF1;
}

.page.dark .house-tag.location-tag {
  background-color: rgba(13, 148, 136, 0.15);
  color: #5EEAD4;
}

.house-tag.rent-type-tag {
  color: #0284C7;
  background-color: #E0F2FE;
}

.page.dark .house-tag.rent-type-tag {
  background-color: rgba(2, 132, 199, 0.15);
  color: #38BDF8;
}

.house-tag.gender-tag {
  color: #7C3AED;
  background-color: #EDE9FE;
}

.page.dark .house-tag.gender-tag {
  background-color: rgba(124, 58, 237, 0.15);
  color: #A78BFA;
}

.house-tag.lease-tag {
  color: #DB2777;
  background-color: #FCE7F3;
}

.page.dark .house-tag.lease-tag {
  background-color: rgba(219, 39, 119, 0.15);
  color: #F472B6;
}

.house-tag.status-tag {
  color: #fff;
}

.house-tag.status-tag.reserved {
  background-color: #F59E0B;
}

.house-tag.status-tag.rented {
  background-color: #6B7280;
}

.house-meta-row {
  display: flex;
  align-items: stretch;
  background-color: #F8F9FA;
  border-radius: 16rpx;
  padding: 20rpx 0;
  margin-bottom: 16rpx;
}

.page.dark .house-meta-row {
  background-color: #2A2F3D;
}

.meta-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.meta-divider {
  width: 1rpx;
  background-color: #E5E7EB;
  margin: 8rpx 0;
}

.page.dark .meta-divider {
  background-color: #3A3F4D;
}

.meta-value {
  font-size: 30rpx;
  font-weight: 600;
  color: #111;
  margin-bottom: 6rpx;
}

.page.dark .meta-value {
  color: #E8ECF1;
}

.meta-label {
  font-size: 22rpx;
  color: #999;
}

.extra-info {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
}

.extra-item {
  font-size: 26rpx;
  color: #666;
}

.page.dark .extra-item {
  color: #9AA0A6;
}

.extra-sep {
  color: #DDD;
  margin: 0 8rpx;
}

.page.dark .extra-sep {
  color: #3A3F4D;
}

.detail-section {
  background-color: #fff;
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.page.dark .detail-section {
  background-color: #1A1D29;
}

.section-title {
  display: flex;
  align-items: center;
  font-size: 30rpx;
  font-weight: 700;
  color: #111;
  margin-bottom: 20rpx;
}

.page.dark .section-title {
  color: #E8ECF1;
}

.section-title::before {
  content: '';
  width: 6rpx;
  height: 28rpx;
  background: linear-gradient(180deg, #FF6B6B 0%, #FF8E8E 100%);
  border-radius: 3rpx;
  margin-right: 12rpx;
}

.facility-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.facility-item {
  width: calc((100% - 80rpx) / 5);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 16rpx 0;
}

.facility-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.facility-name {
  font-size: 24rpx;
  color: #666;
}

.page.dark .facility-name {
  color: #9AA0A6;
}

.description-content {
  font-size: 28rpx;
  color: #4B5563;
  line-height: 1.8;
  white-space: pre-wrap;
}

.page.dark .description-content {
  color: #D1D5DB;
}

.location-card {
  background-color: #F8F9FA;
  border-radius: 16rpx;
  overflow: hidden;
}

.page.dark .location-card {
  background-color: #2A2F3D;
}

.location-map {
  position: relative;
  height: 300rpx;
}

.map-view {
  width: 100%;
  height: 100%;
}

.map-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: rgba(0, 0, 0, 0.1);
  pointer-events: none;
}

.map-icon {
  font-size: 56rpx;
  filter: drop-shadow(0 4rpx 8rpx rgba(0, 0, 0, 0.2));
}

.location-info {
  padding: 20rpx 24rpx;
  border-top: 1rpx solid #E5E7EB;
}

.page.dark .location-info {
  border-top-color: #3A3F4D;
}

.location-address {
  display: block;
  font-size: 28rpx;
  color: #111;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.page.dark .location-address {
  color: #E8ECF1;
}

.location-hint {
  font-size: 24rpx;
  color: #FF6B6B;
}

.surrounding-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.surrounding-item {
  display: flex;
  align-items: flex-start;
}

.surrounding-dot {
  color: #FF6B6B;
  font-size: 24rpx;
  margin-right: 12rpx;
  line-height: 1.6;
}

.surrounding-text {
  flex: 1;
  font-size: 28rpx;
  color: #4B5563;
  line-height: 1.6;
}

.page.dark .surrounding-text {
  color: #D1D5DB;
}

.publish-info {
  background-color: #F8F9FA;
  border-radius: 16rpx;
  overflow: hidden;
}

.page.dark .publish-info {
  background-color: #2A2F3D;
}

.info-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #E5E7EB;
}

.page.dark .info-row {
  border-bottom-color: #3A3F4D;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #6B7280;
}

.page.dark .info-label {
  color: #9AA0A6;
}

.info-value {
  font-size: 28rpx;
  color: #111;
  font-weight: 500;
}

.page.dark .info-value {
  color: #E8ECF1;
}

.info-value.danger {
  color: #EF4444;
}

.report-section {
  padding: 0;
  background-color: transparent;
}

.report-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  background-color: #fff;
  border-radius: 16rpx;
  transition: all 0.2s ease;
}

.page.dark .report-btn {
  background-color: #1A1D29;
}

.report-btn:active {
  opacity: 0.8;
}

.report-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.report-text {
  font-size: 28rpx;
  color: #EF4444;
  font-weight: 500;
}

.bottom-space {
  height: 40rpx;
}

.contact-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background-color: #fff;
  box-shadow: 0 -8rpx 32rpx rgba(0, 0, 0, 0.08);
  z-index: 100;
}

.page.dark .contact-bar {
  background-color: #1A1D29;
  box-shadow: 0 -8rpx 32rpx rgba(0, 0, 0, 0.3);
}

.contact-info {
  flex-shrink: 0;
  margin-right: 20rpx;
}

.contact-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #111;
  margin-bottom: 4rpx;
}

.page.dark .contact-name {
  color: #E8ECF1;
}

.contact-type {
  font-size: 22rpx;
  font-weight: 500;
}

.contact-actions {
  flex: 1;
  display: flex;
  gap: 20rpx;
}

.contact-btn {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 44rpx;
  transition: all 0.2s ease;
}

.contact-btn:active {
  transform: scale(0.96);
}

.contact-btn.secondary {
  background-color: #F5F5F5;
  border: 2rpx solid #E5E7EB;
}

.page.dark .contact-btn.secondary {
  background-color: #2A2F3D;
  border-color: #3A3F4D;
}

.contact-btn.primary {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  box-shadow: 0 8rpx 20rpx rgba(255, 107, 107, 0.35);
}

.btn-icon {
  font-size: 32rpx;
  margin-right: 8rpx;
}

.btn-text {
  font-size: 28rpx;
  font-weight: 600;
}

.contact-btn.secondary .btn-text {
  color: #4B5563;
}

.page.dark .contact-btn.secondary .btn-text {
  color: #D1D5DB;
}

.contact-btn.primary .btn-text {
  color: #fff;
}

.loading-container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: #F8F9FA;
}

.page.dark .loading-container {
  background-color: #0F1117;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #E5E7EB;
  border-top-color: #FF6B6B;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: 28rpx;
  color: #6B7280;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.modal-mask.show {
  opacity: 1;
  visibility: visible;
}

.modal-content {
  width: 100%;
  max-width: 640rpx;
  background-color: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  transform: translateY(20rpx);
  transition: transform 0.3s ease;
}

.modal-mask.show .modal-content {
  transform: translateY(0);
}

.page.dark .modal-content {
  background-color: #1A1D29;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.page.dark .modal-header {
  border-bottom-color: #2A2F3D;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #111;
}

.page.dark .modal-title {
  color: #E8ECF1;
}

.modal-close {
  font-size: 40rpx;
  color: #999;
  padding: 10rpx;
  line-height: 1;
}

.modal-body {
  padding: 30rpx;
}

.form-group {
  margin-bottom: 24rpx;
}

.form-group:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #374151;
  margin-bottom: 16rpx;
}

.page.dark .form-label {
  color: #D1D5DB;
}

.form-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  background-color: #F8F9FA;
  border-radius: 12rpx;
}

.page.dark .form-picker {
  background-color: #2A2F3D;
}

.form-picker .placeholder {
  color: #9CA3AF;
  font-size: 28rpx;
}

.form-picker text {
  font-size: 28rpx;
  color: #111;
}

.page.dark .form-picker text {
  color: #E8ECF1;
}

.picker-arrow {
  font-size: 24rpx;
  color: #9CA3AF;
  margin-left: 12rpx;
}

.form-textarea {
  width: 100%;
  min-height: 160rpx;
  padding: 20rpx 24rpx;
  background-color: #F8F9FA;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #111;
  line-height: 1.7;
  box-sizing: border-box;
}

.page.dark .form-textarea {
  background-color: #2A2F3D;
  color: #E8ECF1;
}

.form-textarea::placeholder {
  color: #9CA3AF;
}

.report-tips {
  margin-top: 16rpx;
  padding: 16rpx 20rpx;
  background-color: #FEF3C7;
  border-radius: 12rpx;
}

.page.dark .report-tips {
  background-color: rgba(245, 158, 11, 0.1);
}

.tip-text {
  font-size: 24rpx;
  color: #92400E;
}

.page.dark .tip-text {
  color: #FCD34D;
}

.modal-footer {
  display: flex;
  gap: 24rpx;
  padding: 0 30rpx 30rpx;
}

.modal-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 44rpx;
  font-size: 28rpx;
  font-weight: 600;
  transition: all 0.2s ease;
}

.modal-btn:active {
  opacity: 0.8;
}

.modal-btn.cancel {
  background-color: #F5F5F5;
  color: #4B5563;
}

.page.dark .modal-btn.cancel {
  background-color: #2A2F3D;
  color: #D1D5DB;
}

.modal-btn.confirm {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  color: #fff;
}
