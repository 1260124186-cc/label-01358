<page-meta page-style="background-color: {{darkMode ? '#0F1117' : '#F8F9FA'}}; color: {{darkMode ? '#E8ECF1' : '#2C3E50'}}"/>
<view class="page {{darkMode ? 'dark' : ''}}">
  <view class="filter-section">
    <view class="search-box">
      <text class="search-icon">🔍</text>
      <input
        class="search-input"
        placeholder="搜索工单号/宿舍号/描述关键词"
        placeholder-class="search-placeholder"
        value="{{keyword}}"
        bindinput="onKeywordInput"
        bindconfirm="onSearch"
        confirm-type="search"
      />
      <view class="clear-btn" wx:if="{{keyword}}" bindtap="onClearKeyword">
        <text class="clear-icon">✕</text>
      </view>
    </view>

    <view class="date-range">
      <view class="date-item">
        <text class="date-label">开始</text>
        <picker mode="date" value="{{startDate}}" bindchange="onStartDateChange">
          <view class="date-picker">
            <text class="date-value">{{startDate || '选择日期'}}</text>
            <text class="date-arrow">▼</text>
          </view>
        </picker>
      </view>
      <text class="date-sep">至</text>
      <view class="date-item">
        <text class="date-label">结束</text>
        <picker mode="date" value="{{endDate}}" bindchange="onEndDateChange">
          <view class="date-picker">
            <text class="date-value">{{endDate || '选择日期'}}</text>
            <text class="date-arrow">▼</text>
          </view>
        </picker>
      </view>
    </view>

    <scroll-view class="type-scroll" scroll-x="{{true}}" enhanced="{{true}}" show-scrollbar="{{false}}">
      <view class="type-inner">
        <view
          class="type-chip {{selectedType === item.value ? 'active' : ''}}"
          wx:for="{{repairTypes}}"
          wx:key="value"
          bindtap="onTypeTap"
          data-value="{{item.value}}"
          style="{{selectedType === item.value ? 'background: ' + (item.color || '#6B7280') + '20; color: ' + (item.color || '#6B7280') + '; border-color: ' + (item.color || '#6B7280') : ''}}"
        >
          <text class="type-icon" wx:if="{{item.icon}}">{{item.icon}}</text>
          <text class="type-label">{{item.label}}</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <scroll-view class="order-list" scroll-y="{{true}}" enhanced="{{true}}" show-scrollbar="{{false}}">
    <view class="list-inner" wx:if="{{filteredOrders.length > 0}}">
      <view
        class="order-card {{item.isUrgent ? 'urgent' : ''}}"
        wx:for="{{filteredOrders}}"
        wx:key="id"
        bindtap="onOrderTap"
        data-id="{{item.id}}"
      >
        <view class="card-header">
          <view class="order-no-row">
            <text class="order-no">工单号：{{item.orderNo}}</text>
            <view class="status-tag" style="background: {{item.statusColor}}15; color: {{item.statusColor}};">
              <text class="status-icon">{{item.statusIcon}}</text>
              <text class="status-text">{{item.statusLabel}}</text>
            </view>
          </view>
          <view class="urgent-badge" wx:if="{{item.isUrgent}}">
            <text class="urgent-icon">⚠️</text>
            <text class="urgent-text">{{item.urgentTypeLabel || '紧急'}}</text>
          </view>
        </view>

        <view class="card-body">
          <view class="type-row">
            <view class="type-badge" style="background: {{item.typeGradient || '#6B7280'}};">
              <text class="type-badge-icon">{{item.typeIcon}}</text>
              <text class="type-badge-label">{{item.typeLabel}}</text>
            </view>
            <text class="dorm-no">🏠 {{item.dormitoryNo}}</text>
          </view>
          <view class="desc-row">
            <text class="desc-text">{{item.description}}</text>
          </view>
          <view class="contact-row" wx:if="{{item.contactName || item.contactPhone}}">
            <text class="contact-text">📞 {{item.contactName || '联系人'}} {{item.contactPhone || ''}}</text>
          </view>
        </view>

        <view class="card-footer">
          <text class="create-time">提交时间：{{item.createTimeText}}</text>
          <view class="worker-info" wx:if="{{item.workerName}}">
            <text class="worker-icon">👷</text>
            <text class="worker-name">{{item.workerName}}</text>
          </view>
        </view>
      </view>
    </view>

    <empty wx:else text="暂无工单记录" icon="📋" />
  </scroll-view>

  <view class="loading-overlay" wx:if="{{loading}}">
    <view class="loading-content">
      <view class="loading-spinner"></view>
      <text class="loading-text">加载中...</text>
    </view>
  </view>
</view>
