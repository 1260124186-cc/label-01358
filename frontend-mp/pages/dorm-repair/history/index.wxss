.page {
  min-height: 100vh;
  background: var(--color-bg-page);
  display: flex;
  flex-direction: column;
}

.page.dark {
  --color-bg-page: #0F1117;
  --color-bg-card: #1A1D29;
  --color-bg-secondary: #252936;
  --color-text-primary: #E8ECF1;
  --color-text-secondary: #9CA3AF;
  --color-text-placeholder: #6B7280;
  --color-border: #2D3142;
  --color-primary: #FF6B6B;
  --color-primary-dark: #E55555;
}

.filter-section {
  background: var(--color-bg-card, #FFFFFF);
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid var(--color-border, #E5E7EB);
}

.search-box {
  display: flex;
  align-items: center;
  background: var(--color-bg-secondary, #F3F4F6);
  border-radius: 40rpx;
  padding: 0 28rpx;
  height: 80rpx;
  margin-bottom: 24rpx;
}

.search-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  height: 80rpx;
  font-size: 28rpx;
  color: var(--color-text-primary, #2C3E50);
}

.search-placeholder {
  color: var(--color-text-placeholder, #BFBFBF);
}

.clear-btn {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: var(--color-text-placeholder, #C9CDD4);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-left: 12rpx;
}

.clear-icon {
  font-size: 22rpx;
  color: #FFFFFF;
}

.date-range {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.date-item {
  flex: 1;
}

.date-label {
  font-size: 24rpx;
  color: var(--color-text-secondary, #9CA3AF);
  display: block;
  margin-bottom: 8rpx;
}

.date-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: var(--color-bg-secondary, #F3F4F6);
  border-radius: 16rpx;
  padding: 16rpx 24rpx;
}

.date-value {
  font-size: 26rpx;
  color: var(--color-text-primary, #2C3E50);
}

.date-arrow {
  font-size: 20rpx;
  color: var(--color-text-secondary, #9CA3AF);
}

.date-sep {
  font-size: 26rpx;
  color: var(--color-text-secondary, #9CA3AF);
  margin-top: 32rpx;
  flex-shrink: 0;
}

.type-scroll {
  white-space: nowrap;
}

.type-inner {
  display: inline-flex;
  gap: 16rpx;
}

.type-chip {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 24rpx;
  border-radius: 32rpx;
  background: var(--color-bg-secondary, #F3F4F6);
  border: 1rpx solid transparent;
}

.type-chip.active {
  border-width: 1rpx;
  border-style: solid;
}

.type-icon {
  font-size: 26rpx;
}

.type-label {
  font-size: 26rpx;
  color: var(--color-text-secondary, #6B7280);
  font-weight: 500;
}

.type-chip.active .type-label {
  font-weight: 600;
}

.order-list {
  flex: 1;
  padding: 24rpx 32rpx 40rpx;
}

.list-inner {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.order-card {
  background: var(--color-bg-card, #FFFFFF);
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
}

.order-card.urgent {
  border-color: #EF4444;
  box-shadow: 0 4rpx 24rpx rgba(239, 68, 68, 0.15);
}

.card-header {
  padding: 24rpx;
  border-bottom: 1rpx solid var(--color-border, #F3F4F6);
}

.order-no-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.order-no {
  font-size: 24rpx;
  color: var(--color-text-secondary, #6B7280);
  font-family: Menlo, Monaco, monospace;
}

.status-tag {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
}

.status-icon {
  font-size: 24rpx;
}

.status-text {
  font-size: 24rpx;
  font-weight: 500;
}

.urgent-badge {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  background: linear-gradient(135deg, #EF4444, #DC2626);
  padding: 8rpx 20rpx;
  border-radius: 16rpx;
}

.urgent-icon {
  font-size: 24rpx;
}

.urgent-text {
  font-size: 24rpx;
  color: #FFFFFF;
  font-weight: 600;
}

.card-body {
  padding: 20rpx 24rpx;
}

.type-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.type-badge {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 20rpx;
  border-radius: 16rpx;
}

.type-badge-icon {
  font-size: 26rpx;
}

.type-badge-label {
  font-size: 24rpx;
  color: #FFFFFF;
  font-weight: 500;
}

.dorm-no {
  font-size: 28rpx;
  color: var(--color-text-primary, #2C3E50);
  font-weight: 600;
}

.desc-row {
  margin-bottom: 12rpx;
}

.desc-text {
  font-size: 26rpx;
  color: var(--color-text-primary, #2C3E50);
  line-height: 1.6;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.contact-row {
  margin-top: 8rpx;
}

.contact-text {
  font-size: 24rpx;
  color: var(--color-text-secondary, #6B7280);
}

.card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  border-top: 1rpx solid var(--color-border, #F3F4F6);
  background: var(--color-bg-secondary, #FAFAFA);
}

.page.dark .card-footer {
  background: rgba(255, 255, 255, 0.02);
}

.create-time {
  font-size: 22rpx;
  color: var(--color-text-secondary, #9CA3AF);
}

.worker-info {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.worker-icon {
  font-size: 24rpx;
}

.worker-name {
  font-size: 24rpx;
  color: var(--color-text-secondary, #6B7280);
}

.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 255, 255, 0.8);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.page.dark .loading-overlay {
  background: rgba(15, 17, 23, 0.8);
}

.loading-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid var(--color-bg-secondary, #E5E7EB);
  border-top-color: var(--color-primary, #FF6B6B);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: 26rpx;
  color: var(--color-text-secondary, #6B7280);
}
