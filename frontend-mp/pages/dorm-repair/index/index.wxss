.page {
  min-height: 100vh;
  background-color: #F8F9FA;
  padding-bottom: 140rpx;
}

.page.dark {
  background-color: #0F1117;
  color: #E8ECF1;
}

.header-section {
  padding: 20rpx 30rpx;
  background-color: #fff;
}

.page.dark .header-section {
  background-color: #1A1D29;
}

.header-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1F2937;
}

.page.dark .header-title {
  color: #E8ECF1;
}

.submit-btn {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  border-radius: 36rpx;
  flex-shrink: 0;
}

.submit-btn-hover {
  opacity: 0.85;
  transform: scale(0.96);
}

.submit-btn-icon {
  font-size: 26rpx;
  margin-right: 6rpx;
}

.submit-btn-label {
  font-size: 26rpx;
  color: #fff;
  font-weight: 600;
}

.stats-section {
  background-color: #fff;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #EEEEEE;
}

.page.dark .stats-section {
  background-color: #1A1D29;
  border-bottom-color: #2A2F3D;
}

.stats-row {
  display: flex;
  align-items: center;
  justify-content: space-around;
  background-color: #F8F9FA;
  border-radius: 16rpx;
  padding: 28rpx 0;
}

.page.dark .stats-row {
  background-color: #22263A;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
}

.stat-value-orange {
  color: #F59E0B;
}

.stat-value-blue {
  color: #3B82F6;
}

.stat-value-teal {
  color: #14B8A6;
}

.stat-value-green {
  color: #10B981;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
}

.page.dark .stat-label {
  color: #9AA0A6;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background-color: #E5E7EB;
}

.page.dark .stat-divider {
  background-color: #3A3F4D;
}

.tab-section {
  background-color: #fff;
  border-bottom: 1rpx solid #EEEEEE;
}

.page.dark .tab-section {
  background-color: #1A1D29;
  border-bottom-color: #2A2F3D;
}

.tab-scroll {
  white-space: nowrap;
}

.tab-row {
  display: inline-flex;
  padding: 0 20rpx;
}

.tab-row > view {
  margin-right: 8rpx;
}

.tab-row > view:last-child {
  margin-right: 0;
}

.tab-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 28rpx 16rpx;
  position: relative;
  flex-shrink: 0;
}

.tab-text {
  font-size: 28rpx;
  color: #666;
  font-weight: 500;
}

.page.dark .tab-text {
  color: #9AA0A6;
}

.tab-item.active .tab-text {
  color: #FF6B6B;
  font-weight: 600;
}

.tab-indicator {
  width: 40rpx;
  height: 6rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  border-radius: 3rpx;
  margin-top: 12rpx;
}

.type-section {
  background-color: #fff;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #EEEEEE;
}

.page.dark .type-section {
  background-color: #1A1D29;
  border-bottom-color: #2A2F3D;
}

.type-scroll {
  white-space: nowrap;
}

.type-tabs {
  display: inline-flex;
  padding: 0 20rpx;
}

.type-tabs > view {
  margin-right: 12rpx;
}

.type-tabs > view:last-child {
  margin-right: 0;
}

.type-tab {
  display: inline-flex;
  align-items: center;
  padding: 14rpx 24rpx;
  border-radius: 28rpx;
  background-color: #F5F5F5;
  font-size: 24rpx;
  color: #666;
  flex-shrink: 0;
}

.page.dark .type-tab {
  background-color: #2A2F3D;
  color: #9AA0A6;
}

.type-tab.active {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  color: #fff;
}

.type-tab-icon {
  font-size: 26rpx;
  margin-right: 8rpx;
}

.type-tab-label {
  font-weight: 500;
}

.list-scroll {
  height: calc(100vh - 520rpx);
}

.list-container {
  padding: 20rpx;
}

.order-card {
  background-color: #fff;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.page.dark .order-card {
  background-color: #1A1D29;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.3);
}

.order-card-hover {
  transform: scale(0.98);
  opacity: 0.9;
}

.card-header {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  margin-bottom: 16rpx;
}

.card-header > view {
  margin-right: 12rpx;
  margin-bottom: 8rpx;
}

.card-header > view:last-child {
  margin-right: 0;
}

.urgent-tag {
  display: flex;
  align-items: center;
  padding: 6rpx 16rpx;
  background: linear-gradient(135deg, #EF4444 0%, #F87171 100%);
  border-radius: 14rpx;
}

.urgent-icon {
  font-size: 22rpx;
  margin-right: 6rpx;
}

.urgent-text {
  font-size: 22rpx;
  color: #fff;
  font-weight: 600;
}

.type-badge {
  display: flex;
  align-items: center;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.type-badge-icon {
  font-size: 26rpx;
  margin-right: 8rpx;
}

.type-badge-text {
  font-weight: 600;
}

.status-tag {
  display: flex;
  align-items: center;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.status-tag-icon {
  font-size: 22rpx;
  margin-right: 6rpx;
}

.card-dormitory {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.dormitory-icon {
  font-size: 26rpx;
  margin-right: 10rpx;
}

.dormitory-text {
  font-size: 28rpx;
  color: #374151;
  font-weight: 500;
}

.page.dark .dormitory-text {
  color: #D1D5DB;
}

.card-desc {
  margin-bottom: 16rpx;
}

.desc-text {
  font-size: 28rpx;
  color: #4B5563;
  line-height: 1.5;
}

.page.dark .desc-text {
  color: #C8CDD3;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid #F5F5F5;
}

.page.dark .card-footer {
  border-top-color: #2A2F3D;
}

.footer-left {
  display: flex;
  align-items: center;
}

.order-no {
  font-size: 22rpx;
  color: #999;
}

.footer-right {
  display: flex;
  align-items: center;
}

.time-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
}

.time-text {
  font-size: 22rpx;
  color: #999;
}

.fab-btn {
  position: fixed;
  right: 40rpx;
  bottom: 80rpx;
  width: 110rpx;
  height: 110rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 107, 0.4);
  z-index: 99;
}

.fab-btn-hover {
  transform: scale(0.95);
  opacity: 0.9;
}

.fab-icon {
  font-size: 60rpx;
  color: #fff;
  font-weight: 300;
  line-height: 1;
}
