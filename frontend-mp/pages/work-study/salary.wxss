.container {
  min-height: 100vh;
  background: #f5f6fa;
  padding-bottom: 40rpx;
}

.container.dark {
  background: #1a1a1a;
}

.summary-card {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  padding: 36rpx 32rpx;
  color: #fff;
  margin-bottom: 20rpx;
}

.summary-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
  opacity: 0.95;
}

.summary-grid {
  display: flex;
  justify-content: space-between;
}

.summary-item {
  text-align: left;
}

.summary-amount {
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 4rpx;
}

.summary-amount.paid {
  color: #A7F3D0;
  font-size: 32rpx;
}

.summary-amount.pending {
  color: #FDE68A;
  font-size: 32rpx;
}

.summary-label {
  font-size: 22rpx;
  opacity: 0.85;
}

.notice-bar {
  display: flex;
  align-items: center;
  margin: 0 24rpx 20rpx;
  padding: 16rpx 20rpx;
  background: #FEF3C7;
  border-radius: 12rpx;
}

.container.dark .notice-bar {
  background: rgba(253, 224, 71, 0.15);
}

.notice-icon {
  margin-right: 8rpx;
  font-size: 24rpx;
}

.notice-text {
  font-size: 24rpx;
  color: #92400E;
  flex: 1;
  line-height: 1.5;
}

.container.dark .notice-text {
  color: #FDE68A;
}

.tabs-scroll {
  white-space: nowrap;
  width: 100%;
  background: #fff;
  padding: 16rpx 0;
  margin-bottom: 20rpx;
}

.container.dark .tabs-scroll {
  background: #2a2a2a;
}

.tabs {
  display: inline-flex;
  padding: 0 24rpx;
}

.tab-item {
  padding: 14rpx 32rpx;
  font-size: 28rpx;
  color: #6b7280;
  background: #f3f4f6;
  border-radius: 28rpx;
  margin-right: 16rpx;
}

.container.dark .tab-item {
  background: #3a3a3a;
  color: #9ca3af;
}

.tab-item.active {
  background: #FF6B6B;
  color: #fff;
  font-weight: 500;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 160rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #6b7280;
  margin-bottom: 12rpx;
}

.empty-tip {
  font-size: 26rpx;
  color: #9ca3af;
}

.salary-list {
  padding: 0 24rpx;
}

.salary-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.container.dark .salary-card {
  background: #2a2a2a;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.container.dark .card-header {
  border-bottom-color: #3a3a3a;
}

.month-info {
  flex: 1;
}

.month-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 6rpx;
}

.container.dark .month-text {
  color: #fff;
}

.period-text {
  font-size: 24rpx;
  color: #9ca3af;
}

.status-badge {
  display: flex;
  align-items: center;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  flex-shrink: 0;
}

.status-badge text {
  margin-left: 4rpx;
}

.amount-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  margin-bottom: 16rpx;
  background: #FEF2F2;
  border-radius: 12rpx;
  padding: 20rpx;
}

.container.dark .amount-row {
  background: rgba(255, 107, 107, 0.1);
}

.amount-label {
  font-size: 28rpx;
  color: #6b7280;
}

.container.dark .amount-label {
  color: #9ca3af;
}

.amount-value {
  font-size: 44rpx;
  font-weight: 700;
  color: #FF6B6B;
}

.detail-rows {
  margin-bottom: 16rpx;
}

.detail-row {
  display: flex;
  align-items: center;
  padding: 10rpx 0;
}

.detail-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
  width: 32rpx;
}

.detail-label {
  font-size: 26rpx;
  color: #6b7280;
  width: 140rpx;
  flex-shrink: 0;
}

.container.dark .detail-label {
  color: #9ca3af;
}

.detail-value {
  font-size: 26rpx;
  color: #1f2937;
  flex: 1;
  text-align: right;
}

.container.dark .detail-value {
  color: #fff;
}

.time-info {
  padding: 16rpx 0;
  border-top: 1rpx solid #f0f0f0;
  margin-bottom: 16rpx;
}

.container.dark .time-info {
  border-top-color: #3a3a3a;
}

.time-row {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #6b7280;
  padding: 4rpx 0;
}

.container.dark .time-row {
  color: #9ca3af;
}

.time-label {
  margin-right: 8rpx;
}

.time-value {
  flex: 1;
}

.paid-text {
  color: #10B981;
  font-weight: 500;
}

.card-footer {
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.container.dark .card-footer {
  border-top-color: #3a3a3a;
}

.footer-tip {
  font-size: 24rpx;
  color: #9ca3af;
  text-align: center;
}

.footer-btn {
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  font-size: 28rpx;
  border-radius: 36rpx;
  font-weight: 500;
}

.footer-btn.primary {
  background: #f3f4f6;
  color: #6b7280;
}

.paid-success {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #10B981;
}

.success-icon {
  margin-right: 8rpx;
}
