.container {
  min-height: 100vh;
  background: #f5f6fa;
  padding-bottom: 40rpx;
}

.container.dark {
  background: #1a1a1a;
}

.quick-actions {
  display: flex;
  justify-content: space-around;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  padding: 30rpx 20rpx;
  margin-bottom: 20rpx;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #fff;
}

.action-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.action-label {
  font-size: 24rpx;
}

.search-bar {
  display: flex;
  align-items: center;
  margin: 0 24rpx 20rpx;
  background: #fff;
  border-radius: 40rpx;
  padding: 0 24rpx;
  height: 72rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.container.dark .search-bar {
  background: #2a2a2a;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  height: 72rpx;
}

.container.dark .search-input {
  color: #fff;
}

.clear-btn {
  width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  background: #e5e7eb;
  color: #6b7280;
  border-radius: 50%;
  font-size: 24rpx;
  margin-left: 12rpx;
}

.tabs-scroll,
.dept-scroll {
  white-space: nowrap;
  width: 100%;
}

.tabs {
  display: inline-flex;
  padding: 0 24rpx;
  margin-bottom: 16rpx;
}

.tab-item {
  padding: 16rpx 32rpx;
  font-size: 28rpx;
  color: #6b7280;
  background: #fff;
  border-radius: 30rpx;
  margin-right: 16rpx;
}

.container.dark .tab-item {
  background: #2a2a2a;
  color: #9ca3af;
}

.tab-item.active {
  background: #FF6B6B;
  color: #fff;
}

.departments {
  display: inline-flex;
  padding: 0 24rpx;
  margin-bottom: 20rpx;
}

.dept-item {
  display: flex;
  align-items: center;
  padding: 12rpx 24rpx;
  font-size: 26rpx;
  color: #6b7280;
  background: #fff;
  border-radius: 24rpx;
  margin-right: 12rpx;
}

.container.dark .dept-item {
  background: #2a2a2a;
  color: #9ca3af;
}

.dept-item.active {
  background: #FFF0F0;
  color: #FF6B6B;
}

.container.dark .dept-item.active {
  background: rgba(255, 107, 107, 0.2);
}

.dept-icon {
  margin-right: 8rpx;
  font-size: 24rpx;
}

.sort-bar {
  display: flex;
  padding: 0 24rpx;
  margin-bottom: 20rpx;
}

.sort-item {
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  color: #6b7280;
  background: #fff;
  border-radius: 20rpx;
  margin-right: 16rpx;
}

.container.dark .sort-item {
  background: #2a2a2a;
  color: #9ca3af;
}

.sort-item.active {
  background: #E8F4FF;
  color: #3B82F6;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #6b7280;
  margin-bottom: 12rpx;
}

.empty-tip {
  font-size: 26rpx;
  color: #9ca3af;
}

.job-list {
  padding: 0 24rpx;
}

.job-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  position: relative;
}

.container.dark .job-card {
  background: #2a2a2a;
}

.job-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.job-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1f2937;
  flex: 1;
}

.container.dark .job-title {
  color: #fff;
}

.job-status {
  display: flex;
  align-items: center;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  margin-left: 16rpx;
}

.job-status text {
  margin-left: 4rpx;
}

.job-dept {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #6b7280;
  margin-bottom: 20rpx;
}

.container.dark .job-dept {
  color: #9ca3af;
}

.dept-emoji {
  margin-right: 8rpx;
}

.job-info {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.container.dark .job-info {
  border-bottom-color: #3a3a3a;
}

.info-item {
  display: flex;
  align-items: center;
  font-size: 26rpx;
}

.info-icon {
  margin-right: 8rpx;
  font-size: 24rpx;
}

.info-label {
  color: #6b7280;
  margin-right: 8rpx;
}

.container.dark .info-label {
  color: #9ca3af;
}

.info-value {
  color: #1f2937;
  font-weight: 500;
}

.container.dark .info-value {
  color: #fff;
}

.info-value.wage {
  color: #FF6B6B;
  font-weight: 600;
}

.full-tag {
  color: #6b7280;
  margin-right: 4rpx;
}

.remaining {
  color: #10B981;
  margin-right: 4rpx;
}

.job-content {
  display: flex;
  align-items: flex-start;
  font-size: 26rpx;
  color: #4b5563;
  margin-bottom: 16rpx;
  line-height: 1.6;
}

.container.dark .job-content {
  color: #d1d5db;
}

.content-icon {
  margin-right: 8rpx;
  flex-shrink: 0;
}

.content-text {
  flex: 1;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.job-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.time-req {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #6b7280;
  flex: 1;
}

.container.dark .time-req {
  color: #9ca3af;
}

.req-icon {
  margin-right: 6rpx;
}

.publish-time {
  font-size: 22rpx;
  color: #9ca3af;
}

.apply-btn {
  position: absolute;
  right: 28rpx;
  bottom: 28rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  color: #fff;
  font-size: 24rpx;
  padding: 12rpx 28rpx;
  border-radius: 24rpx;
}
