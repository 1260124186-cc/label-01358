.container {
  min-height: 100vh;
  background: #f5f6fa;
  padding-bottom: 200rpx;
}

.container.dark {
  background: #1a1a1a;
}

.job-card {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  padding: 32rpx;
  display: flex;
  align-items: center;
}

.job-icon {
  width: 88rpx;
  height: 88rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  margin-right: 20rpx;
}

.job-info {
  flex: 1;
}

.job-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 8rpx;
}

.job-meta {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

.dot {
  margin: 0 12rpx;
  opacity: 0.6;
}

.wage {
  font-weight: 600;
}

.form-section {
  margin: 20rpx 24rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.container.dark .form-section {
  background: #2a2a2a;
}

.section-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 20rpx;
}

.section-row .section-title {
  margin-bottom: 0;
}

.container.dark .section-title {
  color: #fff;
}

.required {
  color: #FF6B6B;
  margin-right: 4rpx;
}

.select-all {
  font-size: 26rpx;
  color: #FF6B6B;
}

.form-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-item:last-child {
  border-bottom: none;
}

.container.dark .form-item {
  border-bottom-color: #3a3a3a;
}

.form-label {
  font-size: 26rpx;
  color: #6b7280;
  margin-bottom: 12rpx;
}

.container.dark .form-label {
  color: #9ca3af;
}

.form-input {
  font-size: 30rpx;
  color: #1f2937;
  height: 56rpx;
  line-height: 56rpx;
}

.container.dark .form-input {
  color: #fff;
}

.resume-tip {
  font-size: 24rpx;
  color: #9ca3af;
  margin-bottom: 16rpx;
}

.form-textarea {
  width: 100%;
  min-height: 200rpx;
  font-size: 28rpx;
  color: #1f2937;
  line-height: 1.6;
  padding: 16rpx;
  background: #f9fafb;
  border-radius: 12rpx;
  box-sizing: border-box;
}

.container.dark .form-textarea {
  color: #fff;
  background: #3a3a3a;
}

.char-count {
  text-align: right;
  font-size: 22rpx;
  color: #9ca3af;
  margin-top: 8rpx;
}

.weekday-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.weekday-item {
  padding: 16rpx 32rpx;
  background: #f3f4f6;
  border-radius: 24rpx;
  font-size: 26rpx;
  color: #6b7280;
}

.container.dark .weekday-item {
  background: #3a3a3a;
  color: #9ca3af;
}

.weekday-item.active {
  background: #FFF0F0;
  color: #FF6B6B;
  font-weight: 500;
}

.container.dark .weekday-item.active {
  background: rgba(255, 107, 107, 0.2);
}

.time-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.time-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #f9fafb;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
}

.container.dark .time-item {
  background: #3a3a3a;
}

.time-item.active {
  background: #FFF8F8;
  border-color: #FF6B6B;
}

.container.dark .time-item.active {
  background: rgba(255, 107, 107, 0.1);
}

.time-check {
  width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  border-radius: 50%;
  background: #e5e7eb;
  color: transparent;
  font-size: 24rpx;
  margin-right: 16rpx;
}

.time-item.active .time-check {
  background: #FF6B6B;
  color: #fff;
}

.time-text {
  font-size: 28rpx;
  color: #1f2937;
}

.container.dark .time-text {
  color: #fff;
}

.picker-display {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background: #f9fafb;
  border-radius: 12rpx;
}

.container.dark .picker-display {
  background: #3a3a3a;
}

.picker-value {
  font-size: 28rpx;
  color: #1f2937;
}

.container.dark .picker-value {
  color: #fff;
}

.picker-arrow {
  font-size: 36rpx;
  color: #9ca3af;
  transform: rotate(90deg);
}

.submit-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.container.dark .submit-bar {
  background: #2a2a2a;
}

.submit-tip {
  font-size: 24rpx;
  color: #9ca3af;
  margin-bottom: 16rpx;
  text-align: center;
}

.submit-btn {
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 32rpx;
  color: #fff;
  border-radius: 44rpx;
  font-weight: 500;
}

.btn-submit {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
}

.btn-loading {
  background: #d1d5db;
}
