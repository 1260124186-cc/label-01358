.container {
  min-height: 100vh;
  background: #f5f6fa;
  padding-bottom: 160rpx;
}

.container.dark {
  background: #1a1a1a;
}

.hero-section {
  position: relative;
  padding: 40rpx 32rpx;
  margin-bottom: 24rpx;
}

.hero-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
}

.hero-content {
  position: relative;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.job-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #fff;
  flex: 1;
  margin-right: 16rpx;
}

.job-status {
  display: flex;
  align-items: center;
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  background: rgba(255, 255, 255, 0.2);
}

.job-status text {
  margin-left: 4rpx;
  color: #fff;
}

.hero-wage {
  position: relative;
  display: flex;
  align-items: baseline;
}

.wage-symbol {
  font-size: 28rpx;
  color: #fff;
  opacity: 0.9;
}

.wage-amount {
  font-size: 56rpx;
  font-weight: 700;
  color: #fff;
  margin: 0 4rpx;
}

.wage-unit {
  font-size: 26rpx;
  color: #fff;
  opacity: 0.9;
}

.info-card {
  margin: 0 24rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 8rpx 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.container.dark .info-card {
  background: #2a2a2a;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-row:last-child {
  border-bottom: none;
}

.container.dark .info-row {
  border-bottom-color: #3a3a3a;
}

.info-label {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #6b7280;
}

.container.dark .info-label {
  color: #9ca3af;
}

.label-icon {
  margin-right: 8rpx;
  font-size: 26rpx;
}

.info-value {
  font-size: 28rpx;
  color: #1f2937;
  font-weight: 500;
}

.container.dark .info-value {
  color: #fff;
}

.full-text {
  color: #6b7280;
  margin-right: 4rpx;
}

.remaining-text {
  color: #10B981;
  margin-right: 4rpx;
}

.count-text {
  color: #9ca3af;
  font-weight: 400;
}

.progress-card {
  margin: 0 24rpx 20rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.container.dark .progress-card {
  background: #2a2a2a;
}

.progress-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.progress-title {
  font-size: 28rpx;
  color: #374151;
  font-weight: 500;
}

.container.dark .progress-title {
  color: #fff;
}

.progress-percent {
  font-size: 28rpx;
  color: #FF6B6B;
  font-weight: 600;
}

.progress-bar {
  height: 16rpx;
  background: #f0f0f0;
  border-radius: 8rpx;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.container.dark .progress-bar {
  background: #3a3a3a;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #FF6B6B, #FF8E8E);
  border-radius: 8rpx;
}

.progress-text {
  font-size: 24rpx;
  color: #6b7280;
}

.container.dark .progress-text {
  color: #9ca3af;
}

.section-card {
  margin: 0 24rpx 20rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.container.dark .section-card {
  background: #2a2a2a;
}

.section-title {
  display: flex;
  align-items: center;
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 20rpx;
}

.container.dark .section-title {
  color: #fff;
}

.title-icon {
  margin-right: 8rpx;
  font-size: 28rpx;
}

.section-content {
  font-size: 28rpx;
  color: #4b5563;
  line-height: 1.8;
}

.container.dark .section-content {
  color: #d1d5db;
}

.requirements-list {
  padding-left: 8rpx;
}

.requirement-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.requirement-item:last-child {
  margin-bottom: 0;
}

.req-dot {
  color: #FF6B6B;
  font-size: 16rpx;
  margin-right: 12rpx;
  margin-top: 8rpx;
  flex-shrink: 0;
}

.req-text {
  font-size: 28rpx;
  color: #4b5563;
  line-height: 1.6;
  flex: 1;
}

.container.dark .req-text {
  color: #d1d5db;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  gap: 20rpx;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.container.dark .bottom-bar {
  background: #2a2a2a;
}

.btn-secondary {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 30rpx;
  color: #6b7280;
  background: #f3f4f6;
  border-radius: 44rpx;
}

.container.dark .btn-secondary {
  background: #3a3a3a;
  color: #9ca3af;
}

.btn-primary {
  flex: 2;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 30rpx;
  color: #fff;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  border-radius: 44rpx;
  font-weight: 500;
}

.btn-disabled {
  flex: 2;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 30rpx;
  color: #fff;
  background: #d1d5db;
  border-radius: 44rpx;
  font-weight: 500;
}
