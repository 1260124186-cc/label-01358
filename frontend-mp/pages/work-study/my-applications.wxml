<view class="container {{darkMode ? 'dark' : ''}}">
  <view class="stats-header">
    <view class="stat-item">
      <view class="stat-number">{{stats.total}}</view>
      <view class="stat-label">总申请</view>
    </view>
    <view class="stat-item">
      <view class="stat-number pending">{{stats.pending}}</view>
      <view class="stat-label">待审核</view>
    </view>
    <view class="stat-item">
      <view class="stat-number approved">{{stats.approved}}</view>
      <view class="stat-label">已录用</view>
    </view>
    <view class="stat-item">
      <view class="stat-number rejected">{{stats.rejected}}</view>
      <view class="stat-label">已拒绝</view>
    </view>
  </view>

  <scroll-view class="tabs-scroll" scroll-x="true" enhanced="{{true}}" show-scrollbar="{{false}}">
    <view class="tabs">
      <view
        wx:for="{{tabs}}"
        wx:key="value"
        class="tab-item {{currentTab === item.value ? 'active' : ''}}"
        data-value="{{item.value}}"
        bindtap="onTabTap"
      >
        {{item.label}}
      </view>
    </view>
  </scroll-view>

  <view wx:if="{{applicationList.length === 0}}" class="empty-state">
    <view class="empty-icon">📝</view>
    <view class="empty-text">暂无申请记录</view>
    <view class="empty-tip">快去申请心仪的岗位吧</view>
  </view>

  <view wx:else class="application-list">
    <view
      wx:for="{{applicationList}}"
      wx:key="id"
      class="application-card"
    >
      <view class="card-header">
        <view class="job-info" data-id="{{item.jobId}}" bindtap="onNavToJob">
          <view class="job-title">{{item.jobTitle}}</view>
          <view class="job-dept">
            <text>{{item.deptIcon}}</text>
            <text>{{item.deptLabel}}</text>
          </view>
        </view>
        <view class="status-badge" style="background: {{item.statusColor}}15; color: {{item.statusColor}};">
          <text>{{item.statusIcon}}</text>
          <text>{{item.statusLabel}}</text>
        </view>
      </view>

      <view class="card-body">
        <view class="info-row">
          <text class="info-icon">💰</text>
          <text class="info-label">时薪</text>
          <text class="info-value">¥{{item.hourlyWage}}/小时</text>
        </view>
        <view class="info-row">
          <text class="info-icon">📅</text>
          <text class="info-label">可工作</text>
          <text class="info-value">{{item.availableDaysText}} · {{item.availableTimeText}}</text>
        </view>
        <view class="info-row">
          <text class="info-icon">⏱️</text>
          <text class="info-label">每周时长</text>
          <text class="info-value">{{item.weekHours}}</text>
        </view>
      </view>

      <view class="card-footer">
        <view class="apply-time">申请时间：{{item.applyTimeText}}</view>
      </view>

      <view wx:if="{{item.status === 'approved'}}" class="card-actions">
        <view
          class="action-btn primary"
          data-applicationid="{{item.id}}"
          data-jobid="{{item.jobId}}"
          data-jobtitle="{{item.jobTitle}}"
          data-hourlywage="{{item.hourlyWage}}"
          bindtap="onRecordHours"
        >
          记录工时
        </view>
        <view class="action-btn secondary" bindtap="onViewSalary">查看薪资</view>
      </view>

      <view wx:if="{{item.status === 'rejected' && item.reviewRemark}}" class="reject-reason">
        <view class="reason-label">拒绝原因</view>
        <view class="reason-text">{{item.reviewRemark}}</view>
      </view>

      <view wx:if="{{item.status === 'approved' && item.reviewRemark}}" class="approve-remark">
        <view class="remark-label">备注信息</view>
        <view class="remark-text">{{item.reviewRemark}}</view>
      </view>

      <view wx:if="{{item.status !== 'pending' && item.reviewTimeText}}" class="review-info">
        <text class="review-icon">✅</text>
        <text>审核时间：{{item.reviewTimeText}}</text>
      </view>
    </view>
  </view>
</view>
