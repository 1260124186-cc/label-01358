.container {
  min-height: 100vh;
  background: #f5f6fa;
  padding-bottom: 40rpx;
}

.container.dark {
  background: #1a1a1a;
}

.stats-header {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  padding: 40rpx 24rpx;
  display: flex;
  justify-content: space-around;
}

.stat-item {
  text-align: center;
  color: #fff;
}

.stat-number {
  font-size: 44rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.stat-number.pending {
  color: #FBBF24;
}

.stat-number.approved {
  color: #34D399;
}

.stat-number.rejected {
  color: #F87171;
}

.stat-label {
  font-size: 24rpx;
  opacity: 0.9;
}

.tabs-scroll {
  white-space: nowrap;
  width: 100%;
  background: #fff;
  padding: 16rpx 0;
  margin-bottom: 20rpx;
}

.container.dark .tabs-scroll {
  background: #2a2a2a;
}

.tabs {
  display: inline-flex;
  padding: 0 24rpx;
}

.tab-item {
  padding: 14rpx 32rpx;
  font-size: 28rpx;
  color: #6b7280;
  background: #f3f4f6;
  border-radius: 28rpx;
  margin-right: 16rpx;
}

.container.dark .tab-item {
  background: #3a3a3a;
  color: #9ca3af;
}

.tab-item.active {
  background: #FF6B6B;
  color: #fff;
  font-weight: 500;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 160rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #6b7280;
  margin-bottom: 12rpx;
}

.empty-tip {
  font-size: 26rpx;
  color: #9ca3af;
}

.application-list {
  padding: 0 24rpx;
}

.application-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.container.dark .application-card {
  background: #2a2a2a;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.container.dark .card-header {
  border-bottom-color: #3a3a3a;
}

.job-info {
  flex: 1;
  margin-right: 16rpx;
}

.job-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 8rpx;
}

.container.dark .job-title {
  color: #fff;
}

.job-dept {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #6b7280;
}

.container.dark .job-dept {
  color: #9ca3af;
}

.job-dept text {
  margin-right: 6rpx;
}

.status-badge {
  display: flex;
  align-items: center;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  flex-shrink: 0;
}

.status-badge text {
  margin-left: 4rpx;
}

.card-body {
  margin-bottom: 16rpx;
}

.info-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.info-row:last-child {
  margin-bottom: 0;
}

.info-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
}

.info-label {
  font-size: 26rpx;
  color: #6b7280;
  width: 120rpx;
  flex-shrink: 0;
}

.container.dark .info-label {
  color: #9ca3af;
}

.info-value {
  font-size: 26rpx;
  color: #1f2937;
  flex: 1;
}

.container.dark .info-value {
  color: #fff;
}

.card-footer {
  border-top: 1rpx solid #f0f0f0;
  padding-top: 16rpx;
}

.container.dark .card-footer {
  border-top-color: #3a3a3a;
}

.apply-time {
  font-size: 24rpx;
  color: #9ca3af;
}

.card-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.container.dark .card-actions {
  border-top-color: #3a3a3a;
}

.action-btn {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  font-size: 28rpx;
  border-radius: 36rpx;
}

.action-btn.primary {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  color: #fff;
}

.action-btn.secondary {
  background: #f3f4f6;
  color: #6b7280;
}

.container.dark .action-btn.secondary {
  background: #3a3a3a;
  color: #9ca3af;
}

.reject-reason,
.approve-remark {
  margin-top: 16rpx;
  padding: 20rpx;
  background: #FEF2F2;
  border-radius: 12rpx;
}

.container.dark .reject-reason {
  background: rgba(248, 113, 113, 0.15);
}

.approve-remark {
  background: #F0FDF4;
}

.container.dark .approve-remark {
  background: rgba(52, 211, 153, 0.15);
}

.reason-label,
.remark-label {
  font-size: 24rpx;
  color: #6b7280;
  margin-bottom: 8rpx;
}

.reason-text,
.remark-text {
  font-size: 26rpx;
  color: #1f2937;
  line-height: 1.6;
}

.container.dark .reason-text,
.container.dark .remark-text {
  color: #fff;
}

.review-info {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #9ca3af;
  display: flex;
  align-items: center;
}

.review-icon {
  margin-right: 6rpx;
}
