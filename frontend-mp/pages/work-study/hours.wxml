<view class="container {{darkMode ? 'dark' : ''}}">
  <view class="summary-card">
    <view class="summary-header">
      <picker mode="selector" range="{{monthOptions}}" value="{{monthIndex}}" bindchange="onMonthChange">
        <view class="month-picker">
          <text class="month-text">{{currentMonth}}</text>
          <text class="picker-arrow">▾</text>
        </view>
      </picker>
      <view class="add-btn" bindtap="onOpenAddModal">
        <text>+ 记录工时</text>
      </view>
    </view>
    <view class="summary-grid">
      <view class="summary-item">
        <view class="summary-value">{{monthlySummary.totalHours}}h</view>
        <view class="summary-label">总工时</view>
      </view>
      <view class="summary-item">
        <view class="summary-value highlight">¥{{monthlySummary.totalSalary}}</view>
        <view class="summary-label">预估薪资</view>
      </view>
      <view class="summary-item">
        <view class="summary-value confirmed">{{monthlySummary.confirmedHours}}h</view>
        <view class="summary-label">已确认</view>
      </view>
      <view class="summary-item">
        <view class="summary-value confirmed-highlight">¥{{monthlySummary.confirmedSalary}}</view>
        <view class="summary-label">已确认薪资</view>
      </view>
    </view>
  </view>

  <scroll-view class="tabs-scroll" scroll-x="true" enhanced="{{true}}" show-scrollbar="{{false}}">
    <view class="tabs">
      <view
        wx:for="{{tabs}}"
        wx:key="value"
        class="tab-item {{currentTab === item.value ? 'active' : ''}}"
        data-value="{{item.value}}"
        bindtap="onTabTap"
      >
        {{item.label}}
      </view>
    </view>
  </scroll-view>

  <view wx:if="{{hoursList.length === 0}}" class="empty-state">
    <view class="empty-icon">⏱️</view>
    <view class="empty-text">暂无工时记录</view>
    <view class="empty-tip">点击右上角「记录工时」开始记录</view>
  </view>

  <view wx:else class="hours-list">
    <view wx:for="{{hoursList}}" wx:key="id" class="hours-card">
      <view class="card-header">
        <view class="job-title">{{item.jobTitle}}</view>
        <view class="status-badge" style="background: {{item.statusColor}}15; color: {{item.statusColor}};">
          <text>{{item.statusIcon}}</text>
          <text>{{item.statusLabel}}</text>
        </view>
      </view>
      <view class="card-body">
        <view class="info-row">
          <text class="info-icon">📅</text>
          <text class="info-label">日期</text>
          <text class="info-value">{{item.date}}</text>
        </view>
        <view class="info-row">
          <text class="info-icon">⏰</text>
          <text class="info-label">时段</text>
          <text class="info-value">{{item.startTime}} - {{item.endTime}}</text>
        </view>
        <view class="info-row">
          <text class="info-icon">⏱️</text>
          <text class="info-label">工时</text>
          <text class="info-value highlight">{{item.hours}}小时</text>
        </view>
        <view class="info-row">
          <text class="info-icon">💰</text>
          <text class="info-label">薪资</text>
          <text class="info-value wage">¥{{item.totalSalary}}</text>
        </view>
        <view wx:if="{{item.description}}" class="info-row">
          <text class="info-icon">📝</text>
          <text class="info-label">备注</text>
          <text class="info-value">{{item.description}}</text>
        </view>
      </view>
      <view class="card-footer">
        <text class="submit-text">提交时间：{{item.submitTimeText}}</text>
      </view>
    </view>
  </view>

  <view wx:if="{{showAddModal}}" class="modal-mask" bindtap="onCloseAddModal">
    <view class="modal-content" catchtap="onTapStop">
      <view class="modal-header">
        <view class="modal-title">记录工时</view>
        <view class="modal-close" bindtap="onCloseAddModal">✕</view>
      </view>

      <view class="form-section">
        <view class="form-label">选择岗位</view>
        <picker mode="selector" range="{{approvedJobs}}" range-key="jobTitle" value="{{addForm.applicationIndex}}" bindchange="onJobChange">
          <view class="picker-display">
            <text class="picker-value">{{approvedJobs[addForm.applicationIndex].jobTitle || '请选择岗位'}}</text>
            <text class="picker-arrow">›</text>
          </view>
        </picker>
      </view>

      <view class="form-section">
        <view class="form-label">日期</view>
        <picker mode="date" value="{{addForm.date}}" bindchange="onDateChange">
          <view class="picker-display">
            <text class="picker-value">{{addForm.date}}</text>
            <text class="picker-arrow">›</text>
          </view>
        </picker>
      </view>

      <view class="form-row">
        <view class="form-section half">
          <view class="form-label">开始时间</view>
          <picker mode="time" value="{{addForm.startTime}}" bindchange="onStartTimeChange">
            <view class="picker-display">
              <text class="picker-value">{{addForm.startTime}}</text>
              <text class="picker-arrow">›</text>
            </view>
          </picker>
        </view>
        <view class="form-section half">
          <view class="form-label">结束时间</view>
          <picker mode="time" value="{{addForm.endTime}}" bindchange="onEndTimeChange">
            <view class="picker-display">
              <text class="picker-value">{{addForm.endTime}}</text>
              <text class="picker-arrow">›</text>
            </view>
          </picker>
        </view>
      </view>

      <view class="form-section">
        <view class="form-label">工时（小时）</view>
        <input
          class="form-input"
          type="digit"
          value="{{addForm.hours}}"
          bindinput="onHoursInput"
          placeholder="请输入工时"
        />
      </view>

      <view class="form-section">
        <view class="form-label">工作内容（选填）</view>
        <textarea
          class="form-textarea"
          value="{{addForm.description}}"
          bindinput="onDescInput"
          placeholder="请简要描述工作内容"
          maxlength="200"
          auto-height
        />
      </view>

      <view class="modal-footer">
        <view class="btn-cancel" bindtap="onCloseAddModal">取消</view>
        <view class="{{submitting ? 'btn-loading' : 'btn-submit'}}" bindtap="onSubmitHours">
          <text wx:if="{{submitting}}">提交中...</text>
          <text wx:else>提交</text>
        </view>
      </view>
    </view>
  </view>
</view>
