<page-meta page-style="{{pageStyle}}"/>
<view class="{{pageClass}}">
  <view class="tab-bar">
    <view
      class="{{item.activeClass}}"
      wx:for="{{tabs}}"
      wx:key="value"
      bindtap="onTabChange"
      data-value="{{item.value}}"
    >
      <text class="tab-icon">{{item.icon}}</text>
      <text class="tab-label">{{item.label}}</text>
    </view>
  </view>

  <scroll-view class="content-scroll" scroll-y="{{true}}">
    <view wx:if="{{currentTab === 'policy'}}" class="tab-content">
      <view class="search-bar">
        <input
          class="search-input"
          placeholder="搜索奖学金名称"
          placeholder-style="color: #9CA3AF;"
          value="{{searchKeyword}}"
          bindinput="onSearchInput"
          confirm-type="search"
        />
        <text class="search-icon">🔍</text>
      </view>

      <view class="filter-row">
        <scroll-view class="filter-scroll" scroll-x="{{true}}" show-scrollbar="{{false}}">
          <view class="filter-chips">
            <view
              class="{{item.activeClass}}"
              wx:for="{{categoryOptions}}"
              wx:key="value"
              bindtap="onCategoryChange"
              data-value="{{item.value}}"
            >
              {{item.label}}
            </view>
          </view>
        </scroll-view>
        <view class="sort-btn" bindtap="onSortChange">
          <text class="sort-icon">📊</text>
          <text class="sort-text">{{currentSortLabel}}</text>
        </view>
      </view>

      <view class="section-header">
        <text class="section-title">📚 奖学金政策</text>
        <text class="section-count">{{policyCountText}}</text>
      </view>

      <view class="policy-list" wx:if="{{policyListFiltered.length > 0}}">
        <view
          class="policy-card"
          wx:for="{{policyListFiltered}}"
          wx:key="id"
          bindtap="onPolicyClick"
          data-id="{{item.id}}"
        >
          <view class="policy-header">
            <view class="policy-title-row">
              <text class="policy-name">{{item.name}}</text>
              <view class="policy-tag" style="{{item.categoryTagStyle}}">
                {{item.categoryColor.label}}
              </view>
            </view>
            <view class="policy-amount-row">
              <text class="policy-amount">{{item.amountDisplayText}}</text>
              <view class="{{item.badgeClass}}">
                {{item.daysLeft.text}}
              </view>
            </view>
          </view>

          <view class="policy-info">
            <view class="info-item">
              <text class="info-icon">📅</text>
              <text class="info-text">{{item.applyDateText}}</text>
            </view>
            <view class="info-item">
              <text class="info-icon">👥</text>
              <text class="info-text">{{item.quota}}</text>
            </view>
            <view class="info-item">
              <text class="info-icon">🏫</text>
              <text class="info-text">{{item.sponsor}}</text>
            </view>
          </view>

          <view class="policy-desc">
            <text class="desc-text">{{item.description}}</text>
          </view>

          <view class="eligibility-preview">
            <text class="eligibility-title">📋 申请条件</text>
            <view class="eligibility-list">
              <text class="eligibility-item" wx:for="{{item.previewEligibility}}" wx:for-item="cond" wx:key="index">
                • {{cond}}
              </text>
              <text class="eligibility-more" wx:if="{{item.hasMoreEligibility}}">{{item.eligibilityMoreText}}</text>
            </view>
          </view>

          <view class="policy-actions">
            <view class="action-btn action-secondary" catchtap="onViewMaterials" data-id="{{item.id}}">
              <text class="btn-icon">📋</text>
              <text class="btn-text">材料清单</text>
            </view>
            <view class="{{item.applyBtnClass}}" catchtap="onApplyClick" data-id="{{item.id}}">
              <text class="btn-icon">✍️</text>
              <text class="btn-text">{{item.applyBtnText}}</text>
            </view>
          </view>
        </view>
      </view>

      <empty wx:if="{{policyListFiltered.length === 0}}" text="暂无符合条件的奖学金" />
    </view>

    <view wx:if="{{currentTab === 'match'}}" class="tab-content">
      <view class="user-profile-card gradient-card profile-gradient" wx:if="{{userProfile}}">
        <view class="profile-header">
          <view class="avatar-circle">
            <text class="avatar-text">{{userProfile.avatarLetter}}</text>
          </view>
          <view class="profile-info">
            <text class="profile-name">{{userProfile.name}}</text>
            <text class="profile-college">{{userProfile.collegeText}}</text>
            <text class="profile-grade">{{userProfile.grade}}</text>
          </view>
        </view>

        <view class="profile-stats">
          <view class="stat-item">
            <view class="stat-circle">
              <view class="stat-progress" style="{{userProfile.gpaProgressStyle}}"></view>
            </view>
            <view class="stat-info">
              <text class="stat-value">{{userProfile.gpa}}</text>
              <text class="stat-label">GPA</text>
            </view>
          </view>
          <view class="stat-item">
            <view class="stat-info-rank">
              <text class="{{userProfile.gpaRankClass}}">{{userProfile.gpaRankDisplayText}}</text>
              <text class="stat-label">专业排名</text>
              <text class="stat-percent">{{userProfile.gpaRankPercentText}}</text>
            </view>
          </view>
          <view class="stat-item">
            <view class="stat-info-rank">
              <text class="{{userProfile.comprehensiveRankClass}}">{{userProfile.comprehensiveRankDisplayText}}</text>
              <text class="stat-label">综测排名</text>
              <text class="stat-percent">{{userProfile.comprehensiveRankPercentText}}</text>
            </view>
          </view>
        </view>

        <view class="profile-tags">
          <view class="profile-tag" wx:if="{{userProfile.awardsCount > 0}}">
            <text class="tag-icon">🏆</text>
            <text class="tag-text">{{userProfile.awardsText}}</text>
          </view>
          <view class="profile-tag" wx:if="{{userProfile.clubCount > 0}}">
            <text class="tag-icon">🎖️</text>
            <text class="tag-text">{{userProfile.clubText}}</text>
          </view>
          <view class="profile-tag" wx:if="{{userProfile.researchCount > 0}}">
            <text class="tag-icon">🔬</text>
            <text class="tag-text">{{userProfile.researchText}}</text>
          </view>
          <view class="profile-tag">
            <text class="tag-icon">💝</text>
            <text class="tag-text">{{userProfile.volunteerHoursText}}</text>
          </view>
        </view>
      </view>

      <view class="section-header">
        <text class="section-title">🎯 为你推荐</text>
        <text class="section-count">{{matchCountText}}</text>
      </view>

      <view class="match-list" wx:if="{{matchedList.length > 0}}">
        <view
          class="match-card"
          wx:for="{{matchedList}}"
          wx:key="id"
          bindtap="onPolicyClick"
          data-id="{{item.id}}"
        >
          <view class="match-header">
            <view class="match-title-row">
              <text class="match-name">{{item.name}}</text>
              <view class="match-level-badge" style="{{item.matchLevelBadgeStyle}}">
                {{item.matchLevelText}}
              </view>
            </view>
            <text class="match-amount">{{item.amountDisplayText}}</text>
          </view>

          <view class="match-score-section">
            <view class="score-bar">
              <view class="score-fill" style="{{item.matchBarStyle}}"></view>
            </view>
            <text class="score-text">{{item.matchScoreText}}</text>
          </view>

          <view class="match-reasons">
            <view class="reason-tag" wx:for="{{item.matchReasonsPreview}}" wx:for-item="reason" wx:key="index">
              ✓ {{reason}}
            </view>
          </view>

          <view class="match-footer">
            <view class="match-info">
              <view class="policy-tag small" style="{{item.smallCategoryTagStyle}}">
                {{item.categoryColor.label}}
              </view>
              <view class="{{item.smallBadgeClass}}">
                {{item.daysLeft.text}}
              </view>
            </view>
            <view class="match-apply-btn" catchtap="onMatchApplyClick" data-id="{{item.id}}">
              立即申请
            </view>
          </view>
        </view>
      </view>

      <empty wx:if="{{matchedList.length === 0}}" text="暂无匹配的奖学金，建议提升综测成绩" />
    </view>

    <view wx:if="{{currentTab === 'progress'}}" class="tab-content">
      <view class="progress-overview gradient-card progress-gradient">
        <view class="overview-row">
          <view class="overview-item">
            <text class="overview-value">{{applicationStats.total}}</text>
            <text class="overview-label">申请总数</text>
          </view>
          <view class="overview-divider"></view>
          <view class="overview-item">
            <text class="overview-value success">{{applicationStats.approved}}</text>
            <text class="overview-label">已通过</text>
          </view>
          <view class="overview-divider"></view>
          <view class="overview-item">
            <text class="overview-value warning">{{applicationStats.reviewing}}</text>
            <text class="overview-label">审核中</text>
          </view>
        </view>
      </view>

      <view class="section-header">
        <text class="section-title">📊 申请进度</text>
        <text class="section-count">{{applicationCountText}}</text>
      </view>

      <view class="application-list" wx:if="{{applicationList.length > 0}}">
        <view
          class="application-card"
          wx:for="{{applicationList}}"
          wx:key="id"
          bindtap="onApplicationClick"
          data-id="{{item.id}}"
        >
          <view class="app-header">
            <text class="app-name">{{item.scholarshipName}}</text>
            <view class="app-status-badge" style="{{item.statusBadgeStyle}}">
              {{item.statusText}}
            </view>
          </view>

          <view class="app-info-row">
            <text class="app-amount">{{item.amountDisplayText}}</text>
            <text class="app-time">📅 {{item.applyTimeText}}</text>
          </view>

          <view class="app-progress-section">
            <view class="progress-header">
              <text class="progress-label">申请进度</text>
              <text class="progress-text">{{item.stepProgressText}}</text>
            </view>
            <view class="progress-bar-bg">
              <view class="progress-bar-fill" style="{{item.progressBarStyle}}"></view>
            </view>
          </view>

          <view class="app-steps">
            <view
              class="{{step.stepClass}}"
              wx:for="{{item.steps}}"
              wx:for-item="step"
              wx:key="name"
            >
              <view class="step-dot">
                <text class="step-icon">{{step.stepIcon}}</text>
              </view>
              <text class="step-name">{{step.name}}</text>
            </view>
          </view>

          <view class="app-remark" wx:if="{{item.hasRemark}}">
            <text class="remark-icon">💬</text>
            <text class="remark-text">{{item.remark}}</text>
          </view>
        </view>
      </view>

      <empty wx:if="{{applicationList.length === 0}}" text="暂无申请记录，快去申请奖学金吧！" />
    </view>

    <view wx:if="{{currentTab === 'material'}}" class="tab-content">
      <view class="material-header gradient-card material-gradient">
        <text class="material-header-title">📋 申请材料清单</text>
        <text class="material-header-desc">准备好以下材料，申请更顺利</text>
      </view>

      <view class="section-header">
        <text class="section-title">📄 通用材料清单</text>
        <text class="section-count">{{materialCountText}}</text>
      </view>

      <view class="material-list" wx:if="{{materialList.length > 0}}">
        <view
          class="material-card"
          wx:for="{{materialList}}"
          wx:key="id"
          bindtap="onMaterialClick"
          data-id="{{item.id}}"
        >
          <view class="material-icon-wrap">
            <text class="material-icon">📄</text>
          </view>
          <view class="material-info">
            <view class="material-title-row">
              <text class="material-name">{{item.name}}</text>
              <view class="required-tag" style="{{item.requiredTagStyle}}">
                {{item.requiredText}}
              </view>
            </view>
            <text class="material-desc">{{item.description}}</text>
            <view class="material-meta">
              <text class="meta-item">{{item.formatText}}</text>
              <text class="meta-item">{{item.sizeText}}</text>
            </view>
          </view>
          <text class="material-arrow">›</text>
        </view>
      </view>

      <view class="material-tips-card">
        <text class="tips-title">💡 材料准备注意事项</text>
        <view class="tips-list">
          <text class="tip-item">• 所有材料需清晰可辨，扫描件建议300DPI以上</text>
          <text class="tip-item">• 获奖证书需包含证书名称、获奖时间、颁发单位完整信息</text>
          <text class="tip-item">• 成绩单需加盖教务处公章方为有效</text>
          <text class="tip-item">• 申请表需本人签字并经学院审核盖章</text>
          <text class="tip-item">• 建议提前准备电子版材料，方便多次使用</text>
          <text class="tip-item">• 材料提交后请关注审核进度，及时补充缺失材料</text>
        </view>
      </view>

      <empty wx:if="{{materialList.length === 0}}" text="暂无材料清单" />
    </view>

    <view wx:if="{{currentTab === 'public'}}" class="tab-content">
      <view class="filter-row">
        <scroll-view class="filter-scroll" scroll-x="{{true}}" show-scrollbar="{{false}}">
          <view class="filter-chips">
            <view
              class="{{item.activeClass}}"
              wx:for="{{yearOptions}}"
              wx:key="value"
              bindtap="onYearChange"
              data-value="{{item.value}}"
            >
              {{item.label}}
            </view>
          </view>
        </scroll-view>
      </view>

      <view class="public-header gradient-card public-gradient">
        <text class="public-header-title">📜 获奖公示名单</text>
        <text class="public-header-desc">公开透明，接受监督</text>
      </view>

      <view class="section-header">
        <text class="section-title">🏆 获奖公示</text>
        <text class="section-count">{{publicCountText}}</text>
      </view>

      <view class="public-list" wx:if="{{publicList.length > 0}}">
        <view
          class="public-card"
          wx:for="{{publicList}}"
          wx:key="id"
          bindtap="onPublicClick"
          data-id="{{item.id}}"
        >
          <view class="public-header-row">
            <text class="public-name">{{item.scholarshipName}}</text>
            <text class="public-year">{{item.year}}</text>
          </view>

          <view class="public-stats">
            <view class="public-stat-item">
              <text class="stat-icon">👥</text>
              <text class="stat-text">{{item.studentCountText}}</text>
            </view>
            <view class="public-stat-item">
              <text class="stat-icon">💰</text>
              <text class="stat-text">{{item.totalAmountText}}</text>
            </view>
            <view class="public-stat-item">
              <text class="stat-icon">🏢</text>
              <text class="stat-text">{{item.college}}</text>
            </view>
          </view>

          <view class="public-list-preview">
            <text class="list-title">获奖名单（部分）：</text>
            <view class="winner-chips">
              <view class="winner-chip" wx:for="{{item.previewWinners}}" wx:for-item="winner" wx:key="index">
                <text class="winner-name">{{winner.name}}</text>
                <text class="winner-major">{{winner.major}}</text>
              </view>
              <text class="more-winners" wx:if="{{item.hasMoreWinners}}">{{item.moreWinnersText}}</text>
            </view>
          </view>

          <view class="public-footer">
            <text class="publish-time">{{item.publishTimeDisplayText}}</text>
            <view class="view-detail-btn">
              <text class="btn-text">查看详情</text>
              <text class="btn-arrow">›</text>
            </view>
          </view>

          <view class="privacy-notice">
            <text class="privacy-icon">🔒</text>
            <text class="privacy-text">名单已做脱敏处理，保护个人隐私</text>
          </view>
        </view>
      </view>

      <empty wx:if="{{publicList.length === 0}}" text="暂无公示名单" />
    </view>

    <view class="bottom-space"></view>
  </scroll-view>

  <view class="{{modalClass}}" catchtap="closeMaterialModal">
    <view class="modal-content" catchtap="">
      <view class="modal-header">
        <text class="modal-title">📋 所需材料清单</text>
        <view class="modal-close" catchtap="closeMaterialModal">✕</view>
      </view>
      <scroll-view class="modal-body" scroll-y="{{true}}">
        <view class="modal-material-list">
          <view
            class="modal-material-item"
            wx:for="{{modalMaterials}}"
            wx:key="id"
            bindtap="onMaterialClick"
            data-id="{{item.id}}"
          >
            <view class="material-icon-wrap small">
              <text class="material-icon">📄</text>
            </view>
            <view class="material-info">
              <view class="material-title-row">
                <text class="material-name">{{item.name}}</text>
                <view class="required-tag" style="{{item.requiredTagStyle}}">
                  {{item.requiredText}}
                </view>
              </view>
              <text class="material-desc">{{item.description}}</text>
            </view>
          </view>
        </view>
      </scroll-view>
      <view class="modal-footer">
        <view class="modal-btn" catchtap="closeMaterialModal">
          知道了
        </view>
      </view>
    </view>
  </view>
</view>
