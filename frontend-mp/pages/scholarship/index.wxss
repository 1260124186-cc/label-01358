  border-bottom-color: #2D3139;
}

.public-stat-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.stat-icon {
  font-size: 24rpx;
}

.stat-text {
  font-size: 24rpx;
  color: #6B7280;
}

.page.dark .stat-text {
  color: #9CA3AF;
}

.public-list-preview {
  margin-bottom: 16rpx;
}

.list-title {
  display: block;
  font-size: 26rpx;
