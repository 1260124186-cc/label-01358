}

.bottom-space {
  height: 40rpx;
}

.material-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  visibility: hidden;
  opacity: 0;
  transition: all 0.3s ease;
}

.material-modal.show {
  visibility: visible;
  opacity: 1;
}

.material-modal .modal-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  max-height: 80vh;
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  display: flex;
  flex-direction: column;
}

.page.dark .material-modal .modal-content {
  background: #1A1D26;
}

.material-modal.show .modal-content {
  transform: translateY(0);
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid #F3F4F6;
  flex-shrink: 0;
}

.page.dark .modal-header {
  border-bottom-color: #2D3139;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2C3E50;
}

.page.dark .modal-title {
  color: #E8ECF1;
}

.modal-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #9CA3AF;
  background: #F3F4F6;
  border-radius: 50%;
}

.page.dark .modal-close {
  background: #2D3139;
  color: #D1D5DB;
}

.modal-body {
  flex: 1;
  overflow-y: auto;
  padding: 24rpx 32rpx;
}

.modal-material-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.modal-material-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx;
  background: #F9FAFB;
  border-radius: 16rpx;
}

.page.dark .modal-material-item {
  background: #2D3139;
}

.modal-footer {
  padding: 24rpx 32rpx 48rpx;
  border-top: 1rpx solid #F3F4F6;
  flex-shrink: 0;
}

.page.dark .modal-footer {
  border-top-color: #2D3139;
}

.modal-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  background: linear-gradient(135deg, #3B82F6, #60A5FA);
  border-radius: 44rpx;
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(59, 130, 246, 0.3);
}

.modal-btn:active {
  transform: scale(0.98);
}
