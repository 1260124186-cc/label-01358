}

.public-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  transition: all 0.2s ease;
}

.page.dark .public-card {
  background: #1A1D26;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.3);
}

.public-card:active {
  transform: scale(0.98);
}

.public-header-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.public-name {
  flex: 1;
  font-size: 30rpx;
  font-weight: 600;
  color: #2C3E50;
}

.page.dark .public-name {
  color: #E8ECF1;
}

.public-year {
  font-size: 24rpx;
  color: #3B82F6;
  font-weight: 500;
  background: #EFF6FF;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
}

.page.dark .public-year {
  background: rgba(59, 130, 246, 0.15);
  color: #60A5FA;
}

.public-stats {
  display: flex;
  justify-content: space-around;
  padding: 16rpx 0;
  border-top: 1rpx solid #F3F4F6;
  border-bottom: 1rpx solid #F3F4F6;
