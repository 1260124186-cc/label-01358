.container {
  min-height: 100vh;
  background: #F8F9FA;
  padding: 20rpx;
  box-sizing: border-box;
}

.container.dark {
  background: #1a1a1a;
}

.stats-card {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  color: #fff;
}

.stats-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.stats-title {
  font-size: 32rpx;
  font-weight: 600;
}

.stats-actions {
  display: flex;
  gap: 20rpx;
}

.icon-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  font-size: 28rpx;
}

.stats-grid {
  display: flex;
  justify-content: space-around;
  margin-bottom: 20rpx;
}

.stats-item {
  text-align: center;
}

.stats-number {
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.stats-label {
  font-size: 24rpx;
  opacity: 0.9;
}

.module-stats {
  display: flex;
  justify-content: center;
  gap: 40rpx;
  padding-top: 20rpx;
  border-top: 1px solid rgba(255, 255, 255, 0.2);
}

.module-stat {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.module-icon {
  font-size: 28rpx;
}

.module-count {
  font-size: 26rpx;
  font-weight: 500;
}

.section-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.container.dark .section-card {
  background: #2a2a2a;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.container.dark .section-title {
  color: #fff;
}

.add-btn {
  background: #FF6B6B;
  color: #fff;
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
}

.empty-state {
  text-align: center;
  padding: 60rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 30rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.container.dark .empty-text {
  color: #999;
}

.empty-desc {
  font-size: 24rpx;
  color: #999;
}

.subscription-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.subscription-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  background: #F8F9FA;
  border-radius: 16rpx;
}

.container.dark .subscription-item {
  background: #333;
}

.item-main {
  flex: 1;
  margin-right: 20rpx;
}

.item-keyword {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.container.dark .item-keyword {
  color: #fff;
}

.item-info {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
  font-size: 24rpx;
  color: #999;
}

.container.dark .item-info {
  color: #666;
}

.item-divider {
  color: #ddd;
}

.container.dark .item-divider {
  color: #444;
}

.item-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.delete-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.hot-keywords {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.hot-keyword {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: #F8F9FA;
  padding: 12rpx 20rpx;
  border-radius: 30rpx;
  border: 1px solid #eee;
}

.container.dark .hot-keyword {
  background: #333;
  border-color: #444;
}

.keyword-text {
  font-size: 26rpx;
  color: #333;
}

.container.dark .keyword-text {
  color: #fff;
}

.keyword-count {
  font-size: 22rpx;
  color: #FF6B6B;
  background: rgba(255, 107, 107, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
}

.disabled-banner {
  background: #fff;
  border-radius: 20rpx;
  padding: 60rpx 30rpx;
  text-align: center;
}

.container.dark .disabled-banner {
  background: #2a2a2a;
}

.disabled-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.disabled-text {
  font-size: 30rpx;
  color: #666;
  margin-bottom: 20rpx;
}

.container.dark .disabled-text {
  color: #999;
}

.disabled-btn {
  display: inline-block;
  background: #FF6B6B;
  color: #fff;
  padding: 16rpx 40rpx;
  border-radius: 30rpx;
  font-size: 28rpx;
}

.dialog-mask,
.drawer-mask,
.picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
}

.dialog-content,
.drawer-content,
.picker-content {
  position: fixed;
  background: #fff;
  z-index: 101;
  border-radius: 24rpx 24rpx 0 0;
}

.container.dark .dialog-content,
.container.dark .drawer-content,
.container.dark .picker-content {
  background: #2a2a2a;
}

.dialog-content {
  bottom: 0;
  left: 0;
  right: 0;
  padding: 30rpx;
}

.dialog-header,
.drawer-header,
.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.dialog-title,
.drawer-title,
.picker-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

.container.dark .dialog-title,
.container.dark .drawer-title,
.container.dark .picker-title {
  color: #fff;
}

.dialog-close,
.drawer-close {
  font-size: 48rpx;
  color: #999;
  line-height: 1;
}

.form-group {
  margin-bottom: 30rpx;
}

.form-label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.container.dark .form-label {
  color: #fff;
}

.select-all {
  font-size: 26rpx;
  color: #FF6B6B;
}

.form-input {
  background: #F8F9FA;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: #333;
}

.container.dark .form-input {
  background: #333;
  color: #fff;
}

.module-options {
  display: flex;
  gap: 16rpx;
}

.module-option {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 24rpx 16rpx;
  background: #F8F9FA;
  border-radius: 16rpx;
  border: 2px solid transparent;
  transition: all 0.3s;
}

.container.dark .module-option {
  background: #333;
}

.module-option.selected {
  border-color: #FF6B6B;
  background: rgba(255, 107, 107, 0.1);
}

.module-option .module-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.module-option .module-label {
  font-size: 24rpx;
  color: #666;
}

.container.dark .module-option .module-label {
  color: #999;
}

.module-option.selected .module-label {
  color: #FF6B6B;
}

.dialog-footer,
.picker-footer {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
}

.cancel-btn,
.confirm-btn {
  flex: 1;
  padding: 24rpx;
  border-radius: 12rpx;
  text-align: center;
  font-size: 30rpx;
}

.cancel-btn {
  background: #F8F9FA;
  color: #666;
}

.container.dark .cancel-btn {
  background: #333;
  color: #999;
}

.confirm-btn {
  background: #FF6B6B;
  color: #fff;
}

.drawer-content {
  bottom: 0;
  left: 0;
  right: 0;
  max-height: 70vh;
  padding: 30rpx;
  overflow-y: auto;
}

.setting-list {
  display: flex;
  flex-direction: column;
}

.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1px solid #f0f0f0;
}

.container.dark .setting-item {
  border-color: #333;
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-info {
  flex: 1;
}

.setting-name {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 6rpx;
}

.container.dark .setting-name {
  color: #fff;
}

.setting-desc {
  font-size: 24rpx;
  color: #999;
}

.container.dark .setting-desc {
  color: #666;
}

.setting-action {
  color: #FF6B6B;
  font-size: 26rpx;
  padding: 8rpx 16rpx;
}

.setting-value {
  font-size: 28rpx;
  color: #FF6B6B;
}

.picker-content {
  bottom: 0;
  left: 0;
  right: 0;
  padding: 30rpx;
}

.picker-view {
  height: 400rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.time-separator {
  width: 60rpx;
  text-align: center;
  font-size: 40rpx;
  color: #333;
  line-height: 50px;
}

.container.dark .time-separator {
  color: #fff;
}
