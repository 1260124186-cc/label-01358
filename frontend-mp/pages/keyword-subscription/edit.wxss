.container {
  min-height: 100vh;
  background: #F8F9FA;
  padding: 20rpx;
  box-sizing: border-box;
}

.container.dark {
  background: #1a1a1a;
}

.loading {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}

.form-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.container.dark .form-card {
  background: #2a2a2a;
}

.form-group {
  margin-bottom: 40rpx;
}

.form-group:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.container.dark .form-label {
  color: #fff;
}

.select-all {
  font-size: 26rpx;
  color: #FF6B6B;
  font-weight: normal;
}

.form-input {
  background: #F8F9FA;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 30rpx;
  color: #333;
}

.container.dark .form-input {
  background: #333;
  color: #fff;
}

.form-desc {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.container.dark .form-desc {
  color: #666;
}

.module-options {
  display: flex;
  gap: 16rpx;
}

.module-option {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 24rpx 16rpx;
  background: #F8F9FA;
  border-radius: 16rpx;
  border: 2px solid transparent;
  transition: all 0.3s;
}

.container.dark .module-option {
  background: #333;
}

.module-option.selected {
  border-color: #FF6B6B;
  background: rgba(255, 107, 107, 0.1);
}

.module-option .module-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.module-option .module-label {
  font-size: 24rpx;
  color: #666;
}

.container.dark .module-option .module-label {
  color: #999;
}

.module-option.selected .module-label {
  color: #FF6B6B;
}

.stats-group {
  margin-top: 40rpx;
  padding-top: 30rpx;
  border-top: 1px solid #f0f0f0;
}

.container.dark .stats-group {
  border-color: #333;
}

.stats-row {
  display: flex;
  justify-content: space-around;
}

.stats-item {
  text-align: center;
}

.stats-value {
  font-size: 36rpx;
  font-weight: 600;
  color: #FF6B6B;
  margin-bottom: 8rpx;
}

.stats-text {
  font-size: 24rpx;
  color: #999;
}

.container.dark .stats-text {
  color: #666;
}

.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx;
  background: #fff;
  display: flex;
  gap: 20rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.container.dark .bottom-actions {
  background: #2a2a2a;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.3);
}

.delete-btn,
.save-btn {
  flex: 1;
  padding: 28rpx;
  border-radius: 12rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 500;
}

.delete-btn {
  background: #F8F9FA;
  color: #EF4444;
}

.container.dark .delete-btn {
  background: #333;
}

.save-btn {
  background: #FF6B6B;
  color: #fff;
}

.save-btn.disabled {
  opacity: 0.6;
}
