.page {
  min-height: 100vh;
  background-color: var(--color-bg-page);
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.content {
  padding: 24rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-secondary);
  margin: 16rpx 8rpx;
}

.settings-card {
  background-color: var(--color-bg-card);
  border-radius: var(--radius-2xl);
  overflow: hidden;
  box-shadow: var(--shadow-card);
  margin-bottom: 24rpx;
}

.setting-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 24rpx;
  transition: all var(--transition-fast);
}

.setting-item:not(:last-child) {
  border-bottom: 1rpx solid var(--color-border-light);
}

.setting-item.no-border {
  border-bottom: none;
}

.setting-item:active {
  background-color: var(--color-bg-page);
}

.setting-left {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.setting-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: var(--radius-lg);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.setting-info {
  flex: 1;
  min-width: 0;
}

.setting-label {
  display: block;
  font-size: 30rpx;
  font-weight: 500;
  color: var(--color-text-primary);
  margin-bottom: 6rpx;
}

.setting-desc {
  font-size: 24rpx;
  color: var(--color-text-muted);
}

.setting-right {
  display: flex;
  align-items: center;
  flex-shrink: 0;
}

.setting-value {
  font-size: 26rpx;
  color: var(--color-text-muted);
  margin-right: 8rpx;
  max-width: 200rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.setting-switch {
  flex-shrink: 0;
  transform: scale(0.9);
}

.setting-arrow {
  font-size: 32rpx;
  color: var(--color-text-muted);
  flex-shrink: 0;
}

.highlight-item {
  background: linear-gradient(135deg, rgba(254, 226, 226, 0.3) 0%, rgba(254, 249, 195, 0.3) 100%);
}

.danger-item .setting-label {
  color: #DC2626;
}

.dark .danger-item .setting-label {
  color: #FCA5A5;
}

.custom-phone-input {
  flex-shrink: 0;
  width: 220rpx;
  font-size: 26rpx;
  color: var(--color-text-primary);
  text-align: right;
}

.tip-card {
  margin-top: 32rpx;
  padding: 28rpx 24rpx;
  background: linear-gradient(135deg, #FEF3C7 0%, #FEE2E2 100%);
  border-radius: var(--radius-2xl);
}

.dark .tip-card {
  background: linear-gradient(135deg, #4A3F20 0%, #4A2020 100%);
}

.tip-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #92400E;
  margin-bottom: 12rpx;
}

.dark .tip-title {
  color: #FCD34D;
}

.tip-content {
  font-size: 26rpx;
  color: #78350F;
  line-height: 1.6;
}

.dark .tip-content {
  color: #FDE68A;
}

.picker-mask,
.delete-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
}

.picker-dialog,
.delete-dialog {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--color-bg-card);
  border-radius: 32rpx 32rpx 0 0;
  z-index: 101;
  transform: translateY(100%);
  transition: transform 0.3s ease;
}

.picker-dialog.show,
.delete-dialog.show {
  transform: translateY(0);
}

.picker-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid var(--color-border-light);
}

.picker-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.picker-close {
  font-size: 36rpx;
  color: var(--color-text-muted);
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.picker-options {
  padding: 16rpx 0;
  max-height: 60vh;
  overflow-y: auto;
}

.picker-option {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  transition: background-color 0.2s;
}

.picker-option:active {
  background-color: var(--color-bg-page);
}

.option-info {
  flex: 1;
  min-width: 0;
}

.option-label {
  display: block;
  font-size: 30rpx;
  color: var(--color-text-primary);
  margin-bottom: 8rpx;
}

.option-desc {
  font-size: 24rpx;
  color: var(--color-text-muted);
}

.option-check {
  font-size: 36rpx;
  color: #FF6B6B;
  margin-left: 20rpx;
  flex-shrink: 0;
}

.delete-header {
  padding: 32rpx;
  border-bottom: 1rpx solid var(--color-border-light);
}

.delete-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #DC2626;
}

.dark .delete-title {
  color: #FCA5A5;
}

.delete-content {
  padding: 32rpx;
  max-height: 60vh;
  overflow-y: auto;
}

.delete-step {
  margin-bottom: 20rpx;
}

.step-number {
  font-size: 24rpx;
  color: var(--color-text-muted);
  font-weight: 500;
}

.delete-desc {
  display: block;
  font-size: 28rpx;
  color: var(--color-text-primary);
  margin-bottom: 20rpx;
  line-height: 1.5;
}

.delete-list {
  margin-bottom: 20rpx;
}

.delete-list-item {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
}

.delete-icon {
  font-size: 24rpx;
  color: #10B981;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.delete-list-item text:last-child {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.5;
}

.delete-note {
  font-size: 24rpx;
  color: #F59E0B;
  line-height: 1.5;
}

.dark .delete-note {
  color: #FCD34D;
}

.delete-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  border: 2rpx solid var(--color-border-light);
  border-radius: var(--radius-lg);
  font-size: 28rpx;
  color: var(--color-text-primary);
  box-sizing: border-box;
}

.delete-actions {
  display: flex;
  gap: 20rpx;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.delete-btn {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-lg);
  font-size: 28rpx;
  transition: opacity 0.2s;
}

.delete-btn:active {
  opacity: 0.8;
}

.delete-btn.cancel {
  background-color: var(--color-bg-page);
  color: var(--color-text-secondary);
}

.delete-btn.next {
  background-color: #FF6B6B;
  color: #FFFFFF;
}

.delete-btn.confirm {
  background-color: #DC2626;
  color: #FFFFFF;
}
