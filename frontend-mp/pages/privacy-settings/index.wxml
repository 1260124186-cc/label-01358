<page-meta page-style="background-color: {{darkMode ? '#0F1117' : '#F8F9FA'}}; color: {{darkMode ? '#E8ECF1' : '#2C3E50'}}"/>
<view class="page {{darkMode ? 'dark' : ''}}">
  <view class="content">

    <view class="section-title">个人信息展示</view>
    <view class="settings-card">

      <view class="setting-item" bindtap="onPhoneDisplayTap">
        <view class="setting-left">
          <view class="setting-icon" style="background-color: #DBEAFE; color: #3B82F6;">
            📱
          </view>
          <view class="setting-info">
            <text class="setting-label">手机号展示方式</text>
            <text class="setting-desc">控制您的手机号在个人主页的展示方式</text>
          </view>
        </view>
        <view class="setting-right">
          <text class="setting-value">{{privacySettings.phoneDisplayMode === 'hidden' ? '完全隐藏' : (privacySettings.phoneDisplayMode === 'masked' ? '脱敏展示' : '登录可见')}}</text>
          <text class="setting-arrow">›</text>
        </view>
      </view>

      <view class="setting-item">
        <view class="setting-left">
          <view class="setting-icon" style="background-color: #D1FAE5; color: #10B981;">
            ✓
          </view>
          <view class="setting-info">
            <text class="setting-label">展示实名认证标识</text>
            <text class="setting-desc">在个人主页展示已实名认证的标识</text>
          </view>
        </view>
        <switch
          class="setting-switch"
          checked="{{privacySettings.showRealNameBadge}}"
          color="#FF6B6B"
          bindchange="onRealNameBadgeChange"
        />
      </view>

      <view class="setting-item no-border">
        <view class="setting-left">
          <view class="setting-icon" style="background-color: #FEF3C7; color: #F59E0B;">
            💬
          </view>
          <view class="setting-info">
            <text class="setting-label">允许被私信</text>
            <text class="setting-desc">关闭后其他用户将无法向您发送私信</text>
          </view>
        </view>
        <switch
          class="setting-switch"
          checked="{{privacySettings.allowPrivateMessage}}"
          color="#FF6B6B"
          bindchange="onPrivateMessageChange"
        />
      </view>
    </view>

    <view class="section-title">发布内容设置</view>
    <view class="settings-card">

      <view class="setting-item" bindtap="onContactStrategyTap">
        <view class="setting-left">
          <view class="setting-icon" style="background-color: #E0E7FF; color: #6366F1;">
            📞
          </view>
          <view class="setting-info">
            <text class="setting-label">默认联系方式</text>
            <text class="setting-desc">发布内容时默认使用的联系方式</text>
          </view>
        </view>
        <view class="setting-right">
          <text class="setting-value">{{privacySettings.defaultContactStrategy === 'account' ? '账号绑定手机' : '自定义'}}</text>
          <text class="setting-arrow">›</text>
        </view>
      </view>

      <view class="setting-item no-border" wx:if="{{privacySettings.defaultContactStrategy === 'custom'}}">
        <view class="setting-left">
          <view class="setting-icon" style="background-color: #E0E7FF; color: #6366F1;">
            ✏️
          </view>
          <view class="setting-info">
            <text class="setting-label">自定义手机号</text>
            <text class="setting-desc">发布内容时显示的联系电话</text>
          </view>
        </view>
        <input
          class="custom-phone-input"
          type="number"
          maxlength="11"
          placeholder="请输入手机号"
          value="{{privacySettings.customContactPhone}}"
          bindinput="onCustomPhoneInput"
          bindblur="onCustomPhoneBlur"
        />
      </view>
    </view>

    <view class="section-title">数据导出</view>
    <view class="settings-card">

      <view class="setting-item" bindtap="onExportData" data-type="publications">
        <view class="setting-left">
          <view class="setting-icon" style="background-color: #DBEAFE; color: #3B82F6;">
            📤
          </view>
          <view class="setting-info">
            <text class="setting-label">导出我的发布</text>
            <text class="setting-desc">导出您发布的所有内容为 JSON 文件</text>
          </view>
        </view>
        <text class="setting-arrow">›</text>
      </view>

      <view class="setting-item" bindtap="onExportData" data-type="favorites">
        <view class="setting-left">
          <view class="setting-icon" style="background-color: #FEF3C7; color: #F59E0B;">
            ⭐
          </view>
          <view class="setting-info">
            <text class="setting-label">导出我的收藏</text>
            <text class="setting-desc">导出您的所有收藏记录为 JSON 文件</text>
          </view>
        </view>
        <text class="setting-arrow">›</text>
      </view>

      <view class="setting-item no-border" bindtap="onExportData" data-type="points">
        <view class="setting-left">
          <view class="setting-icon" style="background-color: #D1FAE5; color: #10B981;">
            💰
          </view>
          <view class="setting-info">
            <text class="setting-label">导出积分流水</text>
            <text class="setting-desc">导出您的所有积分变动记录为 JSON 文件</text>
          </view>
        </view>
        <text class="setting-arrow">›</text>
      </view>
    </view>

    <view class="settings-card">
      <view class="setting-item highlight-item" bindtap="onExportData" data-type="all">
        <view class="setting-left">
          <view class="setting-icon" style="background-color: #FEE2E2; color: #EF4444;">
            📦
          </view>
          <view class="setting-info">
            <text class="setting-label">一键导出全部数据</text>
            <text class="setting-desc">导出您的所有个人数据为 JSON 文件</text>
          </view>
        </view>
        <text class="setting-arrow">›</text>
      </view>
    </view>

    <view class="section-title">账号管理</view>
    <view class="settings-card">

      <view class="setting-item" bindtap="onBlacklistTap">
        <view class="setting-left">
          <view class="setting-icon" style="background-color: #FEE2E2; color: #EF4444;">
            🚫
          </view>
          <view class="setting-info">
            <text class="setting-label">黑名单管理</text>
            <text class="setting-desc">管理您的黑名单用户列表</text>
          </view>
        </view>
        <view class="setting-right">
          <text class="setting-value" wx:if="{{blacklistCount > 0}}">{{blacklistCount}}人</text>
          <text class="setting-arrow">›</text>
        </view>
      </view>

      <view class="setting-item danger-item no-border" bindtap="onDeleteAccountTap">
        <view class="setting-left">
          <view class="setting-icon" style="background-color: #FEF2F2; color: #DC2626;">
            🗑
          </view>
          <view class="setting-info">
            <text class="setting-label">注销账号</text>
            <text class="setting-desc">清除所有个人数据，保留匿名化统计</text>
          </view>
        </view>
        <text class="setting-arrow">›</text>
      </view>
    </view>

    <view class="tip-card">
      <text class="tip-title">💡 隐私提示</text>
      <text class="tip-content">我们重视您的隐私安全。您可以随时在此页面调整隐私设置、导出个人数据或注销账号。注销账号后，您的个人数据将被永久清除，但匿名化的统计数据将被保留用于平台运营分析。</text>
    </view>
  </view>

  <view class="picker-mask" wx:if="{{showPhonePicker}}" bindtap="onClosePhonePicker"></view>
  <view class="picker-dialog {{showPhonePicker ? 'show' : ''}}">
    <view class="picker-header">
      <text class="picker-title">手机号展示方式</text>
      <view class="picker-close" bindtap="onClosePhonePicker">✕</view>
    </view>
    <view class="picker-options">
      <view
        class="picker-option {{privacySettings.phoneDisplayMode === item.value ? 'active' : ''}}"
        wx:for="{{phoneDisplayOptions}}"
        wx:key="value"
        bindtap="onPhoneOptionSelect"
        data-value="{{item.value}}"
      >
        <view class="option-info">
          <text class="option-label">{{item.label}}</text>
          <text class="option-desc">{{item.desc}}</text>
        </view>
        <view class="option-check" wx:if="{{privacySettings.phoneDisplayMode === item.value}}">✓</view>
      </view>
    </view>
  </view>

  <view class="picker-mask" wx:if="{{showContactPicker}}" bindtap="onCloseContactPicker"></view>
  <view class="picker-dialog {{showContactPicker ? 'show' : ''}}">
    <view class="picker-header">
      <text class="picker-title">默认联系方式</text>
      <view class="picker-close" bindtap="onCloseContactPicker">✕</view>
    </view>
    <view class="picker-options">
      <view
        class="picker-option {{privacySettings.defaultContactStrategy === item.value ? 'active' : ''}}"
        wx:for="{{contactStrategyOptions}}"
        wx:key="value"
        bindtap="onContactOptionSelect"
        data-value="{{item.value}}"
      >
        <view class="option-info">
          <text class="option-label">{{item.label}}</text>
          <text class="option-desc">{{item.desc}}</text>
        </view>
        <view class="option-check" wx:if="{{privacySettings.defaultContactStrategy === item.value}}">✓</view>
      </view>
    </view>
  </view>

  <view class="delete-mask" wx:if="{{showDeleteConfirm}}" bindtap="onCloseDeleteConfirm"></view>
  <view class="delete-dialog {{showDeleteConfirm ? 'show' : ''}}">
    <view class="delete-header">
      <text class="delete-title">⚠️ 账号注销</text>
    </view>

    <view class="delete-content" wx:if="{{deleteStep === 1}}">
      <view class="delete-step">
        <text class="step-number">1 / 3</text>
      </view>
      <text class="delete-desc">注销账号将清除以下数据：</text>
      <view class="delete-list">
        <view class="delete-list-item">
          <text class="delete-icon">✓</text>
          <text>个人资料与实名认证信息</text>
        </view>
        <view class="delete-list-item">
          <text class="delete-icon">✓</text>
          <text>所有发布的内容</text>
        </view>
        <view class="delete-list-item">
          <text class="delete-icon">✓</text>
          <text>收藏记录与浏览历史</text>
        </view>
        <view class="delete-list-item">
          <text class="delete-icon">✓</text>
          <text>积分与积分流水记录</text>
        </view>
        <view class="delete-list-item">
          <text class="delete-icon">✓</text>
          <text>黑名单设置</text>
        </view>
      </view>
      <text class="delete-note">* 匿名化统计数据将被保留用于平台运营分析</text>
    </view>

    <view class="delete-content" wx:if="{{deleteStep === 2}}">
      <view class="delete-step">
        <text class="step-number">2 / 3</text>
      </view>
      <text class="delete-desc">注销账号后：</text>
      <view class="delete-list">
        <view class="delete-list-item">
          <text class="delete-icon">•</text>
          <text>您的账号将无法恢复</text>
        </view>
        <view class="delete-list-item">
          <text class="delete-icon">•</text>
          <text>您发布的内容将被全部删除</text>
        </view>
        <view class="delete-list-item">
          <text class="delete-icon">•</text>
          <text>您的积分将被清零且无法恢复</text>
        </view>
        <view class="delete-list-item">
          <text class="delete-icon">•</text>
          <text>如需重新使用，需重新注册</text>
        </view>
      </view>
    </view>

    <view class="delete-content" wx:if="{{deleteStep === 3}}">
      <view class="delete-step">
        <text class="step-number">3 / 3</text>
      </view>
      <text class="delete-desc">请输入"注销账号"确认操作：</text>
      <input
        class="delete-input"
        placeholder="请输入 注销账号"
        value="{{deleteConfirmText}}"
        bindinput="onDeleteConfirmInput"
      />
    </view>

    <view class="delete-actions">
      <view class="delete-btn cancel" bindtap="onCloseDeleteConfirm" wx:if="{{deleteStep === 1}}">
        <text>取消</text>
      </view>
      <view class="delete-btn cancel" bindtap="onCloseDeleteConfirm" wx:if="{{deleteStep > 1}}">
        <text>取消</text>
      </view>
      <view class="delete-btn next" bindtap="onDeleteStep1Next" wx:if="{{deleteStep === 1}}">
        <text>我已知晓，继续</text>
      </view>
      <view class="delete-btn next" bindtap="onDeleteStep2Next" wx:if="{{deleteStep === 2}}">
        <text>继续下一步</text>
      </view>
      <view class="delete-btn confirm" bindtap="onConfirmDelete" wx:if="{{deleteStep === 3}}">
        <text>确认注销</text>
      </view>
    </view>
  </view>
</view>
