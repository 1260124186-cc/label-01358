.page {
  min-height: 100vh;
  background-color: var(--color-bg-page);
}

.header-section {
  position: relative;
  padding: 40rpx 32rpx 32rpx;
  overflow: hidden;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 300rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 50%, #FFB3B3 100%);
  border-radius: 0 0 48rpx 48rpx;
}

.header-content {
  position: relative;
  z-index: 1;
}

.header-title {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.header-icon {
  font-size: 48rpx;
  margin-right: 16rpx;
}

.header-text {
  font-size: 40rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.header-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-left: 64rpx;
}

.stats-section {
  padding: 0 24rpx;
  margin-top: -20rpx;
  position: relative;
  z-index: 2;
}

.stats-card {
  display: flex;
  align-items: center;
  justify-content: space-around;
  background: var(--color-bg-card);
  border-radius: 24rpx;
  padding: 32rpx 24rpx;
  box-shadow: var(--shadow-card);
  margin-bottom: 24rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  margin-bottom: 8rpx;
}

.stat-item.highlight .stat-value {
  color: var(--color-primary);
}

.stat-label {
  font-size: 24rpx;
  color: var(--color-text-muted);
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: var(--color-border-light);
}

.level-stats {
  display: flex;
  gap: 16rpx;
}

.level-stat {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 12rpx;
  border-radius: 16rpx;
  background: var(--color-bg-card);
  box-shadow: var(--shadow-card);
}

.level-stat.excellent {
  background: linear-gradient(135deg, #FEE2E2 0%, #FECACA 100%);
}

.level-stat.high {
  background: linear-gradient(135deg, #FEF3C7 0%, #FDE68A 100%);
}

.level-stat.medium {
  background: linear-gradient(135deg, #DBEAFE 0%, #BFDBFE 100%);
}

.level-stat.low {
  background: linear-gradient(135deg, #F3F4F6 0%, #E5E7EB 100%);
}

.level-icon {
  font-size: 32rpx;
  margin-bottom: 8rpx;
}

.level-count {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  margin-bottom: 4rpx;
}

.level-label {
  font-size: 20rpx;
  color: var(--color-text-secondary);
}

.filter-section {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: var(--color-bg-card);
  margin: 24rpx;
  border-radius: 20rpx;
  box-shadow: var(--shadow-card);
}

.tab-scroll {
  flex: 1;
  white-space: nowrap;
}

.tabs {
  display: inline-flex;
  gap: 12rpx;
}

.tab {
  padding: 12rpx 24rpx;
  border-radius: 20rpx;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  background: var(--color-bg-input);
  white-space: nowrap;
  transition: all var(--transition-fast);
}

.tab.active {
  background: var(--color-primary);
  color: #FFFFFF;
  font-weight: 500;
}

.filter-actions {
  margin-left: 16rpx;
}

.sort-btn {
  display: flex;
  align-items: center;
  padding: 12rpx 20rpx;
  background: var(--color-bg-input);
  border-radius: 16rpx;
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.sort-btn > text {
  margin-right: 8rpx;
}

.sort-btn > text:last-child {
  margin-right: 0;
}

.filter-panel {
  margin: 0 24rpx 24rpx;
  padding: 24rpx;
  background: var(--color-bg-card);
  border-radius: 20rpx;
  box-shadow: var(--shadow-card);
}

.filter-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 20rpx;
}

.score-options {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.score-option {
  padding: 16rpx 32rpx;
  border-radius: 24rpx;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  background: var(--color-bg-input);
  border: 2rpx solid transparent;
  transition: all var(--transition-fast);
}

.score-option.active {
  background: rgba(255, 107, 107, 0.1);
  border-color: var(--color-primary);
  color: var(--color-primary);
  font-weight: 500;
}

.match-list {
  height: calc(100vh - 500rpx);
  padding: 0 24rpx 120rpx;
}

.matches-container {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.match-card {
  background: var(--color-bg-card);
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: var(--shadow-card);
  transition: all var(--transition-fast);
}

.match-card:active {
  transform: scale(0.99);
}

.match-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.match-level {
  display: flex;
  align-items: center;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.match-level > text {
  margin-right: 8rpx;
}

.match-level > text:last-child {
  margin-right: 0;
}

.match-score {
  text-align: right;
}

.score-value {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--color-primary);
  line-height: 1;
}

.score-label {
  font-size: 22rpx;
  color: var(--color-text-muted);
  display: block;
  margin-top: 4rpx;
}

.match-items {
  display: flex;
  align-items: stretch;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.match-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding: 16rpx;
  border-radius: 16rpx;
  position: relative;
}

.match-item.lost {
  background: linear-gradient(135deg, #FEF2F2 0%, #FEE2E2 100%);
}

.match-item.found {
  background: linear-gradient(135deg, #ECFDF5 0%, #D1FAE5 100%);
}

.item-type-badge {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  font-size: 20rpx;
  font-weight: 500;
  z-index: 1;
}

.item-type-badge.lost {
  background: #EF4444;
  color: #FFFFFF;
}

.item-type-badge.found {
  background: #10B981;
  color: #FFFFFF;
}

.item-image {
  width: 100%;
  height: 140rpx;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
}

.item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.item-title {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
}

.item-desc {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  flex: 1;
}

.item-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.meta-tag {
  padding: 4rpx 12rpx;
  background: rgba(255, 255, 255, 0.8);
  border-radius: 8rpx;
  font-size: 20rpx;
  color: var(--color-text-secondary);
}

.match-vs {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 60rpx;
  flex-shrink: 0;
}

.vs-text {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--color-primary);
}

.vs-icon {
  font-size: 28rpx;
  margin-top: 4rpx;
}

.match-tags {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx;
  background: var(--color-bg-input);
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.match-tag-label {
  font-size: 24rpx;
  color: var(--color-text-muted);
  margin-right: 8rpx;
}

.match-tag {
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.match-tag.color {
  background: rgba(59, 130, 246, 0.15);
  color: #3B82F6;
}

.match-tag.brand {
  background: rgba(16, 185, 129, 0.15);
  color: #10B981;
}

.match-actions {
  display: flex;
  gap: 12rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  background: var(--color-bg-input);
  color: var(--color-text-primary);
  transition: all var(--transition-fast);
}

.action-btn:active {
  transform: scale(0.96);
}

.action-btn > text {
  margin-right: 8rpx;
}

.action-btn > text:last-child {
  margin-right: 0;
}

.action-btn.compare {
  background: linear-gradient(135deg, #6366F1 0%, #8B5CF6 100%);
  color: #FFFFFF;
}

.action-btn.contact-lost {
  background: linear-gradient(135deg, #F87171 0%, #EF4444 100%);
  color: #FFFFFF;
}

.action-btn.contact-found {
  background: linear-gradient(135deg, #34D399 0%, #10B981 100%);
  color: #FFFFFF;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: var(--color-text-muted);
  text-align: center;
  margin-bottom: 32rpx;
}

.empty-actions {
  display: flex;
  gap: 24rpx;
}

.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid var(--color-border);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 26rpx;
  color: var(--color-text-muted);
}

.quick-actions {
  position: fixed;
  bottom: 120rpx;
  right: 32rpx;
  z-index: 100;
}

.quick-btn {
  width: 112rpx;
  height: 112rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  border-radius: 50%;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 107, 0.4);
  color: #FFFFFF;
  transition: all var(--transition-fast);
}

.quick-btn:active {
  transform: scale(0.95);
}

.quick-icon {
  font-size: 40rpx;
  line-height: 1;
  margin-bottom: 4rpx;
}

.quick-text {
  font-size: 20rpx;
  font-weight: 500;
}

.page.dark .match-item.lost {
  background: linear-gradient(135deg, rgba(239, 68, 68, 0.2) 0%, rgba(239, 68, 68, 0.1) 100%);
}

.page.dark .match-item.found {
  background: linear-gradient(135deg, rgba(16, 185, 129, 0.2) 0%, rgba(16, 185, 129, 0.1) 100%);
}

.page.dark .meta-tag {
  background: rgba(0, 0, 0, 0.3);
}

.page.dark .level-stat.excellent {
  background: linear-gradient(135deg, rgba(239, 68, 68, 0.2) 0%, rgba(239, 68, 68, 0.1) 100%);
}

.page.dark .level-stat.high {
  background: linear-gradient(135deg, rgba(245, 158, 11, 0.2) 0%, rgba(245, 158, 11, 0.1) 100%);
}

.page.dark .level-stat.medium {
  background: linear-gradient(135deg, rgba(59, 130, 246, 0.2) 0%, rgba(59, 130, 246, 0.1) 100%);
}

.page.dark .level-stat.low {
  background: linear-gradient(135deg, rgba(107, 114, 128, 0.2) 0%, rgba(107, 114, 128, 0.1) 100%);
}
