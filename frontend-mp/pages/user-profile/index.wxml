<page-meta page-style="background-color: {{darkMode ? '#0F1117' : '#F8F9FA'}}; color: {{darkMode ? '#E8ECF1' : '#2C3E50'}}"/>
<view class="page {{darkMode ? 'dark' : ''}}" wx:if="{{userInfo}}">
  <!-- 用户头部信息 -->
  <view class="user-header">
    <view class="header-bg"></view>
    <view class="user-info">
      <view class="avatar-wrap" bindtap="onAvatarTap">
        <image class="avatar" src="{{userInfo.avatarUrl || '/assets/images/default-avatar.png'}}" mode="aspectFill"/>
        <view class="avatar-edit" wx:if="{{isCurrentUser}}">
          <text class="edit-icon">📷</text>
        </view>
      </view>
      <view class="user-meta">
        <view class="name-row">
          <text class="nickname">{{userInfo.nickName}}</text>
          <view class="verify-badge" wx:if="{{userInfo.realNameVerified}}">
            <text class="verify-icon">✓</text>
            <text class="verify-text">已认证</text>
          </view>
          <view class="verify-badge pending" wx:elif="{{userInfo.realNameInfo && userInfo.realNameInfo.status === 'pending'}}">
            <text class="verify-icon">⏳</text>
            <text class="verify-text">审核中</text>
          </view>
        </view>
        <view class="user-extra">
          <text class="user-id" wx:if="{{userInfo.realNameInfo && userInfo.realNameInfo.department}}">
            🎓 {{userInfo.realNameInfo.department}}
          </text>
        </view>
        <view class="user-signature" wx:if="{{userInfo.signature}}">
          <text>{{userInfo.signature}}</text>
        </view>
      </view>
      <view class="more-btn" wx:if="{{!isCurrentUser}}" bindtap="onMoreTap">
        <text class="more-icon">⋯</text>
      </view>
    </view>

    <!-- 信用评分 -->
    <view class="credit-section" bindtap="onCreditDetail">
      <view class="credit-info">
        <text class="credit-label">信用评分</text>
        <view class="credit-score-row">
          <text class="credit-score" style="color: {{userInfo.creditLevel.color}};">{{userInfo.creditScore}}</text>
          <view class="credit-level" style="background: {{userInfo.creditLevel.color}};">
            <text class="level-text">{{userInfo.creditLevel.level}}</text>
          </view>
        </view>
        <text class="credit-level-label" style="color: {{userInfo.creditLevel.color}};">{{userInfo.creditLevel.label}}</text>
      </view>
      <view class="credit-stats">
        <view class="stat-item">
          <text class="stat-value">{{userStats.totalPublications}}</text>
          <text class="stat-label">发布</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <text class="stat-value">{{userStats.completedDeals}}</text>
          <text class="stat-label">完成</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <text class="stat-value">{{userStats.successRate}}%</text>
          <text class="stat-label">成功率</text>
        </view>
      </view>
    </view>

    <!-- 操作按钮 -->
    <view class="action-buttons" wx:if="{{isCurrentUser}}">
      <btn type="secondary" size="medium" bind:click="onEditProfile">
        <text class="btn-icon">✏️</text>
        编辑资料
      </btn>
      <btn type="primary" size="medium" bind:click="onVerifyIdentity" wx:if="{{!userInfo.realNameVerified}}">
        <text class="btn-icon">🎓</text>
        实名认证
      </btn>
    </view>

    <!-- 黑名单提示 -->
    <view class="blacklist-tip" wx:if="{{isBlacklisted && !isCurrentUser}}">
      <text class="tip-icon">🚫</text>
      <text class="tip-text">该用户已被您加入黑名单</text>
    </view>
  </view>

  <!-- Tab切换 -->
  <view class="tab-bar">
    <view 
      class="tab-item {{activeTab === tab.value ? 'active' : ''}}" 
      wx:for="{{tabs}}" 
      wx:key="value"
      bindtap="onTabChange"
      data-value="{{tab.value}}"
    >
      <text class="tab-text">{{tab.label}}</text>
      <view class="tab-indicator" wx:if="{{activeTab === tab.value}}"></view>
    </view>
  </view>

  <!-- 内容列表 -->
  <scroll-view class="content-scroll" scroll-y>
    <!-- 失物招领 -->
    <block wx:if="{{activeTab === 'all' || activeTab === 'lostFound'}}">
      <view class="section-title" wx:if="{{publications.lostFound.length > 0}}">
        <text class="title-text">失物招领</text>
        <text class="title-count">{{publications.lostFound.length}}</text>
      </view>
      <view class="item-list">
        <view 
          class="item-card" 
          wx:for="{{publications.lostFound}}" 
          wx:key="id"
          bindtap="onItemTap"
          data-type="lostFound"
          data-id="{{item.id}}"
        >
          <image class="item-image" src="{{item.images && item.images[0] ? item.images[0] : '/assets/images/default-banner.png'}}" mode="aspectFill"/>
          <view class="item-content">
            <view class="item-header">
              <text class="item-type {{item.type === 'lost' ? 'lost' : 'found'}}">{{item.type === 'lost' ? '寻物' : '招领'}}</text>
              <text class="item-title">{{item.title}}</text>
            </view>
            <text class="item-desc">{{item.description}}</text>
            <view class="item-footer">
              <text class="item-time">{{item.timeText}}</text>
              <text class="item-status" wx:if="{{item.status === 'resolved'}}">已解决</text>
              <text class="item-status active" wx:elif="{{item.status === 'active'}}">进行中</text>
            </view>
          </view>
        </view>
      </view>
    </block>

    <!-- 二手市场 -->
    <block wx:if="{{activeTab === 'all' || activeTab === 'market'}}">
      <view class="section-title" wx:if="{{publications.market.length > 0}}">
        <text class="title-text">二手市场</text>
        <text class="title-count">{{publications.market.length}}</text>
      </view>
      <view class="item-grid">
        <view 
          class="grid-item" 
          wx:for="{{publications.market}}" 
          wx:key="id"
          bindtap="onItemTap"
          data-type="market"
          data-id="{{item.id}}"
        >
          <image class="grid-image" src="{{item.images && item.images[0] ? item.images[0] : '/assets/images/default-banner.png'}}" mode="aspectFill"/>
          <view class="grid-info">
            <text class="grid-title">{{item.title}}</text>
            <text class="grid-price">¥{{item.price}}</text>
            <view class="grid-footer">
              <text class="grid-time">{{item.timeText}}</text>
              <text class="grid-status" wx:if="{{item.status === 'sold'}}">已售出</text>
              <text class="grid-status selling" wx:elif="{{item.status === 'selling'}}">出售中</text>
            </view>
          </view>
        </view>
      </view>
    </block>

    <!-- 论坛帖子 -->
    <block wx:if="{{activeTab === 'all' || activeTab === 'forum'}}">
      <view class="section-title" wx:if="{{publications.forum.length > 0}}">
        <text class="title-text">论坛帖子</text>
        <text class="title-count">{{publications.forum.length}}</text>
      </view>
      <view class="item-list">
        <view 
          class="item-card forum-card" 
          wx:for="{{publications.forum}}" 
          wx:key="id"
          bindtap="onItemTap"
          data-type="forum"
          data-id="{{item.id}}"
        >
          <view class="item-content">
            <text class="item-title">{{item.title}}</text>
            <text class="item-desc">{{item.content}}</text>
            <view class="item-footer">
              <text class="item-time">{{item.timeText}}</text>
              <view class="item-meta">
                <text class="meta-item">👁 {{item.views || 0}}</text>
                <text class="meta-item">💬 {{item.commentCount || 0}}</text>
                <text class="meta-item">❤️ {{item.likes || 0}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>
    </block>

    <!-- 校园风景 -->
    <block wx:if="{{activeTab === 'all' || activeTab === 'scenery'}}">
      <view class="section-title" wx:if="{{publications.scenery.length > 0}}">
        <text class="title-text">校园风景</text>
        <text class="title-count">{{publications.scenery.length}}</text>
      </view>
      <view class="item-grid">
        <view 
          class="grid-item scenery-grid" 
          wx:for="{{publications.scenery}}" 
          wx:key="id"
          bindtap="onItemTap"
          data-type="scenery"
          data-id="{{item.id}}"
        >
          <image class="grid-image" src="{{item.image || '/assets/images/default-scenery.png'}}" mode="aspectFill"/>
          <view class="scenery-overlay">
            <text class="scenery-title">{{item.title}}</text>
            <view class="scenery-meta">
              <text class="meta-item">❤️ {{item.likes || 0}}</text>
              <text class="meta-item">💬 {{item.commentCount || 0}}</text>
            </view>
          </view>
        </view>
      </view>
    </block>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{
      (activeTab === 'all' && publications.lostFound.length === 0 && publications.market.length === 0 && publications.forum.length === 0 && publications.scenery.length === 0) ||
      (activeTab === 'lostFound' && publications.lostFound.length === 0) ||
      (activeTab === 'market' && publications.market.length === 0) ||
      (activeTab === 'forum' && publications.forum.length === 0) ||
      (activeTab === 'scenery' && publications.scenery.length === 0)
    }}">
      <text class="empty-icon">📭</text>
      <text class="empty-text">暂无发布内容</text>
    </view>

    <view class="bottom-space"></view>
  </scroll-view>

  <!-- 操作菜单 -->
  <view class="action-sheet-mask" wx:if="{{showActionSheet}}" bindtap="onActionClose"></view>
  <view class="action-sheet {{showActionSheet ? 'show' : ''}}">
    <view class="sheet-handle"></view>
    <view class="sheet-title">
      <text>操作</text>
    </view>
    <view 
      class="sheet-item {{item.value === 'report' ? 'danger' : ''}}" 
      wx:for="{{actionSheetItems}}" 
      wx:key="value"
      bindtap="onActionSelect"
      data-value="{{item.value}}"
    >
      <text class="sheet-item-text">{{item.label}}</text>
    </view>
    <view class="sheet-item cancel" bindtap="onActionClose">
      <text class="sheet-item-text">取消</text>
    </view>
  </view>
</view>

<!-- 加载状态 -->
<view class="loading-state" wx:if="{{loading}}">
  <text class="loading-icon">⏳</text>
  <text class="loading-text">加载中...</text>
</view>
