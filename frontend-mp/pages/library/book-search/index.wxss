.page {
  min-height: 100vh;
  background: var(--color-bg-page);
  display: flex;
  flex-direction: column;
}

.page.dark {
  --color-bg-page: #0F1117;
  --color-bg-card: #1A1D29;
  --color-bg-secondary: #252936;
  --color-text-primary: #E8ECF1;
  --color-text-secondary: #9CA3AF;
  --color-text-placeholder: #6B7280;
  --color-border: #2D3142;
  --color-primary: #FF6B6B;
  --color-primary-dark: #E55555;
}

.top-bar {
  display: flex;
  align-items: center;
  padding: 20rpx 32rpx;
  background: var(--color-bg-card, #FFFFFF);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.search-box {
  flex: 1;
  display: flex;
  align-items: center;
  background: var(--color-bg-secondary, #F3F4F6);
  border-radius: 40rpx;
  padding: 16rpx 24rpx;
  gap: 12rpx;
}

.search-icon {
  font-size: 28rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--color-text-primary, #2C3E50);
}

.search-placeholder {
  color: var(--color-text-placeholder, #9CA3AF);
}

.search-clear {
  font-size: 24rpx;
  color: var(--color-text-secondary, #9CA3AF);
  padding: 4rpx 8rpx;
}

.category-tabs {
  white-space: nowrap;
  padding: 20rpx 0;
  background: var(--color-bg-card, #FFFFFF);
  border-bottom: 1rpx solid var(--color-border, #E5E7EB);
}

.category-tabs-inner {
  display: inline-flex;
  padding: 0 24rpx;
  gap: 16rpx;
}

.category-tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 28rpx;
  background: var(--color-bg-secondary, #F3F4F6);
  border-radius: 20rpx;
  gap: 8rpx;
  transition: all 0.3s ease;
}

.category-tab-item.active {
  background: linear-gradient(135deg, var(--color-primary, #FF6B6B), var(--color-primary-dark, #E55555));
}

.category-tab-item .tab-icon {
  font-size: 36rpx;
}

.category-tab-item .tab-label {
  font-size: 24rpx;
  color: var(--color-text-secondary, #6B7280);
}

.category-tab-item.active .tab-label {
  color: #FFFFFF;
  font-weight: 500;
}

.book-list {
  flex: 1;
  padding: 20rpx 32rpx 40rpx;
}

.book-list-inner {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.book-card {
  display: flex;
  background: var(--color-bg-card, #FFFFFF);
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  gap: 24rpx;
  padding: 24rpx;
}

.book-cover-wrap {
  position: relative;
  width: 180rpx;
  flex-shrink: 0;
}

.book-cover {
  width: 180rpx;
  height: 240rpx;
  border-radius: 12rpx;
}

.status-badge {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  padding: 6rpx 12rpx;
  border-radius: 16rpx;
}

.status-text {
  font-size: 20rpx;
  color: #FFFFFF;
  font-weight: 500;
}

.book-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.book-title-row {
  margin-bottom: 12rpx;
}

.book-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary, #2C3E50);
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.book-author,
.book-publisher {
  margin-bottom: 8rpx;
  font-size: 24rpx;
  display: flex;
}

.info-label {
  color: var(--color-text-secondary, #9CA3AF);
  flex-shrink: 0;
}

.info-value {
  color: var(--color-text-primary, #2C3E50);
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.book-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin: 12rpx 0;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.meta-icon {
  font-size: 24rpx;
}

.meta-text {
  font-size: 22rpx;
  color: var(--color-text-secondary, #6B7280);
}

.book-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 12rpx;
  border-top: 1rpx solid var(--color-border, #E5E7EB);
  margin-top: auto;
}

.call-number {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.call-label {
  font-size: 22rpx;
  color: var(--color-text-secondary, #9CA3AF);
  flex-shrink: 0;
}

.call-value {
  font-size: 22rpx;
  color: var(--color-primary, #FF6B6B);
  font-weight: 500;
  font-family: monospace;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.detail-btn {
  font-size: 24rpx;
  color: var(--color-primary, #FF6B6B);
  font-weight: 500;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 255, 255, 0.8);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.page.dark .loading-overlay {
  background: rgba(15, 17, 23, 0.8);
}

.loading-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid var(--color-bg-secondary, #E5E7EB);
  border-top-color: var(--color-primary, #FF6B6B);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: 26rpx;
  color: var(--color-text-secondary, #6B7280);
}
