<view class="page {{darkMode ? 'dark' : ''}} {{fontSizeClass}}">
  <view class="tab-bar">
    <view
      wx:for="{{tabs}}"
      wx:key="value"
      class="tab-item {{activeTab === item.value ? 'active' : ''}}"
      data-value="{{item.value}}"
      bindtap="onTabChange"
    >
      {{item.label}}
    </view>
  </view>

  <view class="tip-bar" wx:if="{{activeTab === 'upcoming' || hasTimeoutRecords}}">
    <text class="tip-icon">⏰</text>
    <text class="tip-text">{{timeoutTip}}</text>
  </view>

  <view class="content" wx:if="{{!loading}}">
    <view class="reservation-list">
      <view
        wx:for="{{reservationList}}"
        wx:key="id"
        class="reservation-card"
      >
        <view class="card-header">
          <view class="header-left">
            <text class="room-icon">📚</text>
            <view class="room-info">
              <text class="room-name">{{item.roomName}}</text>
              <text class="seat-number">{{item.seatNumber}}号座位</text>
            </view>
          </view>
          <view
            class="status-badge"
            style="background: {{item.statusColor}}20; color: {{item.statusColor}};"
          >
            <text class="status-icon">{{item.statusIcon}}</text>
            <text class="status-text">{{item.statusText}}</text>
          </view>
        </view>

        <view class="card-body">
          <view class="info-row">
            <view class="info-item">
              <text class="item-label">📅 日期</text>
              <text class="item-value">{{item.dateText}}</text>
            </view>
            <view class="info-item">
              <text class="item-label">⏱️ 时段</text>
              <text class="item-value highlight">{{item.timeSlotText}}</text>
            </view>
          </view>

          <view class="info-row time-detail">
            <view class="info-item">
              <text class="item-label">开始</text>
              <text class="item-value">{{item.startTimeText}}</text>
            </view>
            <view class="time-arrow">→</view>
            <view class="info-item">
              <text class="item-label">结束</text>
              <text class="item-value">{{item.endTimeText}}</text>
            </view>
          </view>

          <view class="detail-tags">
            <view wx:if="{{item.checkInTimeText}}" class="detail-tag success">
              签到时间：{{item.checkInTimeText}}
            </view>
            <view wx:if="{{item.checkOutTimeText}}" class="detail-tag primary">
              签退时间：{{item.checkOutTimeText}}
            </view>
            <view wx:if="{{item.isTimeout}}" class="detail-tag danger">
              ⚠️ 超时未签到已自动释放
            </view>
          </view>
        </view>

        <view class="card-footer" wx:if="{{item.canCheckIn || item.canCheckOut || item.canCancel}}">
          <view class="action-buttons">
            <view
              wx:if="{{item.canCancel}}"
              class="action-btn btn-secondary"
              data-id="{{item.id}}"
              bindtap="onCancelTap"
            >
              取消预约
            </view>
            <view
              wx:if="{{item.canCheckIn}}"
              class="action-btn btn-warning"
              data-id="{{item.id}}"
              bindtap="onCheckInTap"
            >
              立即签到
            </view>
            <view
              wx:if="{{item.canCheckOut}}"
              class="action-btn btn-primary"
              data-id="{{item.id}}"
              bindtap="onCheckOutTap"
            >
              立即签退
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="empty-state" wx:if="{{reservationList.length === 0}}">
      <view class="empty-icon">📭</view>
      <view class="empty-title">暂无预约记录</view>
      <view class="empty-desc">
        <text wx:if="{{activeTab === 'upcoming'}}">暂无即将开始的预约</text>
        <text wx:elif="{{activeTab === 'ongoing'}}">暂无进行中的预约</text>
        <text wx:else>暂无历史预约记录</text>
      </view>
    </view>
  </view>

  <view class="loading-state" wx:if="{{loading}}">
    <view class="loading-icon">⏳</view>
    <view class="loading-text">加载中...</view>
  </view>
</view>
