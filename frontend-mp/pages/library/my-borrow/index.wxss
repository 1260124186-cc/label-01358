.page {
  min-height: 100vh;
  background: var(--color-bg-page, #F8F9FA);
  display: flex;
  flex-direction: column;
}

.page.dark {
  --color-bg-page: #0F1117;
  --color-bg-card: #1A1D29;
  --color-bg-secondary: #252936;
  --color-bg-input: #262A3A;
  --color-text-primary: #E8ECF1;
  --color-text-secondary: #9CA3AF;
  --color-text-placeholder: #6B7280;
  --color-border: #2D3142;
}

.page-scroll {
  flex: 1;
  height: 100vh;
}

.stats-card {
  position: relative;
  margin: 24rpx 32rpx;
  padding: 32rpx 28rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 50%, #4ECDC4 100%);
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 107, 0.3);
  overflow: hidden;
}

.page.dark .stats-card {
  background: linear-gradient(135deg, #C04040 0%, #D06060 50%, #3A9E96 100%);
  box-shadow: 0 8rpx 24rpx rgba(192, 64, 64, 0.35);
}

.stats-bg-overlay {
  position: absolute;
  top: -50%;
  right: -30%;
  width: 300rpx;
  height: 300rpx;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.15) 0%, transparent 70%);
  border-radius: 50%;
}

.stats-grid {
  position: relative;
  display: flex;
  z-index: 1;
}

.stats-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 8rpx 0;
}

.stats-count {
  font-size: 48rpx;
  font-weight: 700;
  color: #FFFFFF;
  line-height: 1.2;
  margin-bottom: 8rpx;
}

.stats-count.overdue {
  color: #FFE082;
}

.stats-count.renew {
  color: #B2EBF2;
}

.stats-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
  font-weight: 500;
}

.tabs-wrap {
  margin: 0 32rpx 24rpx;
  background: var(--color-bg-card, #FFFFFF);
  border-radius: 20rpx;
  padding: 8rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.tabs-container {
  display: flex;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
  position: relative;
}

.tab-text {
  font-size: 28rpx;
  color: var(--color-text-secondary, #6B7280);
  font-weight: 500;
  transition: all 0.3s ease;
}

.tab-item.active .tab-text {
  color: var(--color-primary, #FF6B6B);
  font-weight: 600;
}

.tab-indicator {
  position: absolute;
  bottom: 8rpx;
  width: 48rpx;
  height: 6rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  border-radius: 3rpx;
}

.list-container {
  padding: 0 32rpx;
}

.borrow-card {
  background: var(--color-bg-card, #FFFFFF);
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  overflow: hidden;
}

.card-main {
  display: flex;
  padding: 28rpx;
  gap: 24rpx;
}

.book-cover {
  width: 160rpx;
  height: 220rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  background: var(--color-bg-secondary, #F3F4F6);
}

.book-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.book-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.book-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary, #2C3E50);
  line-height: 1.4;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.status-badge {
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.status-text {
  font-size: 22rpx;
  font-weight: 500;
}

.book-author {
  font-size: 24rpx;
  color: var(--color-text-secondary, #6B7280);
  margin-bottom: 12rpx;
}

.book-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.meta-icon {
  font-size: 22rpx;
}

.meta-text {
  font-size: 22rpx;
  color: var(--color-text-secondary, #6B7280);
}

.date-info {
  background: var(--color-bg-secondary, #F9FAFB);
  border-radius: 16rpx;
  padding: 16rpx 20rpx;
}

.page.dark .date-info {
  background: var(--color-bg-secondary, #252936);
}

.date-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.date-row:last-child {
  margin-bottom: 0;
}

.date-label {
  font-size: 24rpx;
  color: var(--color-text-secondary, #6B7280);
}

.date-value-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.date-value {
  font-size: 24rpx;
  color: var(--color-text-primary, #2C3E50);
  font-weight: 500;
}

.date-value.warning {
  color: #F59E0B;
}

.date-value.overdue {
  color: #EF4444;
}

.days-tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  background: rgba(59, 130, 246, 0.1);
  color: #3B82F6;
}

.days-tag.warning {
  background: rgba(245, 158, 11, 0.15);
  color: #F59E0B;
}

.days-tag.overdue {
  background: rgba(239, 68, 68, 0.1);
  color: #EF4444;
}

.overdue-fee {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 12rpx;
  padding: 12rpx 16rpx;
  background: rgba(239, 68, 68, 0.08);
  border-radius: 12rpx;
}

.fee-icon {
  font-size: 24rpx;
}

.fee-label {
  font-size: 24rpx;
  color: var(--color-text-secondary, #6B7280);
}

.fee-value {
  font-size: 26rpx;
  color: #EF4444;
  font-weight: 600;
}

.renew-info {
  margin-top: 12rpx;
}

.renew-text {
  font-size: 22rpx;
  color: #8B5CF6;
}

.card-footer {
  padding: 20rpx 28rpx 28rpx;
  border-top: 1rpx solid var(--color-border, #F0F0F0);
}

.renew-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 80rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  border-radius: 40rpx;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 107, 0.3);
  transition: all 0.3s ease;
}

.page.dark .renew-btn {
  background: linear-gradient(135deg, #C04040 0%, #D06060 100%);
  box-shadow: 0 4rpx 16rpx rgba(192, 64, 64, 0.35);
}

.renew-btn.disabled {
  background: var(--color-bg-secondary, #E5E7EB);
  box-shadow: none;
}

.renew-btn .btn-text {
  font-size: 28rpx;
  color: #FFFFFF;
  font-weight: 500;
}

.renew-btn.disabled .btn-text {
  color: var(--color-text-secondary, #9CA3AF);
}

.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
  gap: 20rpx;
}

.loading-spinner {
  width: 56rpx;
  height: 56rpx;
  border: 4rpx solid var(--color-bg-secondary, #E5E7EB);
  border-top-color: var(--color-primary, #FF6B6B);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: 26rpx;
  color: var(--color-text-secondary, #6B7280);
}

.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  gap: 20rpx;
}

.empty-icon {
  font-size: 100rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: var(--color-text-secondary, #9CA3AF);
}

.bottom-space {
  height: 60rpx;
}
