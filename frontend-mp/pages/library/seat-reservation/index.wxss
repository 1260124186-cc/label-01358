.page {
  min-height: 100vh;
  background: #F5F7FA;
  padding-bottom: 20rpx;
}

.page.dark {
  background: #1A1A1A;
}

.header {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  background: #FFFFFF;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  position: sticky;
  top: 0;
  z-index: 10;
}

.dark .header {
  background: #2A2A2A;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

.type-tabs {
  flex: 1;
  white-space: nowrap;
  overflow: hidden;
}

.type-tabs-inner {
  display: inline-flex;
  gap: 16rpx;
  padding-right: 16rpx;
}

.type-tab {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 24rpx;
  background: #F0F2F5;
  border-radius: 12rpx;
  transition: all 0.2s;
  flex-shrink: 0;
}

.dark .type-tab {
  background: #3A3A3A;
}

.type-tab.active {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
}

.type-icon {
  font-size: 28rpx;
  margin-bottom: 4rpx;
}

.type-label {
  font-size: 22rpx;
  color: #666;
}

.type-tab.active .type-label {
  color: #FFFFFF;
  font-weight: 600;
}

.header-right {
  margin-left: 16rpx;
  flex-shrink: 0;
}

.my-seats-btn {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: linear-gradient(135deg, #45B7D1 0%, #6DD5ED 100%);
  border-radius: 12rpx;
  gap: 8rpx;
}

.my-seats-icon {
  font-size: 28rpx;
}

.my-seats-text {
  font-size: 24rpx;
  color: #FFFFFF;
  font-weight: 600;
}

.content {
  padding: 24rpx;
}

.room-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.room-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
  transition: all 0.2s;
}

.dark .room-card {
  background: #2A2A2A;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.2);
}

.room-card:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.room-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.room-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 1;
}

.room-icon {
  font-size: 40rpx;
}

.room-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #1A1A1A;
}

.dark .room-name {
  color: #FFFFFF;
}

.room-floor {
  font-size: 24rpx;
  color: #FF6B6B;
  background: rgba(255, 107, 107, 0.1);
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-weight: 600;
}

.room-info {
  display: flex;
  gap: 40rpx;
  margin-bottom: 20rpx;
}

.info-item {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.info-label {
  font-size: 22rpx;
  color: #999;
}

.dark .info-label {
  color: #888;
}

.info-value {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

.dark .info-value {
  color: #CCCCCC;
}

.available-num {
  color: #10B981;
  font-weight: 700;
}

.total-num {
  color: #999;
}

.progress-wrap {
  margin-bottom: 20rpx;
}

.progress-bar {
  height: 12rpx;
  background: #F0F2F5;
  border-radius: 6rpx;
  overflow: hidden;
  margin-bottom: 8rpx;
}

.dark .progress-bar {
  background: #3A3A3A;
}

.progress-fill {
  height: 100%;
  border-radius: 6rpx;
  transition: width 0.3s;
}

.progress-text {
  font-size: 22rpx;
  color: #999;
}

.room-facilities {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.facility-tag {
  font-size: 22rpx;
  color: #666;
  background: #F5F7FA;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}

.dark .facility-tag {
  color: #AAA;
  background: #3A3A3A;
}

.empty-state,
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-icon,
.loading-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-text,
.loading-text {
  font-size: 28rpx;
  color: #999;
}

.dark .empty-text,
.dark .loading-text {
  color: #888;
}

.seat-modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
}

.seat-modal {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  top: 150rpx;
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  z-index: 101;
  display: flex;
  flex-direction: column;
  transform: translateY(100%);
  transition: transform 0.3s ease;
}

.dark .seat-modal {
  background: #2A2A2A;
}

.seat-modal.show {
  transform: translateY(0);
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #F0F2F5;
  flex-shrink: 0;
}

.dark .modal-header {
  border-bottom-color: #3A3A3A;
}

.modal-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.modal-icon {
  font-size: 40rpx;
}

.modal-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #1A1A1A;
}

.dark .modal-name {
  color: #FFFFFF;
}

.modal-close {
  font-size: 40rpx;
  color: #999;
  padding: 8rpx;
  line-height: 1;
}

.modal-body {
  flex: 1;
  overflow: auto;
  padding: 24rpx 32rpx;
}

.filter-section {
  margin-bottom: 32rpx;
}

.filter-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.dark .filter-title {
  color: #CCCCCC;
}

.date-tabs {
  white-space: nowrap;
  overflow: hidden;
}

.date-tabs-inner {
  display: inline-flex;
  gap: 16rpx;
}

.date-tab {
  display: inline-block;
  padding: 16rpx 28rpx;
  background: #F5F7FA;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #666;
  flex-shrink: 0;
}

.dark .date-tab {
  background: #3A3A3A;
  color: #AAA;
}

.date-tab.active {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  color: #FFFFFF;
  font-weight: 600;
}

.time-slot-list {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.time-slot {
  padding: 20rpx 16rpx;
  background: #F5F7FA;
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #666;
  text-align: center;
}

.dark .time-slot {
  background: #3A3A3A;
  color: #AAA;
}

.time-slot.active {
  background: linear-gradient(135deg, #45B7D1 0%, #6DD5ED 100%);
  color: #FFFFFF;
  font-weight: 600;
}

.seat-section {
  margin-top: 8rpx;
}

.section-title {
  margin-bottom: 16rpx;
}

.title-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A1A;
}

.dark .title-text {
  color: #FFFFFF;
}

.seat-legend {
  display: flex;
  justify-content: space-around;
  padding: 16rpx 0;
  margin-bottom: 12rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.legend-box {
  width: 28rpx;
  height: 28rpx;
  border-radius: 8rpx;
}

.legend-text {
  font-size: 22rpx;
  color: #666;
}

.dark .legend-text {
  color: #AAA;
}

.seat-available {
  background: #10B981;
}

.seat-occupied {
  background: #EF4444;
}

.seat-reserved {
  background: #F59E0B;
}

.seat-suspended {
  background: #9CA3AF;
}

.seat-tags-legend {
  display: flex;
  gap: 20rpx;
  justify-content: center;
  margin-bottom: 24rpx;
}

.legend-tag {
  font-size: 22rpx;
  color: #999;
}

.seat-map {
  background: #FAFBFC;
  border-radius: 16rpx;
  padding: 24rpx 16rpx;
  border: 1rpx solid #F0F2F5;
}

.dark .seat-map {
  background: #333;
  border-color: #3A3A3A;
}

.seat-stage {
  text-align: center;
  padding: 16rpx;
  background: linear-gradient(135deg, #E8F4FF 0%, #DBEAFE 100%);
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #3B82F6;
  font-weight: 600;
  margin-bottom: 32rpx;
}

.dark .seat-stage {
  background: linear-gradient(135deg, #1E3A5F 0%, #172554 100%);
  color: #60A5FA;
}

.seat-row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.row-label {
  width: 100rpx;
  flex-shrink: 0;
  font-size: 22rpx;
  color: #999;
  text-align: center;
}

.row-seats {
  flex: 1;
  display: flex;
  justify-content: center;
  flex-wrap: wrap;
  gap: 12rpx;
}

.seat-item {
  width: 72rpx;
  height: 80rpx;
  border-radius: 12rpx 12rpx 8rpx 8rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  transition: all 0.15s;
  border: 3rpx solid transparent;
}

.seat-item.available {
  background: #D1FAE5;
}

.dark .seat-item.available {
  background: #064E3B;
}

.seat-item.occupied {
  background: #FEE2E2;
}

.dark .seat-item.occupied {
  background: #7F1D1D;
}

.seat-item.reserved {
  background: #FEF3C7;
}

.dark .seat-item.reserved {
  background: #78350F;
}

.seat-item.suspended {
  background: #F3F4F6;
  opacity: 0.6;
}

.dark .seat-item.suspended {
  background: #374151;
}

.seat-item.selected {
  border-color: #FF6B6B;
  transform: translateY(-4rpx);
  box-shadow: 0 6rpx 16rpx rgba(255, 107, 107, 0.3);
}

.seat-number {
  font-size: 20rpx;
  font-weight: 700;
  color: #333;
}

.dark .seat-number {
  color: #FFF;
}

.seat-markers {
  position: absolute;
  top: -12rpx;
  right: -8rpx;
  display: flex;
  gap: 2rpx;
}

.marker {
  font-size: 16rpx;
  line-height: 1;
}

.modal-footer {
  border-top: 1rpx solid #F0F2F5;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  flex-shrink: 0;
}

.dark .modal-footer {
  border-top-color: #3A3A3A;
}

.selected-info {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.info-label {
  font-size: 26rpx;
  color: #999;
}

.dark .info-label {
  color: #888;
}

.info-value {
  font-size: 28rpx;
  font-weight: 700;
  color: #FF6B6B;
}

.info-tag {
  font-size: 22rpx;
  color: #45B7D1;
  background: rgba(69, 183, 209, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.info-placeholder {
  font-size: 26rpx;
  color: #CCC;
}

.dark .info-placeholder {
  color: #666;
}

.footer-actions {
  display: flex;
  gap: 20rpx;
}

.btn {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  transition: all 0.15s;
}

.btn:active {
  opacity: 0.85;
  transform: scale(0.98);
}

.btn-cancel {
  background: #F0F2F5;
  color: #666;
}

.dark .btn-cancel {
  background: #3A3A3A;
  color: #AAA;
}

.btn-confirm {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  color: #FFFFFF;
}

.btn-confirm.disabled {
  opacity: 0.5;
  pointer-events: none;
}
