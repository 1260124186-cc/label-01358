<page-meta page-style="background-color: {{darkMode ? '#0F1117' : '#F8F9FA'}}; color: {{darkMode ? '#E8ECF1' : '#2C3E50'}}"/>
<view class="page {{darkMode ? 'dark' : ''}}">
  <scroll-view class="page-scroll" scroll-y="{{true}}" enhanced="{{true}}" show-scrollbar="{{false}}">
    <view class="book-hero">
      <view class="hero-bg" style="background-image: url('{{book.cover}}');"></view>
      <view class="hero-overlay"></view>
      <view class="hero-content">
        <image class="book-cover-large" src="{{book.cover}}" mode="aspectFill" />
        <view class="hero-info">
          <view class="hero-tags">
            <view class="hero-tag status-tag" style="background: {{book.statusInfo.color}};">
              <text class="tag-text">{{book.statusInfo.label}}</text>
            </view>
            <view class="hero-tag category-tag">
              <text class="tag-icon">{{book.categoryIcon}}</text>
              <text class="tag-text">{{book.categoryLabel}}</text>
            </view>
          </view>
          <text class="hero-title">{{book.title}}</text>
          <text class="hero-subtitle" wx:if="{{book.subtitle}}">{{book.subtitle}}</text>
          <view class="hero-stats">
            <view class="stat-item">
              <text class="stat-icon">👁️</text>
              <text class="stat-text">{{book.views || 0}} 浏览</text>
            </view>
            <view class="stat-item">
              <text class="stat-icon">📖</text>
              <text class="stat-text">{{book.pageCount || 0}} 页</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="info-section">
      <view class="section-title">基本信息</view>
      <view class="info-grid">
        <view class="info-item">
          <text class="info-icon">✍️</text>
          <view class="info-content">
            <text class="info-label">作者</text>
            <text class="info-value">{{book.author}}</text>
          </view>
        </view>
        <view class="info-item" wx:if="{{book.translator}}">
          <text class="info-icon">🔄</text>
          <view class="info-content">
            <text class="info-label">译者</text>
            <text class="info-value">{{book.translator}}</text>
          </view>
        </view>
        <view class="info-item">
          <text class="info-icon">🏢</text>
          <view class="info-content">
            <text class="info-label">出版社</text>
            <text class="info-value">{{book.publisher}}</text>
          </view>
        </view>
        <view class="info-item">
          <text class="info-icon">📅</text>
          <view class="info-content">
            <text class="info-label">出版日期</text>
            <text class="info-value">{{book.publishDate}}</text>
          </view>
        </view>
        <view class="info-item">
          <text class="info-icon">🏷️</text>
          <view class="info-content">
            <text class="info-label">ISBN</text>
            <text class="info-value isbn">{{book.isbn}}</text>
          </view>
        </view>
        <view class="info-item">
          <text class="info-icon">💰</text>
          <view class="info-content">
            <text class="info-label">定价</text>
            <text class="info-value price">¥{{book.price}}</text>
          </view>
        </view>
      </view>
    </view>

    <view class="info-section">
      <view class="section-title">馆藏信息</view>
      <view class="collection-info">
        <view class="collection-item">
          <view class="collection-label-row">
            <text class="collection-icon">📍</text>
            <text class="collection-label">馆藏地</text>
          </view>
          <text class="collection-value">{{book.location}}</text>
        </view>
        <view class="collection-item">
          <view class="collection-label-row">
            <text class="collection-icon">🔢</text>
            <text class="collection-label">索书号</text>
          </view>
          <text class="collection-value call-number">{{book.callNumber}}</text>
        </view>
        <view class="collection-row">
          <view class="collection-item half">
            <view class="collection-label-row">
              <text class="collection-icon">📚</text>
              <text class="collection-label">总藏量</text>
            </view>
            <text class="collection-value">{{book.totalCopies}} 册</text>
          </view>
          <view class="collection-item half">
            <view class="collection-label-row">
              <text class="collection-icon">✅</text>
              <text class="collection-label">可借数量</text>
            </view>
            <text class="collection-value available" style="color: {{book.statusInfo.color}};">{{book.availableCopies}} 册</text>
          </view>
        </view>
        <view class="collection-status">
          <view class="status-tag-large" style="background: {{book.statusInfo.color}};">
            <text class="status-text-large">{{book.statusInfo.label}}</text>
          </view>
        </view>
      </view>
    </view>

    <view class="info-section" wx:if="{{book.description}}">
      <view class="section-title">内容简介</view>
      <view class="desc-box">
        <text class="desc-text {{showFullDesc ? '' : 'clamp'}}">{{book.description}}</text>
        <view class="desc-toggle" bindtap="onToggleDesc" wx:if="{{book.description.length > 100}}">
          <text class="toggle-text">{{showFullDesc ? '收起 ▲' : '展开 ▼'}}</text>
        </view>
      </view>
    </view>

    <view class="info-section" wx:if="{{book.tags && book.tags.length > 0}}">
      <view class="section-title">标签</view>
      <view class="tags-list">
        <view class="tag-item" wx:for="{{book.tags}}" wx:key="*this">
          <text class="tag-text-item">#{{item}}</text>
        </view>
      </view>
    </view>

    <view class="info-section" wx:if="{{book.tableOfContents && book.tableOfContents.length > 0}}">
      <view class="section-title">目录</view>
      <view class="toc-list">
        <view class="toc-item" wx:for="{{book.tableOfContents}}" wx:key="index" wx:for-index="idx">
          <text class="toc-index">{{idx + 1}}.</text>
          <text class="toc-title">{{item}}</text>
        </view>
      </view>
    </view>

    <view class="bottom-space"></view>
  </scroll-view>

  <view class="bottom-bar">
    <view class="action-btn favorite {{isFavorited ? 'active' : ''}}" bindtap="onToggleFavorite">
      <text class="action-icon">{{isFavorited ? '❤️' : '🤍'}}</text>
      <text class="action-text">{{isFavorited ? '已收藏' : '收藏'}}</text>
    </view>
    <view class="action-btn borrow" bindtap="onBorrow">
      <btn
        type="primary"
        size="large"
        disabled="{{book.availableCopies <= 0}}"
        block
      >
        {{book.availableCopies <= 0 ? '暂无馆藏' : '去借阅'}}
      </btn>
    </view>
  </view>

  <view class="loading-overlay" wx:if="{{loading}}">
    <view class="loading-content">
      <view class="loading-spinner"></view>
      <text class="loading-text">加载中...</text>
    </view>
  </view>
</view>
