.page {
  min-height: 100vh;
  background: var(--color-bg-page, #F8F9FA);
  display: flex;
  flex-direction: column;
}

.page.dark {
  --color-bg-page: #0F1117;
  --color-bg-card: #1A1D29;
  --color-bg-secondary: #252936;
  --color-bg-input: #262A3A;
  --color-text-primary: #E8ECF1;
  --color-text-secondary: #9CA3AF;
  --color-text-placeholder: #6B7280;
  --color-border: #2D3142;
}

.page-scroll {
  flex: 1;
  height: 100vh;
}

.form-section {
  padding: 24rpx 32rpx 0;
}

.section-header {
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--color-text-primary, #2C3E50);
  display: block;
  margin-bottom: 8rpx;
}

.section-desc {
  font-size: 24rpx;
  color: var(--color-text-secondary, #6B7280);
}

.form-card {
  background: var(--color-bg-card, #FFFFFF);
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.form-item {
  margin-bottom: 28rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.label-text {
  font-size: 28rpx;
  color: var(--color-text-primary, #2C3E50);
  font-weight: 500;
}

.required {
  color: #F5222D;
  margin-left: 6rpx;
  font-size: 28rpx;
}

.optional {
  font-size: 22rpx;
  color: var(--color-text-secondary, #9CA3AF);
  margin-left: 10rpx;
  padding: 4rpx 12rpx;
  background: var(--color-bg-secondary, #F3F4F6);
  border-radius: 8rpx;
}

.form-input-wrap {
  height: 88rpx;
  padding: 0 24rpx;
  background: var(--color-bg-secondary, #F9FAFB);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
}

.page.dark .form-input-wrap {
  background: var(--color-bg-input, #262A3A);
}

.form-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--color-text-primary, #2C3E50);
}

.form-placeholder {
  color: var(--color-text-placeholder, #9CA3AF);
}

.form-picker-wrap {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 24rpx;
  background: var(--color-bg-secondary, #F9FAFB);
  border-radius: 16rpx;
  border: 2rpx solid transparent;
}

.page.dark .form-picker-wrap {
  background: var(--color-bg-input, #262A3A);
}

.form-picker-text {
  font-size: 28rpx;
  color: var(--color-text-primary, #2C3E50);
}

.picker-arrow {
  font-size: 32rpx;
  color: var(--color-text-secondary, #9CA3AF);
  font-weight: 500;
}

.form-textarea-wrap {
  padding: 20rpx 24rpx;
  background: var(--color-bg-secondary, #F9FAFB);
  border-radius: 16rpx;
  min-height: 180rpx;
}

.page.dark .form-textarea-wrap {
  background: var(--color-bg-input, #262A3A);
}

.form-textarea {
  width: 100%;
  font-size: 28rpx;
  color: var(--color-text-primary, #2C3E50);
  line-height: 1.6;
}

.word-count {
  text-align: right;
  font-size: 22rpx;
  color: var(--color-text-secondary, #9CA3AF);
  margin-top: 10rpx;
}

.submit-wrap {
  margin-top: 32rpx;
  margin-bottom: 8rpx;
}

.submit-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 96rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  border-radius: 48rpx;
  box-shadow: 0 6rpx 20rpx rgba(255, 107, 107, 0.35);
  transition: all 0.3s ease;
}

.page.dark .submit-btn {
  background: linear-gradient(135deg, #C04040 0%, #D06060 100%);
  box-shadow: 0 6rpx 20rpx rgba(192, 64, 64, 0.35);
}

.submit-btn.disabled {
  opacity: 0.7;
}

.submit-text {
  font-size: 30rpx;
  color: #FFFFFF;
  font-weight: 600;
}

.history-section {
  padding: 40rpx 32rpx 0;
}

.history-card {
  background: var(--color-bg-card, #FFFFFF);
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.history-header {
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid var(--color-border, #F0F0F0);
}

.history-title-wrap {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.history-book-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary, #2C3E50);
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.status-badge {
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.status-text {
  font-size: 22rpx;
  font-weight: 500;
}

.history-time {
  font-size: 22rpx;
  color: var(--color-text-secondary, #9CA3AF);
}

.history-meta {
  margin-bottom: 16rpx;
}

.meta-row {
  display: flex;
  align-items: flex-start;
  margin-bottom: 10rpx;
  gap: 16rpx;
}

.meta-row:last-child {
  margin-bottom: 0;
}

.meta-label {
  width: 100rpx;
  font-size: 24rpx;
  color: var(--color-text-secondary, #6B7280);
  flex-shrink: 0;
}

.meta-value {
  flex: 1;
  font-size: 24rpx;
  color: var(--color-text-primary, #2C3E50);
}

.category-tag {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 4rpx 14rpx;
  background: var(--color-bg-secondary, #F3F4F6);
  border-radius: 10rpx;
  width: auto;
}

.page.dark .category-tag {
  background: var(--color-bg-secondary, #252936);
}

.category-icon {
  font-size: 22rpx;
}

.category-text {
  font-size: 22rpx;
  color: var(--color-text-secondary, #6B7280);
}

.history-reason {
  background: var(--color-bg-secondary, #F9FAFB);
  border-radius: 16rpx;
  padding: 16rpx 20rpx;
}

.page.dark .history-reason {
  background: var(--color-bg-secondary, #252936);
}

.reason-label {
  font-size: 22rpx;
  color: var(--color-text-secondary, #6B7280);
  display: block;
  margin-bottom: 8rpx;
}

.reason-content {
  background: transparent;
}

.reason-text {
  font-size: 24rpx;
  color: var(--color-text-primary, #2C3E50);
  line-height: 1.6;
}

.reply-section {
  margin-top: 16rpx;
  padding: 20rpx;
  background: linear-gradient(135deg, rgba(78, 205, 196, 0.1) 0%, rgba(69, 183, 209, 0.1) 100%);
  border-radius: 16rpx;
  border-left: 6rpx solid #4ECDC4;
}

.page.dark .reply-section {
  background: linear-gradient(135deg, rgba(58, 158, 150, 0.15) 0%, rgba(69, 183, 209, 0.15) 100%);
}

.reply-header {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 10rpx;
}

.reply-icon {
  font-size: 26rpx;
}

.reply-title {
  font-size: 24rpx;
  color: #14B8A6;
  font-weight: 600;
}

.reply-content {
  background: transparent;
}

.reply-text {
  font-size: 24rpx;
  color: var(--color-text-primary, #2C3E50);
  line-height: 1.6;
}

.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
  gap: 20rpx;
  background: var(--color-bg-card, #FFFFFF);
  border-radius: 24rpx;
}

.loading-spinner {
  width: 56rpx;
  height: 56rpx;
  border: 4rpx solid var(--color-bg-secondary, #E5E7EB);
  border-top-color: var(--color-primary, #FF6B6B);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: 26rpx;
  color: var(--color-text-secondary, #6B7280);
}

.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
  gap: 20rpx;
  background: var(--color-bg-card, #FFFFFF);
  border-radius: 24rpx;
}

.empty-icon {
  font-size: 100rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: var(--color-text-secondary, #9CA3AF);
}

.bottom-space {
  height: 60rpx;
}
