/* 登录页面 */
.page {
  min-height: 100vh;
  background-color: #FFFFFF;
}

/* Logo区域 */
.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0 60rpx;
}

.logo-wrap {
  width: 160rpx;
  height: 160rpx;
  background-color: rgba(255, 255, 255, 0.95);
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.15);
  margin-bottom: 24rpx;
}

.logo-icon {
  font-size: 80rpx;
}

.logo-title {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--color-primary);
  margin-bottom: 12rpx;
  text-shadow: none;
}

.logo-desc {
  font-size: 28rpx;
  color: #FF8E8E;
}

/* 表单区域 */
.form-section {
  padding: 0 32rpx;
}

.form-card {
  background-color: var(--color-bg-card);
  border-radius: var(--radius-2xl);
  padding: 16rpx 32rpx;
  box-shadow: var(--shadow-lg);
  border: 2rpx solid #FF8E8E;
}

.form-item {
  display: flex;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 1rpx solid #EEEEEE;
}

.form-item.no-border {
  border-bottom: none;
}

.form-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.form-input {
  flex: 1;
  font-size: 30rpx;
  color: var(--color-text-primary);
  height: 48rpx;
  line-height: 48rpx;
}

.form-input::placeholder {
  color: var(--color-text-muted);
}

.form-eye {
  font-size: 36rpx;
  padding: 8rpx;
  flex-shrink: 0;
}

/* 提交按钮 */
.submit-section {
  padding: 48rpx 0 32rpx;
}

/* 切换登录/注册 */
.switch-section {
  display: flex;
  justify-content: center;
  align-items: center;
  padding-bottom: 48rpx;
}

.switch-text {
  font-size: 28rpx;
  color: #666666;
}

.switch-link {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-primary);
  margin-left: 8rpx;
}
