<page-meta page-style="background-color: {{darkMode ? '#0F1117' : '#F8F9FA'}}; color: {{darkMode ? '#E8ECF1' : '#2C3E50'}}"/>
<view class="page {{darkMode ? 'dark' : ''}}">
  <!-- Logo区域 -->
  <view class="logo-section">
    <view class="logo-wrap">
      <text class="logo-icon">🎓</text>
    </view>
    <text class="logo-title">校园生活服务</text>
    <text class="logo-desc">{{isLogin ? '欢迎回来' : '注册新账号'}}</text>
  </view>

  <!-- 表单区域 -->
  <view class="form-section">
    <view class="form-card">
      <view class="form-item">
        <text class="form-icon">📱</text>
        <input
          class="form-input"
          placeholder="请输入账号/手机号"
          value="{{formData.account}}"
          bindinput="onInputChange"
          data-field="account"
          maxlength="20"
        />
      </view>

      <view class="form-item">
        <text class="form-icon">🔒</text>
        <input
          class="form-input"
          placeholder="请输入密码"
          password="{{!showPassword}}"
          value="{{formData.password}}"
          bindinput="onInputChange"
          data-field="password"
          maxlength="20"
        />
        <text class="form-eye" bindtap="togglePassword">{{showPassword ? '🙈' : '👁'}}</text>
      </view>

      <!-- 密码强度指示器 -->
      <view class="password-strength" wx:if="{{passwordStrength > 0}}">
        <view class="strength-bar">
          <view class="strength-fill" style="width: {{passwordStrength}}%; background: {{passwordStrengthColor}};"></view>
        </view>
        <text class="strength-text" style="color: {{passwordStrengthColor}};">密码强度: {{passwordStrengthText}}</text>
      </view>

      <!-- 注册时确认密码 -->
      <view class="form-item no-border" wx:if="{{!isLogin}}">
        <text class="form-icon">🔒</text>
        <input
          class="form-input"
          placeholder="请确认密码"
          password="{{!showConfirmPassword}}"
          value="{{formData.confirmPassword}}"
          bindinput="onInputChange"
          data-field="confirmPassword"
          maxlength="20"
        />
        <text class="form-eye" bindtap="toggleConfirmPassword">{{showConfirmPassword ? '🙈' : '👁'}}</text>
      </view>
    </view>

    <!-- 提交按钮 -->
    <view class="submit-section">
      <btn type="primary" size="large" block="{{true}}" loading="{{submitting}}" bind:click="onSubmit">
        {{isLogin ? '登录' : '注册'}}
      </btn>
    </view>

    <!-- 切换登录/注册 -->
    <view class="switch-section">
      <text class="switch-text">{{isLogin ? '还没有账号？' : '已有账号？'}}</text>
      <text class="switch-link" bindtap="toggleMode">{{isLogin ? '立即注册' : '去登录'}}</text>
    </view>
  </view>

  <!-- 校区选择器 -->
  <campus-selector
    visible="{{showCampusSelector}}"
    required="{{true}}"
    showClose="{{false}}"
    title="选择您的校区"
    bind:confirm="onCampusConfirm"
    bind:close="onCampusClose"
  />
</view>
