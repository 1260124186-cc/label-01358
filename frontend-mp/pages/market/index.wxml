<page-meta page-style="background-color: {{darkMode ? '#0F1117' : '#F8F9FA'}}; color: {{darkMode ? '#E8ECF1' : '#2C3E50'}}"/>
<view class="page {{darkMode ? 'dark' : ''}}">
  <!-- 顶部筛选 -->
  <view class="filter-section">
    <scroll-view class="filter-scroll" scroll-x="{{true}}" enhanced="{{true}}" show-scrollbar="{{false}}">
      <view class="filter-tabs">
        <view
          class="filter-tab {{currentCategory === '' ? 'active' : ''}}"
          bindtap="onCategoryChange"
          data-category=""
        >全部</view>
        <view
          class="filter-tab {{currentCategory === item.value ? 'active' : ''}}"
          wx:for="{{categories}}"
          wx:key="value"
          bindtap="onCategoryChange"
          data-category="{{item.value}}"
        >{{item.label}}</view>
      </view>
    </scroll-view>
    <view class="filter-buttons">
      <view class="filter-btn" bindtap="onShowPricePicker">
        <text class="filter-btn-text">{{currentPriceText || '价格'}}</text>
        <text class="filter-btn-arrow">▼</text>
      </view>
      <view class="filter-btn {{currentDistanceRange ? 'active' : ''}}" bindtap="onShowDistancePicker">
        <text class="filter-btn-icon">📍</text>
        <text class="filter-btn-text">{{currentDistanceText || '附近'}}</text>
      </view>
    </view>
  </view>

  <!-- 定位提示 -->
  <view class="location-tip" wx:if="{{locationTip}}">
    <text class="location-tip-text">{{locationTip}}</text>
    <text class="location-tip-action" bindtap="requestLocationAuth">去开启</text>
  </view>

  <!-- 学习资料入口 - 图书分类互补 -->
  <view wx:if="{{!showSkeleton && (currentCategory === 'book' || currentCategory === '')}}" class="study-entry-banner" bindtap="onStudyEntry">
    <view class="study-entry-content">
      <view class="study-entry-icon">📚</view>
      <view class="study-entry-info">
        <view class="study-entry-title">学习资料专区</view>
        <view class="study-entry-desc">免费下载笔记、课件、试卷 · 考研考证互助</view>
      </view>
    </view>
    <view class="study-entry-action">
      <text class="entry-btn-text">立即进入</text>
      <text class="entry-arrow">›</text>
    </view>
  </view>

  <!-- 列表区域 -->
  <scroll-view
    class="list-scroll"
    scroll-y="{{true}}"
    refresher-enabled="{{true}}"
    refresher-triggered="{{refreshing}}"
    bindrefresherrefresh="onListRefresh"
    bindscrolltolower="onListLoadMore"
    lower-threshold="50"
  >
    <!-- 骨架屏 -->
    <skeleton
      wx:if="{{showSkeleton}}"
      type="{{skeletonConfig.type}}"
      count="{{skeletonConfig.count}}"
      loading="{{true}}"
    />

    <!-- 列表内容 -->
    <view class="list-container" wx:if="{{!showSkeleton && list.length > 0}}">
      <view class="goods-grid">
        <view
          class="goods-card"
          wx:for="{{list}}"
          wx:key="id"
          hover-class="goods-card-hover"
          bindtap="onItemTap"
          data-item="{{item}}"
        >
          <view class="goods-image-wrap">
            <image
              class="goods-image"
              src="{{item.images[0] || '/assets/images/default-goods.png'}}"
              mode="aspectFill"
            />
            <view class="goods-status {{item.status}}" wx:if="{{item.status !== 'selling'}}">
              {{item.statusText}}
            </view>
          </view>
          <view class="goods-info">
            <text class="goods-title">{{item.title}}</text>
            <text class="goods-desc">{{item.description}}</text>
            <view class="goods-bottom">
              <text class="goods-price">¥{{item.priceText}}</text>
              <view class="goods-meta">
                <text class="goods-distance" wx:if="{{item.hasDistance}}">
                  📍{{item.distanceText}}
                </text>
                <text class="goods-views">{{item.views}}浏览</text>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 加载更多 -->
    <view class="load-more" wx:if="{{!showSkeleton && list.length > 0}}">
      <view class="load-more-loading" wx:if="{{loadingMore}}">
        <view class="loading-spinner"></view>
        <text class="load-more-text">加载中...</text>
      </view>
      <view class="load-more-no-more" wx:elif="{{noMore}}">
        <text class="load-more-text">没有更多了</text>
      </view>
      <view class="load-more-tip" wx:else>
        <text class="load-more-text">上拉加载更多</text>
      </view>
    </view>

    <!-- 空状态 -->
    <empty
      wx:if="{{!showSkeleton && !loading && list.length === 0}}"
      image="{{emptyConfig.image}}"
      text="{{emptyConfig.text}}"
      showAction="{{emptyConfig.showAction}}"
      actionText="{{emptyConfig.actionText}}"
      bindaction="onEmptyAction"
    />
  </scroll-view>

  <!-- 发布按钮 -->
  <view class="publish-btn" hover-class="publish-btn-hover" bindtap="onPublish">
    <text class="publish-icon">+</text>
  </view>

  <!-- 价格选择器 -->
  <view class="picker-mask {{showPricePicker ? 'show' : ''}}" bindtap="onHidePricePicker">
    <view class="picker-content" catchtap="stopPropagation">
      <view class="picker-header">
        <text class="picker-title">选择价格区间</text>
        <text class="picker-close" bindtap="onHidePricePicker">×</text>
      </view>
      <view class="picker-options">
        <view
          class="picker-option {{currentPriceRange === '' ? 'active' : ''}}"
          bindtap="onPriceSelect"
          data-value=""
        >不限价格</view>
        <view
          class="picker-option {{currentPriceRange === item.value ? 'active' : ''}}"
          wx:for="{{priceRanges}}"
          wx:key="value"
          bindtap="onPriceSelect"
          data-value="{{item.value}}"
          data-min="{{item.min}}"
          data-max="{{item.max}}"
        >{{item.label}}</view>
      </view>
    </view>
  </view>

  <!-- 距离选择器 -->
  <view class="picker-mask {{showDistancePicker ? 'show' : ''}}" bindtap="onHideDistancePicker">
    <view class="picker-content" catchtap="stopPropagation">
      <view class="picker-header">
        <text class="picker-title">选择距离范围</text>
        <text class="picker-close" bindtap="onHideDistancePicker">×</text>
      </view>
      <view class="picker-options">
        <view
          class="picker-option {{currentDistanceRange === '' ? 'active' : ''}}"
          bindtap="onDistanceSelect"
          data-value=""
        >不限距离</view>
        <view
          class="picker-option {{currentDistanceRange === item.value ? 'active' : ''}}"
          wx:for="{{distanceRanges}}"
          wx:key="value"
          wx:if="{{item.value !== ''}}"
          bindtap="onDistanceSelect"
          data-value="{{item.value}}"
          data-min="{{item.min}}"
          data-max="{{item.max}}"
        >{{item.label}}</view>
      </view>
    </view>
  </view>
</view>
