/* 二手市场列表 - 参考闲鱼瀑布流设计 */
.page {
  min-height: 100vh;
  background-color: var(--color-bg-page);
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
}

/* ==================== 筛选区域 ==================== */
.filter-section {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background-color: var(--color-bg-card);
  border-bottom: 1rpx solid var(--color-border-light);
  position: sticky;
  top: 0;
  z-index: 100;
}

.filter-scroll {
  flex: 1;
  white-space: nowrap;
}

.filter-tabs {
  display: inline-flex;
  padding-right: 16rpx;
}

.filter-tabs > view { margin-right: 12rpx; }

.filter-tabs > view:last-child { margin-right: 0; }

.filter-tab {
  display: inline-block;
  padding: 14rpx 24rpx;
  font-size: 26rpx;
  font-weight: 500;
  color: var(--color-text-secondary);
  background-color: var(--color-bg-input);
  border-radius: var(--radius-full);
  transition: all var(--transition-fast);
}

.filter-tab:active {
  transform: scale(0.96);
}

.filter-tab.active {
  color: #FFFFFF;
  background: linear-gradient(135deg, var(--color-primary) 0%, #FF8E8E 100%);
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 107, 0.3);
}

.filter-buttons {
  display: flex;
  align-items: center;
  margin-left: 12rpx;
  flex-shrink: 0;
}

.filter-btn {
  display: flex;
  align-items: center;
  padding: 14rpx 20rpx;
  margin-left: 8rpx;
  background-color: var(--color-bg-input);
  border-radius: var(--radius-full);
  flex-shrink: 0;
  transition: all var(--transition-fast);
}

.filter-btn:active {
  background-color: var(--color-border);
}

.filter-btn.active {
  background: linear-gradient(135deg, var(--color-primary) 0%, #FF8E8E 100%);
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 107, 0.3);
}

.filter-btn.active .filter-btn-text,
.filter-btn.active .filter-btn-arrow,
.filter-btn.active .filter-btn-icon {
  color: #FFFFFF;
}

.filter-btn-text {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.filter-btn-arrow {
  font-size: 20rpx;
  color: var(--color-text-muted);
  margin-left: 6rpx;
}

.filter-btn-icon {
  font-size: 24rpx;
  margin-right: 4rpx;
}

/* 定位提示 */
.location-tip {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 0 24rpx 16rpx;
  padding: 16rpx 24rpx;
  background: linear-gradient(135deg, rgba(245, 158, 11, 0.1) 0%, rgba(251, 191, 36, 0.1) 100%);
  border-radius: var(--radius-lg);
  border: 1rpx solid rgba(245, 158, 11, 0.2);
}

.location-tip-text {
  font-size: 24rpx;
  color: #D97706;
  flex: 1;
}

.location-tip-action {
  font-size: 24rpx;
  color: var(--color-primary);
  font-weight: 600;
  padding: 8rpx 16rpx;
  background-color: rgba(255, 107, 107, 0.1);
  border-radius: var(--radius-md);
  margin-left: 16rpx;
}

/* ==================== 学习资料入口 ==================== */
.study-entry-banner {
  margin: 20rpx 24rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: var(--radius-xl);
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.35);
}

.study-entry-banner:active {
  transform: scale(0.98);
  transition: transform var(--transition-fast);
}

.study-entry-content {
  display: flex;
  align-items: center;
  flex: 1;
}

.study-entry-content > view { margin-right: 16rpx; }

.study-entry-content > view:last-child { margin-right: 0; }

.study-entry-icon {
  font-size: 48rpx;
  flex-shrink: 0;
}

.study-entry-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.study-entry-info > view { margin-bottom: 6rpx; }

.study-entry-info > view:last-child { margin-bottom: 0; }

.study-entry-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #fff;
}

.study-entry-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
}

.study-entry-action {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.2);
  padding: 10rpx 20rpx;
  border-radius: var(--radius-full);
}

.study-entry-action > view { margin-right: 4rpx; }

.study-entry-action > view:last-child { margin-right: 0; }

.entry-btn-text {
  font-size: 24rpx;
  color: #fff;
  font-weight: 600;
}

.entry-arrow {
  font-size: 28rpx;
  color: #fff;
  font-weight: 300;
}

/* ==================== 列表区域 ==================== */
.list-scroll {
  height: calc(100vh - 100rpx);
}

.page.dark .study-entry-banner {
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.25);
}

.list-container {
  padding: 16rpx;
}

/* ==================== 瀑布流商品卡片 ==================== */
.goods-grid {
  display: flex;
  flex-wrap: wrap;
}

.goods-grid { margin-right: -16rpx; margin-bottom: -16rpx; }

.goods-grid > view { margin-right: 16rpx; margin-bottom: 16rpx; }

.goods-card {
  width: calc(50% - 8rpx);
  background-color: var(--color-bg-card);
  border-radius: var(--radius-xl);
  overflow: hidden;
  box-shadow: var(--shadow-card);
  transition: all var(--transition-fast);
}

.goods-card:active {
  transform: scale(0.98);
  box-shadow: var(--shadow-sm);
}

.goods-image-wrap {
  position: relative;
  width: 100%;
  aspect-ratio: 1;
  overflow: hidden;
}

.goods-image {
  width: 100%;
  height: 100%;
  transition: transform 0.4s ease;
}

.goods-card:active .goods-image {
  transform: scale(1.05);
}

.goods-status {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  padding: 8rpx 16rpx;
  font-size: 22rpx;
  font-weight: 600;
  border-radius: var(--radius-sm);
  backdrop-filter: blur(8rpx);
  -webkit-backdrop-filter: blur(8rpx);
}

.goods-status.reserved {
  color: #F59E0B;
  background-color: rgba(254, 243, 199, 0.95);
}

.goods-status.sold {
  color: #6B7280;
  background-color: rgba(243, 244, 246, 0.95);
}

.goods-info {
  padding: 16rpx 16rpx 20rpx;
}

.goods-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  margin-bottom: 8rpx;
  min-height: 78rpx;
}

.goods-desc {
  font-size: 24rpx;
  color: var(--color-text-muted);
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.goods-bottom {
  display: flex;
  flex-direction: column;
}

.goods-price {
  font-size: 36rpx;
  font-weight: 800;
  color: var(--color-primary);
  margin-bottom: 8rpx;
}

.goods-price::before {
  content: '¥';
  font-size: 24rpx;
  font-weight: 600;
}

.goods-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.goods-distance {
  font-size: 22rpx;
  color: #10B981;
  background-color: rgba(16, 185, 129, 0.1);
  padding: 4rpx 10rpx;
  border-radius: var(--radius-sm);
  font-weight: 500;
}

.goods-views {
  font-size: 22rpx;
  color: var(--color-text-muted);
}

/* ==================== 发布按钮 ==================== */
.publish-btn {
  position: fixed;
  right: 32rpx;
  bottom: calc(200rpx + env(safe-area-inset-bottom));
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, var(--color-primary) 0%, #FF8E8E 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(255, 107, 107, 0.45);
  transition: all var(--transition-normal);
  z-index: 100;
}

.publish-btn::before {
  content: '';
  position: absolute;
  top: -8rpx;
  left: -8rpx;
  right: -8rpx;
  bottom: -8rpx;
  background: linear-gradient(135deg, var(--color-primary) 0%, #FF8E8E 100%);
  border-radius: 50%;
  opacity: 0.3;
  z-index: -1;
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); opacity: 0.3; }
  50% { transform: scale(1.1); opacity: 0.15; }
}

.publish-btn:active {
  transform: scale(0.92);
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 107, 0.35);
}

.publish-icon {
  font-size: 56rpx;
  color: #FFFFFF;
  font-weight: 300;
  line-height: 1;
}

/* ==================== 选择器弹窗 ==================== */
.picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.picker-mask.show {
  opacity: 1;
  visibility: visible;
}

.picker-content {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: var(--color-bg-card);
  border-radius: var(--radius-2xl) var(--radius-2xl) 0 0;
  padding-bottom: env(safe-area-inset-bottom);
  transform: translateY(100%);
  transition: transform 0.35s cubic-bezier(0.32, 0.72, 0, 1);
}

.picker-mask.show .picker-content {
  transform: translateY(0);
}

.picker-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid var(--color-border-light);
}

.picker-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

.picker-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: var(--color-text-muted);
  background-color: var(--color-bg-input);
  border-radius: 50%;
}

.picker-options {
  padding: 16rpx 32rpx 32rpx;
}

.picker-option {
  padding: 24rpx 0;
  font-size: 30rpx;
  color: var(--color-text-primary);
  border-bottom: 1rpx solid var(--color-border-light);
  transition: all var(--transition-fast);
}

.picker-option:last-child {
  border-bottom: none;
}

.picker-option:active {
  background-color: var(--color-bg-page);
}

.picker-option.active {
  color: var(--color-primary);
  font-weight: 600;
}
