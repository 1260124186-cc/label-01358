.page {
  min-height: 100vh;
  background-color: #F8F9FA;
  padding-bottom: 40rpx;
}

.page.dark {
  background-color: #0F1117;
  color: #E8ECF1;
}

.checkin-container {
  padding: 20rpx;
}

.house-card {
  display: flex;
  padding: 24rpx;
  background-color: #fff;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
}

.page.dark .house-card {
  background-color: #1A1D29;
}

.house-cover {
  width: 160rpx;
  height: 120rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.house-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.house-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #111;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.page.dark .house-title {
  color: #E8ECF1;
}

.house-address {
  font-size: 24rpx;
  color: #6B7280;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.page.dark .house-address {
  color: #9AA0A6;
}

.appointment-time {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #FF6B6B;
  font-weight: 500;
}

.time-icon {
  margin-right: 8rpx;
}

.checkin-status {
  padding: 60rpx 40rpx;
  background-color: #fff;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
}

.page.dark .checkin-status {
  background-color: #1A1D29;
}

.status-success {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.status-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #10B981 0%, #34D399 100%);
  color: #fff;
  font-size: 60rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.status-text {
  font-size: 36rpx;
  font-weight: 700;
  color: #111;
  margin-bottom: 12rpx;
}

.page.dark .status-text {
  color: #E8ECF1;
}

.status-time {
  font-size: 26rpx;
  color: #6B7280;
}

.page.dark .status-time {
  color: #9AA0A6;
}

.checkin-actions {
  display: flex;
  margin-bottom: 24rpx;
}

.checkin-actions > view {
  margin-right: 20rpx;
}

.checkin-actions > view:last-child {
  margin-right: 0;
}

.action-card {
  flex: 1;
  background-color: #fff;
  border-radius: 16rpx;
  padding: 40rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: all 0.2s ease;
}

.page.dark .action-card {
  background-color: #1A1D29;
}

.action-card:active {
  transform: scale(0.96);
}

.scan-card {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
}

.scan-card .action-title,
.scan-card .action-desc {
  color: #fff;
}

.scan-card .action-desc {
  opacity: 0.9;
}

.action-icon {
  font-size: 64rpx;
  margin-bottom: 20rpx;
}

.action-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #111;
  margin-bottom: 8rpx;
}

.page.dark .action-title {
  color: #E8ECF1;
}

.action-desc {
  font-size: 22rpx;
  color: #6B7280;
  text-align: center;
  line-height: 1.5;
}

.page.dark .action-desc {
  color: #9AA0A6;
}

.status-pending {
  padding: 60rpx 40rpx;
  background-color: #fff;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.page.dark .status-pending {
  background-color: #1A1D29;
}

.pending-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.pending-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #F59E0B;
  margin-bottom: 12rpx;
}

.pending-desc {
  font-size: 26rpx;
  color: #6B7280;
  text-align: center;
}

.page.dark .pending-desc {
  color: #9AA0A6;
}

.checkin-code-section {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.page.dark .checkin-code-section {
  background-color: #1A1D29;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #111;
  margin-bottom: 20rpx;
}

.page.dark .section-title {
  color: #E8ECF1;
}

.code-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  background-color: #F0FDF4;
  border-radius: 12rpx;
  border: 2rpx dashed #10B981;
}

.page.dark .code-card {
  background-color: rgba(16, 185, 129, 0.1);
  border-color: #10B981;
}

.code-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #10B981;
  letter-spacing: 4rpx;
}

.code-actions {
  display: flex;
}

.code-actions > view {
  margin-left: 16rpx;
}

.code-btn {
  display: flex;
  align-items: center;
  padding: 12rpx 20rpx;
  background-color: #fff;
  border-radius: 20rpx;
  transition: all 0.2s ease;
}

.code-btn:active {
  opacity: 0.8;
}

.code-btn-icon {
  font-size: 24rpx;
  margin-right: 6rpx;
}

.code-btn-text {
  font-size: 24rpx;
  color: #10B981;
  font-weight: 500;
}

.code-tip {
  display: flex;
  align-items: flex-start;
  margin-top: 16rpx;
  padding: 16rpx;
  background-color: #FEF3C7;
  border-radius: 8rpx;
}

.page.dark .code-tip {
  background-color: rgba(245, 158, 11, 0.1);
}

.tip-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
  flex-shrink: 0;
}

.tip-text {
  flex: 1;
  font-size: 24rpx;
  color: #92400E;
  line-height: 1.6;
}

.page.dark .tip-text {
  color: #FCD34D;
}

.tips-section {
  padding: 24rpx;
  background-color: #fff;
  border-radius: 16rpx;
}

.page.dark .tips-section {
  background-color: #1A1D29;
}

.tips-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #111;
  margin-bottom: 16rpx;
}

.page.dark .tips-title {
  color: #E8ECF1;
}

.tips-list {
  display: flex;
  flex-direction: column;
}

.tips-list > view {
  margin-bottom: 12rpx;
}

.tips-list > view:last-child {
  margin-bottom: 0;
}

.tip-item {
  display: flex;
  align-items: flex-start;
}

.tip-dot {
  color: #3B82F6;
  font-size: 24rpx;
  margin-right: 8rpx;
  line-height: 1.8;
}

.tip-text {
  flex: 1;
  font-size: 26rpx;
  color: #4B5563;
  line-height: 1.8;
}

.page.dark .tip-text {
  color: #D1D5DB;
}

.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #E5E7EB;
  border-top-color: #FF6B6B;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 16rpx;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: 26rpx;
  color: #9CA3AF;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.modal-mask.show {
  opacity: 1;
  visibility: visible;
}

.modal-content {
  width: 100%;
  max-width: 640rpx;
  background-color: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  transform: translateY(20rpx);
  transition: transform 0.3s ease;
}

.modal-mask.show .modal-content {
  transform: translateY(0);
}

.page.dark .modal-content {
  background-color: #1A1D29;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.page.dark .modal-header {
  border-bottom-color: #2A2F3D;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #111;
}

.page.dark .modal-title {
  color: #E8ECF1;
}

.modal-close {
  font-size: 40rpx;
  color: #999;
  padding: 10rpx;
  line-height: 1;
}

.modal-body {
  padding: 30rpx;
}

.code-input {
  width: 100%;
  height: 100rpx;
  padding: 0 24rpx;
  background-color: #F8F9FA;
  border-radius: 12rpx;
  font-size: 36rpx;
  font-weight: 600;
  color: #111;
  text-align: center;
  letter-spacing: 8rpx;
  box-sizing: border-box;
}

.page.dark .code-input {
  background-color: #2A2F3D;
  color: #E8ECF1;
}

.code-input::placeholder {
  color: #9CA3AF;
  font-size: 28rpx;
  font-weight: 400;
  letter-spacing: 0;
}

.input-tip {
  font-size: 24rpx;
  color: #9CA3AF;
  text-align: center;
  margin-top: 16rpx;
}

.modal-footer {
  display: flex;
  padding: 0 30rpx 30rpx;
}

.modal-footer > view { margin-right: 24rpx; }

.modal-footer > view:last-child { margin-right: 0; }

.modal-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 44rpx;
  font-size: 28rpx;
  font-weight: 600;
  transition: all 0.2s ease;
}

.modal-btn:active {
  opacity: 0.8;
}

.modal-btn.cancel {
  background-color: #F5F5F5;
  color: #4B5563;
}

.page.dark .modal-btn.cancel {
  background-color: #2A2F3D;
  color: #D1D5DB;
}

.modal-btn.confirm {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  color: #fff;
}
