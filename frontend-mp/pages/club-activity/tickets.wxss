.page {
  min-height: 100vh;
  background-color: var(--color-bg-page);
  padding-bottom: 32rpx;
}

.page.dark {
  background-color: var(--color-bg-page-dark);
}

.header {
  background: linear-gradient(135deg, var(--color-primary) 0%, #8B5CF6 50%, #FF6B6B 100%);
  padding: 0;
}

.header-inner {
  padding: 80rpx 32rpx 48rpx;
}

.page-title {
  font-size: 52rpx;
  font-weight: 800;
  color: #FFFFFF;
  margin-bottom: 28rpx;
  text-shadow: 0 4rpx 12rpx rgba(0,0,0,0.12);
}

.wallet-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  background: linear-gradient(135deg, rgba(255,255,255,0.95) 0%, rgba(255,255,255,0.85) 100%);
  border-radius: var(--radius-2xl);
  box-shadow: 0 12rpx 40rpx rgba(0,0,0,0.12);
  backdrop-filter: blur(20rpx);
}

.wallet-label {
  font-size: var(--font-xs);
  color: var(--color-text-secondary);
  margin-bottom: 8rpx;
}

.wallet-balance {
  font-size: 44rpx;
  font-weight: 800;
  color: var(--color-primary);
}

.wallet-icon {
  font-size: 56rpx;
  filter: drop-shadow(0 4rpx 12rpx rgba(255,107,107,0.35));
}

.tabs-bar {
  background-color: var(--color-bg-page);
  padding: 0;
  position: sticky;
  top: 0;
  z-index: 100;
}

.page.dark .tabs-bar {
  background-color: var(--color-bg-page-dark);
}

.tabs-scroll {
  display: flex;
  padding: 20rpx 24rpx 16rpx;
  gap: 12rpx;
  overflow-x: auto;
  white-space: nowrap;
}

.tab-item {
  display: inline-flex;
  align-items: center;
  padding: 14rpx 28rpx;
  background-color: var(--color-bg-input);
  border-radius: var(--radius-full);
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
  font-weight: 500;
  transition: all var(--transition-fast);
  flex-shrink: 0;
}

.tab-item.active {
  background-color: var(--color-primary);
  color: #FFFFFF;
  box-shadow: 0 6rpx 20rpx rgba(255,107,107,0.3);
  font-weight: 700;
}

.page.dark .tab-item {
  background-color: rgba(255,255,255,0.06);
}

.tab-count {
  margin-left: 8rpx;
  min-width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  text-align: center;
  font-size: 20rpx;
  border-radius: var(--radius-full);
  background-color: rgba(0,0,0,0.08);
  padding: 0 8rpx;
  font-weight: 600;
}

.tab-item.active .tab-count {
  background-color: rgba(255,255,255,0.3);
  color: #FFFFFF;
}

.order-list {
  padding: 16rpx 24rpx;
}

.order-card {
  background-color: var(--color-bg-card);
  border-radius: var(--radius-2xl);
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-sm);
  transition: all var(--transition-fast);
}

.order-card:active {
  transform: scale(0.985);
  box-shadow: var(--shadow-xs);
}

.order-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid var(--color-border-light);
  margin-bottom: 20rpx;
}

.order-no {
  font-size: var(--font-xs);
  color: var(--color-text-tertiary);
  font-family: 'Menlo', monospace;
  letter-spacing: 1rpx;
}

.order-status {
  font-size: var(--font-xs);
  font-weight: 700;
}

.order-body {
  display: flex;
  margin-bottom: 20rpx;
}

.cover-mini {
  width: 180rpx;
  height: 180rpx;
  border-radius: var(--radius-xl);
  overflow: hidden;
  flex-shrink: 0;
  margin-right: 20rpx;
  background-color: var(--color-bg-input);
}

.cover-img {
  width: 100%;
  height: 100%;
  display: block;
}

.cover-placeholder {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #FEF3C7 0%, #FDE68A 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.page.dark .cover-placeholder {
  background: linear-gradient(135deg, rgba(254,243,199,0.12) 0%, rgba(253,230,138,0.12) 100%);
}

.cover-ph-icon {
  font-size: 56rpx;
  filter: drop-shadow(0 4rpx 12rpx rgba(245,158,11,0.25));
}

.info-wrap {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.activity-title {
  font-size: var(--font-md);
  font-weight: 700;
  color: var(--color-text-primary);
  line-height: 1.4;
  margin-bottom: 12rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.activity-meta {
  flex: 1;
}

.meta-line {
  display: flex;
  align-items: flex-start;
  margin-bottom: 6rpx;
}

.meta-icon {
  font-size: 22rpx;
  margin-right: 8rpx;
  opacity: 0.7;
  line-height: 1.6;
}

.meta-text {
  font-size: var(--font-xs);
  color: var(--color-text-secondary);
  line-height: 1.6;
  flex: 1;
}

.order-footer {
  padding-top: 16rpx;
  border-top: 1rpx solid var(--color-border-light);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.order-total {
  display: flex;
  align-items: baseline;
}

.total-label {
  font-size: var(--font-xs);
  color: var(--color-text-tertiary);
}

.total-value {
  font-size: 30rpx;
  font-weight: 800;
  color: #EF4444;
  margin-right: 4rpx;
}

.time-label {
  font-size: var(--font-xs);
  color: var(--color-text-tertiary);
}

.order-actions {
  display: flex;
  gap: 12rpx;
  align-items: center;
}

.btn-ghost {
  padding: 12rpx 24rpx;
  border-radius: var(--radius-lg);
  font-size: var(--font-xs);
  color: var(--color-text-secondary);
  background-color: var(--color-bg-input);
  font-weight: 500;
  transition: all var(--transition-fast);
}

.btn-ghost:active {
  background-color: var(--color-border);
}

.btn-primary {
  padding: 12rpx 24rpx;
  border-radius: var(--radius-lg);
  font-size: var(--font-xs);
  color: #FFFFFF;
  background: linear-gradient(135deg, var(--color-primary) 0%, #FF8E8E 100%);
  font-weight: 600;
  transition: all var(--transition-fast);
  box-shadow: 0 4rpx 12rpx rgba(255,107,107,0.25);
}

.btn-primary:active {
  opacity: 0.9;
  transform: scale(0.97);
}

.empty-block {
  padding: 120rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
  opacity: 0.6;
}

.empty-text {
  font-size: var(--font-md);
  color: var(--color-text-secondary);
  margin-bottom: 12rpx;
  font-weight: 600;
}

.empty-sub {
  font-size: var(--font-sm);
  color: var(--color-text-tertiary);
}

.modal-mask {
  position: fixed;
  inset: 0;
  background-color: rgba(0,0,0,0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: all var(--transition-normal);
}

.modal-mask.show {
  opacity: 1;
  visibility: visible;
}

.modal-content {
  width: 85%;
  max-width: 600rpx;
  background-color: var(--color-bg-card);
  border-radius: var(--radius-2xl);
  overflow: hidden;
  transform: scale(0.9);
  transition: transform 0.3s ease;
  max-height: 85vh;
  display: flex;
  flex-direction: column;
}

.modal-mask.show .modal-content {
  transform: scale(1);
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 28rpx;
  border-bottom: 1rpx solid var(--color-border-light);
  flex-shrink: 0;
}

.modal-title {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--color-text-primary);
}

.modal-close {
  font-size: 48rpx;
  color: var(--color-text-tertiary);
  font-weight: 300;
  line-height: 1;
  margin-top: -8rpx;
}

.modal-body {
  padding: 28rpx 28rpx;
  flex: 1;
  overflow-y: auto;
}

.modal-footer {
  display: flex;
  padding: 20rpx 28rpx 28rpx;
  gap: 20rpx;
  flex-shrink: 0;
}

.modal-btn {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-xl);
  font-size: var(--font-md);
  font-weight: 600;
  border: none;
}

.modal-btn::after {
  border: none;
}

.modal-btn.cancel {
  background-color: var(--color-bg-input);
  color: var(--color-text-secondary);
}

.modal-btn.confirm {
  background: linear-gradient(135deg, var(--color-primary) 0%, #FF8E8E 100%);
  color: #FFFFFF;
}

.modal-btn[disabled] {
  opacity: 0.5 !important;
}

.ticket-modal {
  width: 88%;
  max-width: 640rpx;
}

.ticket-tabs {
  display: flex;
  margin-bottom: 28rpx;
  background-color: var(--color-bg-input);
  border-radius: var(--radius-lg);
  padding: 6rpx;
}

.tt-tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
  border-radius: var(--radius-md);
  transition: all var(--transition-fast);
  font-weight: 500;
}

.tt-tab.active {
  background-color: var(--color-bg-card);
  color: var(--color-primary);
  box-shadow: var(--shadow-sm);
  font-weight: 700;
}

.qr-code-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.qr-code-wrap.big {
  margin-bottom: 24rpx;
}

.qr-code-placeholder {
  width: 440rpx;
  height: 440rpx;
  background: linear-gradient(135deg, #F0FDF4 0%, #D1FAE5 100%);
  border: 4rpx dashed #10B981;
  border-radius: var(--radius-2xl);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  box-sizing: border-box;
}

.qr-code-placeholder.ticket-qr {
  width: 480rpx;
  height: 540rpx;
  background: linear-gradient(135deg, #FEF3C7 0%, #FDE68A 100%);
  border: 4rpx dashed #F59E0B;
}

.qr-big-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.qr-code-placeholder .qr-label {
  font-size: var(--font-sm);
  color: #6B7280;
  font-weight: 500;
  margin-bottom: 16rpx;
}

.qr-code-placeholder.ticket-qr .qr-label {
  color: #92400E;
}

.qr-code-display {
  font-size: 32rpx;
  font-weight: 800;
  color: #92400E;
  letter-spacing: 3rpx;
  font-family: 'Menlo', monospace;
  padding: 16rpx 24rpx;
  background-color: rgba(255,255,255,0.6);
  border-radius: var(--radius-lg);
  margin: 12rpx 0;
}

.qr-desc {
  font-size: var(--font-xs);
  color: #B45309;
  margin-top: 8rpx;
  margin-bottom: 16rpx;
  text-align: center;
}

.qr-status {
  padding: 10rpx 32rpx;
  background-color: #F59E0B;
  color: #FFFFFF;
  border-radius: var(--radius-full);
  font-size: var(--font-xs);
  font-weight: 600;
}

.qr-status.verified {
  background-color: #10B981;
}

.ticket-code-row {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx;
  background-color: var(--color-bg-input);
  border-radius: var(--radius-lg);
  margin-bottom: 24rpx;
}

.tcr-label {
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
}

.tcr-value {
  font-size: var(--font-md);
  font-weight: 700;
  color: var(--color-text-primary);
  font-family: 'Menlo', monospace;
  letter-spacing: 2rpx;
  margin: 0 12rpx;
}

.tcr-copy {
  font-size: var(--font-xs);
  color: var(--color-primary);
  font-weight: 500;
  padding: 6rpx 16rpx;
  background-color: var(--color-bg-card);
  border-radius: var(--radius-md);
}

.ticket-info-box {
  background-color: var(--color-bg-input);
  border-radius: var(--radius-xl);
  padding: 20rpx 24rpx;
}

.ticket-info-box .qr-activity,
.ticket-info-box .qr-time,
.ticket-info-box .qr-location,
.ticket-info-box .qr-user {
  display: block;
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
  line-height: 2;
}

.ticket-info-box .qr-activity {
  color: var(--color-text-primary);
  font-weight: 600;
}

.refund-modal {
  width: 88%;
  max-width: 640rpx;
}

.refund-summary {
  background: linear-gradient(135deg, #F0FDF4 0%, #ECFDF5 100%);
  border-radius: var(--radius-xl);
  padding: 24rpx 28rpx;
  margin-bottom: 28rpx;
}

.page.dark .refund-summary {
  background: linear-gradient(135deg, rgba(16,185,129,0.08) 0%, rgba(5,150,105,0.08) 100%);
}

.rs-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10rpx 0;
}

.rs-label {
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
}

.rs-value {
  font-size: var(--font-md);
  color: var(--color-text-primary);
  font-weight: 600;
}

.rs-row.highlight {
  padding: 20rpx 0;
  margin: 8rpx 0;
  border-top: 1rpx dashed rgba(16,185,129,0.3);
  border-bottom: 1rpx dashed rgba(16,185,129,0.3);
}

.rs-value.big {
  font-size: 40rpx;
  color: #10B981;
}

.rs-reason-box {
  margin-top: 16rpx;
  padding: 16rpx 20rpx;
  background-color: rgba(255,255,255,0.5);
  border-radius: var(--radius-lg);
}

.page.dark .rs-reason-box {
  background-color: rgba(0,0,0,0.15);
}

.rsr-text {
  display: block;
  font-size: var(--font-xs);
  color: #059669;
  line-height: 1.5;
  margin-bottom: 8rpx;
}

.rsr-hours {
  display: block;
  font-size: var(--font-xs);
  color: var(--color-text-tertiary);
}

.buy-notice {
  padding: 16rpx 20rpx;
  background-color: #FFFBEB;
  border-radius: var(--radius-lg);
  border-left: 6rpx solid #F59E0B;
  margin-bottom: 20rpx;
}

.page.dark .buy-notice {
  background-color: rgba(245,158,11,0.12);
}

.bn-title {
  font-size: var(--font-xs);
  color: #92400E;
  font-weight: 600;
}

.page.dark .bn-title {
  color: #FCD34D;
}

.bn-desc {
  font-size: var(--font-xs);
  color: #B45309;
  line-height: 1.5;
  margin-top: 4rpx;
}

.page.dark .bn-desc {
  color: #FDE68A;
}

.refund-reason-input {
  margin-bottom: 8rpx;
}

.rri-label {
  display: block;
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
  margin-bottom: 12rpx;
  font-weight: 500;
}

.rri-textarea {
  width: 100%;
  min-height: 160rpx;
  padding: 20rpx 24rpx;
  background-color: var(--color-bg-input);
  border-radius: var(--radius-xl);
  font-size: var(--font-sm);
  color: var(--color-text-primary);
  line-height: 1.6;
  box-sizing: border-box;
  border: 2rpx solid transparent;
  transition: all var(--transition-fast);
}

.rri-textarea:focus {
  border-color: var(--color-primary);
  background-color: var(--color-bg-card);
}

.refund-btn {
  background: linear-gradient(135deg, #10B981 0%, #34D399 100%);
  color: #FFFFFF;
}
