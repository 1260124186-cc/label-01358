<page-meta page-style="background-color: {{darkMode ? '#0F1117' : '#F8F9FA'}}; color: {{darkMode ? '#E8ECF1' : '#2C3E50'}}"/>
<view class="page {{darkMode ? 'dark' : ''}}">
  <scroll-view class="scroll-wrap" scroll-y="{{true}}">
    <view class="form-container">

      <view class="form-card">
        <view class="card-title">基础信息</view>

        <view class="form-item">
          <view class="label required">活动标题</view>
          <input
            class="input"
            placeholder="请输入活动标题"
            value="{{formData.title}}"
            bindinput="onInputChange"
            data-field="title"
            maxlength="50"
          />
        </view>

        <view class="form-item">
          <view class="label required">所属社团</view>
          <picker
            mode="selector"
            range="{{clubList}}"
            range-key="name"
            value="{{clubIndex}}"
            bindchange="onClubChange"
          >
            <view class="picker-value {{clubIndex === -1 ? 'placeholder' : ''}}">
              {{clubIndex === -1 ? '请选择社团' : clubList[clubIndex].name}}
              <text class="arrow">›</text>
            </view>
          </picker>
        </view>

        <view class="form-item">
          <view class="label required">活动分类</view>
          <picker
            mode="selector"
            range="{{categories}}"
            range-key="label"
            value="{{categoryIndex}}"
            bindchange="onCategoryChange"
          >
            <view class="picker-value {{categoryIndex === -1 ? 'placeholder' : ''}}">
              <block wx:if="{{categoryIndex !== -1}}">
                <text>{{categories[categoryIndex].icon}} {{categories[categoryIndex].label}}</text>
              </block>
              <block wx:else>
                请选择分类
              </block>
              <text class="arrow">›</text>
            </view>
          </picker>
        </view>

        <view class="form-item">
          <view class="label required">活动封面</view>
          <view class="cover-uploader" bindtap="onChooseCover">
            <block wx:if="{{formData.cover}}">
              <image src="{{formData.cover}}" mode="aspectFill" class="cover-image"/>
              <view class="change-cover">更换封面</view>
            </block>
            <block wx:else>
              <view class="uploader-hint">
                <text class="upload-icon">📷</text>
                <text class="upload-text">点击上传封面图</text>
                <text class="upload-desc">建议尺寸 16:9，清晰美观</text>
              </view>
            </block>
          </view>
        </view>
      </view>

      <view class="form-card">
        <view class="card-title">时间地点</view>

        <view class="form-item row">
          <view class="label required">开始时间</view>
          <view class="date-time-wrap">
            <picker mode="date" value="{{formData.activityDate}}" bindchange="onActivityDateChange">
              <view class="picker-value small {{!formData.activityDate ? 'placeholder' : ''}}">
                {{formData.activityDate || '日期'}} <text class="arrow">›</text>
              </view>
            </picker>
            <picker mode="time" value="{{formData.activityTime}}" bindchange="onActivityTimeChange">
              <view class="picker-value small {{!formData.activityTime ? 'placeholder' : ''}}">
                {{formData.activityTime || '时间'}} <text class="arrow">›</text>
              </view>
            </picker>
          </view>
        </view>

        <view class="form-item row">
          <view class="label required">结束时间</view>
          <view class="date-time-wrap">
            <picker mode="date" value="{{formData.endDate}}" bindchange="onEndDateChange">
              <view class="picker-value small {{!formData.endDate ? 'placeholder' : ''}}">
                {{formData.endDate || '日期'}} <text class="arrow">›</text>
              </view>
            </picker>
            <picker mode="time" value="{{formData.endTime}}" bindchange="onEndTimeChange">
              <view class="picker-value small {{!formData.endTime ? 'placeholder' : ''}}">
                {{formData.endTime || '时间'}} <text class="arrow">›</text>
              </view>
            </picker>
          </view>
        </view>

        <view class="form-item row">
          <view class="label required">报名截止</view>
          <view class="date-time-wrap">
            <picker mode="date" value="{{formData.deadlineDate}}" bindchange="onDeadlineDateChange">
              <view class="picker-value small {{!formData.deadlineDate ? 'placeholder' : ''}}">
                {{formData.deadlineDate || '日期'}} <text class="arrow">›</text>
              </view>
            </picker>
            <picker mode="time" value="{{formData.deadlineTime}}" bindchange="onDeadlineTimeChange">
              <view class="picker-value small {{!formData.deadlineTime ? 'placeholder' : ''}}">
                {{formData.deadlineTime || '时间'}} <text class="arrow">›</text>
              </view>
            </picker>
          </view>
        </view>

        <view class="form-item">
          <view class="label required">活动地点</view>
          <input
            class="input"
            placeholder="请输入活动具体地点"
            value="{{formData.location}}"
            bindinput="onInputChange"
            data-field="location"
            maxlength="50"
          />
        </view>

        <view class="form-item row">
          <view class="label required">人数上限</view>
          <input
            class="input small"
            type="number"
            placeholder="0"
            value="{{formData.capacity}}"
            bindinput="onInputChange"
            data-field="capacity"
          />
        </view>

        <view class="form-item row">
          <view class="label">活动费用</view>
          <view style="display:flex;align-items:center;gap:8rpx;">
            <input
              class="input small"
              type="digit"
              placeholder="0"
              value="{{formData.fee}}"
              bindinput="onInputChange"
              data-field="fee"
            />
            <text class="unit">元</text>
          </view>
        </view>
      </view>

      <view class="form-card">
        <view class="card-title">活动详情</view>

        <view class="form-item">
          <view class="label required">详细描述</view>
          <textarea
            class="textarea"
            placeholder="请详细描述活动内容、流程安排、注意事项等..."
            value="{{formData.description}}"
            bindinput="onInputChange"
            data-field="description"
            maxlength="2000"
            auto-height="{{true}}"
          />
          <view class="text-count">{{formData.description.length || 0}}/2000</view>
        </view>

        <view class="form-item">
          <view class="label">活动标签</view>
          <view class="tags-wrap">
            <view class="tag" wx:for="{{formData.tags}}" wx:key="*this" bindtap="onRemoveTag" data-index="{{index}}">
              {{item}} <text class="close">×</text>
            </view>
            <view class="tag-input-wrap">
              <input
                class="tag-input"
                placeholder="添加标签"
                value="{{tagInput}}"
                bindinput="onTagInput"
                bindconfirm="onAddTag"
                maxlength="10"
              />
              <view class="add-tag-btn" bindtap="onAddTag">+</view>
            </view>
          </view>
          <view class="tag-hint">最多5个标签，回车或点击+号添加</view>
        </view>
      </view>

      <view class="form-card">
        <view class="card-title">联系方式</view>

        <view class="form-item">
          <view class="label">负责人</view>
          <input
            class="input"
            placeholder="请输入负责人姓名"
            value="{{formData.organizerName}}"
            bindinput="onInputChange"
            data-field="organizerName"
            maxlength="20"
          />
        </view>

        <view class="form-item">
          <view class="label">联系电话</view>
          <input
            class="input"
            type="number"
            placeholder="请输入联系电话"
            value="{{formData.organizerPhone}}"
            bindinput="onInputChange"
            data-field="organizerPhone"
            maxlength="20"
          />
        </view>
      </view>

      <view class="submit-wrap">
        <button
          class="submit-btn {{submitting ? 'disabled' : ''}}"
          bindtap="onSubmit"
          disabled="{{submitting}}"
          loading="{{submitting}}"
        >
          {{submitting ? '发布中...' : '立即发布'}}
        </button>
      </view>

    </view>
  </scroll-view>
</view>
