.page {
  min-height: 100vh;
  background-color: var(--color-bg-page);
  padding: 24rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.result-header {
  margin-bottom: 20rpx;
}

.result-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  line-height: 1.4;
  display: block;
  margin-bottom: 12rpx;
}

.result-desc {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  line-height: 1.6;
  display: block;
  margin-bottom: 20rpx;
}

.result-stats {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 40rpx;
  padding: 16rpx 0;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 800;
  color: var(--color-primary);
  line-height: 1;
}

.stat-label {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background-color: var(--color-border);
}

.chart-toggle {
  display: flex;
  background-color: var(--color-bg-input);
  border-radius: var(--radius-lg);
  padding: 6rpx;
  margin-bottom: 20rpx;
}

.toggle-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 0;
  font-size: 26rpx;
  font-weight: 500;
  color: var(--color-text-secondary);
  border-radius: var(--radius-md);
  transition: all var(--transition-fast);
}

.toggle-btn.active {
  background-color: var(--color-bg-card);
  color: var(--color-text-primary);
  box-shadow: var(--shadow-sm);
}

.toggle-btn:active {
  transform: scale(0.98);
}

.stat-card {
  margin-bottom: 20rpx;
}

.stat-question-header {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 8rpx;
  flex-wrap: wrap;
}

.stat-index {
  min-width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, var(--color-primary) 0%, #FF8E8E 100%);
  color: #FFFFFF;
  font-size: 22rpx;
  font-weight: 700;
  border-radius: 50%;
  flex-shrink: 0;
}

.stat-title {
  flex: 1;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  line-height: 1.5;
}

.stat-type-tag {
  padding: 4rpx 12rpx;
  font-size: 20rpx;
  font-weight: 600;
  border-radius: var(--radius-xs);
}

.stat-type-tag.single {
  color: var(--color-info);
  background-color: rgba(52, 152, 219, 0.1);
}

.stat-type-tag.multiple {
  color: var(--color-secondary);
  background-color: rgba(78, 205, 196, 0.1);
}

.stat-type-tag.fill {
  color: var(--color-warning);
  background-color: rgba(243, 156, 18, 0.1);
}

.stat-total {
  font-size: 24rpx;
  color: var(--color-text-muted);
  display: block;
  margin-bottom: 16rpx;
}

.chart-canvas {
  width: 100%;
  height: 300rpx;
  margin-bottom: 16rpx;
}

.legend {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx 20rpx;
  margin-bottom: 20rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.legend-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 4rpx;
  flex-shrink: 0;
}

.legend-label {
  font-size: 24rpx;
  color: var(--color-text-primary);
  max-width: 120rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.legend-count {
  font-size: 22rpx;
  color: var(--color-text-muted);
}

.legend-percent {
  font-size: 22rpx;
  font-weight: 600;
  color: var(--color-primary);
}

.progress-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.progress-item {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.progress-label-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.progress-label {
  font-size: 26rpx;
  color: var(--color-text-primary);
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.progress-percent {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--color-primary);
  flex-shrink: 0;
  margin-left: 12rpx;
}

.progress-bar {
  height: 16rpx;
  background-color: var(--color-bg-input);
  border-radius: 8rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: 8rpx;
  transition: width 0.6s ease;
  min-width: 4rpx;
}

.fill-responses {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.fill-response-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  padding: 16rpx;
  background-color: var(--color-bg-input);
  border-radius: var(--radius-md);
}

.response-avatar {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, var(--color-primary) 0%, #FF8E8E 100%);
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: 600;
  border-radius: 50%;
  flex-shrink: 0;
}

.response-text {
  flex: 1;
  font-size: 28rpx;
  color: var(--color-text-primary);
  line-height: 1.6;
  padding-top: 8rpx;
}

.no-response {
  padding: 24rpx;
  text-align: center;
}

.no-response text {
  font-size: 26rpx;
  color: var(--color-text-muted);
}
