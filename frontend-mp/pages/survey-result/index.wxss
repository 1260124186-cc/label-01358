.page {
  min-height: 100vh;
  background-color: var(--color-bg-page);
  padding: 24rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.result-header {
  margin-bottom: 20rpx;
}

.result-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  line-height: 1.4;
  display: block;
  margin-bottom: 12rpx;
}

.result-desc {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  line-height: 1.6;
  display: block;
  margin-bottom: 20rpx;
}

.result-stats {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 0;
  gap: 40rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 800;
  color: var(--color-primary);
  line-height: 1;
}

.stat-label {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background-color: var(--color-border);
}

.no-permission-banner {
  padding: 24rpx;
  background-color: rgba(239, 68, 68, 0.08);
  border-radius: var(--radius-lg);
  margin-top: 16rpx;
}

.no-permission-text {
  font-size: 28rpx;
  color: var(--color-danger);
  font-weight: 500;
}

.action-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
  gap: 16rpx;
}

.chart-toggle {
  display: flex;
  background-color: var(--color-bg-input);
  border-radius: var(--radius-lg);
  padding: 6rpx;
  flex-shrink: 0;
}

.toggle-btn {
  padding: 16rpx 24rpx;
  font-size: 26rpx;
  font-weight: 500;
  color: var(--color-text-secondary);
  border-radius: var(--radius-md);
  transition: all var(--transition-fast);
}

.toggle-btn.active {
  background-color: var(--color-bg-card);
  color: var(--color-text-primary);
  box-shadow: var(--shadow-sm);
}

.toggle-btn:active {
  transform: scale(0.98);
}

.action-btns {
  display: flex;
  gap: 12rpx;
}

.action-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 12rpx 20rpx;
  background-color: var(--color-bg-input);
  border-radius: var(--radius-lg);
}

.action-btn-icon {
  font-size: 28rpx;
}

.action-btn-text {
  font-size: 24rpx;
  font-weight: 500;
  color: var(--color-text-primary);
}

.action-btn:active {
  transform: scale(0.96);
}

.stat-card {
  margin-bottom: 20rpx;
}

.stat-question-header {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
  flex-wrap: wrap;
  gap: 10rpx;
}

.stat-index {
  min-width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, var(--color-primary) 0%, #FF8E8E 100%);
  color: #FFFFFF;
  font-size: 22rpx;
  font-weight: 700;
  border-radius: 50%;
  flex-shrink: 0;
}

.stat-title {
  flex: 1;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  line-height: 1.5;
}

.stat-type-tag {
  padding: 4rpx 12rpx;
  font-size: 20rpx;
  font-weight: 600;
  border-radius: var(--radius-xs);
}

.stat-type-tag.single {
  color: var(--color-info);
  background-color: rgba(52, 152, 219, 0.1);
}

.stat-type-tag.multiple {
  color: var(--color-secondary);
  background-color: rgba(78, 205, 196, 0.1);
}

.stat-type-tag.fill {
  color: var(--color-warning);
  background-color: rgba(243, 156, 18, 0.1);
}

.stat-type-tag.nps {
  color: #8B5CF6;
  background-color: rgba(139, 92, 246, 0.1);
}

.stat-type-tag.likert {
  color: #F59E0B;
  background-color: rgba(245, 158, 11, 0.1);
}

.stat-type-tag.date {
  color: #10B981;
  background-color: rgba(16, 185, 129, 0.1);
}

.stat-total {
  font-size: 24rpx;
  color: var(--color-text-muted);
  display: block;
  margin-bottom: 16rpx;
}

.chart-canvas {
  width: 100%;
  height: 300rpx;
  margin-bottom: 16rpx;
}

.legend {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.legend-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 4rpx;
  flex-shrink: 0;
}

.legend-label {
  font-size: 24rpx;
  color: var(--color-text-primary);
  max-width: 120rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.legend-count {
  font-size: 22rpx;
  color: var(--color-text-muted);
}

.legend-percent {
  font-size: 22rpx;
  font-weight: 600;
  color: var(--color-primary);
}

.progress-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.progress-item {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.progress-label-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.progress-label {
  font-size: 26rpx;
  color: var(--color-text-primary);
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.progress-percent {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--color-primary);
  flex-shrink: 0;
  margin-left: 12rpx;
}

.progress-bar {
  height: 16rpx;
  background-color: var(--color-bg-input);
  border-radius: 8rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: 8rpx;
  transition: width 0.6s ease;
  min-width: 4rpx;
}

.nps-summary {
  display: flex;
  gap: 20rpx;
  margin-bottom: 16rpx;
}

.nps-score-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  background-color: var(--color-bg-input);
  border-radius: var(--radius-lg);
}

.nps-score-value {
  font-size: 44rpx;
  font-weight: 800;
  color: #8B5CF6;
  line-height: 1;
}

.nps-score-label {
  font-size: 22rpx;
  color: var(--color-text-muted);
  margin-top: 8rpx;
}

.nps-categories {
  display: flex;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.nps-category {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx;
  border-radius: var(--radius-lg);
}

.nps-category.detractor {
  background-color: rgba(239, 68, 68, 0.1);
}

.nps-category.passive {
  background-color: rgba(245, 158, 11, 0.1);
}

.nps-category.promoter {
  background-color: rgba(16, 185, 129, 0.1);
}

.nps-cat-count {
  font-size: 32rpx;
  font-weight: 700;
}

.nps-category.detractor .nps-cat-count {
  color: #EF4444;
}

.nps-category.passive .nps-cat-count {
  color: #F59E0B;
}

.nps-category.promoter .nps-cat-count {
  color: #10B981;
}

.nps-cat-label {
  font-size: 22rpx;
  color: var(--color-text-muted);
  margin-top: 4rpx;
}

.likert-summary {
  margin-bottom: 16rpx;
}

.likert-avg {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  background-color: var(--color-bg-input);
  border-radius: var(--radius-lg);
}

.likert-avg-value {
  font-size: 44rpx;
  font-weight: 800;
  color: #F59E0B;
  line-height: 1;
}

.likert-avg-label {
  font-size: 22rpx;
  color: var(--color-text-muted);
  margin-top: 8rpx;
}

.likert-distribution {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.likert-dist-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.likert-dist-label {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  min-width: 120rpx;
  flex-shrink: 0;
}

.likert-dist-bar {
  flex: 1;
  height: 16rpx;
  background-color: var(--color-bg-input);
  border-radius: 8rpx;
  overflow: hidden;
}

.likert-dist-fill {
  height: 100%;
  border-radius: 8rpx;
  transition: width 0.6s ease;
  min-width: 4rpx;
}

.likert-fill-1 { background-color: #EF4444; }
.likert-fill-2 { background-color: #F97316; }
.likert-fill-3 { background-color: #F59E0B; }
.likert-fill-4 { background-color: #84CC16; }
.likert-fill-5 { background-color: #10B981; }

.likert-dist-count {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  min-width: 40rpx;
  text-align: right;
}

.date-answers {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.date-answer-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 14rpx 20rpx;
  background-color: var(--color-bg-input);
  border-radius: var(--radius-md);
}

.date-answer-icon {
  font-size: 28rpx;
}

.date-answer-text {
  font-size: 28rpx;
  color: var(--color-text-primary);
}

.tag-cloud {
  margin-bottom: 20rpx;
}

.tag-cloud-title {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text-secondary);
  margin-bottom: 16rpx;
}

.tag-cloud-container {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx 16rpx;
  padding: 16rpx;
  background-color: var(--color-bg-input);
  border-radius: var(--radius-lg);
}

.tag-item {
  font-weight: 600;
  line-height: 1.4;
  padding: 4rpx 8rpx;
}

.tag-count {
  font-size: 18rpx;
  font-weight: 400;
  opacity: 0.7;
}

.fill-responses {
  margin-top: 16rpx;
}

.fill-responses-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx;
  background-color: var(--color-bg-input);
  border-radius: var(--radius-lg);
}

.fill-responses-title {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.fill-toggle-icon {
  font-size: 24rpx;
  color: var(--color-primary);
  font-weight: 500;
}

.fill-responses-list {
  margin-top: 12rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.fill-response-item {
  display: flex;
  align-items: flex-start;
  padding: 16rpx;
  background-color: var(--color-bg-input);
  border-radius: var(--radius-md);
  gap: 12rpx;
}

.response-avatar {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, var(--color-primary) 0%, #FF8E8E 100%);
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: 600;
  border-radius: 50%;
  flex-shrink: 0;
}

.response-text {
  flex: 1;
  font-size: 28rpx;
  color: var(--color-text-primary);
  line-height: 1.6;
  padding-top: 8rpx;
}

.no-response {
  padding: 24rpx;
  text-align: center;
}

.no-response text {
  font-size: 26rpx;
  color: var(--color-text-muted);
}

.csv-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 999;
}

.csv-modal {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  max-height: 80vh;
  background-color: var(--color-bg-card);
  border-radius: 24rpx 24rpx 0 0;
  z-index: 1000;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  display: flex;
  flex-direction: column;
}

.csv-modal.show {
  transform: translateY(0);
}

.csv-modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  border-bottom: 2rpx solid var(--color-border-light);
}

.csv-modal-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

.csv-modal-close {
  font-size: 32rpx;
  color: var(--color-text-muted);
  padding: 8rpx;
}

.csv-modal-body {
  flex: 1;
  padding: 24rpx 32rpx;
  max-height: 60vh;
}

.csv-text {
  font-size: 24rpx;
  font-family: monospace;
  color: var(--color-text-primary);
  line-height: 1.6;
  white-space: pre-wrap;
  word-break: break-all;
}

.csv-modal-footer {
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  border-top: 2rpx solid var(--color-border-light);
}

.csv-copy-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  background: linear-gradient(135deg, var(--color-primary) 0%, #FF8E8E 100%);
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: var(--radius-lg);
}

.csv-copy-btn:active {
  opacity: 0.8;
}
