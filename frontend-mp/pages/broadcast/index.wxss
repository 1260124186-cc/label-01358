/* 校园广播播放器增强版 */
.page {
  min-height: 100vh;
  background-color: var(--color-bg-page);
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

/* ==================== 分类切换 ==================== */
.category-tabs {
  padding: 20rpx 24rpx 0;
  position: sticky;
  top: 0;
  z-index: 10;
  background-color: var(--color-bg-page);
}

.category-scroll {
  white-space: nowrap;
}

.category-list {
  display: inline-flex;
  padding: 4rpx 0;
}

.category-item {
  display: inline-flex;
  align-items: center;
  margin-right: 16rpx;
  padding: 16rpx 28rpx;
  background-color: var(--color-bg-card);
  border-radius: 40rpx;
  transition: all var(--transition-fast);
  box-shadow: var(--shadow-sm);
}

.category-item:last-child {
  margin-right: 0;
}

.category-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.category-icon:last-child {
  margin-right: 0;
}

.category-name {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  font-weight: 500;
}

.category-item.active {
  background: linear-gradient(135deg, var(--color-primary) 0%, #FF8E8E 100%);
  box-shadow: 0 6rpx 20rpx rgba(255, 107, 107, 0.35);
}

.category-item.active .category-name {
  color: #FFFFFF;
  font-weight: 600;
}

.category-item:active {
  transform: scale(0.96);
}

/* ==================== 播放器区域 ==================== */
.player-section {
  padding: 24rpx;
}

.player-card {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 50%, #FFB88C 100%);
  border-radius: var(--radius-2xl);
  padding: 32rpx;
  box-shadow: 0 12rpx 40rpx rgba(255, 107, 107, 0.35);
  position: relative;
  overflow: hidden;
}

.player-card::before {
  content: '';
  position: absolute;
  top: -30%;
  right: -20%;
  width: 300rpx;
  height: 300rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.player-card::after {
  content: '';
  position: absolute;
  bottom: -20%;
  left: -10%;
  width: 200rpx;
  height: 200rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 50%;
}

/* 播放器头部 */
.player-header {
  display: flex;
  align-items: flex-start;
  position: relative;
  z-index: 1;
  margin-bottom: 24rpx;
}

.player-cover {
  width: 140rpx;
  height: 140rpx;
  border-radius: var(--radius-lg);
  flex-shrink: 0;
  box-shadow: var(--shadow-md);
}

.player-info {
  flex: 1;
  margin-left: 20rpx;
  margin-right: 16rpx;
  color: #FFFFFF;
}

.player-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  overflow: hidden;
}

.player-desc {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-bottom: 6rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  overflow: hidden;
}

.player-anchor {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
}

.favorite-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: rgba(255, 255, 255, 0.25);
  backdrop-filter: blur(10rpx);
  -webkit-backdrop-filter: blur(10rpx);
  border-radius: 50%;
  flex-shrink: 0;
}

.favorite-icon {
  font-size: 32rpx;
}

.favorite-icon.active {
  animation: heartBeat 0.3s ease;
}

@keyframes heartBeat {
  0% { transform: scale(1); }
  50% { transform: scale(1.3); }
  100% { transform: scale(1); }
}

/* ==================== 歌词/文稿区域 ==================== */
.lyrics-section {
  position: relative;
  z-index: 1;
  margin-bottom: 20rpx;
}

.lyrics-toggle {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx 0;
}

.lyrics-toggle-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-right: 8rpx;
}

.lyrics-toggle-text:last-child {
  margin-right: 0;
}

.lyrics-toggle-icon {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.6);
}

.lyrics-container {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.3s ease;
}

.lyrics-container.expanded {
  max-height: 400rpx;
}

.lyrics-scroll {
  height: 360rpx;
  background-color: rgba(255, 255, 255, 0.12);
  backdrop-filter: blur(10rpx);
  -webkit-backdrop-filter: blur(10rpx);
  border-radius: var(--radius-lg);
  padding: 20rpx;
}

.lyrics-list {
  padding: 160rpx 0;
}

.lyric-item {
  padding: 16rpx 0;
  text-align: center;
  transition: all 0.3s ease;
}

.lyric-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
  line-height: 1.6;
}

.lyric-item.active .lyric-text {
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

/* ==================== 进度条 ==================== */
.progress-wrap {
  margin-bottom: 24rpx;
  position: relative;
  z-index: 1;
}

.progress-slider {
  margin: 0 -16rpx;
}

.progress-time {
  display: flex;
  justify-content: space-between;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 4rpx;
}

/* ==================== 播放控制 ==================== */
.player-controls {
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  z-index: 1;
  margin-bottom: 24rpx;
}

.control-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: rgba(255, 255, 255, 0.25);
  backdrop-filter: blur(10rpx);
  -webkit-backdrop-filter: blur(10rpx);
  border-radius: 50%;
  transition: all var(--transition-fast);
  box-sizing: border-box;
  margin-right: 24rpx;
}

.control-btn:last-child {
  margin-right: 0;
}

.control-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
  font-size: 32rpx;
  color: #FFFFFF;
}

.control-btn:active {
  transform: scale(0.92);
  background-color: rgba(255, 255, 255, 0.35);
}

.control-btn.play-btn {
  width: 112rpx;
  height: 112rpx;
  background-color: #FFFFFF;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
}

.control-btn.play-btn .control-icon {
  color: var(--color-primary);
  font-size: 40rpx;
  margin-left: 6rpx;
}

.control-btn.play-btn:active {
  transform: scale(0.94);
}

.mode-btn .control-icon {
  font-size: 28rpx;
}

.rate-btn .rate-text {
  font-size: 22rpx;
  color: #FFFFFF;
  font-weight: 600;
}

/* ==================== 倍速选择器 ==================== */
.rate-picker {
  position: absolute;
  right: 24rpx;
  bottom: 180rpx;
  background-color: #FFFFFF;
  border-radius: var(--radius-lg);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.15);
  padding: 8rpx 0;
  opacity: 0;
  transform: translateY(10rpx);
  pointer-events: none;
  transition: all 0.2s ease;
  z-index: 20;
}

.rate-picker.show {
  opacity: 1;
  transform: translateY(0);
  pointer-events: auto;
}

.picker-arrow {
  position: absolute;
  bottom: -12rpx;
  right: 28rpx;
  width: 0;
  height: 0;
  border-left: 12rpx solid transparent;
  border-right: 12rpx solid transparent;
  border-top: 12rpx solid #FFFFFF;
}

.rate-option {
  padding: 16rpx 32rpx;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  text-align: center;
  transition: all 0.2s ease;
}

.rate-option:active {
  background-color: var(--color-bg-page);
}

.rate-option.active {
  color: var(--color-primary);
  font-weight: 600;
}

/* ==================== 底部工具区 ==================== */
.bottom-tools {
  display: flex;
  justify-content: space-around;
  position: relative;
  z-index: 1;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.15);
}

.tool-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 8rpx 24rpx;
}

.tool-icon {
  font-size: 32rpx;
  margin-bottom: 6rpx;
}

.tool-icon:last-child {
  margin-bottom: 0;
}

.tool-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
  max-width: 160rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ==================== 定时关闭选择器 ==================== */
.sleep-picker {
  position: absolute;
  left: 24rpx;
  bottom: 180rpx;
  background-color: #FFFFFF;
  border-radius: var(--radius-lg);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.15);
  padding: 8rpx 0;
  opacity: 0;
  transform: translateY(10rpx);
  pointer-events: none;
  transition: all 0.2s ease;
  z-index: 20;
}

.sleep-picker.show {
  opacity: 1;
  transform: translateY(0);
  pointer-events: auto;
}

.sleep-arrow {
  position: absolute;
  bottom: -12rpx;
  left: 36rpx;
  right: auto;
  border-left: 12rpx solid transparent;
  border-right: 12rpx solid transparent;
  border-top: 12rpx solid #FFFFFF;
}

.sleep-option {
  padding: 16rpx 32rpx;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  text-align: center;
  transition: all 0.2s ease;
}

.sleep-option:active {
  background-color: var(--color-bg-page);
}

.sleep-option.active {
  color: var(--color-primary);
  font-weight: 600;
}

/* ==================== 列表 Tab 切换 ==================== */
.list-tabs {
  display: flex;
  padding: 0 24rpx;
  margin-bottom: 16rpx;
}

.list-tab {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 8rpx;
  padding: 20rpx 16rpx;
  background-color: var(--color-bg-card);
  border-radius: var(--radius-lg);
  font-size: 26rpx;
  color: var(--color-text-secondary);
  transition: all var(--transition-fast);
  box-shadow: var(--shadow-sm);
}

.list-tab:last-child {
  margin-right: 0;
}

.list-tab.active {
  background: linear-gradient(135deg, var(--color-primary) 0%, #FF8E8E 100%);
  color: #FFFFFF;
  font-weight: 600;
  box-shadow: 0 6rpx 20rpx rgba(255, 107, 107, 0.3);
}

.tab-badge {
  min-width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  padding: 0 8rpx;
  background-color: rgba(255, 255, 255, 0.3);
  border-radius: 16rpx;
  font-size: 20rpx;
  text-align: center;
  margin-left: 8rpx;
}

/* ==================== 列表区域 ==================== */
.list-section {
  padding: 0 24rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.section-title-wrap {
  display: flex;
  align-items: center;
}

.section-icon {
  width: 8rpx;
  height: 32rpx;
  background: linear-gradient(180deg, var(--color-primary) 0%, #FF8E8E 100%);
  border-radius: 4rpx;
  margin-right: 12rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

.section-count {
  font-size: 24rpx;
  color: var(--color-text-muted);
}

.broadcast-list {
  background-color: var(--color-bg-card);
  border-radius: var(--radius-2xl);
  overflow: hidden;
  box-shadow: var(--shadow-card);
}

.broadcast-item {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  transition: all var(--transition-fast);
}

.broadcast-item:not(:last-child) {
  border-bottom: 1rpx solid var(--color-border-light);
}

.broadcast-item:active {
  background-color: var(--color-bg-page);
}

.broadcast-item.active {
  background: linear-gradient(135deg, rgba(255, 107, 107, 0.08) 0%, rgba(255, 142, 142, 0.05) 100%);
}

.broadcast-cover {
  width: 96rpx;
  height: 96rpx;
  border-radius: var(--radius-lg);
  flex-shrink: 0;
  box-shadow: var(--shadow-sm);
}

.broadcast-info {
  flex: 1;
  margin-left: 20rpx;
  margin-right: 16rpx;
  min-width: 0;
}

.broadcast-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 6rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  overflow: hidden;
}

.broadcast-item.active .broadcast-title {
  color: var(--color-primary);
}

.broadcast-desc {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-bottom: 8rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  overflow: hidden;
}

.broadcast-meta {
  display: flex;
  align-items: center;
}

.meta-tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  background-color: rgba(255, 107, 107, 0.1);
  color: var(--color-primary);
  border-radius: 20rpx;
  font-weight: 500;
  margin-right: 12rpx;
}

.meta-tag:last-child {
  margin-right: 0;
}

.meta-duration {
  font-size: 20rpx;
  color: var(--color-text-muted);
}

.broadcast-actions {
  flex-shrink: 0;
  display: flex;
  align-items: center;
}

.action-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12rpx;
}

.action-btn:last-child {
  margin-right: 0;
}

.action-icon {
  font-size: 28rpx;
}

.broadcast-status {
  flex-shrink: 0;
}

.status-text {
  font-size: 24rpx;
  color: var(--color-primary);
  font-weight: 500;
}

/* 播放动画 */
.playing-indicator {
  display: flex;
  align-items: flex-end;
  height: 32rpx;
}

.playing-indicator .bar {
  width: 6rpx;
  background: linear-gradient(180deg, var(--color-primary) 0%, #FF8E8E 100%);
  border-radius: 3rpx;
  animation: sound 0.5s ease infinite alternate;
  margin-right: 4rpx;
}

.playing-indicator .bar:last-child {
  margin-right: 0;
}

.playing-indicator .bar:nth-child(1) {
  height: 12rpx;
  animation-delay: 0s;
}

.playing-indicator .bar:nth-child(2) {
  height: 24rpx;
  animation-delay: 0.2s;
}

.playing-indicator .bar:nth-child(3) {
  height: 16rpx;
  animation-delay: 0.4s;
}

@keyframes sound {
  0% { height: 8rpx; }
  100% { height: 32rpx; }
}

/* ==================== 空状态 ==================== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
  background-color: var(--color-bg-card);
  border-radius: var(--radius-2xl);
  box-shadow: var(--shadow-card);
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 30rpx;
  color: var(--color-text-secondary);
  font-weight: 500;
  margin-bottom: 8rpx;
}

.empty-desc {
  font-size: 24rpx;
  color: var(--color-text-muted);
}

/* ==================== 暗色模式 ==================== */
.dark .category-tabs {
  background-color: #0F1117;
}

.dark .category-item {
  background-color: #1A1D26;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
}

.dark .category-name {
  color: var(--color-text-secondary);
}

.dark .category-item.active {
  box-shadow: 0 6rpx 20rpx rgba(192, 64, 64, 0.4);
}

.dark .player-card {
  background: linear-gradient(135deg, #8B3A3A 0%, #9E5050 50%, #8B6B50 100%);
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.5);
}

.dark .player-card::before {
  background: rgba(255, 255, 255, 0.06);
}

.dark .player-card::after {
  background: rgba(255, 255, 255, 0.04);
}

.dark .player-title {
  text-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.4);
}

.dark .player-desc {
  color: rgba(255, 255, 255, 0.9);
}

.dark .progress-time {
  color: rgba(255, 255, 255, 0.85);
}

.dark .control-btn {
  background-color: rgba(255, 255, 255, 0.2);
}

.dark .control-btn:active {
  background-color: rgba(255, 255, 255, 0.3);
}

.dark .control-btn.play-btn {
  background-color: #FFFFFF;
}

.dark .control-btn.play-btn .control-icon {
  color: #C04040;
}

.dark .rate-picker,
.dark .sleep-picker {
  background-color: #1A1D26;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.5);
}

.dark .picker-arrow {
  border-top-color: #1A1D26;
}

.dark .rate-option,
.dark .sleep-option {
  color: var(--color-text-secondary);
}

.dark .rate-option:active,
.dark .sleep-option:active {
  background-color: #252832;
}

.dark .rate-option.active,
.dark .sleep-option.active {
  color: #FF8E8E;
}

.dark .bottom-tools {
  border-top-color: rgba(255, 255, 255, 0.1);
}

.dark .list-tab {
  background-color: #1A1D26;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
}

.dark .list-tab.active {
  box-shadow: 0 6rpx 20rpx rgba(192, 64, 64, 0.35);
}

.dark .broadcast-list {
  background-color: #1A1D26;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.3);
}

.dark .broadcast-item:not(:last-child) {
  border-bottom-color: #252832;
}

.dark .broadcast-item:active {
  background-color: #252832;
}

.dark .broadcast-item.active {
  background: linear-gradient(135deg, rgba(255, 138, 138, 0.12) 0%, rgba(255, 142, 142, 0.06) 100%);
}

.dark .meta-tag {
  background-color: rgba(255, 138, 138, 0.15);
}

.dark .empty-state {
  background-color: #1A1D26;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.3);
}

.dark .lyrics-scroll {
  background-color: rgba(0, 0, 0, 0.2);
}
