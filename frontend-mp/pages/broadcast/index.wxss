/* 校园广播 - 与首页风格统一 */
.page {
  min-height: 100vh;
  background-color: var(--color-bg-page);
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

/* ==================== 播放器区域 ==================== */
.player-section {
  padding: 24rpx;
}

.player-card {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 50%, #FFB88C 100%);
  border-radius: var(--radius-2xl);
  padding: 32rpx;
  box-shadow: 0 12rpx 40rpx rgba(255, 107, 107, 0.35);
  position: relative;
  overflow: hidden;
}

.player-card::before {
  content: '';
  position: absolute;
  top: -30%;
  right: -20%;
  width: 300rpx;
  height: 300rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.player-card::after {
  content: '';
  position: absolute;
  bottom: -20%;
  left: -10%;
  width: 200rpx;
  height: 200rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 50%;
}

.player-cover {
  width: 100%;
  height: 300rpx;
  border-radius: var(--radius-xl);
  margin-bottom: 28rpx;
  box-shadow: var(--shadow-lg);
  position: relative;
  z-index: 1;
}

.player-info {
  color: #FFFFFF;
  position: relative;
  z-index: 1;
}

.player-title {
  display: block;
  font-size: 38rpx;
  font-weight: 700;
  margin-bottom: 10rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
}

.player-desc {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-bottom: 28rpx;
}

/* 进度条 */
.progress-wrap {
  margin-bottom: 28rpx;
}

.progress-slider {
  margin: 0 -16rpx;
}

.progress-time {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 8rpx;
}

/* 控制按钮 */
.player-controls {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 48rpx;
}

.control-btn {
  width: 88rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: rgba(255, 255, 255, 0.25);
  backdrop-filter: blur(10rpx);
  -webkit-backdrop-filter: blur(10rpx);
  border-radius: 50%;
  transition: all var(--transition-fast);
  box-sizing: border-box;
}

.control-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
  font-size: 36rpx;
  color: #FFFFFF;
}

.control-btn:active {
  transform: scale(0.92);
  background-color: rgba(255, 255, 255, 0.35);
}

.control-btn.play-btn {
  width: 120rpx;
  height: 120rpx;
  background-color: #FFFFFF;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
}

.control-btn.play-btn .control-icon {
  color: var(--color-primary);
  font-size: 44rpx;
  /* 三角形字符需要微调位置实现视觉居中 */
  margin-left: 6rpx;
}

/* ==================== 列表区域 ==================== */
.list-section {
  padding: 0 24rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-title-wrap {
  display: flex;
  align-items: center;
}

.section-icon {
  width: 8rpx;
  height: 32rpx;
  background: linear-gradient(180deg, var(--color-primary) 0%, #FF8E8E 100%);
  border-radius: 4rpx;
  margin-right: 12rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

.section-count {
  font-size: 26rpx;
  color: var(--color-text-muted);
}

.broadcast-list {
  background-color: var(--color-bg-card);
  border-radius: var(--radius-2xl);
  overflow: hidden;
  box-shadow: var(--shadow-card);
}

.broadcast-item {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  transition: all var(--transition-fast);
}

.broadcast-item:not(:last-child) {
  border-bottom: 1rpx solid var(--color-border-light);
}

.broadcast-item:active {
  background-color: var(--color-bg-page);
}

.broadcast-item.active {
  background: linear-gradient(135deg, rgba(255, 107, 107, 0.08) 0%, rgba(255, 142, 142, 0.05) 100%);
}

.broadcast-cover {
  width: 100rpx;
  height: 100rpx;
  border-radius: var(--radius-lg);
  flex-shrink: 0;
  box-shadow: var(--shadow-sm);
}

.broadcast-info {
  flex: 1;
  margin-left: 20rpx;
  margin-right: 16rpx;
}

.broadcast-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 6rpx;
}

.broadcast-item.active .broadcast-title {
  color: var(--color-primary);
}

.broadcast-desc {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-bottom: 6rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  overflow: hidden;
}

.broadcast-duration {
  font-size: 22rpx;
  color: var(--color-text-muted);
}

.broadcast-status {
  flex-shrink: 0;
}

.status-text {
  font-size: 24rpx;
  color: var(--color-primary);
  font-weight: 500;
}

/* 播放动画 */
.playing-indicator {
  display: flex;
  align-items: flex-end;
  gap: 4rpx;
  height: 32rpx;
}

.playing-indicator .bar {
  width: 6rpx;
  background: linear-gradient(180deg, var(--color-primary) 0%, #FF8E8E 100%);
  border-radius: 3rpx;
  animation: sound 0.5s ease infinite alternate;
}

.playing-indicator .bar:nth-child(1) {
  height: 12rpx;
  animation-delay: 0s;
}

.playing-indicator .bar:nth-child(2) {
  height: 24rpx;
  animation-delay: 0.2s;
}

.playing-indicator .bar:nth-child(3) {
  height: 16rpx;
  animation-delay: 0.4s;
}

@keyframes sound {
  0% { height: 8rpx; }
  100% { height: 32rpx; }
}

/* ==================== 暗色模式 - 播放器对比度增强 ==================== */
page.dark .player-card {
  background: linear-gradient(135deg, #8B3A3A 0%, #9E5050 50%, #8B6B50 100%);
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.5);
}

page.dark .player-card::before {
  background: rgba(255, 255, 255, 0.06);
}

page.dark .player-card::after {
  background: rgba(255, 255, 255, 0.04);
}

page.dark .player-title {
  text-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.4);
}

page.dark .player-desc {
  color: rgba(255, 255, 255, 0.9);
}

page.dark .progress-time {
  color: rgba(255, 255, 255, 0.85);
}

page.dark .control-btn {
  background-color: rgba(255, 255, 255, 0.2);
}

page.dark .control-btn:active {
  background-color: rgba(255, 255, 255, 0.3);
}

page.dark .control-btn.play-btn {
  background-color: #FFFFFF;
}

page.dark .control-btn.play-btn .control-icon {
  color: #C04040;
}

page.dark .broadcast-item:active {
  background-color: var(--color-bg-input);
}

page.dark .broadcast-item.active {
  background: linear-gradient(135deg, rgba(255, 138, 138, 0.12) 0%, rgba(255, 142, 142, 0.06) 100%);
}
