/* 学习悬赏大厅 - 列表样式 */
.page {
  min-height: 100vh;
  background-color: var(--color-bg-page);
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
}

/* ==================== 顶部积分卡片 ==================== */
.header-section {
  padding: 24rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.points-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: var(--radius-xl);
  backdrop-filter: blur(10rpx);
  -webkit-backdrop-filter: blur(10rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
}

.points-card:active {
  transform: scale(0.98);
  transition: transform var(--transition-fast);
}

.points-info {
  display: flex;
  flex-direction: column;
}

.points-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 8rpx;
}

.points-value {
  font-size: 48rpx;
  font-weight: 800;
  color: #FFFFFF;
  line-height: 1.2;
}

.points-action {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.25);
  padding: 16rpx 24rpx;
  border-radius: var(--radius-full);
}

.points-action-text {
  font-size: 26rpx;
  color: #FFFFFF;
  font-weight: 600;
}

.points-arrow {
  font-size: 32rpx;
  color: #FFFFFF;
  margin-left: 8rpx;
  font-weight: 300;
}

/* ==================== 筛选区域 ==================== */
.filter-section {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background-color: var(--color-bg-card);
  border-bottom: 1rpx solid var(--color-border-light);
  position: sticky;
  top: 0;
  z-index: 100;
}

.filter-scroll {
  flex: 1;
  white-space: nowrap;
}

.filter-tabs {
  display: inline-flex;
  padding-right: 16rpx;
}

.filter-tabs > view { margin-right: 12rpx; }

.filter-tabs > view:last-child { margin-right: 0; }

.filter-btn {
  display: inline-flex;
  align-items: center;
  padding: 14rpx 20rpx;
  font-size: 26rpx;
  font-weight: 500;
  color: var(--color-text-secondary);
  background-color: var(--color-bg-input);
  border-radius: var(--radius-full);
  transition: all var(--transition-fast);
  flex-shrink: 0;
}

.filter-btn:active {
  transform: scale(0.96);
}

.filter-btn.active {
  color: #FFFFFF;
  background: linear-gradient(135deg, var(--color-primary) 0%, #FF8E8E 100%);
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 107, 0.3);
}

.filter-btn.active .filter-btn-text,
.filter-btn.active .filter-btn-arrow,
.filter-btn.active .filter-btn-icon {
  color: #FFFFFF;
}

.filter-btn.sort-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.filter-btn.sort-btn .filter-btn-text,
.filter-btn.sort-btn .filter-btn-icon {
  color: #FFFFFF;
}

.filter-btn-text {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.filter-btn-arrow {
  font-size: 20rpx;
  color: var(--color-text-muted);
  margin-left: 6rpx;
}

.filter-btn-icon {
  font-size: 24rpx;
  margin-right: 6rpx;
}

/* ==================== 列表区域 ==================== */
.list-scroll {
  height: calc(100vh - 280rpx);
}

.list-container {
  padding: 24rpx;
}

/* ==================== 悬赏卡片 ==================== */
.reward-card {
  background-color: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-card);
  transition: all var(--transition-fast);
}

.reward-card:last-child {
  margin-bottom: 0;
}

.reward-card:active {
  transform: scale(0.98);
  box-shadow: var(--shadow-sm);
}

.card-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.card-title {
  flex: 1;
  margin-right: 16rpx;
}

.title-text {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.status-tag {
  padding: 8rpx 16rpx;
  font-size: 22rpx;
  font-weight: 600;
  border-radius: var(--radius-md);
  white-space: nowrap;
  flex-shrink: 0;
}

.card-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.meta-item {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 16rpx;
  background-color: var(--color-bg-input);
  border-radius: var(--radius-md);
}

.meta-icon {
  font-size: 22rpx;
  margin-right: 6rpx;
}

.meta-text {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--color-border-light);
  margin-bottom: 16rpx;
}

.reward-points {
  display: flex;
  align-items: baseline;
}

.points-icon {
  font-size: 28rpx;
  margin-right: 6rpx;
}

.points-value {
  font-size: 40rpx;
  font-weight: 800;
  color: var(--color-primary);
  line-height: 1;
}

.points-label {
  font-size: 24rpx;
  color: var(--color-text-muted);
  margin-left: 4rpx;
}

.card-stats {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.stat-item {
  display: flex;
  align-items: center;
}

.stat-icon {
  font-size: 22rpx;
  margin-right: 4rpx;
}

.stat-text {
  font-size: 24rpx;
  color: var(--color-text-muted);
}

.card-publisher {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.publisher-info {
  display: flex;
  align-items: center;
}

.publisher-credit-icon {
  font-size: 24rpx;
  margin-right: 6rpx;
}

.publisher-name {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-right: 12rpx;
}

.publisher-credit {
  font-size: 22rpx;
  font-weight: 600;
  padding: 4rpx 10rpx;
  background-color: currentColor;
  opacity: 0.1;
  border-radius: var(--radius-sm);
}

.publish-time {
  font-size: 22rpx;
  color: var(--color-text-muted);
}

/* ==================== 加载更多 ==================== */
.load-more {
  padding: 32rpx 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.load-more-loading {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.loading-spinner {
  width: 32rpx;
  height: 32rpx;
  border: 3rpx solid var(--color-border);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.load-more-text {
  font-size: 24rpx;
  color: var(--color-text-muted);
}

.load-more-no-more .load-more-text,
.load-more-tip .load-more-text {
  color: var(--color-text-muted);
}

/* ==================== 发布按钮 ==================== */
.publish-btn {
  position: fixed;
  right: 32rpx;
  bottom: calc(200rpx + env(safe-area-inset-bottom));
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, var(--color-primary) 0%, #FF8E8E 100%);
  border-radius: 50%;
  box-shadow: 0 8rpx 32rpx rgba(255, 107, 107, 0.45);
  transition: all var(--transition-normal);
  z-index: 100;
}

.publish-btn::before {
  content: '';
  position: absolute;
  top: -8rpx;
  left: -8rpx;
  right: -8rpx;
  bottom: -8rpx;
  background: linear-gradient(135deg, var(--color-primary) 0%, #FF8E8E 100%);
  border-radius: 50%;
  opacity: 0.3;
  z-index: -1;
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); opacity: 0.3; }
  50% { transform: scale(1.1); opacity: 0.15; }
}

.publish-btn:active {
  transform: scale(0.92);
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 107, 0.35);
}

.publish-icon {
  font-size: 40rpx;
  color: #FFFFFF;
  font-weight: 300;
  line-height: 1;
}

.publish-text {
  font-size: 22rpx;
  color: #FFFFFF;
  font-weight: 600;
  margin-top: 4rpx;
}

/* ==================== 选择器弹窗 ==================== */
.picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.picker-mask.show {
  opacity: 1;
  visibility: visible;
}

.picker-content {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: var(--color-bg-card);
  border-radius: var(--radius-2xl) var(--radius-2xl) 0 0;
  padding-bottom: env(safe-area-inset-bottom);
  transform: translateY(100%);
  transition: transform 0.35s cubic-bezier(0.32, 0.72, 0, 1);
  max-height: 70vh;
  overflow-y: auto;
}

.picker-mask.show .picker-content {
  transform: translateY(0);
}

.picker-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid var(--color-border-light);
  position: sticky;
  top: 0;
  background-color: var(--color-bg-card);
  z-index: 10;
}

.picker-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

.picker-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: var(--color-text-muted);
  background-color: var(--color-bg-input);
  border-radius: 50%;
}

.picker-options {
  padding: 16rpx 32rpx 32rpx;
}

.picker-option {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  font-size: 30rpx;
  color: var(--color-text-primary);
  border-bottom: 1rpx solid var(--color-border-light);
  transition: all var(--transition-fast);
}

.picker-option:last-child {
  border-bottom: none;
}

.picker-option:active {
  background-color: var(--color-bg-page);
}

.picker-option.active {
  color: var(--color-primary);
  font-weight: 600;
}

.option-icon {
  font-size: 28rpx;
  margin-right: 16rpx;
}

.option-label {
  flex: 1;
}

.status-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}

/* ==================== 暗色模式 ==================== */
.page.dark .reward-card {
  background-color: var(--color-bg-card-dark);
}

.page.dark .filter-section {
  background-color: var(--color-bg-card-dark);
  border-bottom-color: var(--color-border-dark);
}

.page.dark .filter-btn {
  background-color: var(--color-bg-input-dark);
}

.page.dark .meta-item {
  background-color: var(--color-bg-input-dark);
}

.page.dark .card-footer {
  border-top-color: var(--color-border-dark);
}

.page.dark .picker-content {
  background-color: var(--color-bg-card-dark);
}

.page.dark .picker-header {
  background-color: var(--color-bg-card-dark);
  border-bottom-color: var(--color-border-dark);
}

.page.dark .picker-option {
  border-bottom-color: var(--color-border-dark);
}

.page.dark .picker-close {
  background-color: var(--color-bg-input-dark);
}
