/* 失物招领列表 - 参考闲鱼/小红书设计 */
.page {
  min-height: 100vh;
  background-color: var(--color-bg-page);
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
}

/* ==================== 筛选区域 ==================== */
.filter-section {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx;
  background-color: var(--color-bg-card);
  border-bottom: 1rpx solid var(--color-border-light);
  position: sticky;
  top: 0;
  z-index: 100;
}

.filter-tabs {
  display: flex;
}

.filter-tabs > view { margin-right: 12rpx; }

.filter-tabs > view:last-child { margin-right: 0; }

.filter-tab {
  padding: 14rpx 28rpx;
  font-size: 26rpx;
  font-weight: 500;
  color: var(--color-text-secondary);
  background-color: var(--color-bg-input);
  border-radius: var(--radius-full);
  transition: all var(--transition-fast);
}

.filter-tab:active {
  transform: scale(0.96);
}

.filter-tab.active {
  color: #FFFFFF;
  background: linear-gradient(135deg, var(--color-primary) 0%, #FF8E8E 100%);
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 107, 0.3);
}

.filter-picker {
  display: flex;
  align-items: center;
  padding: 14rpx 20rpx;
  background-color: var(--color-bg-input);
  border-radius: var(--radius-full);
  transition: all var(--transition-fast);
}

.filter-picker:active {
  background-color: var(--color-border);
}

.picker-text {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  margin-right: 8rpx;
}

.picker-arrow {
  font-size: 20rpx;
  color: var(--color-text-muted);
}

/* ==================== 列表区域 ==================== */
.list-scroll {
  height: calc(100vh - 100rpx);
}

/* ==================== 智能匹配入口 ==================== */
.smart-match-entry {
  margin: 20rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, #6366F1 0%, #8B5CF6 50%, #A78BFA 100%);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 8rpx 24rpx rgba(99, 102, 241, 0.35);
  transition: all var(--transition-fast);
}

.smart-match-entry:active {
  transform: scale(0.98);
}

.entry-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.entry-icon {
  width: 80rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 20rpx;
}

.entry-info {
  flex: 1;
}

.entry-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 6rpx;
}

.entry-desc {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
}

.entry-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.entry-stats {
  display: flex;
  align-items: center;
}

.stat-badge {
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.stat-badge.excellent {
  background: rgba(255, 255, 255, 0.25);
  color: #FFFFFF;
}

.stat-badge.high {
  background: rgba(255, 255, 255, 0.2);
  color: #FFFFFF;
}

.entry-arrow {
  font-size: 40rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-left: 8rpx;
}

/* ==================== 匹配徽章 ==================== */
.match-badge {
  display: flex;
  align-items: center;
  padding: 6rpx 14rpx;
  background: linear-gradient(135deg, rgba(99, 102, 241, 0.1) 0%, rgba(139, 92, 246, 0.1) 100%);
  border-radius: 12rpx;
  margin-right: auto;
  margin-left: 16rpx;
}

.match-icon {
  font-size: 20rpx;
  margin-right: 6rpx;
}

.match-count {
  font-size: 20rpx;
  color: #6366F1;
  font-weight: 600;
}

/* ==================== 匹配推荐 ==================== */
.match-recommend {
  margin-top: 12rpx;
  padding: 12rpx 16rpx;
  background: linear-gradient(135deg, rgba(99, 102, 241, 0.08) 0%, rgba(139, 92, 246, 0.08) 100%);
  border-radius: 12rpx;
  border-left: 4rpx solid #6366F1;
  display: flex;
  flex-wrap: wrap;
  align-items: center;
}

.recommend-label {
  font-size: 22rpx;
  color: #6366F1;
  font-weight: 600;
  flex-shrink: 0;
}

.recommend-text {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.list-container {
  padding: 0 20rpx 20rpx;
}

/* ==================== 卡片样式 ==================== */
.item-card {
  background-color: var(--color-bg-card);
  border-radius: var(--radius-2xl);
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-card);
  transition: all var(--transition-fast);
  overflow: hidden;
}

.item-card:active {
  transform: scale(0.99);
  box-shadow: var(--shadow-sm);
}

.item-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.item-type {
  padding: 8rpx 20rpx;
  font-size: 24rpx;
  font-weight: 600;
  border-radius: var(--radius-sm);
}

.type-lost {
  color: #E74C3C;
  background: linear-gradient(135deg, #FFEAEA 0%, #FFD4D4 100%);
}

.type-found {
  color: #27AE60;
  background: linear-gradient(135deg, #E8F8EF 0%, #D1F2E1 100%);
}

.item-time {
  font-size: 24rpx;
  color: var(--color-text-muted);
}

.item-body {
  display: flex;
}

.item-info {
  flex: 1;
  margin-right: 20rpx;
}

.item-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  overflow: hidden;
  margin-bottom: 10rpx;
}

.item-desc {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.6;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  margin-bottom: 16rpx;
}

.item-tags {
  display: flex;
  flex-wrap: wrap;
}

.item-tags { margin-right: -10rpx; margin-bottom: -10rpx; }

.item-tags > view { margin-right: 10rpx; margin-bottom: 10rpx; }

.item-tag {
  padding: 6rpx 14rpx;
  font-size: 22rpx;
  color: var(--color-text-secondary);
  background-color: var(--color-bg-input);
  border-radius: var(--radius-xs);
}

.item-image {
  width: 180rpx;
  height: 140rpx;
  border-radius: var(--radius-lg);
  flex-shrink: 0;
  overflow: hidden;
}

.item-image image {
  width: 100%;
  height: 100%;
  transition: transform 0.3s ease;
}

.item-card:active .item-image image {
  transform: scale(1.05);
}

/* ==================== 发布按钮 ==================== */
.publish-btn {
  position: fixed;
  right: 32rpx;
  bottom: calc(200rpx + env(safe-area-inset-bottom));
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, var(--color-primary) 0%, #FF8E8E 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(255, 107, 107, 0.45);
  transition: all var(--transition-normal);
  z-index: 100;
}

.publish-btn::before {
  content: '';
  position: absolute;
  top: -8rpx;
  left: -8rpx;
  right: -8rpx;
  bottom: -8rpx;
  background: linear-gradient(135deg, var(--color-primary) 0%, #FF8E8E 100%);
  border-radius: 50%;
  opacity: 0.3;
  z-index: -1;
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); opacity: 0.3; }
  50% { transform: scale(1.1); opacity: 0.15; }
}

.publish-btn:active {
  transform: scale(0.92);
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 107, 0.35);
}

.publish-icon {
  font-size: 56rpx;
  color: #FFFFFF;
  font-weight: 300;
  line-height: 1;
}

/* ==================== 选择器弹窗 ==================== */
.picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.picker-mask.show {
  opacity: 1;
  visibility: visible;
}

.picker-content {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: var(--color-bg-card);
  border-radius: var(--radius-2xl) var(--radius-2xl) 0 0;
  padding-bottom: env(safe-area-inset-bottom);
  transform: translateY(100%);
  transition: transform 0.35s cubic-bezier(0.32, 0.72, 0, 1);
}

.picker-mask.show .picker-content {
  transform: translateY(0);
}

.picker-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid var(--color-border-light);
}

.picker-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

.picker-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: var(--color-text-muted);
  background-color: var(--color-bg-input);
  border-radius: 50%;
}

.picker-options {
  padding: 16rpx 32rpx 32rpx;
  max-height: 60vh;
  overflow-y: auto;
}

.picker-option {
  padding: 24rpx 0;
  font-size: 30rpx;
  color: var(--color-text-primary);
  border-bottom: 1rpx solid var(--color-border-light);
  transition: all var(--transition-fast);
}

.picker-option:last-child {
  border-bottom: none;
}

.picker-option:active {
  background-color: var(--color-bg-page);
}

.picker-option.active {
  color: var(--color-primary);
  font-weight: 600;
}

/* ==================== 加载更多 ==================== */
.load-more {
  padding: 32rpx 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.load-more-loading {
  display: flex;
  align-items: center;
}

.load-more-loading > view { margin-right: 16rpx; }

.load-more-loading > view:last-child { margin-right: 0; }

.loading-spinner {
  width: 32rpx;
  height: 32rpx;
  border: 3rpx solid var(--color-border-light);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.load-more-text {
  font-size: 26rpx;
  color: var(--color-text-muted);
}

.load-more-no-more .load-more-text,
.load-more-tip .load-more-text {
  color: var(--color-text-muted);
}

/* ==================== 骨架屏适配 ==================== */
.list-scroll .skeleton {
  padding: 20rpx;
}

.dark .loading-spinner {
  border-color: #2a2d34;
  border-top-color: var(--color-primary);
}

/* ==================== 状态小标签 ==================== */
.status-mini-tag {
  padding: 4rpx 14rpx;
  font-size: 20rpx;
  font-weight: 600;
  border-radius: var(--radius-xs);
  margin-left: 12rpx;
  flex-shrink: 0;
}

.status-claim_pending {
  color: #B45309;
  background: linear-gradient(135deg, #FEF3C7 0%, #FDE68A 100%);
}

.status-verifying {
  color: #6D28D9;
  background: linear-gradient(135deg, #EDE9FE 0%, #DDD6FE 100%);
}

.status-resolved {
  color: #047857;
  background: linear-gradient(135deg, #D1FAE5 0%, #A7F3D0 100%);
}

.status-claimed,
.status-returned {
  color: #047857;
  background: linear-gradient(135deg, #D1FAE5 0%, #A7F3D0 100%);
}

.status-closed {
  color: #4B5563;
  background: linear-gradient(135deg, #F3F4F6 0%, #E5E7EB 100%);
}

.dark .status-claim_pending {
  color: #FBBF24;
  background: rgba(251, 191, 36, 0.15);
}

.dark .status-verifying {
  color: #A78BFA;
  background: rgba(167, 139, 250, 0.15);
}

.dark .status-resolved,
.dark .status-claimed,
.dark .status-returned {
  color: #34D399;
  background: rgba(52, 211, 153, 0.15);
}

.dark .status-closed {
  color: #9CA3AF;
  background: rgba(156, 163, 175, 0.15);
}

/* ==================== 智能匹配提示标签 ==================== */
.match-hints {
  display: flex;
  flex-wrap: wrap;
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 1rpx dashed var(--color-border-light);
}

.match-hints > text {
  margin-right: 10rpx;
  margin-bottom: 8rpx;
}

.match-hint-tag {
  display: inline-block;
  padding: 6rpx 14rpx;
  font-size: 22rpx;
  color: #6366F1;
  background: linear-gradient(135deg, rgba(99, 102, 241, 0.08) 0%, rgba(139, 92, 246, 0.08) 100%);
  border: 1rpx solid rgba(99, 102, 241, 0.15);
  border-radius: var(--radius-xs);
  font-weight: 500;
}

.dark .match-hint-tag {
  color: #A5B4FC;
  background: rgba(99, 102, 241, 0.12);
  border-color: rgba(99, 102, 241, 0.25);
}
