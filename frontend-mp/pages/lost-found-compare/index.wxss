.page {
  min-height: 100vh;
  background-color: var(--color-bg-page);
}

.header-section {
  position: relative;
  padding: 40rpx 32rpx 60rpx;
  overflow: hidden;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 400rpx;
  background: linear-gradient(135deg, #6366F1 0%, #8B5CF6 50%, #A78BFA 100%);
  border-radius: 0 0 48rpx 48rpx;
}

.header-content {
  position: relative;
  z-index: 1;
}

.score-display {
  display: flex;
  align-items: center;
  gap: 32rpx;
}

.score-circle {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.score-inner {
  width: 130rpx;
  height: 130rpx;
  border-radius: 50%;
  background: var(--color-bg-card);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.score-value {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  line-height: 1;
}

.score-label {
  font-size: 20rpx;
  color: var(--color-text-muted);
  margin-top: 4rpx;
}

.level-info {
  flex: 1;
}

.level-badge {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 24rpx;
  border-radius: 24rpx;
  font-size: 26rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.level-badge > text {
  margin-right: 8rpx;
}

.level-badge > text:last-child {
  margin-right: 0;
}

.level-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.5;
}

.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 40rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid var(--color-border);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 26rpx;
  color: var(--color-text-muted);
}

.content {
  height: calc(100vh - 280rpx);
  padding: 0 24rpx 40rpx;
  margin-top: -40rpx;
  position: relative;
  z-index: 2;
}

.items-compare {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.item-card {
  flex: 1;
  background: var(--color-bg-card);
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: var(--shadow-card);
}

.item-card.lost {
  border: 2rpx solid rgba(239, 68, 68, 0.3);
}

.item-card.found {
  border: 2rpx solid rgba(16, 185, 129, 0.3);
}

.item-header {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
  font-weight: 600;
}

.item-header.lost {
  background: linear-gradient(135deg, #FEF2F2 0%, #FEE2E2 100%);
}

.item-header.found {
  background: linear-gradient(135deg, #ECFDF5 0%, #D1FAE5 100%);
}

.item-type-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.item-type-text {
  font-size: 26rpx;
  color: var(--color-text-primary);
}

.image-swiper {
  width: 100%;
  height: 200rpx;
}

.item-image {
  width: 100%;
  height: 100%;
}

.image-placeholder {
  width: 100%;
  height: 200rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: var(--color-bg-input);
}

.placeholder-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
  opacity: 0.5;
}

.placeholder-text {
  font-size: 22rpx;
  color: var(--color-text-muted);
}

.item-info {
  padding: 20rpx;
}

.item-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 8rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.item-desc {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  margin-bottom: 16rpx;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.item-meta {
  margin-bottom: 16rpx;
}

.meta-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.meta-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
  flex-shrink: 0;
}

.meta-label {
  font-size: 22rpx;
  color: var(--color-text-muted);
  margin-right: 8rpx;
  flex-shrink: 0;
}

.meta-value {
  font-size: 22rpx;
  color: var(--color-text-primary);
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ai-tags-section {
  background: var(--color-bg-input);
  border-radius: 16rpx;
  padding: 16rpx;
  margin-bottom: 16rpx;
}

.tags-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.tags-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
}

.tags-title {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.tag-group {
  margin-bottom: 12rpx;
}

.tag-group:last-child {
  margin-bottom: 0;
}

.tag-group-label {
  font-size: 20rpx;
  color: var(--color-text-muted);
  margin-bottom: 8rpx;
  display: block;
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.tag-item {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 14rpx;
  border-radius: 12rpx;
  margin-right: 8rpx;
  margin-bottom: 8rpx;
}

.tag-item.category {
  background: rgba(139, 92, 246, 0.15);
}

.tag-item.color {
  background: rgba(59, 130, 246, 0.15);
}

.tag-item.brand {
  background: rgba(16, 185, 129, 0.15);
}

.tag-value {
  font-size: 20rpx;
  color: var(--color-text-primary);
  font-weight: 500;
}

.tag-confidence {
  font-size: 18rpx;
  color: var(--color-text-muted);
  margin-left: 6rpx;
}

.item-actions {
  display: flex;
  gap: 8rpx;
  padding: 0 20rpx 20rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 12rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  font-weight: 500;
  transition: all var(--transition-fast);
}

.action-btn:active {
  transform: scale(0.96);
}

.action-btn.primary {
  background: var(--color-primary);
  color: #FFFFFF;
}

.action-btn.call.lost {
  background: linear-gradient(135deg, #F87171 0%, #EF4444 100%);
  color: #FFFFFF;
}

.action-btn.call.found {
  background: linear-gradient(135deg, #34D399 0%, #10B981 100%);
  color: #FFFFFF;
}

.action-btn.call {
  background: linear-gradient(135deg, #6366F1 0%, #8B5CF6 100%);
  color: #FFFFFF;
}

.vs-divider {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 60rpx;
  flex-shrink: 0;
}

.vs-line {
  flex: 1;
  width: 2rpx;
  background: var(--color-border);
}

.vs-badge {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 16rpx 0;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 107, 0.4);
}

.vs-text {
  font-size: 22rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.score-analysis-section {
  background: var(--color-bg-card);
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-card);
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.score-bars {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.score-bar-item {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.bar-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.bar-label {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.bar-score {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.bar-track {
  height: 12rpx;
  background: var(--color-bg-input);
  border-radius: 6rpx;
  overflow: hidden;
}

.bar-fill {
  height: 100%;
  border-radius: 6rpx;
  transition: width 0.5s ease;
}

.comparison-section {
  background: var(--color-bg-card);
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-card);
}

.comparison-table {
  border-radius: 16rpx;
  overflow: hidden;
  border: 2rpx solid var(--color-border-light);
}

.comparison-row {
  display: flex;
  align-items: center;
  position: relative;
}

.comparison-row.header {
  background: var(--color-bg-input);
}

.comparison-row:not(.header) {
  border-top: 2rpx solid var(--color-border-light);
}

.comparison-row.matched {
  background: rgba(16, 185, 129, 0.05);
}

.comparison-cell {
  flex: 1;
  padding: 16rpx 12rpx;
  font-size: 22rpx;
  text-align: center;
}

.comparison-cell.field {
  flex: 0.8;
  color: var(--color-text-muted);
  font-weight: 500;
  background: var(--color-bg-input);
  text-align: left;
  padding-left: 16rpx;
}

.comparison-cell.lost {
  color: #EF4444;
}

.comparison-cell.found {
  color: #10B981;
}

.comparison-row.header .comparison-cell {
  font-weight: 600;
  color: var(--color-text-primary);
}

.match-indicator {
  position: absolute;
  right: 8rpx;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: 700;
}

.match-indicator.yes {
  background: rgba(16, 185, 129, 0.15);
  color: #10B981;
}

.match-indicator.no {
  background: rgba(239, 68, 68, 0.15);
  color: #EF4444;
}

.bottom-actions {
  display: flex;
  gap: 16rpx;
  padding: 24rpx 0 40rpx;
}

.bottom-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 500;
  border: none;
  transition: all var(--transition-fast);
}

.bottom-btn::after {
  border: none;
}

.bottom-btn:active {
  transform: scale(0.98);
}

.bottom-btn.secondary {
  background: var(--color-bg-card);
  color: var(--color-text-primary);
  box-shadow: var(--shadow-card);
}

.bottom-btn.share {
  background: linear-gradient(135deg, #6366F1 0%, #8B5CF6 100%);
  color: #FFFFFF;
  box-shadow: 0 8rpx 24rpx rgba(99, 102, 241, 0.4);
}

.page.dark .item-header.lost {
  background: linear-gradient(135deg, rgba(239, 68, 68, 0.2) 0%, rgba(239, 68, 68, 0.1) 100%);
}

.page.dark .item-header.found {
  background: linear-gradient(135deg, rgba(16, 185, 129, 0.2) 0%, rgba(16, 185, 129, 0.1) 100%);
}

.page.dark .score-inner {
  background: #1E293B;
}

.page.dark .comparison-row.matched {
  background: rgba(16, 185, 129, 0.1);
}
