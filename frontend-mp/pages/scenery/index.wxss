.page {
  min-height: 100vh;
  background-color: var(--color-bg-page);
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

/* ==================== 顶部横幅 ==================== */
.banner {
  position: relative;
  padding: 48rpx 32rpx 32rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 50%, #FFB3B3 100%);
  overflow: hidden;
}

.banner::before {
  content: '';
  position: absolute;
  top: -100rpx;
  right: -100rpx;
  width: 300rpx;
  height: 300rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.banner::after {
  content: '';
  position: absolute;
  bottom: -80rpx;
  left: -80rpx;
  width: 240rpx;
  height: 240rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 50%;
}

.banner-content {
  position: relative;
  z-index: 1;
}

.banner-title {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 8rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.banner-subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

.banner-decoration {
  position: absolute;
  right: 32rpx;
  top: 50%;
  transform: translateY(-50%);
  display: flex;
  flex-direction: column;
  z-index: 1;
}

.banner-decoration > * { margin-bottom: 8rpx; }

.banner-decoration > *:last-child { margin-bottom: 0; }

.deco-icon {
  font-size: 32rpx;
  opacity: 0.6;
  animation: float 3s ease-in-out infinite;
}

.deco-icon:nth-child(2) {
  animation-delay: 0.5s;
}

.deco-icon:nth-child(3) {
  animation-delay: 1s;
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-8rpx); }
}

/* ==================== 分类 Tab ==================== */
.tab-scroll {
  background-color: var(--color-bg-page);
  position: sticky;
  top: 0;
  z-index: 10;
  padding: 16rpx 0;
}

.tab-list {
  display: flex;
  padding: 0 24rpx;
}

.tab-list > * { margin-right: 16rpx; }

.tab-list > *:last-child { margin-right: 0; }

.tab-item {
  display: flex;
  align-items: center;
  padding: 16rpx 28rpx;
  background-color: var(--color-bg-card);
  border-radius: var(--radius-full);
  border: 2rpx solid transparent;
  transition: all var(--transition-fast);
  flex-shrink: 0;
  box-shadow: var(--shadow-sm);
}

.tab-item > * { margin-right: 8rpx; }

.tab-item > *:last-child { margin-right: 0; }

.tab-item:active {
  transform: scale(0.96);
}

.tab-item.active {
  background: linear-gradient(135deg, var(--color-primary) 0%, #FF8E8E 100%);
  border-color: var(--color-primary);
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 107, 0.3);
}

.tab-icon {
  font-size: 28rpx;
}

.tab-label {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-secondary);
}

.tab-item.active .tab-label {
  color: #FFFFFF;
}

/* ==================== 通用 Section ==================== */
.section {
  padding: 24rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-title-wrap {
  display: flex;
  align-items: center;
}

.section-icon {
  width: 8rpx;
  height: 32rpx;
  background: linear-gradient(180deg, var(--color-primary) 0%, #FF8E8E 100%);
  border-radius: 4rpx;
  margin-right: 12rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

.section-count {
  font-size: 26rpx;
  color: var(--color-text-muted);
}

.section-more {
  display: flex;
  align-items: center;
}

.section-more > * { margin-right: 4rpx; }

.section-more > *:last-child { margin-right: 0; }

.more-text {
  font-size: 26rpx;
  color: var(--color-text-muted);
}

.more-arrow {
  font-size: 32rpx;
  color: var(--color-text-muted);
  font-weight: 600;
}

/* ==================== 主题合集 ==================== */
.collection-scroll {
  margin: 0 -24rpx;
  padding: 0 24rpx;
}

.collection-list {
  display: flex;
  padding-right: 24rpx;
}

.collection-list > * { margin-right: 20rpx; }

.collection-list > *:last-child { margin-right: 0; }

.collection-card {
  position: relative;
  width: 320rpx;
  height: 200rpx;
  flex-shrink: 0;
  border-radius: var(--radius-xl);
  overflow: hidden;
  box-shadow: var(--shadow-card);
  transition: all var(--transition-fast);
}

.collection-card:active {
  transform: scale(0.96);
}

.collection-cover {
  width: 100%;
  height: 100%;
}

.collection-overlay {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 70%;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.8) 0%, rgba(0, 0, 0, 0.3) 60%, transparent 100%);
  pointer-events: none;
}

.collection-info {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx;
}

.collection-badge {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.collection-badge > * { margin-right: 8rpx; }

.collection-badge > *:last-child { margin-right: 0; }

.badge-icon {
  font-size: 28rpx;
}

.badge-text {
  font-size: 26rpx;
  font-weight: 600;
  color: #FFFFFF;
  text-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.3);
}

.collection-stats {
  display: flex;
}

.collection-stats > * { margin-right: 16rpx; }

.collection-stats > *:last-child { margin-right: 0; }

.stat-item {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
}

/* ==================== 照片网格 ==================== */
.photo-grid {
  display: flex;
  flex-wrap: wrap;
}

.photo-grid { margin-right: -16rpx; margin-bottom: -16rpx; }

.photo-grid > * { margin-right: 16rpx; margin-bottom: 16rpx; }

.photo-item {
  width: calc((100% - 16rpx) / 2);
  background-color: var(--color-bg-card);
  border-radius: var(--radius-xl);
  overflow: hidden;
  box-shadow: var(--shadow-card);
  transition: all var(--transition-fast);
}

.photo-item:active {
  transform: scale(0.96);
}

.photo-image-wrap {
  position: relative;
  width: 100%;
  height: 280rpx;
  overflow: hidden;
}

.photo-image {
  width: 100%;
  height: 100%;
  transition: transform 0.3s ease;
}

.photo-item:active .photo-image {
  transform: scale(1.05);
}

.photo-category-tag {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  padding: 8rpx 12rpx;
  border-radius: var(--radius-full);
  backdrop-filter: blur(10px);
}

.tag-icon {
  font-size: 24rpx;
}

.photo-stats {
  position: absolute;
  bottom: 12rpx;
  right: 12rpx;
  display: flex;
}

.photo-stats > * { margin-right: 12rpx; }

.photo-stats > *:last-child { margin-right: 0; }

.stat-badge {
  display: flex;
  align-items: center;
  padding: 6rpx 12rpx;
  background: rgba(0, 0, 0, 0.5);
  backdrop-filter: blur(10px);
  border-radius: var(--radius-full);
}

.stat-badge > * { margin-right: 4rpx; }

.stat-badge > *:last-child { margin-right: 0; }

.stat-icon {
  font-size: 22rpx;
}

.stat-number {
  font-size: 22rpx;
  color: #FFFFFF;
  font-weight: 500;
}

.photo-info {
  padding: 16rpx;
}

.photo-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.photo-meta {
  display: flex;
  align-items: center;
}

.photo-location {
  font-size: 22rpx;
  color: var(--color-text-muted);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ==================== 空状态 ==================== */
.empty-state {
  padding: 80rpx 24rpx;
  text-align: center;
}

.empty-icon {
  display: block;
  font-size: 80rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.empty-text {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-secondary);
  margin-bottom: 8rpx;
}

.empty-subtitle {
  display: block;
  font-size: 26rpx;
  color: var(--color-text-muted);
}

/* ==================== 底部留白 ==================== */
.bottom-padding {
  height: 120rpx;
}

/* ==================== 悬浮投稿按钮 ==================== */
.publish-btn {
  position: fixed;
  right: 32rpx;
  bottom: calc(40rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  padding: 24rpx 36rpx;
  background: linear-gradient(135deg, var(--color-primary) 0%, #FF8E8E 100%);
  border-radius: var(--radius-full);
  box-shadow: 0 12rpx 32rpx rgba(255, 107, 107, 0.4);
  z-index: 100;
  transition: all var(--transition-fast);
  animation: pulse 2s ease-in-out infinite;
}

.publish-btn > * { margin-right: 10rpx; }

.publish-btn > *:last-child { margin-right: 0; }

.publish-btn:active {
  transform: scale(0.95);
}

@keyframes pulse {
  0%, 100% { box-shadow: 0 12rpx 32rpx rgba(255, 107, 107, 0.4); }
  50% { box-shadow: 0 12rpx 48rpx rgba(255, 107, 107, 0.6); }
}

.publish-icon {
  font-size: 32rpx;
}

.publish-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #FFFFFF;
}

/* ==================== 合集详情弹窗 ==================== */
.collection-modal {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.collection-modal.show {
  opacity: 1;
  visibility: visible;
}

.modal-mask {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  backdrop-filter: blur(4px);
}

.modal-content {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  max-height: 85vh;
  background-color: var(--color-bg-card);
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx;
  transform: translateY(100%);
  transition: transform 0.3s ease;
}

.collection-modal.show .modal-content {
  transform: translateY(0);
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.modal-title-wrap {
  display: flex;
  align-items: center;
}

.modal-title-wrap > * { margin-right: 12rpx; }

.modal-title-wrap > *:last-child { margin-right: 0; }

.modal-icon {
  font-size: 40rpx;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

.modal-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: var(--color-bg-page);
  border-radius: 50%;
}

.close-icon {
  font-size: 28rpx;
  color: var(--color-text-muted);
}

.modal-desc {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  line-height: 1.6;
  margin-bottom: 24rpx;
}

.modal-stats {
  display: flex;
  padding: 24rpx;
  background-color: var(--color-bg-page);
  border-radius: var(--radius-xl);
  margin-bottom: 24rpx;
}

.modal-stats > * { margin-right: 48rpx; }

.modal-stats > *:last-child { margin-right: 0; }

.modal-stat {
  flex: 1;
  text-align: center;
}

.modal-stat-number {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-primary);
  margin-bottom: 4rpx;
}

.modal-stat-label {
  font-size: 24rpx;
  color: var(--color-text-muted);
}

.modal-subtitle {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 16rpx;
}

.modal-grid-scroll {
  max-height: 400rpx;
}

.modal-photo-grid {
  display: flex;
  flex-wrap: wrap;
}

.modal-photo-grid { margin-right: -12rpx; margin-bottom: -12rpx; }

.modal-photo-grid > * { margin-right: 12rpx; margin-bottom: 12rpx; }

.modal-photo-item {
  width: calc((100% - 24rpx) / 3);
  height: 180rpx;
  border-radius: var(--radius-lg);
  overflow: hidden;
}

.modal-photo-item:active {
  transform: scale(0.96);
}

.modal-photo-image {
  width: 100%;
  height: 100%;
}

/* ==================== 深色模式 ==================== */
.page.dark .tab-scroll {
  background-color: var(--color-bg-page);
}

.page.dark .tab-item {
  background-color: var(--color-bg-card);
}

.page.dark .collection-card {
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.3);
}

.page.dark .modal-content {
  background-color: var(--color-bg-card);
}
