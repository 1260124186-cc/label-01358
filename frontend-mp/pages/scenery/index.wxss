/* 校园风光 - 与首页风格统一 */
.page {
  min-height: 100vh;
  background-color: var(--color-bg-page);
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

/* ==================== 轮播区域 ==================== */
.swiper-section {
  padding: 24rpx;
}

.scenery-swiper {
  height: 480rpx;
  border-radius: var(--radius-2xl);
  overflow: hidden;
  box-shadow: var(--shadow-lg);
}

.swiper-item {
  position: relative;
  width: 100%;
  height: 100%;
  overflow: hidden;
}

.swiper-image {
  width: 100%;
  height: 100%;
  transition: transform 0.5s ease;
}

.swiper-item:active .swiper-image {
  transform: scale(1.03);
}

.swiper-overlay {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 65%;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.75) 0%, rgba(0, 0, 0, 0.3) 50%, transparent 100%);
  pointer-events: none;
}

.swiper-info {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 32rpx;
}

.swiper-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 12rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
}

.swiper-desc {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.5;
}

/* ==================== 缩略图区域 ==================== */
.thumb-section {
  padding: 0 24rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-title-wrap {
  display: flex;
  align-items: center;
}

.section-icon {
  width: 8rpx;
  height: 32rpx;
  background: linear-gradient(180deg, var(--color-primary) 0%, #FF8E8E 100%);
  border-radius: 4rpx;
  margin-right: 12rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

.section-count {
  font-size: 26rpx;
  color: var(--color-text-muted);
}

.thumb-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.thumb-item {
  width: calc((100% - 32rpx) / 3);
  background-color: var(--color-bg-card);
  border-radius: var(--radius-xl);
  overflow: hidden;
  box-shadow: var(--shadow-card);
  transition: all var(--transition-fast);
  position: relative;
}

.thumb-item:active {
  transform: scale(0.96);
}

.thumb-item.active {
  box-shadow: 0 0 0 4rpx var(--color-primary), var(--shadow-md);
}

.thumb-image-wrap {
  position: relative;
  width: 100%;
  height: 160rpx;
  overflow: hidden;
}

.thumb-image {
  width: 100%;
  height: 100%;
  transition: transform 0.3s ease;
}

.thumb-item:active .thumb-image {
  transform: scale(1.05);
}

.thumb-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(255, 107, 107, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
}

.thumb-current {
  padding: 8rpx 20rpx;
  background: linear-gradient(135deg, var(--color-primary) 0%, #FF8E8E 100%);
  color: #FFFFFF;
  font-size: 22rpx;
  font-weight: 600;
  border-radius: var(--radius-sm);
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 107, 0.4);
}

.thumb-title {
  display: block;
  padding: 14rpx 12rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ==================== 提示区域 ==================== */
.tip-section {
  padding: 40rpx 24rpx;
  text-align: center;
}

.tip-card {
  display: inline-flex;
  align-items: center;
  padding: 16rpx 32rpx;
  background-color: var(--color-bg-card);
  border-radius: var(--radius-full);
  box-shadow: var(--shadow-sm);
}

.tip-icon {
  font-size: 28rpx;
  margin-right: 10rpx;
}

.tip-text {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}
