.page {
  min-height: 100vh;
  background-color: #F8F9FA;
  display: flex;
  flex-direction: column;
}

.page.dark {
  background-color: #0F1117;
  color: #E8ECF1;
}

.compare-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  background-color: #fff;
  border-bottom: 1rpx solid #F5F5F5;
  position: sticky;
  top: 0;
  z-index: 50;
}

.page.dark .compare-header {
  background-color: #1A1D29;
  border-bottom-color: #2A2F3D;
}

.header-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.header-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #111;
}

.page.dark .header-title {
  color: #E8ECF1;
}

.header-count {
  display: flex;
  align-items: baseline;
  padding: 8rpx 20rpx;
  background-color: #FEF2F2;
  border-radius: 20rpx;
}

.page.dark .header-count {
  background-color: rgba(255, 107, 107, 0.15);
}

.count-num {
  font-size: 28rpx;
  font-weight: 700;
  color: #EF4444;
}

.count-text {
  font-size: 24rpx;
  font-weight: 500;
  color: #EF4444;
}

.header-action {
  display: flex;
  align-items: center;
  padding: 12rpx 24rpx;
  background-color: #F8F9FA;
  border-radius: 30rpx;
  transition: all 0.2s ease;
}

.page.dark .header-action {
  background-color: #2A2F3D;
}

.header-action:active {
  background-color: #F3F4F6;
}

.page.dark .header-action:active {
  background-color: #3A3F4D;
}

.action-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.action-text {
  font-size: 26rpx;
  font-weight: 500;
  color: #6B7280;
}

.page.dark .action-text {
  color: #9AA0A6;
}

.empty-state {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 48rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
  opacity: 0.4;
}

.empty-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #374151;
  margin-bottom: 16rpx;
}

.page.dark .empty-title {
  color: #D1D5DB;
}

.empty-desc {
  font-size: 28rpx;
  color: #9CA3AF;
  text-align: center;
}

.compare-scroll {
  flex: 1;
  width: 100%;
  white-space: nowrap;
}

.compare-container {
  display: inline-block;
  min-width: 100%;
  padding: 20rpx;
  box-sizing: border-box;
}

.compare-table {
  display: inline-flex;
  flex-direction: column;
  background-color: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  min-width: 100%;
}

.page.dark .compare-table {
  background-color: #1A1D29;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.3);
}

.compare-row {
  display: flex;
  min-height: 120rpx;
}

.header-row {
  min-height: 360rpx;
  background-color: #FAFAFA;
  border-bottom: 2rpx solid #E5E7EB;
}

.page.dark .header-row {
  background-color: #2A2F3D;
  border-bottom-color: #3A3F4D;
}

.data-row {
  border-bottom: 1rpx solid #F3F4F6;
  min-height: 100rpx;
}

.page.dark .data-row {
  border-bottom-color: #2A2F3D;
}

.data-row:last-child,
.action-row {
  border-bottom: none;
}

.action-row {
  background-color: #FAFAFA;
}

.page.dark .action-row {
  background-color: #2A2F3D;
}

.compare-cell {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
  min-width: 260rpx;
  box-sizing: border-box;
}

.label-cell {
  min-width: 180rpx;
  align-items: flex-start;
  background-color: #F9FAFB;
  font-size: 26rpx;
  font-weight: 600;
  color: #4B5563;
  position: sticky;
  left: 0;
  z-index: 10;
}

.page.dark .label-cell {
  background-color: #252836;
  color: #9AA0A6;
}

.header-row .label-cell {
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
  color: #111;
}

.page.dark .header-row .label-cell {
  color: #E8ECF1;
}

.house-cell {
  position: relative;
  align-items: center;
  padding: 28rpx 24rpx;
  border-left: 1rpx solid #E5E7EB;
}

.page.dark .house-cell {
  border-left-color: #3A3F4D;
}

.value-cell {
  border-left: 1rpx solid #F3F4F6;
}

.page.dark .value-cell {
  border-left-color: #2A2F3D;
}

.house-remove {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 48rpx;
  height: 48rpx;
  background-color: rgba(239, 68, 68, 0.1);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
  transition: all 0.2s ease;
}

.house-remove:active {
  background-color: rgba(239, 68, 68, 0.25);
  transform: scale(0.9);
}

.remove-icon {
  font-size: 36rpx;
  color: #EF4444;
  line-height: 1;
  font-weight: 300;
}

.house-image-wrap {
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
  transition: transform 0.2s ease;
}

.house-image-wrap:active {
  transform: scale(0.96);
}

.house-image {
  width: 100%;
  height: 100%;
}

.house-image.placeholder {
  background-color: #F3F4F6;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 80rpx;
  opacity: 0.5;
}

.house-title {
  width: 100%;
  font-size: 28rpx;
  font-weight: 600;
  color: #111;
  line-height: 1.4;
  margin-bottom: 12rpx;
  text-align: left;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  white-space: normal;
  word-break: break-all;
}

.page.dark .house-title {
  color: #E8ECF1;
}

.house-type-badge {
  width: 100%;
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 22rpx;
  font-weight: 500;
  text-align: left;
}

.badge-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
}

.cell-content {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  width: 100%;
  gap: 8rpx;
}

.cell-text {
  font-size: 26rpx;
  color: #374151;
  text-align: center;
  line-height: 1.5;
  white-space: normal;
  word-break: break-all;
  font-weight: 500;
}

.page.dark .cell-text {
  color: #D1D5DB;
}

.value-cell.best {
  background-color: #FEF3C7;
}

.page.dark .value-cell.best {
  background-color: rgba(245, 158, 11, 0.1);
}

.value-cell.best .cell-text {
  color: #B45309;
  font-weight: 700;
}

.page.dark .value-cell.best .cell-text {
  color: #F59E0B;
}

.best-badge {
  padding: 4rpx 16rpx;
  background-color: #F59E0B;
  color: #fff;
  font-size: 20rpx;
  font-weight: 600;
  border-radius: 12rpx;
}

.publisher-cell .cell-text {
  font-weight: 600;
}

.facilities-label-cell {
  align-items: flex-start;
  padding-top: 28rpx;
}

.facilities-cell {
  align-items: stretch;
  padding: 24rpx;
}

.facilities-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12rpx;
  width: 100%;
}

.facility-chip {
  display: flex;
  align-items: center;
  padding: 10rpx 14rpx;
  border-radius: 10rpx;
  font-size: 22rpx;
  transition: all 0.2s ease;
}

.facility-chip.has {
  background-color: #ECFDF5;
  border: 1rpx solid #6EE7B7;
}

.page.dark .facility-chip.has {
  background-color: rgba(16, 185, 129, 0.1);
  border-color: rgba(16, 185, 129, 0.4);
}

.facility-chip.has .chip-label {
  color: #065F46;
  font-weight: 500;
}

.page.dark .facility-chip.has .chip-label {
  color: #6EE7B7;
}

.facility-chip.missing {
  background-color: #F9FAFB;
  border: 1rpx solid #E5E7EB;
  opacity: 0.5;
}

.page.dark .facility-chip.missing {
  background-color: #2A2F3D;
  border-color: #3A3F4D;
}

.facility-chip.missing .chip-label {
  color: #9CA3AF;
  text-decoration: line-through;
}

.chip-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
  line-height: 1;
}

.chip-label {
  font-size: 22rpx;
  line-height: 1.3;
  white-space: nowrap;
}

.detail-btn {
  padding: 16rpx 40rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  border-radius: 40rpx;
  color: #fff;
  font-size: 26rpx;
  font-weight: 600;
  box-shadow: 0 6rpx 16rpx rgba(255, 107, 107, 0.35);
  transition: all 0.2s ease;
}

.detail-btn:active {
  transform: scale(0.96);
  box-shadow: 0 4rpx 10rpx rgba(255, 107, 107, 0.25);
}

.compare-tip {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  padding: 20rpx 28rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background-color: #FFFBEB;
  border-top: 1rpx solid #FDE68A;
}

.page.dark .compare-tip {
  background-color: rgba(245, 158, 11, 0.08);
  border-top-color: rgba(245, 158, 11, 0.3);
}

.tip-text {
  flex: 1;
  font-size: 24rpx;
  color: #92400E;
  line-height: 1.6;
}

.page.dark .tip-text {
  color: #FCD34D;
}
