<view class="page {{darkMode ? 'dark' : ''}}">
  <view class="compare-header" wx:if="{{compareList.length > 0}}">
    <view class="header-left">
      <text class="header-title">房源对比</text>
      <view class="header-count">
        <text class="count-num">{{compareList.length}}</text>
        <text class="count-text">/3</text>
      </view>
    </view>
    <view class="header-action" bindtap="onClearCompare">
      <text class="action-icon">🗑</text>
      <text class="action-text">清空</text>
    </view>
  </view>

  <view class="empty-state" wx:if="{{compareList.length === 0}}">
    <view class="empty-icon">🏠</view>
    <view class="empty-title">暂无对比房源</view>
    <view class="empty-desc">请在房源列表中添加对比（最多3套）</view>
  </view>

  <scroll-view
    wx:if="{{compareList.length > 0}}"
    class="compare-scroll"
    scroll-x
    enhanced
    show-scrollbar="{{false}}"
  >
    <view class="compare-container">
      <view class="compare-table">
        <view class="compare-row header-row">
          <view class="compare-cell label-cell sticky-cell">
            <text>房源信息</text>
          </view>
          <view
            class="compare-cell house-cell"
            wx:for="{{compareList}}"
            wx:for-item="house"
            wx:for-index="houseIndex"
            wx:key="id"
          >
            <view class="house-remove" catchtap="onRemoveCompare" data-id="{{house.id}}">
              <text class="remove-icon">×</text>
            </view>
            <view
              class="house-image-wrap"
              bindtap="onPreviewImage"
              data-house-index="{{houseIndex}}"
              data-index="{{0}}"
            >
              <image
                wx:if="{{house.images && house.images.length > 0}}"
                class="house-image"
                src="{{house.images[0]}}"
                mode="aspectFill"
              />
              <view wx:else class="house-image placeholder">
                <text>🏠</text>
              </view>
            </view>
            <view class="house-title" bindtap="onViewDetail" data-id="{{house.id}}">{{house.title}}</view>
            <view class="house-type-badge" style="color: {{house.publisherTypeColor}};">
              <text class="badge-dot" style="background-color: {{house.publisherTypeColor}};"></text>
              <text>{{house.publisherTypeText || '-'}}</text>
            </view>
          </view>
        </view>

        <view
          class="compare-row data-row"
          wx:for="{{visibleFields}}"
          wx:for-item="field"
          wx:key="key"
        >
          <view class="compare-cell label-cell sticky-cell">
            <text>{{field.label}}</text>
          </view>
          <view
            class="compare-cell value-cell {{house.bestClassMap[field.key]}}"
            wx:for="{{compareList}}"
            wx:for-item="house"
            wx:for-index="hIdx"
            wx:key="id"
          >
            <view
              class="cell-content"
              wx:if="{{field.key !== 'publisherTypeText'}}"
            >
              <text class="cell-text">{{house.fieldValues[field.key]}}</text>
              <text class="best-badge" wx:if="{{house.bestClassMap[field.key]}}">最优</text>
            </view>
            <view
              class="cell-content publisher-cell"
              wx:else
              style="color: {{house.publisherTypeColor}};"
            >
              <text class="cell-text">{{house.fieldValues[field.key]}}</text>
            </view>
          </view>
        </view>

        <view class="compare-row data-row">
          <view class="compare-cell label-cell sticky-cell facilities-label-cell">
            <text>房源设施</text>
          </view>
          <view
            class="compare-cell value-cell facilities-cell"
            wx:for="{{compareList}}"
            wx:for-item="house"
            wx:for-index="hIdx"
            wx:key="id"
          >
            <view class="facilities-grid">
              <view
                class="facility-chip {{house.facilityObj[fac.value] ? 'has' : 'missing'}}"
                wx:for="{{allFacilities}}"
                wx:for-item="fac"
                wx:key="value"
              >
                <text class="chip-icon">{{fac.icon}}</text>
                <text class="chip-label">{{fac.label}}</text>
              </view>
            </view>
          </view>
        </view>

        <view class="compare-row action-row">
          <view class="compare-cell label-cell sticky-cell">
            <text>操作</text>
          </view>
          <view
            class="compare-cell value-cell"
            wx:for="{{compareList}}"
            wx:for-item="house"
            wx:key="id"
          >
            <view
              class="detail-btn"
              bindtap="onViewDetail"
              data-id="{{house.id}}"
            >
              <text>查看详情</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>

  <view class="compare-tip" wx:if="{{compareList.length > 0}}">
    <text>💡</text>
    <text class="tip-text">高亮"最优"标记表示该字段在对比房源中最具优势（租金/押金最低、面积最大）</text>
  </view>
</view>
