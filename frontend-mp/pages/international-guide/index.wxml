<page-meta page-style="background-color: {{darkMode ? '#0F1117' : '#F8F9FA'}}; color: {{darkMode ? '#E8ECF1' : '#2C3E50'}}"/>
<view class="page {{darkMode ? 'dark' : ''}}">
  <view class="tabs-bar">
    <view
      class="tab-item {{currentCategory === item.value ? 'active' : ''}}"
      wx:for="{{categoryTabs}}"
      wx:key="value"
      bindtap="onCategoryTap"
      data-value="{{item.value}}"
      style="{{currentCategory === item.value ? 'color: ' + item.color + ';' : ''}}"
    >
      <text class="tab-icon">{{item.icon}}</text>
      <text class="tab-label">{{item.label}}</text>
      <view class="tab-indicator" wx:if="{{currentCategory === item.value}}" style="background: {{item.color}};"></view>
    </view>
  </view>

  <view class="header-section" style="background: linear-gradient(135deg, {{currentData.color}}20 0%, {{currentData.color}}10 100%);" wx:if="{{currentData}}">
    <text class="header-icon">{{currentData.icon}}</text>
    <text class="header-title">{{currentData.title}}</text>
  </view>

  <view class="section" wx:if="{{currentData}}">
    <view class="section-header">
      <text class="section-icon">📝</text>
      <text class="section-title">{{lang === 'zh' ? '办理步骤' : 'Steps'}}</text>
    </view>
    <view class="steps-timeline">
      <view class="step-item" wx:for="{{currentData.steps}}" wx:key="title">
        <view class="step-indicator">
          <view class="step-dot" style="background: {{currentData.color}};">
            <text>{{index + 1}}</text>
          </view>
          <view class="step-line" style="background: {{currentData.color}}30;" wx:if="{{index < currentData.steps.length - 1}}"></view>
        </view>
        <view class="step-content">
          <text class="step-title">{{item.title}}</text>
          <text class="step-desc">{{item.desc}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="section" wx:if="{{currentData}}">
    <view class="section-header">
      <text class="section-icon">📋</text>
      <text class="section-title">{{lang === 'zh' ? '所需材料' : 'Required Documents'}}</text>
    </view>
    <view class="docs-list">
      <view class="doc-item" wx:for="{{currentData.documents}}" wx:key="*this">
        <text class="doc-check">✓</text>
        <text class="doc-text">{{item}}</text>
      </view>
    </view>
  </view>

  <view class="section" wx:if="{{currentData}}">
    <view class="section-header">
      <text class="section-icon">💡</text>
      <text class="section-title">{{lang === 'zh' ? '温馨提示' : 'Tips'}}</text>
    </view>
    <view class="tips-list">
      <view class="tip-item" wx:for="{{currentData.tips}}" wx:key="*this">
        <text class="tip-bullet">•</text>
        <text class="tip-text">{{item}}</text>
      </view>
    </view>
  </view>

  <view class="section contact-section" wx:if="{{currentData}}">
    <view class="section-header">
      <text class="section-icon">📞</text>
      <text class="section-title">{{lang === 'zh' ? '咨询电话' : 'Contact'}}</text>
    </view>
    <view class="contact-card" bindtap="onCallContact" data-phone="010-11223344">
      <text class="contact-info">{{currentData.contact}}</text>
      <view class="contact-btn">
        <text>{{lang === 'zh' ? '拨打' : 'Call'}}</text>
      </view>
    </view>
  </view>

  <view class="bottom-spacer"></view>
</view>
