/* 失物招领详情 - 与首页风格统一 */
.page {
  min-height: 100vh;
  background-color: var(--color-bg-page);
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
}

/* ==================== 图片区域 ==================== */
.image-section {
  background-color: #1F2937;
}

.image-swiper {
  height: 480rpx;
}

.swiper-image {
  width: 100%;
  height: 100%;
}

/* ==================== 基本信息 ==================== */
.info-section {
  background-color: var(--color-bg-card);
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.info-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
  flex-wrap: wrap;
}

.status-badge {
  padding: 8rpx 20rpx;
  font-size: 24rpx;
  font-weight: 600;
  border-radius: var(--radius-full);
  flex-shrink: 0;
}

.info-type {
  padding: 10rpx 24rpx;
  font-size: 26rpx;
  font-weight: 600;
  border-radius: var(--radius-sm);
}

.type-lost {
  color: #E74C3C;
  background: linear-gradient(135deg, #FFEAEA 0%, #FFD4D4 100%);
}

.type-found {
  color: #27AE60;
  background: linear-gradient(135deg, #E8F8EF 0%, #D1F2E1 100%);
}

.info-actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  display: flex;
  align-items: center;
  padding: 10rpx 20rpx;
  background-color: var(--color-bg-input);
  border-radius: var(--radius-full);
  transition: all var(--transition-fast);
  gap: 8rpx;
}

.action-btn:active {
  transform: scale(0.96);
}

.action-btn.active {
  background: linear-gradient(135deg, #FEF3C7 0%, #FDE68A 100%);
}

.action-icon {
  font-size: 28rpx;
  color: var(--color-text-muted);
}

.action-btn.active .action-icon {
  color: #F59E0B;
}

.action-text {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.info-title {
  font-size: 38rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  line-height: 1.4;
  margin-bottom: 12rpx;
}

.info-time {
  font-size: 26rpx;
  color: var(--color-text-muted);
}

/* ==================== 详细信息 ==================== */
.detail-section {
  padding: 0 24rpx;
  margin-bottom: 20rpx;
}

.detail-card {
  background-color: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: 0 24rpx;
  box-shadow: var(--shadow-card);
}

.detail-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--color-border-light);
}

.detail-item:last-child {
  border-bottom: none;
}

.detail-label {
  font-size: 28rpx;
  color: var(--color-text-secondary);
}

.detail-value {
  font-size: 28rpx;
  color: var(--color-text-primary);
  font-weight: 600;
}

/* ==================== 描述 ==================== */
.desc-section {
  padding: 0 24rpx;
  margin-bottom: 20rpx;
}

.section-title {
  display: flex;
  align-items: center;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  margin-bottom: 16rpx;
}

.section-title::before {
  content: '';
  width: 6rpx;
  height: 28rpx;
  background: linear-gradient(180deg, var(--color-primary) 0%, #FF8E8E 100%);
  border-radius: 3rpx;
  margin-right: 12rpx;
}

.desc-card {
  background-color: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: 24rpx;
  box-shadow: var(--shadow-card);
}

.desc-text {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  line-height: 1.8;
}

/* ==================== 智能匹配推荐 ==================== */
.match-section {
  padding: 0 24rpx;
  margin-bottom: 20rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.section-header .section-title {
  margin-bottom: 0;
}

.section-header .section-title::before {
  display: none;
}

.title-icon {
  margin-right: 8rpx;
}

.section-action {
  display: flex;
  align-items: center;
  padding: 8rpx 16rpx;
  background: linear-gradient(135deg, rgba(99, 102, 241, 0.1) 0%, rgba(139, 92, 246, 0.1) 100%);
  border-radius: 20rpx;
}

.section-action:active {
  opacity: 0.8;
}

.section-action .action-text {
  font-size: 24rpx;
  color: #6366F1;
  font-weight: 500;
}

.section-action .action-arrow {
  font-size: 28rpx;
  color: #6366F1;
  margin-left: 4rpx;
}

.match-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.match-item {
  background-color: var(--color-bg-card);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-card);
  overflow: hidden;
  transition: all var(--transition-fast);
}

.match-item:active {
  transform: scale(0.99);
}

.match-main {
  display: flex;
  padding: 20rpx;
}

.match-image {
  width: 140rpx;
  height: 140rpx;
  border-radius: var(--radius-lg);
  flex-shrink: 0;
  margin-right: 20rpx;
}

.match-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.match-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.match-type {
  padding: 6rpx 14rpx;
  font-size: 22rpx;
  font-weight: 600;
  border-radius: var(--radius-xs);
  flex-shrink: 0;
}

.match-score-badge {
  padding: 6rpx 14rpx;
  font-size: 22rpx;
  font-weight: 600;
  border-radius: var(--radius-xs);
  flex-shrink: 0;
}

.match-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  overflow: hidden;
}

.match-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.meta-item {
  font-size: 22rpx;
  color: var(--color-text-muted);
}

.match-actions {
  display: flex;
  padding: 0 20rpx 20rpx;
  justify-content: flex-end;
}

.compare-btn {
  display: flex;
  align-items: center;
  padding: 12rpx 24rpx;
  background: linear-gradient(135deg, #6366F1 0%, #8B5CF6 100%);
  border-radius: var(--radius-full);
  box-shadow: 0 4rpx 12rpx rgba(99, 102, 241, 0.3);
  transition: all var(--transition-fast);
}

.compare-btn:active {
  transform: scale(0.96);
  box-shadow: 0 2rpx 8rpx rgba(99, 102, 241, 0.25);
}

.compare-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
}

.compare-text {
  font-size: 24rpx;
  color: #FFFFFF;
  font-weight: 600;
}

/* ==================== 联系方式 ==================== */
.contact-section {
  padding: 0 24rpx;
}

.contact-card {
  background-color: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: 0 24rpx;
  box-shadow: var(--shadow-card);
}

.contact-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--color-border-light);
}

.contact-item:last-child {
  border-bottom: none;
}

.contact-label {
  font-size: 28rpx;
  color: var(--color-text-secondary);
}

.contact-value {
  font-size: 28rpx;
  color: var(--color-text-primary);
  font-weight: 600;
}

.contact-value.phone {
  color: var(--color-primary);
}

/* ==================== 地点定位 ==================== */
.location-item {
  cursor: pointer;
}

.detail-value-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 16rpx;
}

.detail-value-wrap .detail-value {
  text-align: right;
}

.locate-action {
  display: flex;
  align-items: center;
  padding: 8rpx 16rpx;
  background: linear-gradient(135deg, #CFFAFE 0%, #A5F3FC 100%);
  border-radius: 20rpx;
  flex-shrink: 0;
  gap: 6rpx;
}

.locate-icon {
  font-size: 24rpx;
}

.locate-text {
  font-size: 22rpx;
  color: #0891B2;
  font-weight: 500;
}

.poi-card {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #F0F9FF;
  border-radius: 16rpx;
  margin-top: 16rpx;
  gap: 20rpx;
}

.page.dark .poi-card {
  background: rgba(59, 130, 246, 0.1);
}

.poi-card-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.poi-card-icon text {
  font-size: 36rpx;
}

.poi-card-info {
  flex: 1;
  min-width: 0;
}

.poi-card-name {
  font-size: 28rpx;
  color: #0369A1;
  font-weight: 500;
  display: block;
  margin-bottom: 8rpx;
}

.page.dark .poi-card-name {
  color: #60A5FA;
}

.poi-card-addr {
  font-size: 24rpx;
  color: #64748B;
}

.page.dark .poi-card-addr {
  color: #94A3B8;
}

.poi-card-arrow {
  font-size: 32rpx;
  color: #94A3B8;
  flex-shrink: 0;
}

/* ==================== 底部操作栏 ==================== */
.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background-color: var(--color-bg-card);
  box-shadow: 0 -8rpx 32rpx rgba(0, 0, 0, 0.08);
  z-index: 100;
}

.bottom-bar .btn {
  width: 100% !important;
}

/* ==================== 发布者信息区域 ==================== */
.publisher-section {
  display: flex;
  align-items: center;
  margin-top: 28rpx;
  padding-top: 28rpx;
  border-top: 1rpx solid var(--color-border-light);
}

.publisher-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background-color: var(--color-bg-input);
  flex-shrink: 0;
}

.publisher-info {
  flex: 1;
  margin-left: 20rpx;
  min-width: 0;
}

.publisher-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 8rpx;
}

.publisher-phone {
  display: block;
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.publisher-tag {
  padding: 8rpx 16rpx;
  background: linear-gradient(135deg, #FEF3C7 0%, #FDE68A 100%);
  color: #B45309;
  font-size: 22rpx;
  font-weight: 600;
  border-radius: var(--radius-full);
  flex-shrink: 0;
}

/* ==================== 已关闭提示 ==================== */
.closed-tip {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 20rpx;
  padding: 20rpx;
  background: #F0FDF4;
  border-radius: var(--radius-lg);
}

.page.dark .closed-tip {
  background: rgba(16, 185, 129, 0.1);
}

.closed-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.closed-text {
  font-size: 26rpx;
  color: #059669;
}

.page.dark .closed-text {
  color: #34D399;
}

/* ==================== 发布者操作按钮 ==================== */
.publisher-actions {
  padding: 0 24rpx;
  margin-bottom: 20rpx;
}

/* ==================== 已关闭状态底部栏 ==================== */
.closed-bar {
  opacity: 0.7;
}

.closed-bar .btn {
  opacity: 0.6;
}

/* ==================== 空状态 ==================== */
.empty-page {
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-text {
  font-size: 28rpx;
  color: var(--color-text-muted);
}

/* ==================== 认领状态卡片 ==================== */
.claim-status-card {
  margin: 0 24rpx 20rpx;
  padding: 28rpx;
  border-radius: var(--radius-xl);
  display: flex;
  align-items: center;
  gap: 20rpx;
  box-shadow: var(--shadow-card);
}

.claim-status-card.claim-pending {
  background: linear-gradient(135deg, rgba(245, 158, 11, 0.08) 0%, rgba(251, 191, 36, 0.08) 100%);
  border: 1rpx solid rgba(245, 158, 11, 0.2);
}

.claim-status-card.verifying {
  background: linear-gradient(135deg, rgba(139, 92, 246, 0.08) 0%, rgba(167, 139, 250, 0.08) 100%);
  border: 1rpx solid rgba(139, 92, 246, 0.2);
}

.claim-status-card.resolved {
  background: linear-gradient(135deg, rgba(16, 185, 129, 0.08) 0%, rgba(52, 211, 153, 0.08) 100%);
  border: 1rpx solid rgba(16, 185, 129, 0.2);
}

.claim-status-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: rgba(245, 158, 11, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  flex-shrink: 0;
}

.claim-status-icon.verify {
  background: rgba(139, 92, 246, 0.15);
}

.claim-status-icon.done {
  background: rgba(16, 185, 129, 0.15);
}

.claim-status-info {
  flex: 1;
  min-width: 0;
}

.claim-status-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #B45309;
  margin-bottom: 8rpx;
}

.claim-pending .claim-status-title {
  color: #B45309;
}

.verifying .claim-status-title {
  color: #6D28D9;
}

.resolved .claim-status-title {
  color: #047857;
}

.page.dark .claim-status-title {
  opacity: 0.9;
}

.claim-status-desc {
  display: block;
  font-size: 24rpx;
  color: #92400E;
  opacity: 0.8;
}

.claim-pending .claim-status-desc {
  color: #92400E;
}

.verifying .claim-status-desc {
  color: #5B21B6;
}

.resolved .claim-status-desc {
  color: #065F46;
}

.page.dark .claim-status-desc {
  opacity: 0.85;
}

.claim-status-action {
  display: flex;
  align-items: center;
  padding: 12rpx 20rpx;
  background: rgba(255, 255, 255, 0.6);
  border-radius: var(--radius-full);
  flex-shrink: 0;
}

.page.dark .claim-status-action {
  background: rgba(255, 255, 255, 0.1);
}

.claim-status-action text:first-child {
  font-size: 24rpx;
  font-weight: 600;
  color: #78350F;
}

.claim-pending .claim-status-action text:first-child {
  color: #78350F;
}

.verifying .claim-status-action text:first-child {
  color: #4C1D95;
}

.claim-status-action .arrow {
  font-size: 28rpx;
  margin-left: 4rpx;
}

/* ==================== 互评入口卡片 ==================== */
.review-entry-card {
  margin: 0 24rpx 20rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, #FEF3C7 0%, #FDE68A 100%);
  border-radius: var(--radius-xl);
  display: flex;
  align-items: center;
  gap: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(251, 191, 36, 0.2);
}

.page.dark .review-entry-card {
  background: linear-gradient(135deg, rgba(251, 191, 36, 0.15) 0%, rgba(245, 158, 11, 0.15) 100%);
}

.review-entry-icon {
  font-size: 40rpx;
  flex-shrink: 0;
}

.review-entry-info {
  flex: 1;
  min-width: 0;
}

.review-entry-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #92400E;
  margin-bottom: 6rpx;
}

.review-entry-desc {
  display: block;
  font-size: 22rpx;
  color: #A16207;
  opacity: 0.9;
}

.review-entry-actions {
  display: flex;
  gap: 12rpx;
  flex-shrink: 0;
}

.review-btn {
  padding: 12rpx 24rpx;
  background: #FFFFFF;
  border-radius: var(--radius-full);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.review-btn text {
  font-size: 24rpx;
  font-weight: 600;
  color: #B45309;
}

.review-btn:active {
  transform: scale(0.96);
}

/* ==================== 我的认领申请卡片 ==================== */
.my-claim-card {
  margin: 0 24rpx 20rpx;
  padding: 24rpx;
  background-color: var(--color-bg-card);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-card);
}

.my-claim-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid var(--color-border-light);
}

.my-claim-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

.my-claim-status {
  padding: 8rpx 16rpx;
  font-size: 22rpx;
  font-weight: 600;
  border-radius: var(--radius-full);
}

.my-claim-body {
  margin-bottom: 20rpx;
}

.my-claim-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 8rpx 0;
}

.my-claim-label {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  flex-shrink: 0;
}

.my-claim-value {
  font-size: 24rpx;
  color: var(--color-text-primary);
  text-align: right;
  flex: 1;
  margin-left: 20rpx;
}

.my-claim-actions {
  display: flex;
  gap: 16rpx;
}

.claim-action-btn {
  flex: 1;
  padding: 16rpx;
  border-radius: var(--radius-lg);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all var(--transition-fast);
}

.claim-action-btn.secondary {
  background-color: var(--color-bg-input);
}

.claim-action-btn.secondary text {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  font-weight: 500;
}

.claim-action-btn.primary {
  background: linear-gradient(135deg, #8B5CF6 0%, #A78BFA 100%);
  box-shadow: 0 4rpx 12rpx rgba(139, 92, 246, 0.25);
}

.claim-action-btn.primary text {
  font-size: 26rpx;
  color: #FFFFFF;
  font-weight: 600;
}

.claim-action-btn:active {
  transform: scale(0.98);
}

/* ==================== 认领管理按钮 ==================== */
.manage-claim-btn {
  position: relative;
  padding: 24rpx;
  background: linear-gradient(135deg, #FEF3C7 0%, #FDE68A 100%);
  border-radius: var(--radius-xl);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  transition: all var(--transition-fast);
}

.page.dark .manage-claim-btn {
  background: linear-gradient(135deg, rgba(251, 191, 36, 0.2) 0%, rgba(245, 158, 11, 0.2) 100%);
}

.manage-claim-btn.secondary {
  background: var(--color-bg-card);
  border: 1rpx solid var(--color-border-light);
}

.manage-claim-btn text {
  font-size: 28rpx;
  font-weight: 600;
  color: #B45309;
}

.manage-claim-btn.secondary text {
  color: var(--color-text-primary);
}

.page.dark .manage-claim-btn text {
  color: #F59E0B;
}

.manage-claim-btn.manage-claim-btn:active {
  transform: scale(0.98);
}

.manage-claim-badge {
  position: absolute;
  top: -12rpx;
  right: 24rpx;
  min-width: 40rpx;
  height: 40rpx;
  padding: 0 12rpx;
  background: #EF4444;
  color: #FFFFFF;
  font-size: 22rpx;
  font-weight: 700;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ==================== 新版底部操作栏 ==================== */
.bottom-bar-inner {
  display: flex;
  gap: 16rpx;
}

.bottom-secondary-btn {
  flex: 1;
  padding: 24rpx;
  background: var(--color-bg-input);
  border-radius: var(--radius-xl);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  transition: all var(--transition-fast);
}

.bottom-secondary-btn text {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  font-weight: 500;
}

.bottom-secondary-btn .phone-icon {
  font-size: 28rpx;
}

.bottom-secondary-btn:active {
  transform: scale(0.98);
}

.bottom-primary-btn {
  flex: 2;
  padding: 24rpx;
  background: linear-gradient(135deg, var(--color-primary) 0%, #FF8E8E 100%);
  border-radius: var(--radius-xl);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 107, 0.3);
  transition: all var(--transition-fast);
}

.bottom-primary-btn text {
  font-size: 30rpx;
  color: #FFFFFF;
  font-weight: 700;
}

.bottom-primary-btn .claim-icon,
.bottom-primary-btn .verify-icon {
  font-size: 30rpx;
}

.bottom-primary-btn:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 107, 0.25);
}

.bottom-primary-btn.applied {
  background: linear-gradient(135deg, #F59E0B 0%, #FBBF24 100%);
  box-shadow: 0 8rpx 24rpx rgba(245, 158, 11, 0.3);
}

.bottom-primary-btn.approved {
  background: linear-gradient(135deg, #8B5CF6 0%, #A78BFA 100%);
  box-shadow: 0 8rpx 24rpx rgba(139, 92, 246, 0.3);
}

.bottom-primary-btn.rejected {
  background: linear-gradient(135deg, #6B7280 0%, #9CA3AF 100%);
  box-shadow: 0 8rpx 24rpx rgba(107, 114, 128, 0.25);
}

.bottom-primary-btn.verified {
  background: linear-gradient(135deg, #10B981 0%, #34D399 100%);
  box-shadow: 0 8rpx 24rpx rgba(16, 185, 129, 0.3);
}
