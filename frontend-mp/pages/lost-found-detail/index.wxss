/* 失物招领详情 - 与首页风格统一 */
.page {
  min-height: 100vh;
  background-color: var(--color-bg-page);
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
}

/* ==================== 图片区域 ==================== */
.image-section {
  background-color: #1F2937;
}

.image-swiper {
  height: 480rpx;
}

.swiper-image {
  width: 100%;
  height: 100%;
}

/* ==================== 基本信息 ==================== */
.info-section {
  background-color: var(--color-bg-card);
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.info-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
  flex-wrap: wrap;
}

.status-badge {
  padding: 8rpx 20rpx;
  font-size: 24rpx;
  font-weight: 600;
  border-radius: var(--radius-full);
  flex-shrink: 0;
}

.info-type {
  padding: 10rpx 24rpx;
  font-size: 26rpx;
  font-weight: 600;
  border-radius: var(--radius-sm);
}

.type-lost {
  color: #E74C3C;
  background: linear-gradient(135deg, #FFEAEA 0%, #FFD4D4 100%);
}

.type-found {
  color: #27AE60;
  background: linear-gradient(135deg, #E8F8EF 0%, #D1F2E1 100%);
}

.info-actions {
  display: flex;
}

.info-actions > * { margin-right: 16rpx; }

.info-actions > *:last-child { margin-right: 0; }

.action-btn {
  display: flex;
  align-items: center;
  padding: 10rpx 20rpx;
  background-color: var(--color-bg-input);
  border-radius: var(--radius-full);
  transition: all var(--transition-fast);
}

.action-btn > * { margin-right: 8rpx; }

.action-btn > *:last-child { margin-right: 0; }

.action-btn:active {
  transform: scale(0.96);
}

.action-btn.active {
  background: linear-gradient(135deg, #FEF3C7 0%, #FDE68A 100%);
}

.action-icon {
  font-size: 28rpx;
  color: var(--color-text-muted);
}

.action-btn.active .action-icon {
  color: #F59E0B;
}

.action-text {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.info-title {
  font-size: 38rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  line-height: 1.4;
  margin-bottom: 12rpx;
}

.info-time {
  font-size: 26rpx;
  color: var(--color-text-muted);
}

/* ==================== 详细信息 ==================== */
.detail-section {
  padding: 0 24rpx;
  margin-bottom: 20rpx;
}

.detail-card {
  background-color: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: 0 24rpx;
  box-shadow: var(--shadow-card);
}

.detail-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--color-border-light);
}

.detail-item:last-child {
  border-bottom: none;
}

.detail-label {
  font-size: 28rpx;
  color: var(--color-text-secondary);
}

.detail-value {
  font-size: 28rpx;
  color: var(--color-text-primary);
  font-weight: 600;
}

/* ==================== 描述 ==================== */
.desc-section {
  padding: 0 24rpx;
  margin-bottom: 20rpx;
}

.section-title {
  display: flex;
  align-items: center;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  margin-bottom: 16rpx;
}

.section-title::before {
  content: '';
  width: 6rpx;
  height: 28rpx;
  background: linear-gradient(180deg, var(--color-primary) 0%, #FF8E8E 100%);
  border-radius: 3rpx;
  margin-right: 12rpx;
}

.desc-card {
  background-color: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: 24rpx;
  box-shadow: var(--shadow-card);
}

.desc-text {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  line-height: 1.8;
}

/* ==================== 联系方式 ==================== */
.contact-section {
  padding: 0 24rpx;
}

.contact-card {
  background-color: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: 0 24rpx;
  box-shadow: var(--shadow-card);
}

.contact-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--color-border-light);
}

.contact-item:last-child {
  border-bottom: none;
}

.contact-label {
  font-size: 28rpx;
  color: var(--color-text-secondary);
}

.contact-value {
  font-size: 28rpx;
  color: var(--color-text-primary);
  font-weight: 600;
}

.contact-value.phone {
  color: var(--color-primary);
}

/* ==================== 地点定位 ==================== */
.location-item {
  cursor: pointer;
}

.detail-value-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.detail-value-wrap > * { margin-right: 16rpx; }

.detail-value-wrap > *:last-child { margin-right: 0; }

.detail-value-wrap .detail-value {
  text-align: right;
}

.locate-action {
  display: flex;
  align-items: center;
  padding: 8rpx 16rpx;
  background: linear-gradient(135deg, #CFFAFE 0%, #A5F3FC 100%);
  border-radius: 20rpx;
  flex-shrink: 0;
}

.locate-action > * { margin-right: 6rpx; }

.locate-action > *:last-child { margin-right: 0; }

.locate-icon {
  font-size: 24rpx;
}

.locate-text {
  font-size: 22rpx;
  color: #0891B2;
  font-weight: 500;
}

.poi-card {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #F0F9FF;
  border-radius: 16rpx;
  margin-top: 16rpx;
}

.poi-card > * { margin-right: 20rpx; }

.poi-card > *:last-child { margin-right: 0; }

.page.dark .poi-card {
  background: rgba(59, 130, 246, 0.1);
}

.poi-card-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.poi-card-icon text {
  font-size: 36rpx;
}

.poi-card-info {
  flex: 1;
  min-width: 0;
}

.poi-card-name {
  font-size: 28rpx;
  color: #0369A1;
  font-weight: 500;
  display: block;
  margin-bottom: 8rpx;
}

.page.dark .poi-card-name {
  color: #60A5FA;
}

.poi-card-addr {
  font-size: 24rpx;
  color: #64748B;
}

.page.dark .poi-card-addr {
  color: #94A3B8;
}

.poi-card-arrow {
  font-size: 32rpx;
  color: #94A3B8;
  flex-shrink: 0;
}

/* ==================== 底部操作栏 ==================== */
.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background-color: var(--color-bg-card);
  box-shadow: 0 -8rpx 32rpx rgba(0, 0, 0, 0.08);
  z-index: 100;
}

.bottom-bar .btn {
  width: 100% !important;
}

/* ==================== 发布者信息区域 ==================== */
.publisher-section {
  display: flex;
  align-items: center;
  margin-top: 28rpx;
  padding-top: 28rpx;
  border-top: 1rpx solid var(--color-border-light);
}

.publisher-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background-color: var(--color-bg-input);
  flex-shrink: 0;
}

.publisher-info {
  flex: 1;
  margin-left: 20rpx;
  min-width: 0;
}

.publisher-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 8rpx;
}

.publisher-phone {
  display: block;
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.publisher-tag {
  padding: 8rpx 16rpx;
  background: linear-gradient(135deg, #FEF3C7 0%, #FDE68A 100%);
  color: #B45309;
  font-size: 22rpx;
  font-weight: 600;
  border-radius: var(--radius-full);
  flex-shrink: 0;
}

/* ==================== 已关闭提示 ==================== */
.closed-tip {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 20rpx;
  padding: 20rpx;
  background: #F0FDF4;
  border-radius: var(--radius-lg);
}

.page.dark .closed-tip {
  background: rgba(16, 185, 129, 0.1);
}

.closed-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.closed-text {
  font-size: 26rpx;
  color: #059669;
}

.page.dark .closed-text {
  color: #34D399;
}

/* ==================== 发布者操作按钮 ==================== */
.publisher-actions {
  padding: 0 24rpx;
  margin-bottom: 20rpx;
}

/* ==================== 已关闭状态底部栏 ==================== */
.closed-bar {
  opacity: 0.7;
}

.closed-bar .btn {
  opacity: 0.6;
}

/* ==================== 空状态 ==================== */
.empty-page {
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-text {
  font-size: 28rpx;
  color: var(--color-text-muted);
}
