<page-meta page-style="background-color: {{darkMode ? '#0F1117' : '#F8F9FA'}}; color: {{darkMode ? '#E8ECF1' : '#2C3E50'}}"/>
<view class="page {{darkMode ? 'dark' : ''}}" wx:if="{{detail}}">
  <!-- 图片轮播 -->
  <view class="image-section" wx:if="{{detail.images && detail.images.length > 0}}">
    <swiper
      class="image-swiper"
      indicator-dots="{{detail.images.length > 1}}"
      indicator-color="rgba(255,255,255,0.5)"
      indicator-active-color="#FFFFFF"
    >
      <swiper-item
        wx:for="{{detail.images}}"
        wx:key="index"
        bindtap="onPreviewImage"
        data-index="{{index}}"
      >
        <image class="swiper-image" src="{{item}}" mode="aspectFill" />
      </swiper-item>
    </swiper>
  </view>

  <!-- 基本信息 -->
  <view class="info-section">
    <view class="info-header">
      <view class="info-type {{detail.type === 'lost' ? 'type-lost' : 'type-found'}}">
        {{detail.type === 'lost' ? '寻物启事' : '失物招领'}}
      </view>
      <view class="status-badge" style="background: {{statusInfo.color}}20; color: {{statusInfo.color}};">
        {{statusInfo.label}}
      </view>
      <view class="info-actions">
        <view
          class="action-btn {{isFavorite ? 'active' : ''}}"
          bindtap="onToggleFavorite"
        >
          <text class="action-icon">{{isFavorite ? '★' : '☆'}}</text>
          <text class="action-text">{{isFavorite ? '已收藏' : '收藏'}}</text>
        </view>
        <view
          class="action-btn"
          bindtap="onReport"
        >
          <text class="action-icon">🚫</text>
          <text class="action-text">举报</text>
        </view>
      </view>
    </view>

    <text class="info-title">{{detail.title}}</text>
    <text class="info-time">发布于 {{detail.timeText}}</text>

    <!-- 发布者信息 -->
    <view class="publisher-section">
      <image class="publisher-avatar" src="{{detail.userAvatar || '/assets/images/default-avatar.png'}}" mode="aspectFill" />
      <view class="publisher-info">
        <text class="publisher-name">{{detail.userName}}</text>
        <text class="publisher-phone">{{maskedPhone}}</text>
      </view>
      <view class="publisher-tag" wx:if="{{isPublisher}}">我发布的</view>
    </view>
  </view>

  <!-- 详细信息 -->
  <view class="detail-section">
    <view class="detail-card">
      <view class="detail-item">
        <text class="detail-label">物品类型</text>
        <text class="detail-value">{{detail.itemTypeText}}</text>
      </view>
      <view class="detail-item location-item" bindtap="onLocateOnMap" data-location="{{detail.location}}" data-poi-id="{{detail.locationPOIId}}">
        <text class="detail-label">{{detail.type === 'lost' ? '丢失地点' : '拾取地点'}}</text>
        <view class="detail-value-wrap">
          <text class="detail-value">{{detail.locationText}}</text>
          <view class="locate-action">
            <text class="locate-icon">🗺️</text>
            <text class="locate-text">地图定位</text>
          </view>
        </view>
      </view>

      <view class="poi-card" wx:if="{{locationPOI}}" bindtap="onViewPOIDetail" data-poi-id="{{locationPOI.id}}">
        <view class="poi-card-icon" style="background: {{locationPOI.categoryColor}}20;">
          <text>{{locationPOI.categoryIcon}}</text>
        </view>
        <view class="poi-card-info">
          <text class="poi-card-name">{{locationPOI.name}}</text>
          <text class="poi-card-addr">{{locationPOI.categoryLabel}} · 点击查看详情</text>
        </view>
        <text class="poi-card-arrow">›</text>
      </view>
      <view class="detail-item">
        <text class="detail-label">{{detail.type === 'lost' ? '丢失时间' : '拾取时间'}}</text>
        <text class="detail-value">{{detail.date}}</text>
      </view>
    </view>
  </view>

  <!-- 描述 -->
  <view class="desc-section">
    <view class="section-title">详细描述</view>
    <view class="desc-card">
      <text class="desc-text">{{detail.description}}</text>
    </view>
  </view>

  <!-- 智能匹配推荐 -->
  <view class="match-section" wx:if="{{hasRelatedMatches}}">
    <view class="section-header">
      <view class="section-title">
        <text class="title-icon">🤖</text>
        AI智能匹配推荐
      </view>
      <view class="section-action" bindtap="goToMatchCenter">
        <text class="action-text">查看全部</text>
        <text class="action-arrow">›</text>
      </view>
    </view>

    <view class="match-list">
      <view
        class="match-item"
        wx:for="{{relatedMatches}}"
        wx:key="item.id"
        hover-class="match-item-hover"
      >
        <view class="match-main" bindtap="onMatchItemTap" data-item="{{item.item}}">
          <image
            wx:if="{{item.item.images && item.item.images.length > 0}}"
            class="match-image"
            src="{{item.item.images[0]}}"
            mode="aspectFill"
          />
          <view class="match-info">
            <view class="match-header">
              <view class="match-type {{item.item.type === 'lost' ? 'type-lost' : 'type-found'}}">
                {{item.item.type === 'lost' ? '寻物' : '招领'}}
              </view>
              <view class="match-score-badge" style="background: {{item.levelInfo.bgColor}}; color: {{item.levelInfo.color}};">
                {{item.score}}分 · {{item.levelInfo.label}}
              </view>
            </view>
            <text class="match-title">{{item.item.title}}</text>
            <view class="match-meta">
              <text class="meta-item">📍 {{item.item.locationText}}</text>
              <text class="meta-item">🕐 {{item.item.timeText}}</text>
            </view>
          </view>
        </view>
        <view class="match-actions">
          <view
            class="compare-btn"
            catchtap="onCompare"
            data-match="{{item}}"
          >
            <text class="compare-icon">📊</text>
            <text class="compare-text">一键对比</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 联系方式 -->
  <view class="contact-section">
    <view class="section-title">联系方式</view>
    <view class="contact-card">
      <view class="contact-item">
        <text class="contact-label">联系人</text>
        <text class="contact-value">{{detail.contact}}</text>
      </view>
      <view class="contact-item">
        <text class="contact-label">联系电话</text>
        <text class="contact-value phone" bindtap="{{!detail.isClosed ? 'onCallPhone' : ''}}">{{maskedPhone}}</text>
      </view>
    </view>
    <view class="closed-tip" wx:if="{{detail.isClosed}}">
      <text class="closed-icon">✅</text>
      <text class="closed-text">此信息已{{statusInfo.label}}，暂不支持联系</text>
    </view>
  </view>

  <!-- 认领状态卡片 - 待审核中 -->
  <view class="claim-status-card claim-pending" wx:if="{{detail.status === 'claim_pending'}}">
    <view class="claim-status-icon">⏳</view>
    <view class="claim-status-info">
      <text class="claim-status-title">认领审核中</text>
      <text class="claim-status-desc" wx:if="{{isPublisher}}">您有 {{pendingClaimCount}} 个认领申请待审核</text>
      <text class="claim-status-desc" wx:elif="{{myClaimApplication}}">您的认领申请正在审核中，请耐心等待</text>
      <text class="claim-status-desc" wx:else>此物品正在认领审核流程中</text>
    </view>
    <view class="claim-status-action" wx:if="{{isPublisher}}" bindtap="onManageClaims">
      <text>查看申请</text>
      <text class="arrow">›</text>
    </view>
  </view>

  <!-- 认领状态卡片 - 核验中 -->
  <view class="claim-status-card verifying" wx:if="{{detail.status === 'verifying'}}">
    <view class="claim-status-icon verify">🔐</view>
    <view class="claim-status-info">
      <text class="claim-status-title">线下核验中</text>
      <text class="claim-status-desc" wx:if="{{isPublisher}}">请与认领人线下核对核验码，确认物品信息</text>
      <text class="claim-status-desc" wx:elif="{{myClaimApplication && myClaimApplication.status === 'approved'}}">请联系发布者进行线下核验</text>
      <text class="claim-status-desc" wx:else>此物品正在线下核验流程中</text>
    </view>
    <view class="claim-status-action" bindtap="{{isPublisher ? 'onManageClaims' : (myClaimApplication && myClaimApplication.status === 'approved' ? 'onViewVerifyCode' : '')}}">
      <text>{{isPublisher ? '管理核验' : (myClaimApplication && myClaimApplication.status === 'approved' ? '查看核验码' : '')}}</text>
      <text class="arrow">›</text>
    </view>
  </view>

  <!-- 认领完成卡片 - 已完成 -->
  <view class="claim-status-card resolved" wx:if="{{detail.status === 'resolved' && verifiedApplication}}">
    <view class="claim-status-icon done">🎉</view>
    <view class="claim-status-info">
      <text class="claim-status-title">物品已成功{{detail.type === 'lost' ? '找回' : '归还'}}</text>
      <text class="claim-status-desc">完成时间：{{verifiedApplication.verifiedTimeText}}</text>
    </view>
  </view>

  <!-- 互评入口卡片 -->
  <view class="review-entry-card" wx:if="{{needReviewPublisher || needReviewClaimant}}">
    <view class="review-entry-icon">⭐</view>
    <view class="review-entry-info">
      <text class="review-entry-title">完成服务评价</text>
      <text class="review-entry-desc">互评有助于提升用户信用分，共建诚信社区</text>
    </view>
    <view class="review-entry-actions">
      <view class="review-btn" wx:if="{{needReviewPublisher}}" bindtap="onReviewClaimant">
        <text>评价认领人</text>
      </view>
      <view class="review-btn" wx:if="{{needReviewClaimant}}" bindtap="onReviewPublisher">
        <text>评价发布者</text>
      </view>
    </view>
  </view>

  <!-- 我的认领申请卡片 -->
  <view class="my-claim-card" wx:if="{{myClaimApplication && detail.status !== 'resolved'}}">
    <view class="my-claim-header">
      <text class="my-claim-title">我的认领申请</text>
      <view class="my-claim-status" style="background: {{myClaimApplication.statusInfo.color}}20; color: {{myClaimApplication.statusInfo.color}};">
        {{myClaimApplication.statusInfo.icon}} {{myClaimApplication.statusInfo.label}}
      </view>
    </view>
    <view class="my-claim-body">
      <view class="my-claim-row">
        <text class="my-claim-label">提交时间</text>
        <text class="my-claim-value">{{myClaimApplication.timeText}}</text>
      </view>
      <view class="my-claim-row" wx:if="{{myClaimApplication.reviewNote}}">
        <text class="my-claim-label">审核备注</text>
        <text class="my-claim-value">{{myClaimApplication.reviewNote}}</text>
      </view>
    </view>
    <view class="my-claim-actions">
      <view class="claim-action-btn secondary" bindtap="onViewMyApplication">
        <text>查看详情</text>
      </view>
      <view class="claim-action-btn primary" wx:if="{{myClaimApplication.status === 'approved'}}" bindtap="onViewVerifyCode">
        <text>查看核验码</text>
      </view>
    </view>
  </view>

  <!-- 发布者操作 - 认领管理入口 -->
  <view class="publisher-actions" wx:if="{{isPublisher && !detail.isClosed}}">
    <view class="manage-claim-btn" wx:if="{{pendingClaimCount > 0}}" bindtap="onManageClaims">
      <text class="manage-claim-badge">{{pendingClaimCount}}</text>
      <text>查看认领申请</text>
    </view>
    <view class="manage-claim-btn secondary" wx:else bindtap="onManageClaims">
      <text>认领管理</text>
    </view>
    <btn type="danger" size="large" block="{{true}}" bind:click="onCloseLostFound" custom-style="margin-top: 16rpx;">
      标记为{{detail.type === 'lost' ? '已找回' : '已认领'}}
    </btn>
  </view>

  <!-- 底部操作栏 -->
  <view class="bottom-bar" wx:if="{{!detail.isClosed}}">
    <view class="bottom-bar-inner">
      <view class="bottom-secondary-btn" bindtap="onCallPhone">
        <text class="phone-icon">📞</text>
        <text>联系{{isPublisher ? '我' : '发布者'}}</text>
      </view>
      <view class="bottom-primary-btn" wx:if="{{!isPublisher && !myClaimApplication}}" bindtap="onApplyClaim">
        <text class="claim-icon">🤝</text>
        <text>我要认领</text>
      </view>
      <view class="bottom-primary-btn applied" wx:elif="{{!isPublisher && myClaimApplication && myClaimApplication.status === 'pending'}}">
        <text>已提交申请</text>
      </view>
      <view class="bottom-primary-btn approved" wx:elif="{{!isPublisher && myClaimApplication && myClaimApplication.status === 'approved'}}" bindtap="onViewVerifyCode">
        <text class="verify-icon">🔐</text>
        <text>查看核验码</text>
      </view>
      <view class="bottom-primary-btn rejected" wx:elif="{{!isPublisher && myClaimApplication && myClaimApplication.status === 'rejected'}}">
        <text>申请未通过</text>
      </view>
      <view class="bottom-primary-btn verified" wx:elif="{{detail.status === 'verifying' && isPublisher}}" bindtap="onManageClaims">
        <text class="verify-icon">✅</text>
        <text>确认核验完成</text>
      </view>
    </view>
  </view>
  <view class="bottom-bar closed-bar" wx:else>
    <btn type="default" size="large" block="{{true}}" disabled="{{true}}">
      此信息已{{statusInfo.label}}
    </btn>
  </view>
</view>

<view class="page empty-page {{darkMode ? 'dark' : ''}}" wx:else>
  <text class="empty-text">信息不存在或已删除</text>
</view>
