<page-meta page-style="background-color: {{darkMode ? '#0F1117' : '#F8F9FA'}}; color: {{darkMode ? '#E8ECF1' : '#2C3E50'}}"/>
<view class="page {{darkMode ? 'dark' : ''}}" wx:if="{{detail}}">
  <!-- 图片轮播 -->
  <view class="image-section" wx:if="{{detail.images && detail.images.length > 0}}">
    <swiper
      class="image-swiper"
      indicator-dots="{{detail.images.length > 1}}"
      indicator-color="rgba(255,255,255,0.5)"
      indicator-active-color="#FFFFFF"
    >
      <swiper-item
        wx:for="{{detail.images}}"
        wx:key="index"
        bindtap="onPreviewImage"
        data-index="{{index}}"
      >
        <image class="swiper-image" src="{{item}}" mode="aspectFill" />
      </swiper-item>
    </swiper>
  </view>

  <!-- 基本信息 -->
  <view class="info-section">
    <view class="info-header">
      <view class="info-type {{detail.type === 'lost' ? 'type-lost' : 'type-found'}}">
        {{detail.type === 'lost' ? '寻物启事' : '失物招领'}}
      </view>
      <view class="status-badge" style="background: {{statusInfo.color}}20; color: {{statusInfo.color}};">
        {{statusInfo.label}}
      </view>
      <view class="info-actions">
        <view
          class="action-btn {{isFavorite ? 'active' : ''}}"
          bindtap="onToggleFavorite"
        >
          <text class="action-icon">{{isFavorite ? '★' : '☆'}}</text>
          <text class="action-text">{{isFavorite ? '已收藏' : '收藏'}}</text>
        </view>
        <view
          class="action-btn"
          bindtap="onReport"
        >
          <text class="action-icon">🚫</text>
          <text class="action-text">举报</text>
        </view>
      </view>
    </view>

    <text class="info-title">{{detail.title}}</text>
    <text class="info-time">发布于 {{detail.timeText}}</text>

    <!-- 发布者信息 -->
    <view class="publisher-section">
      <image class="publisher-avatar" src="{{detail.userAvatar || '/assets/images/default-avatar.png'}}" mode="aspectFill" />
      <view class="publisher-info">
        <text class="publisher-name">{{detail.userName}}</text>
        <text class="publisher-phone">{{maskedPhone}}</text>
      </view>
      <view class="publisher-tag" wx:if="{{isPublisher}}">我发布的</view>
    </view>
  </view>

  <!-- 详细信息 -->
  <view class="detail-section">
    <view class="detail-card">
      <view class="detail-item">
        <text class="detail-label">物品类型</text>
        <text class="detail-value">{{detail.itemTypeText}}</text>
      </view>
      <view class="detail-item location-item" bindtap="onLocateOnMap" data-location="{{detail.location}}" data-poi-id="{{detail.locationPOIId}}">
        <text class="detail-label">{{detail.type === 'lost' ? '丢失地点' : '拾取地点'}}</text>
        <view class="detail-value-wrap">
          <text class="detail-value">{{detail.locationText}}</text>
          <view class="locate-action">
            <text class="locate-icon">🗺️</text>
            <text class="locate-text">地图定位</text>
          </view>
        </view>
      </view>

      <view class="poi-card" wx:if="{{locationPOI}}" bindtap="onViewPOIDetail" data-poi-id="{{locationPOI.id}}">
        <view class="poi-card-icon" style="background: {{locationPOI.categoryColor}}20;">
          <text>{{locationPOI.categoryIcon}}</text>
        </view>
        <view class="poi-card-info">
          <text class="poi-card-name">{{locationPOI.name}}</text>
          <text class="poi-card-addr">{{locationPOI.categoryLabel}} · 点击查看详情</text>
        </view>
        <text class="poi-card-arrow">›</text>
      </view>
      <view class="detail-item">
        <text class="detail-label">{{detail.type === 'lost' ? '丢失时间' : '拾取时间'}}</text>
        <text class="detail-value">{{detail.date}}</text>
      </view>
    </view>
  </view>

  <!-- 描述 -->
  <view class="desc-section">
    <view class="section-title">详细描述</view>
    <view class="desc-card">
      <text class="desc-text">{{detail.description}}</text>
    </view>
  </view>

  <!-- 联系方式 -->
  <view class="contact-section">
    <view class="section-title">联系方式</view>
    <view class="contact-card">
      <view class="contact-item">
        <text class="contact-label">联系人</text>
        <text class="contact-value">{{detail.contact}}</text>
      </view>
      <view class="contact-item">
        <text class="contact-label">联系电话</text>
        <text class="contact-value phone" bindtap="{{!detail.isClosed ? 'onCallPhone' : ''}}">{{maskedPhone}}</text>
      </view>
    </view>
    <view class="closed-tip" wx:if="{{detail.isClosed}}">
      <text class="closed-icon">✅</text>
      <text class="closed-text">此信息已{{statusInfo.label}}，暂不支持联系</text>
    </view>
  </view>

  <!-- 评论区 -->
  <view class="comment-section">
    <view class="section-title">
      评论
      <text class="comment-count" wx:if="{{comments.length > 0}}">({{comments.length}})</text>
    </view>

    <!-- 评论输入框 -->
    <view class="comment-input-wrap">
      <input
        class="comment-input"
        placeholder="{{detail.isClosed ? '此信息已关闭，无法评论' : '说点什么...'}}"
        value="{{commentInput}}"
        bindinput="onCommentInput"
        confirm-type="send"
        bindconfirm="onSubmitComment"
        disabled="{{detail.isClosed}}"
        maxlength="500"
      />
      <view
        class="comment-submit {{commentInput && !detail.isClosed ? 'active' : ''}}"
        bindtap="onSubmitComment"
      >
        发送
      </view>
    </view>

    <!-- 评论列表 -->
    <view class="comment-list" wx:if="{{comments.length > 0}}">
      <view
        class="comment-item"
        wx:for="{{comments}}"
        wx:key="id"
      >
        <image
          class="comment-avatar"
          src="{{item.userAvatar || '/assets/images/default-avatar.png'}}"
          mode="aspectFill"
        />
        <view class="comment-content">
          <view class="comment-header">
            <text class="comment-name">{{item.userName}}</text>
            <text class="comment-time">{{item.timeText}}</text>
          </view>
          <text class="comment-text">{{item.content}}</text>
        </view>
        <view
          class="comment-delete"
          wx:if="{{item.canDelete}}"
          bindtap="onDeleteComment"
          data-comment-id="{{item.id}}"
        >
          删除
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="comment-empty" wx:else>
      <text class="comment-empty-text">暂无评论，快来抢沙发～</text>
    </view>
  </view>

  <!-- 发布者操作 -->
  <view class="publisher-actions" wx:if="{{isPublisher && !detail.isClosed}}">
    <btn type="danger" size="large" block="{{true}}" bind:click="onCloseLostFound">
      标记为{{detail.type === 'lost' ? '已找回' : '已认领'}}
    </btn>
  </view>

  <!-- 底部操作 -->
  <view class="bottom-bar" wx:if="{{!detail.isClosed}}">
    <btn type="primary" size="large" block="{{true}}" bind:click="onCallPhone">立即联系</btn>
  </view>
  <view class="bottom-bar closed-bar" wx:else>
    <btn type="default" size="large" block="{{true}}" disabled="{{true}}">
      此信息已{{statusInfo.label}}
    </btn>
  </view>
</view>

<view class="page empty-page {{darkMode ? 'dark' : ''}}" wx:else>
  <text class="empty-text">信息不存在或已删除</text>
</view>
