.page {
  min-height: 100vh;
  background: var(--color-bg-page);
  padding-bottom: 40rpx;
}

.page.dark {
  --color-bg-page: #0F1117;
  --color-bg-card: #1A1D29;
  --color-text-primary: #E8ECF1;
  --color-text-secondary: #9CA3AF;
  --color-border: #2D3142;
}

/* 搜索栏 */
.search-section {
  padding: 24rpx 32rpx 16rpx;
  background: var(--color-bg-page);
}

.search-bar {
  display: flex;
  align-items: center;
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: 20rpx 28rpx;
  box-shadow: var(--shadow-card);
}

.search-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
  opacity: 0.6;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--color-text-primary);
}

.search-placeholder {
  color: var(--color-text-secondary);
  font-size: 28rpx;
}

/* 快捷入口导航 */
.quick-nav {
  display: flex;
  justify-content: space-around;
  padding: 16rpx 32rpx 24rpx;
}

.nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 12rpx;
  transition: transform 0.2s ease;
}

.nav-item:active {
  transform: scale(0.95);
}

.nav-icon {
  width: 96rpx;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, rgba(59, 130, 246, 0.1), rgba(99, 102, 241, 0.1));
  border-radius: 28rpx;
  font-size: 44rpx;
}

.nav-label {
  font-size: 24rpx;
  color: var(--color-text-primary);
  font-weight: 500;
}

/* 主标签栏 */
.main-tabs {
  display: flex;
  background: var(--color-bg-card);
  margin: 0 32rpx 24rpx;
  border-radius: var(--radius-xl);
  padding: 8rpx;
  box-shadow: var(--shadow-card);
}

.main-tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 12rpx;
  border-radius: var(--radius-lg);
  transition: all 0.3s ease;
}

.main-tab-item.active {
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-dark));
}

.tab-icon {
  font-size: 36rpx;
  margin-bottom: 8rpx;
}

.tab-label {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  font-weight: 500;
}

.main-tab-item.active .tab-label {
  color: #FFFFFF;
}

/* 子标签栏 */
.sub-tabs {
  display: flex;
  align-items: center;
  padding: 0 32rpx;
  margin-bottom: 20rpx;
  overflow-x: auto;
  white-space: nowrap;
}

.sub-tab-item {
  flex-shrink: 0;
  padding: 16rpx 32rpx;
  margin-right: 16rpx;
  border-radius: 48rpx;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  background: var(--color-bg-card);
  transition: all 0.3s ease;
}

.sub-tab-item.active {
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-dark));
  color: #FFFFFF;
  font-weight: 500;
}

.filter-btn {
  display: flex;
  align-items: center;
  margin-left: auto;
  padding: 12rpx 24rpx;
  background: var(--color-bg-card);
  border-radius: 48rpx;
  font-size: 24rpx;
  color: var(--color-text-primary);
  flex-shrink: 0;
}

.filter-btn.small {
  padding: 8rpx 20rpx;
  font-size: 22rpx;
}

.filter-icon {
  margin-right: 8rpx;
  font-size: 24rpx;
}

/* 发布区域 */
.publish-section {
  padding: 0 32rpx;
  margin-bottom: 24rpx;
}

.publish-icon {
  margin-right: 12rpx;
}

/* 列表滚动容器 */
.list-scroll {
  height: calc(100vh - 480rpx);
  padding: 0 32rpx;
}

/* 项目卡片 */
.project-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.project-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: 32rpx;
  box-shadow: var(--shadow-card);
  transition: transform 0.3s ease;
}

.project-card:active {
  transform: scale(0.98);
}

.project-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.project-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  flex: 1;
}

.tag {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 16rpx;
  border-radius: 24rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.tag.status-tag {
  border: 1rpx solid;
  background: transparent;
}

.project-meta {
  display: flex;
  gap: 16rpx;
  margin-left: 16rpx;
  flex-shrink: 0;
}

.meta-text {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

.project-title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 12rpx;
  line-height: 1.4;
}

.project-desc {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.6;
  margin-bottom: 20rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.project-highlights {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.highlight-item {
  font-size: 24rpx;
  color: var(--color-accent);
  background: rgba(245, 158, 11, 0.1);
  padding: 8rpx 16rpx;
  border-radius: 24rpx;
}

.project-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--color-border);
  margin-bottom: 16rpx;
}

.financing-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.financing-label {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.financing-value {
  font-size: 26rpx;
  font-weight: 600;
}

.team-size {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.team-icon {
  font-size: 28rpx;
}

.team-count {
  font-size: 24rpx;
  color: var(--color-text-primary);
  font-weight: 500;
}

.recruiting-section {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
  padding: 16rpx 20rpx;
  background: rgba(239, 68, 68, 0.08);
  border-radius: var(--radius-lg);
  margin-bottom: 16rpx;
}

.recruiting-label {
  font-size: 24rpx;
  color: #EF4444;
  font-weight: 600;
}

.recruiting-tag {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 16rpx;
  border-radius: 24rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.project-time {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

/* 导师卡片 */
.mentor-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.mentor-card {
  display: flex;
  align-items: center;
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: 28rpx;
  box-shadow: var(--shadow-card);
  transition: transform 0.3s ease;
}

.mentor-card:active {
  transform: scale(0.98);
}

.mentor-avatar {
  position: relative;
  flex-shrink: 0;
  margin-right: 24rpx;
}

.avatar-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  object-fit: cover;
}

.mentor-badge {
  position: absolute;
  bottom: -8rpx;
  left: 50%;
  transform: translateX(-50%);
  padding: 4rpx 16rpx;
  border-radius: 24rpx;
  font-size: 20rpx;
  color: #FFFFFF;
  white-space: nowrap;
}

.mentor-info {
  flex: 1;
  min-width: 0;
}

.mentor-name-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.mentor-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-right: 16rpx;
}

.mentor-rating {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.star {
  font-size: 24rpx;
}

.rating-value {
  font-size: 24rpx;
  color: #F59E0B;
  font-weight: 600;
}

.mentor-dept {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-bottom: 8rpx;
  display: block;
}

.mentor-research {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-bottom: 12rpx;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.mentor-stats {
  display: flex;
  gap: 20rpx;
}

.stat-item {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

.arrow {
  font-size: 36rpx;
  color: var(--color-text-secondary);
  margin-left: 16rpx;
}

/* 路演卡片 */
.roadshow-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.roadshow-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  overflow: hidden;
  box-shadow: var(--shadow-card);
  transition: transform 0.3s ease;
}

.roadshow-card:active {
  transform: scale(0.98);
}

.roadshow-cover {
  position: relative;
  height: 240rpx;
}

.cover-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.roadshow-status {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  font-size: 22rpx;
  color: #FFFFFF;
  font-weight: 500;
}

.roadshow-content {
  padding: 28rpx;
}

.roadshow-title-row {
  margin-bottom: 16rpx;
}

.roadshow-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  display: block;
  margin-bottom: 8rpx;
}

.roadshow-subtitle {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  display: block;
}

.roadshow-info {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.info-item {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.roadshow-progress {
  margin-bottom: 20rpx;
}

.progress-bar {
  width: 100%;
  height: 12rpx;
  background: rgba(59, 130, 246, 0.15);
  border-radius: 6rpx;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--color-primary), var(--color-accent));
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

.progress-text {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

.roadshow-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--color-border);
}

.organizer {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

.views {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

/* 政策卡片 */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.section-more {
  font-size: 24rpx;
  color: var(--color-primary);
}

.policy-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 32rpx;
}

.policy-card {
  display: flex;
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: 24rpx;
  box-shadow: var(--shadow-card);
  transition: transform 0.3s ease;
}

.policy-card:active {
  transform: scale(0.98);
}

.policy-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.policy-content {
  flex: 1;
  min-width: 0;
}

.policy-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 8rpx;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.policy-summary {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-bottom: 12rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  display: block;
}

.policy-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.policy-tags {
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
}

.policy-tag {
  font-size: 20rpx;
  color: var(--color-primary);
  background: rgba(59, 130, 246, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 16rpx;
}

.policy-date {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  flex-shrink: 0;
  margin-left: 12rpx;
}

.policy-favorite {
  margin-left: 12rpx;
  font-size: 28rpx;
}

/* 孵化器卡片 */
.incubator-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 32rpx;
}

.incubator-card {
  display: flex;
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  overflow: hidden;
  box-shadow: var(--shadow-card);
  transition: transform 0.3s ease;
}

.incubator-card:active {
  transform: scale(0.98);
}

.incubator-img {
  width: 180rpx;
  height: 180rpx;
  object-fit: cover;
  flex-shrink: 0;
}

.incubator-info {
  flex: 1;
  padding: 20rpx;
  min-width: 0;
}

.incubator-name-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 8rpx;
}

.incubator-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  flex: 1;
  margin-right: 12rpx;
}

.incubator-level {
  padding: 4rpx 12rpx;
  border-radius: 16rpx;
  font-size: 20rpx;
  font-weight: 500;
  flex-shrink: 0;
}

.incubator-type {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-bottom: 12rpx;
  display: block;
}

.incubator-stats {
  display: flex;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.stat {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

.incubator-address {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 查看更多 */
.view-more-section {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 24rpx;
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  margin-top: 8rpx;
  margin-bottom: 32rpx;
}

.view-more-text {
  font-size: 26rpx;
  color: var(--color-primary);
  margin-right: 8rpx;
}

.view-more-arrow {
  font-size: 28rpx;
  color: var(--color-primary);
}

/* 底部筛选弹窗 */
.picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.picker-mask.show {
  opacity: 1;
  visibility: visible;
}

.picker-content {
  width: 100%;
  background: var(--color-bg-card);
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx;
  max-height: 70vh;
  transform: translateY(100%);
  transition: transform 0.3s ease;
}

.picker-mask.show .picker-content {
  transform: translateY(0);
}

.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid var(--color-border);
}

.picker-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.picker-clear {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.picker-options {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  max-height: 50vh;
  overflow-y: auto;
}

.picker-option {
  display: flex;
  align-items: center;
  padding: 24rpx 20rpx;
  border-radius: var(--radius-lg);
  transition: background 0.2s ease;
}

.picker-option:active {
  background: var(--color-hover);
}

.picker-option.active {
  background: rgba(59, 130, 246, 0.1);
}

.option-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.option-label {
  flex: 1;
  font-size: 28rpx;
  color: var(--color-text-primary);
}

.picker-option.active .option-label {
  color: var(--color-primary);
  font-weight: 500;
}

.option-check {
  font-size: 32rpx;
  color: var(--color-primary);
}

/* 加载状态 */
.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--color-bg-page);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2000;
}

.loading-content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 4rpx solid var(--color-border);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 24rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}
