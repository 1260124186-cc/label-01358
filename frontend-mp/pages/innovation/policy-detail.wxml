<page-meta page-style="background-color: {{darkMode ? '#0F1117' : '#F8F9FA'}}; color: {{darkMode ? '#E8ECF1' : '#2C3E50'}}"/>
<view class="page {{darkMode ? 'dark' : ''}}" wx:if="{{policy}}">
  <scroll-view class="main-scroll" scroll-y="{{true}}" enhanced="{{true}}" show-scrollbar="{{false}}">
    <!-- 头部信息 -->
    <view class="header-section">
      <view class="type-tag" style="background: {{policy.typeInfo.color}}20; color: {{policy.typeInfo.color}}">
        <text class="type-icon">{{policy.typeInfo.icon}}</text>
        <text class="type-label">{{policy.typeInfo.label}}</text>
      </view>
      <text class="policy-title">{{policy.title}}</text>
      <view class="policy-meta">
        <text class="meta-item">📅 {{policy.publishDate}}</text>
        <text class="meta-item">🏛️ {{policy.source}}</text>
        <text class="meta-item">⏰ 截止：{{policy.deadline}}</text>
      </view>
      <view class="policy-stats">
        <text class="stat-item">👁️ {{policy.views}} 次阅读</text>
        <text class="stat-item">❤️ {{policy.isFavorite ? '已收藏' : '未收藏'}}</text>
      </view>
    </view>

    <!-- 政策摘要 -->
    <view class="section-card">
      <view class="section-header">
        <text class="section-title">📝 政策摘要</text>
      </view>
      <text class="summary-text">{{policy.summary}}</text>
    </view>

    <!-- 政策标签 -->
    <view class="section-card" wx:if="{{policy.tags && policy.tags.length > 0}}">
      <view class="section-header">
        <text class="section-title">🏷️ 相关标签</text>
      </view>
      <view class="tags-list">
        <view class="tag-item" wx:for="{{policy.tags}}" wx:key="index">
          <text class="tag-text"># {{item}}</text>
        </view>
      </view>
    </view>

    <!-- 政策内容 -->
    <view class="section-card">
      <view class="section-header">
        <text class="section-title">📄 政策详情</text>
      </view>
      <view class="content-list">
        <text class="content-line" wx:for="{{policy.contentLines}}" wx:key="index">{{item}}</text>
      </view>
    </view>

    <view class="bottom-space"></view>
  </scroll-view>

  <!-- 底部操作栏 -->
  <view class="bottom-bar">
    <view class="action-btn secondary" bindtap="onFavoriteTap">
      <text class="action-icon">{{policy.isFavorite ? '❤️' : '🤍'}}</text>
      <text class="action-text">{{policy.isFavorite ? '已收藏' : '收藏'}}</text>
    </view>
    <view class="action-btn secondary" open-type="share">
      <text class="action-icon">📤</text>
      <text class="action-text">分享</text>
    </view>
    <btn class="action-btn primary" type="primary" bind:click="onApplyTap">
      立即申请
    </btn>
  </view>

  <!-- 加载状态 -->
  <view class="loading-overlay" wx:if="{{loading}}">
    <view class="loading-content">
      <view class="loading-spinner"></view>
      <text class="loading-text">加载中...</text>
    </view>
  </view>
</view>
