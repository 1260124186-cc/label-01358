.page {
  min-height: 100vh;
  background: var(--color-bg-page);
}

.page.dark {
  --color-bg-page: #0F1117;
  --color-bg-card: #1A1D29;
  --color-text-primary: #E8ECF1;
  --color-text-secondary: #9CA3AF;
  --color-border: #2D3142;
}

.main-scroll {
  height: calc(100vh - 120rpx);
}

/* 图片轮播 */
.image-section {
  position: relative;
  width: 100%;
  height: 450rpx;
}

.image-swiper {
  width: 100%;
  height: 100%;
}

.swiper-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.image-badges {
  position: absolute;
  top: 24rpx;
  left: 24rpx;
  right: 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.level-badge {
  padding: 10rpx 24rpx;
  background: rgba(245, 158, 11, 0.9);
  border-radius: 28rpx;
  font-size: 24rpx;
  color: #FFFFFF;
  font-weight: 500;
}

.type-badge {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 20rpx;
  border-radius: 28rpx;
}

.type-icon {
  font-size: 24rpx;
}

.type-label {
  font-size: 24rpx;
  color: #FFFFFF;
  font-weight: 500;
}

/* 内容区域 */
.content-section {
  padding: 0 32rpx;
  margin-top: -30rpx;
  position: relative;
  z-index: 10;
}

.title-section {
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-card);
}

.incubator-name {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  line-height: 1.4;
  margin-bottom: 16rpx;
  display: block;
}

.rating-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.rating-section {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.star {
  font-size: 32rpx;
}

.rating-value {
  font-size: 32rpx;
  font-weight: 600;
  color: #F59E0B;
}

.review-count {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.view-count {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

/* 数据统计 */
.stats-card {
  display: flex;
  align-items: center;
  justify-content: space-around;
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: 32rpx 20rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-card);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  flex: 1;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-primary);
}

.stat-label {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: var(--color-border);
}

/* 通用卡片 */
.section-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-card);
}

.section-header {
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.description-text {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  line-height: 1.8;
}

/* 联系方式 */
.contact-list {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.contact-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--color-border);
}

.contact-item:last-child {
  border-bottom: none;
}

.contact-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.contact-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.contact-label {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.contact-value {
  font-size: 28rpx;
  color: var(--color-text-primary);
  font-weight: 500;
}

.contact-arrow {
  font-size: 36rpx;
  color: var(--color-text-secondary);
  margin-left: 16rpx;
}

/* 服务网格 */
.services-grid {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.service-item {
  padding: 20rpx;
  background: var(--color-bg-page);
  border-radius: var(--radius-lg);
}

.service-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 8rpx;
  display: block;
}

.service-desc {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  line-height: 1.6;
}

/* 政策列表 */
.policies-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.policy-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.policy-dot {
  color: var(--color-primary);
  font-size: 28rpx;
  line-height: 1.6;
}

.policy-text {
  flex: 1;
  font-size: 28rpx;
  color: var(--color-text-secondary);
  line-height: 1.7;
}

/* 成功案例 */
.cases-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.case-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 16rpx 28rpx;
  background: var(--color-bg-page);
  border-radius: var(--radius-lg);
}

.case-icon {
  font-size: 28rpx;
}

.case-name {
  font-size: 26rpx;
  color: var(--color-text-primary);
  font-weight: 500;
}

.bottom-space {
  height: 40rpx;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 32rpx calc(20rpx + env(safe-area-inset-bottom));
  background: var(--color-bg-card);
  border-top: 1rpx solid var(--color-border);
  z-index: 100;
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
}

.action-btn.secondary {
  width: 120rpx;
  padding: 12rpx;
  background: var(--color-bg-page);
  border-radius: var(--radius-lg);
}

.action-btn.primary {
  flex: 1;
  height: 88rpx;
}

.action-icon {
  font-size: 36rpx;
}

.action-text {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 2000;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.modal-mask.show {
  opacity: 1;
  visibility: visible;
}

.modal-content {
  width: 660rpx;
  max-height: 85vh;
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  overflow: hidden;
  transform: scale(0.9);
  transition: transform 0.3s ease;
}

.modal-mask.show .modal-content {
  transform: scale(1);
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid var(--color-border);
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.modal-close {
  font-size: 36rpx;
  color: var(--color-text-secondary);
  padding: 8rpx;
}

.modal-body {
  padding: 32rpx;
  max-height: 60vh;
  overflow-y: auto;
}

.form-item {
  margin-bottom: 28rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: var(--color-text-primary);
  margin-bottom: 12rpx;
  font-weight: 500;
}

.required {
  color: #EF4444;
  margin-left: 4rpx;
}

.form-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  background: var(--color-bg-page);
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-lg);
  font-size: 28rpx;
  color: var(--color-text-primary);
  box-sizing: border-box;
}

.form-input:focus {
  border-color: var(--color-primary);
}

.form-textarea {
  width: 100%;
  height: 200rpx;
  padding: 20rpx 24rpx;
  background: var(--color-bg-page);
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-lg);
  font-size: 28rpx;
  color: var(--color-text-primary);
  box-sizing: border-box;
  line-height: 1.6;
}

.modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 24rpx 32rpx 32rpx;
  border-top: 1rpx solid var(--color-border);
}

.modal-btn {
  flex: 1;
  height: 88rpx;
}

/* 加载状态 */
.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--color-bg-page);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 3000;
}

.loading-content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 4rpx solid var(--color-border);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 24rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}
