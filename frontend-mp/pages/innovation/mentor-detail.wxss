.page {
  min-height: 100vh;
  background: var(--color-bg-page);
  padding-bottom: 140rpx;
}

.page.dark {
  --color-bg-page: #0F1117;
  --color-bg-card: #1A1D29;
  --color-text-primary: #E8ECF1;
  --color-text-secondary: #9CA3AF;
  --color-border: #2D3142;
}

/* 头部 */
.header-section {
  position: relative;
  margin-bottom: 24rpx;
}

.header-bg {
  height: 200rpx;
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-dark));
}

.mentor-info {
  position: relative;
  background: var(--color-bg-card);
  margin: -80rpx 24rpx 0;
  border-radius: var(--radius-xl);
  padding: 40rpx 32rpx;
  box-shadow: var(--shadow-card);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.mentor-avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 80rpx;
  object-fit: cover;
  border: 4rpx solid var(--color-bg-card);
  margin-bottom: 16rpx;
}

.mentor-badge {
  padding: 6rpx 20rpx;
  border-radius: 24rpx;
  font-size: 22rpx;
  color: #FFFFFF;
  margin-bottom: 12rpx;
}

.mentor-name {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  margin-bottom: 8rpx;
}

.mentor-dept {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  margin-bottom: 12rpx;
}

.mentor-rating {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.rating-value {
  font-size: 28rpx;
  color: #F59E0B;
  font-weight: 600;
}

.rating-count {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

/* 内容滚动 */
.content-scroll {
  height: calc(100vh - 460rpx);
}

/* 信息区块 */
.info-section {
  background: var(--color-bg-card);
  margin: 0 24rpx 24rpx;
  padding: 32rpx;
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-card);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 24rpx;
}

.required {
  color: #EF4444;
}

/* 信息网格 */
.info-grid {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.info-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.info-label {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  flex-shrink: 0;
  width: 120rpx;
}

.info-value {
  flex: 1;
  font-size: 26rpx;
  color: var(--color-text-primary);
  line-height: 1.6;
}

/* 标签 */
.tags-container {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag-chip {
  padding: 10rpx 24rpx;
  background: rgba(59, 130, 246, 0.1);
  color: var(--color-primary);
  border-radius: 28rpx;
  font-size: 24rpx;
}

/* 统计 */
.stats-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.stat-card {
  width: calc((100% - 48rpx) / 4);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 12rpx;
  background: var(--color-bg-page);
  border-radius: var(--radius-lg);
}

.stat-value {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-primary);
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

/* 简介 */
.bio-content {
  font-size: 28rpx;
  color: var(--color-text-primary);
  line-height: 1.8;
}

/* 项目列表 */
.project-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.project-item {
  display: flex;
  gap: 16rpx;
  padding: 20rpx;
  background: var(--color-bg-page);
  border-radius: var(--radius-lg);
}

.project-icon {
  font-size: 32rpx;
  flex-shrink: 0;
}

.project-info {
  flex: 1;
  min-width: 0;
}

.project-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  display: block;
  margin-bottom: 6rpx;
}

.project-desc {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  display: block;
  line-height: 1.5;
}

/* 评价 */
.review-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.review-item {
  padding: 24rpx;
  background: var(--color-bg-page);
  border-radius: var(--radius-lg);
}

.review-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.reviewer {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.review-rating {
  font-size: 22rpx;
}

.review-content {
  font-size: 26rpx;
  color: var(--color-text-primary);
  line-height: 1.6;
  display: block;
  margin-bottom: 12rpx;
}

.review-date {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

.bottom-spacing {
  height: 40rpx;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  background: var(--color-bg-card);
  border-top: 1rpx solid var(--color-border);
  z-index: 100;
}

.btn-icon {
  margin-right: 12rpx;
}

/* 弹窗 */
.picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.picker-mask.show {
  opacity: 1;
  visibility: visible;
}

.modal-content,
.picker-content {
  width: 100%;
  background: var(--color-bg-card);
  border-radius: 32rpx 32rpx 0 0;
  transform: translateY(100%);
  transition: transform 0.3s ease;
}

.picker-mask.show .modal-content,
.picker-mask.show .picker-content {
  transform: translateY(0);
}

.modal-content {
  max-height: 85vh;
}

.modal-header,
.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid var(--color-border);
}

.modal-title,
.picker-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.modal-close,
.picker-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: var(--color-text-secondary);
}

.modal-body {
  padding: 32rpx;
  max-height: 60vh;
  overflow-y: auto;
}

.form-item {
  margin-bottom: 28rpx;
}

.form-label {
  display: block;
  font-size: 26rpx;
  color: var(--color-text-primary);
  margin-bottom: 12rpx;
  font-weight: 500;
}

.form-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 28rpx;
  background: var(--color-bg-page);
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-lg);
}

.picker-value {
  font-size: 28rpx;
  color: var(--color-text-primary);
  flex: 1;
}

.picker-value.placeholder {
  color: var(--color-text-secondary);
}

.picker-arrow {
  font-size: 32rpx;
  color: var(--color-text-secondary);
  margin-left: 16rpx;
}

.form-textarea {
  width: 100%;
  min-height: 180rpx;
  padding: 24rpx 28rpx;
  background: var(--color-bg-page);
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-lg);
  font-size: 28rpx;
  color: var(--color-text-primary);
  box-sizing: border-box;
  line-height: 1.6;
}

.notice {
  display: flex;
  gap: 12rpx;
  padding: 20rpx;
  background: rgba(245, 158, 11, 0.1);
  border-radius: var(--radius-lg);
  margin-top: 16rpx;
}

.notice-icon {
  font-size: 28rpx;
  flex-shrink: 0;
}

.notice-text {
  font-size: 24rpx;
  color: #B45309;
  line-height: 1.6;
}

.modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 24rpx 32rpx;
  border-top: 1rpx solid var(--color-border);
}

.modal-footer .btn {
  flex: 1;
}

.picker-options {
  max-height: 50vh;
  overflow-y: auto;
  padding: 16rpx 0;
}

.picker-option {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  transition: background 0.2s ease;
}

.picker-option:active {
  background: var(--color-hover);
}

.picker-option.active {
  background: rgba(59, 130, 246, 0.1);
}

.option-label {
  flex: 1;
  font-size: 28rpx;
  color: var(--color-text-primary);
}

.picker-option.active .option-label {
  color: var(--color-primary);
  font-weight: 500;
}

.option-check {
  font-size: 32rpx;
  color: var(--color-primary);
}

/* 加载状态 */
.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--color-bg-page);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2000;
}

.loading-content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 4rpx solid var(--color-border);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 24rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}
