<page-meta page-style="background-color: {{darkMode ? '#0F1117' : '#F8F9FA'}}; color: {{darkMode ? '#E8ECF1' : '#2C3E50'}}"/>
<view class="page {{darkMode ? 'dark' : ''}}" wx:if="{{incubator}}">
  <scroll-view class="main-scroll" scroll-y="{{true}}" enhanced="{{true}}" show-scrollbar="{{false}}">
    <!-- 图片轮播 -->
    <view class="image-section">
      <swiper class="image-swiper" indicator-dots="{{true}}" autoplay="{{true}}" circular="{{true}}">
        <swiper-item wx:for="{{incubator.images}}" wx:key="index">
          <image class="swiper-img" src="{{item}}" mode="aspectFill"/>
        </swiper-item>
      </swiper>
      <view class="image-badges">
        <view class="level-badge">{{incubator.level}}</view>
        <view class="type-badge" style="background: {{incubator.typeInfo.color}}">
          <text class="type-icon">{{incubator.typeInfo.icon}}</text>
          <text class="type-label">{{incubator.typeInfo.label}}</text>
        </view>
      </view>
    </view>

    <!-- 基本信息 -->
    <view class="content-section">
      <view class="title-section">
        <text class="incubator-name">{{incubator.name}}</text>
        <view class="rating-row">
          <view class="rating-section">
            <text class="star">⭐</text>
            <text class="rating-value">{{incubator.rating}}</text>
            <text class="review-count">({{incubator.reviews}}条评价)</text>
          </view>
          <text class="view-count">👁️ {{incubator.views}}</text>
        </view>
      </view>

      <!-- 数据统计 -->
      <view class="stats-card">
        <view class="stat-item">
          <text class="stat-value">{{incubator.inCubatedCount}}</text>
          <text class="stat-label">在孵企业</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <text class="stat-value">{{incubator.graduatedCount}}</text>
          <text class="stat-label">毕业企业</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <text class="stat-value">{{incubator.occupancyRate}}%</text>
          <text class="stat-label">入驻率</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <text class="stat-value">{{incubator.area}}</text>
          <text class="stat-label">总面积</text>
        </view>
      </view>

      <!-- 联系方式 -->
      <view class="section-card">
        <view class="section-header">
          <text class="section-title">📞 联系方式</text>
        </view>
        <view class="contact-list">
          <view class="contact-item" bindtap="onContactTap">
            <text class="contact-icon">📱</text>
            <view class="contact-info">
              <text class="contact-label">联系电话</text>
              <text class="contact-value">{{incubator.contactPhone}}</text>
            </view>
            <text class="contact-arrow">›</text>
          </view>
          <view class="contact-item">
            <text class="contact-icon">👤</text>
            <view class="contact-info">
              <text class="contact-label">联系人</text>
              <text class="contact-value">{{incubator.contactName}}</text>
            </view>
          </view>
          <view class="contact-item">
            <text class="contact-icon">📧</text>
            <view class="contact-info">
              <text class="contact-label">电子邮箱</text>
              <text class="contact-value">{{incubator.contactEmail}}</text>
            </view>
          </view>
          <view class="contact-item">
            <text class="contact-icon">📍</text>
            <view class="contact-info">
              <text class="contact-label">详细地址</text>
              <text class="contact-value">{{incubator.address}}</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 孵化器介绍 -->
      <view class="section-card">
        <view class="section-header">
          <text class="section-title">📝 孵化器介绍</text>
        </view>
        <text class="description-text">{{incubator.description}}</text>
      </view>

      <!-- 孵化服务 -->
      <view class="section-card" wx:if="{{incubator.services && incubator.services.length > 0}}">
        <view class="section-header">
          <text class="section-title">🛠️ 孵化服务</text>
        </view>
        <view class="services-grid">
          <view class="service-item" wx:for="{{incubator.services}}" wx:key="name">
            <text class="service-name">{{item.name}}</text>
            <text class="service-desc">{{item.desc}}</text>
          </view>
        </view>
      </view>

      <!-- 优惠政策 -->
      <view class="section-card" wx:if="{{incubator.policies && incubator.policies.length > 0}}">
        <view class="section-header">
          <text class="section-title">🎁 优惠政策</text>
        </view>
        <view class="policies-list">
          <view class="policy-item" wx:for="{{incubator.policies}}" wx:key="index">
            <text class="policy-dot">•</text>
            <text class="policy-text">{{item}}</text>
          </view>
        </view>
      </view>

      <!-- 成功案例 -->
      <view class="section-card" wx:if="{{incubator.successCases && incubator.successCases.length > 0}}">
        <view class="section-header">
          <text class="section-title">🏆 成功案例</text>
        </view>
        <view class="cases-list">
          <view class="case-item" wx:for="{{incubator.successCases}}" wx:key="index">
            <text class="case-icon">🚀</text>
            <text class="case-name">{{item}}</text>
          </view>
        </view>
      </view>

      <view class="bottom-space"></view>
    </view>
  </scroll-view>

  <!-- 底部操作栏 -->
  <view class="bottom-bar">
    <view class="action-btn secondary" open-type="share">
      <text class="action-icon">📤</text>
      <text class="action-text">分享</text>
    </view>
    <view class="action-btn secondary" bindtap="onContactTap">
      <text class="action-icon">📞</text>
      <text class="action-text">电话</text>
    </view>
    <btn class="action-btn primary" type="primary" bind:click="onApplyTap">
      申请入驻
    </btn>
  </view>

  <!-- 申请入驻弹窗 -->
  <view class="modal-mask {{showApplyModal ? 'show' : ''}}" bindtap="onCloseModal">
    <view class="modal-content" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">申请入驻</text>
        <text class="modal-close" bindtap="onCloseModal">✕</text>
      </view>
      <view class="modal-body">
        <view class="form-item">
          <text class="form-label">项目名称 <text class="required">*</text></text>
          <input
            class="form-input"
            placeholder="请输入项目名称"
            value="{{applyForm.projectName}}"
            data-field="projectName"
            bindinput="onFormInput"
          />
        </view>
        <view class="form-item">
          <text class="form-label">团队人数</text>
          <input
            class="form-input"
            type="number"
            placeholder="请输入团队人数"
            value="{{applyForm.teamSize}}"
            data-field="teamSize"
            bindinput="onFormInput"
          />
        </view>
        <view class="form-item">
          <text class="form-label">联系人 <text class="required">*</text></text>
          <input
            class="form-input"
            placeholder="请输入联系人姓名"
            value="{{applyForm.contactName}}"
            data-field="contactName"
            bindinput="onFormInput"
          />
        </view>
        <view class="form-item">
          <text class="form-label">联系电话 <text class="required">*</text></text>
          <input
            class="form-input"
            type="number"
            maxlength="11"
            placeholder="请输入联系电话"
            value="{{applyForm.contactPhone}}"
            data-field="contactPhone"
            bindinput="onFormInput"
          />
        </view>
        <view class="form-item">
          <text class="form-label">项目简介</text>
          <textarea
            class="form-textarea"
            placeholder="请简要介绍您的项目"
            value="{{applyForm.description}}"
            data-field="description"
            bindinput="onFormInput"
            maxlength="300"
          />
        </view>
      </view>
      <view class="modal-footer">
        <btn class="modal-btn" type="default" bind:click="onCloseModal">取消</btn>
        <btn class="modal-btn" type="primary" bind:click="onSubmitApply" loading="{{submitting}}">提交申请</btn>
      </view>
    </view>
  </view>

  <!-- 加载状态 -->
  <view class="loading-overlay" wx:if="{{loading}}">
    <view class="loading-content">
      <view class="loading-spinner"></view>
      <text class="loading-text">加载中...</text>
    </view>
  </view>
</view>
