.page {
  min-height: 100vh;
  background: var(--color-bg-page);
}

.page.dark {
  --color-bg-page: #0F1117;
  --color-bg-card: #1A1D29;
  --color-text-primary: #E8ECF1;
  --color-text-secondary: #9CA3AF;
  --color-border: #2D3142;
}

.search-section {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  gap: 16rpx;
}

.search-bar {
  flex: 1;
  display: flex;
  align-items: center;
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: 20rpx 28rpx;
  box-shadow: var(--shadow-card);
}

.search-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
  opacity: 0.6;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--color-text-primary);
}

.search-placeholder {
  color: var(--color-text-secondary);
  font-size: 28rpx;
}

.filter-btn {
  padding: 20rpx 28rpx;
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  font-size: 26rpx;
  color: var(--color-text-primary);
  box-shadow: var(--shadow-card);
  flex-shrink: 0;
}

.list-scroll {
  height: calc(100vh - 120rpx);
  padding: 0 32rpx 40rpx;
}

.roadshow-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.roadshow-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  overflow: hidden;
  box-shadow: var(--shadow-card);
  transition: transform 0.3s ease;
}

.roadshow-card:active {
  transform: scale(0.98);
}

.roadshow-cover {
  position: relative;
  width: 100%;
  height: 320rpx;
}

.cover-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.status-badge {
  position: absolute;
  top: 20rpx;
  left: 20rpx;
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  font-size: 22rpx;
  color: #FFFFFF;
  font-weight: 500;
}

.view-count {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 16rpx;
  background: rgba(0, 0, 0, 0.5);
  border-radius: 24rpx;
  font-size: 22rpx;
  color: #FFFFFF;
}

.count-text {
  font-size: 22rpx;
}

.roadshow-content {
  padding: 28rpx;
}

.roadshow-title-row {
  margin-bottom: 8rpx;
}

.roadshow-title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  line-height: 1.4;
}

.roadshow-subtitle {
  font-size: 26rpx;
  color: var(--color-primary);
  margin-bottom: 16rpx;
  display: block;
}

.roadshow-meta {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  margin-bottom: 20rpx;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.meta-icon {
  font-size: 24rpx;
  opacity: 0.7;
}

.meta-text {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.progress-section {
  margin-bottom: 16rpx;
}

.progress-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.progress-label {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.progress-count {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  font-weight: 500;
}

.progress-bar {
  width: 100%;
  height: 12rpx;
  background: var(--color-border);
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--color-primary), var(--color-primary-light));
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

.highlights {
  padding-top: 16rpx;
  border-top: 1rpx solid var(--color-border);
}

.highlights-text {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  line-height: 1.5;
}

/* 筛选弹窗 */
.picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.picker-mask.show {
  opacity: 1;
  visibility: visible;
}

.picker-content {
  width: 100%;
  background: var(--color-bg-card);
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx;
  max-height: 70vh;
  transform: translateY(100%);
  transition: transform 0.3s ease;
}

.picker-mask.show .picker-content {
  transform: translateY(0);
}

.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid var(--color-border);
}

.picker-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.picker-clear {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.picker-options {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  max-height: 50vh;
  overflow-y: auto;
}

.picker-option {
  display: flex;
  align-items: center;
  padding: 24rpx 20rpx;
  border-radius: var(--radius-lg);
  transition: background 0.2s ease;
}

.picker-option:active {
  background: var(--color-hover);
}

.picker-option.active {
  background: rgba(59, 130, 246, 0.1);
}

.option-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}

.option-label {
  flex: 1;
  font-size: 28rpx;
  color: var(--color-text-primary);
}

.picker-option.active .option-label {
  color: var(--color-primary);
  font-weight: 500;
}

.option-check {
  font-size: 32rpx;
  color: var(--color-primary);
}

/* 加载状态 */
.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--color-bg-page);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2000;
}

.loading-content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 4rpx solid var(--color-border);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 24rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}
