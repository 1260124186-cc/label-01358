.page {
  min-height: 100vh;
  background-color: #F8F9FA;
  padding-bottom: 180rpx;
}

.page.dark {
  background-color: #0F1117;
  color: #E8ECF1;
}

.content-scroll {
  height: calc(100vh - 160rpx);
}

.product-card {
  background-color: #fff;
  margin: 20rpx;
  padding: 30rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.page.dark .product-card {
  background-color: #1A1D29;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.3);
}

.product-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.category-badge {
  display: flex;
  align-items: center;
  padding: 8rpx 20rpx;
  background-color: #FFF4E5;
  color: #FF8C19;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.category-icon {
  margin-right: 8rpx;
}

.status-badge {
  margin-left: 16rpx;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.product-name {
  font-size: 38rpx;
  font-weight: 700;
  color: #111;
  margin-bottom: 16rpx;
}

.page.dark .product-name {
  color: #E8ECF1;
}

.product-desc {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 24rpx;
}

.page.dark .product-desc {
  color: #9AA0A6;
}

.product-price-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
}

.price-info {
  display: flex;
  align-items: baseline;
}

.price-currency {
  font-size: 30rpx;
  color: #FF6B6B;
  font-weight: 600;
}

.price-value {
  font-size: 52rpx;
  color: #FF6B6B;
  font-weight: 700;
  margin: 0 4rpx;
}

.price-unit {
  font-size: 26rpx;
  color: #999;
}

.views-info {
  font-size: 24rpx;
  color: #999;
}

.progress-card {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  margin: 0 20rpx 20rpx;
  padding: 30rpx;
  border-radius: 20rpx;
  color: #fff;
}

.progress-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.progress-title-text {
  font-size: 30rpx;
  font-weight: 600;
}

.progress-remaining {
  font-size: 26rpx;
  background-color: rgba(255, 255, 255, 0.2);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.progress-success {
  font-size: 26rpx;
  background-color: rgba(255, 255, 255, 0.3);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.progress-failed {
  font-size: 26rpx;
  background-color: rgba(255, 255, 255, 0.2);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.progress-bar-wrap {
  width: 100%;
  height: 16rpx;
  background-color: rgba(255, 255, 255, 0.25);
  border-radius: 8rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
}

.progress-bar {
  height: 100%;
  background-color: #fff;
  border-radius: 8rpx;
  transition: width 0.3s ease;
}

.progress-info-row {
  display: flex;
  align-items: center;
}

.progress-item {
  flex: 1;
  text-align: center;
}

.progress-num {
  font-size: 36rpx;
  font-weight: 700;
  display: block;
  margin-bottom: 4rpx;
}

.progress-label {
  font-size: 24rpx;
  opacity: 0.9;
}

.progress-divider {
  width: 1rpx;
  height: 60rpx;
  background-color: rgba(255, 255, 255, 0.3);
}

.info-card {
  background-color: #fff;
  margin: 0 20rpx 20rpx;
  padding: 10rpx 30rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.page.dark .info-card {
  background-color: #1A1D29;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.3);
}

.info-row {
  display: flex;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.page.dark .info-row {
  border-bottom-color: #2A2F3D;
}

.info-row:last-child {
  border-bottom: none;
}

.info-icon {
  width: 56rpx;
  height: 56rpx;
  background-color: #FFF4E5;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.page.dark .info-icon {
  background-color: rgba(255, 140, 25, 0.15);
}

.info-content {
  flex: 1;
}

.info-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 6rpx;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.page.dark .info-value {
  color: #E8ECF1;
}

.info-sub {
  font-size: 24rpx;
  color: #FF6B6B;
  margin-top: 6rpx;
}

.members-card {
  background-color: #fff;
  margin: 0 20rpx 20rpx;
  padding: 10rpx 30rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.page.dark .members-card {
  background-color: #1A1D29;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.3);
}

.members-header {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.page.dark .members-header {
  border-bottom-color: #2A2F3D;
}

.members-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #111;
}

.page.dark .members-title {
  color: #E8ECF1;
}

.member-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.page.dark .member-item {
  border-bottom-color: #2A2F3D;
}

.member-item:last-child {
  border-bottom: none;
}

.member-avatar {
  width: 72rpx;
  height: 72rpx;
  background-color: #F0F0F0;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.page.dark .member-avatar {
  background-color: #2A2F3D;
}

.avatar-icon {
  font-size: 36rpx;
}

.member-info {
  flex: 1;
}

.member-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 6rpx;
  display: flex;
  align-items: center;
}

.page.dark .member-name {
  color: #E8ECF1;
}

.publisher-tag {
  margin-left: 12rpx;
  padding: 2rpx 10rpx;
  background-color: #FFEAEA;
  color: #FF6B6B;
  font-size: 20rpx;
  border-radius: 8rpx;
}

.member-quantity {
  font-size: 24rpx;
  color: #999;
}

.member-status {
  flex-shrink: 0;
}

.paid-tag {
  font-size: 22rpx;
  color: #10B981;
  background-color: #E8F8EF;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.unpaid-tag {
  font-size: 22rpx;
  color: #999;
  background-color: #F5F5F5;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.publisher-card {
  background-color: #fff;
  margin: 0 20rpx 20rpx;
  padding: 30rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.page.dark .publisher-card {
  background-color: #1A1D29;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.3);
}

.publisher-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #111;
  margin-bottom: 20rpx;
}

.page.dark .publisher-title {
  color: #E8ECF1;
}

.publisher-row {
  display: flex;
  align-items: center;
}

.publisher-avatar {
  width: 80rpx;
  height: 80rpx;
  background-color: #F0F0F0;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.page.dark .publisher-avatar {
  background-color: #2A2F3D;
}

.publisher-info {
  flex: 1;
}

.publisher-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 6rpx;
}

.page.dark .publisher-name {
  color: #E8ECF1;
}

.publisher-time {
  font-size: 24rpx;
  color: #999;
}

.action-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 30rpx 40rpx;
  background-color: #fff;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.06);
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.page.dark .action-bar {
  background-color: #1A1D29;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.3);
}

.quantity-selector {
  display: flex;
  align-items: center;
  background-color: #F8F9FA;
  border-radius: 40rpx;
  padding: 6rpx;
}

.page.dark .quantity-selector {
  background-color: #2A2F3D;
}

.qty-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #333;
}

.page.dark .qty-btn {
  color: #E8ECF1;
}

.qty-input {
  width: 80rpx;
  height: 64rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  background-color: transparent;
}

.page.dark .qty-input {
  color: #E8ECF1;
}

.action-btn {
  flex: 1;
  height: 96rpx;
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  line-height: 96rpx;
  padding: 0;
}

.action-btn.primary {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
}

.action-btn.secondary {
  background-color: #F5F5F5;
  color: #666;
}

.page.dark .action-btn.secondary {
  background-color: #2A2F3D;
  color: #9AA0A6;
}

.action-btn.danger {
  background-color: #FFF;
  color: #FF6B6B;
  border: 2rpx solid #FF6B6B;
}

.page.dark .action-btn.danger {
  background-color: transparent;
}

.action-btn.disabled {
  background-color: #E5E5E5;
  color: #999;
}

.action-btn-hover {
  opacity: 0.9;
  transform: scale(0.98);
}

.action-btn[disabled] {
  opacity: 0.6;
}

.loading-wrap {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}
