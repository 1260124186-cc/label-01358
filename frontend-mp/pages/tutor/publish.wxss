.publish-page {
  min-height: 100vh;
  background: #f8f9fa;
  display: flex;
  flex-direction: column;
}

.publish-page.dark {
  background: #1a1a2e;
}

.form-scroll {
  flex: 1;
  height: calc(100vh - 140rpx);
}

.form-section {
  margin: 20rpx 30rpx 0;
  padding: 30rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.publish-page.dark .form-section {
  background: #16213e;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.2);
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.section-header > view { margin-right: 10rpx; }

.section-header > view:last-child { margin-right: 0; }

.publish-page.dark .section-header {
  border-bottom-color: #0f3460;
}

.section-icon {
  font-size: 30rpx;
  margin-right: 10rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
  flex: 1;
}

.publish-page.dark .section-title {
  color: #e0e0e0;
}

.section-required {
  font-size: 22rpx;
  color: #FF6B6B;
  font-weight: 500;
}

.section-hint {
  font-size: 22rpx;
  color: #999;
  font-weight: 500;
}

.publish-page.dark .section-hint {
  color: #888;
}

.form-item {
  margin-bottom: 0;
}

.input-placeholder {
  color: #bbb;
}

.publish-page.dark .input-placeholder {
  color: #666;
}

.multi-select-group {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.multi-select-item {
  display: inline-flex;
  align-items: center;
  padding: 14rpx 24rpx;
  background: #f8f9fa;
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  transition: all 0.2s ease;
}

.publish-page.dark .multi-select-item {
  background: #1a1a2e;
  border-color: #0f3460;
}

.multi-select-item:active {
  transform: scale(0.96);
}

.multi-select-item.active {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  border-color: transparent;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 107, 0.3);
}

.select-item-icon {
  font-size: 26rpx;
  margin-right: 6rpx;
}

.select-item-label {
  font-size: 26rpx;
  color: #555;
  font-weight: 500;
}

.publish-page.dark .select-item-label {
  color: #ccc;
}

.multi-select-item.active .select-item-icon,
.multi-select-item.active .select-item-label {
  color: #FFFFFF;
}

.hourly-input-wrap {
  display: flex;
  align-items: center;
  height: 96rpx;
  padding: 0 28rpx;
  background: #f8f9fa;
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
}

.publish-page.dark .hourly-input-wrap {
  background: #1a1a2e;
  border-color: #0f3460;
}

.hourly-prefix {
  font-size: 36rpx;
  font-weight: 700;
  color: #FF6B6B;
  margin-right: 12rpx;
}

.hourly-input {
  flex: 1;
  height: 100%;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.publish-page.dark .hourly-input {
  color: #e0e0e0;
}

.hourly-suffix {
  font-size: 26rpx;
  color: #999;
  margin-left: 12rpx;
}

.radio-group {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.radio-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #f8f9fa;
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  transition: all 0.2s ease;
}

.publish-page.dark .radio-item {
  background: #1a1a2e;
  border-color: #0f3460;
}

.radio-item:active {
  transform: scale(0.98);
}

.radio-item.active {
  background: rgba(255, 107, 107, 0.08);
  border-color: #FF6B6B;
}

.radio-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
  border-radius: 12rpx;
  margin-right: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.publish-page.dark .radio-icon-wrap {
  background: #0f3460;
  box-shadow: none;
}

.radio-icon {
  font-size: 32rpx;
}

.radio-label {
  flex: 1;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.publish-page.dark .radio-label {
  color: #e0e0e0;
}

.radio-check {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
  border-radius: 50%;
}

.time-select-wrap {
  margin-bottom: 24rpx;
}

.time-select-wrap:last-child {
  margin-bottom: 0;
}

.time-select-label {
  font-size: 26rpx;
  color: #666;
  font-weight: 500;
  margin-bottom: 16rpx;
}

.publish-page.dark .time-select-label {
  color: #aaa;
}

.weekday-group {
  justify-content: space-between;
}

.weekday-item {
  display: flex;
  align-items: center;
  justify-content: center;
  width: calc((100% - 16rpx * 6) / 7);
  min-width: 80rpx;
  height: 72rpx;
  padding: 0 8rpx;
  background: #f8f9fa;
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  transition: all 0.2s ease;
}

.publish-page.dark .weekday-item {
  background: #1a1a2e;
  border-color: #0f3460;
}

.weekday-item:active {
  transform: scale(0.96);
}

.weekday-item.active {
  background: linear-gradient(135deg, #4ECDC4 0%, #6EE7DE 100%);
  border-color: transparent;
  box-shadow: 0 4rpx 12rpx rgba(78, 205, 196, 0.3);
}

.weekday-label {
  font-size: 24rpx;
  color: #555;
  font-weight: 500;
}

.publish-page.dark .weekday-label {
  color: #ccc;
}

.weekday-item.active .weekday-label {
  color: #FFFFFF;
  font-weight: 600;
}

.form-textarea {
  width: 100%;
  min-height: 220rpx;
  padding: 24rpx 28rpx;
  background: #f8f9fa;
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.7;
  box-sizing: border-box;
}

.publish-page.dark .form-textarea {
  background: #1a1a2e;
  border-color: #0f3460;
  color: #e0e0e0;
}

.char-count {
  text-align: right;
  font-size: 22rpx;
  color: #999;
  margin-top: 10rpx;
}

.publish-page.dark .char-count {
  color: #666;
}

.image-upload-group {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.image-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
}

.uploaded-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  background: #f0f0f0;
}

.image-remove {
  position: absolute;
  top: -12rpx;
  right: -12rpx;
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.6);
  border-radius: 50%;
}

.remove-icon {
  color: #fff;
  font-size: 28rpx;
  line-height: 1;
  font-weight: 300;
}

.image-add-btn {
  width: 200rpx;
  height: 200rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #f8f9fa;
  border: 2rpx dashed #ccc;
  border-radius: 12rpx;
  transition: all 0.2s ease;
}

.publish-page.dark .image-add-btn {
  background: #1a1a2e;
  border-color: #0f3460;
}

.image-add-btn:active {
  transform: scale(0.96);
  border-color: #FF6B6B;
}

.add-icon {
  font-size: 56rpx;
  color: #ccc;
  line-height: 1;
  margin-bottom: 8rpx;
}

.publish-page.dark .add-icon {
  color: #666;
}

.add-text {
  font-size: 22rpx;
  color: #999;
}

.publish-page.dark .add-text {
  color: #777;
}

.bottom-spacer {
  height: 40rpx;
}

.submit-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  background: #fff;
  border-top: 1rpx solid #eee;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}

.publish-page.dark .submit-bar {
  background: #16213e;
  border-top-color: #0f3460;
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
  border: none;
  box-shadow: 0 6rpx 20rpx rgba(255, 107, 107, 0.35);
}

.submit-btn::after {
  border: none;
}

.submit-btn.disabled {
  opacity: 0.6;
}
