<view class="page">
  <!-- 分类切换 -->
  <view class="tabs-section">
    <view 
      class="tab-item {{currentTab === 'all' ? 'active' : ''}}"
      bindtap="onTabChange"
      data-tab="all"
    >全部</view>
    <view 
      class="tab-item {{currentTab === 'lostFound' ? 'active' : ''}}"
      bindtap="onTabChange"
      data-tab="lostFound"
    >失物招领</view>
    <view 
      class="tab-item {{currentTab === 'market' ? 'active' : ''}}"
      bindtap="onTabChange"
      data-tab="market"
    >二手商品</view>
  </view>

  <!-- 列表 -->
  <scroll-view class="list-scroll" scroll-y="{{true}}">
    <view class="list-container" wx:if="{{list.length > 0}}">
      <view 
        class="item-card"
        wx:for="{{list}}"
        wx:key="id"
        hover-class="item-card-hover"
        bindtap="onItemTap"
        data-item="{{item}}"
      >
        <image 
          class="item-image" 
          src="{{item.data.images[0] || '/assets/images/default-goods.png'}}" 
          mode="aspectFill" 
        />
        <view class="item-info">
          <view class="item-type-tag {{item.type}}">
            {{item.type === 'lostFound' ? '失物招领' : '二手商品'}}
          </view>
          <text class="item-title">{{item.data.title}}</text>
          <text class="item-desc">{{item.data.description}}</text>
          <text class="item-time">收藏于 {{item.timeText}}</text>
        </view>
        <view class="item-action" catchtap="onRemove" data-item="{{item}}">
          <text class="action-icon">×</text>
        </view>
      </view>
    </view>

    <empty 
      wx:if="{{list.length === 0}}" 
      text="暂无收藏"
    />
  </scroll-view>
</view>
