/* 首页 - 参考小红书/Airbnb设计风格 */
.page {
  min-height: 100vh;
  background-color: var(--color-bg-page);
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
}

/* ==================== 搜索入口 ==================== */
.search-entry {
  padding: 16rpx 24rpx 0;
}

.search-entry-bar {
  display: flex;
  align-items: center;
  height: 72rpx;
  background-color: var(--color-bg-card);
  border-radius: var(--radius-full);
  padding: 0 24rpx;
  box-shadow: var(--shadow-sm);
  transition: all var(--transition-fast);
}

.search-entry-bar:active {
  transform: scale(0.99);
  box-shadow: var(--shadow-xs);
}

.search-entry-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.search-entry-placeholder {
  font-size: var(--font-sm);
  color: var(--color-text-muted);
  flex: 1;
}

/* ==================== 轮播区域 ==================== */
.banner-section {
  padding: 24rpx 24rpx 0;
}

.banner-swiper {
  height: 340rpx;
  border-radius: var(--radius-2xl);
  overflow: hidden;
  box-shadow: var(--shadow-lg);
}

.banner-item {
  position: relative;
  width: 100%;
  height: 100%;
  overflow: hidden;
}

.banner-image {
  width: 100%;
  height: 100%;
  transition: transform 0.5s ease;
}

.banner-item:active .banner-image {
  transform: scale(1.02);
}

.banner-overlay {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 65%;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.7) 0%, rgba(0, 0, 0, 0.3) 50%, transparent 100%);
  pointer-events: none;
}

.banner-content {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 32rpx;
}

.banner-tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  background: rgba(255, 107, 107, 0.9);
  color: #FFFFFF;
  font-size: 22rpx;
  font-weight: 500;
  border-radius: var(--radius-sm);
  margin-bottom: 12rpx;
}

.banner-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #FFFFFF;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
}

/* ==================== 功能导航 ==================== */
.nav-section {
  padding: 24rpx;
}

.nav-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-start;
  background: linear-gradient(135deg, #FFFFFF 0%, #FAFBFC 100%);
  border-radius: var(--radius-2xl);
  padding: 32rpx 0;
  box-shadow: var(--shadow-card);
}

.nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 25%;
  padding: 16rpx 0;
  transition: all var(--transition-normal);
  box-sizing: border-box;
}

.nav-item:active {
  transform: scale(0.92);
}

.nav-icon-wrap {
  width: 108rpx;
  height: 108rpx;
  border-radius: var(--radius-xl);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  position: relative;
  overflow: hidden;
  box-shadow: var(--shadow-sm);
}

.nav-icon-wrap::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(255,255,255,0.4) 0%, transparent 100%);
}

.nav-icon {
  width: 52rpx;
  height: 52rpx;
  position: relative;
  z-index: 1;
}

.nav-text {
  font-size: 26rpx;
  color: var(--color-text-primary);
  font-weight: 600;
}

/* ==================== 校园动态 ==================== */
.news-section {
  padding: 0 24rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-title-wrap {
  display: flex;
  align-items: center;
}

.section-icon {
  width: 8rpx;
  height: 32rpx;
  background: linear-gradient(180deg, var(--color-primary) 0%, #FF8E8E 100%);
  border-radius: 4rpx;
  margin-right: 12rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

.section-more {
  display: flex;
  align-items: center;
  padding: 8rpx 0;
}

.more-text {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.more-arrow {
  font-size: 24rpx;
  color: var(--color-text-muted);
  margin-left: 4rpx;
}

.news-card {
  background-color: var(--color-bg-card);
  border-radius: var(--radius-2xl);
  box-shadow: var(--shadow-card);
  overflow: hidden;
}

.news-scroll {
  padding: 8rpx 0;
  max-height: 800rpx;
}

.news-item {
  display: flex;
  padding: 20rpx 24rpx;
  transition: all var(--transition-fast);
}

.news-item:active {
  background-color: var(--color-bg-page);
}

.news-item:not(:last-child) {
  border-bottom: 1rpx solid var(--color-border-light);
}

.news-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  margin-right: 20rpx;
}

.news-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  line-height: 1.45;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  margin-bottom: 10rpx;
}

.news-summary {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.5;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.news-meta {
  display: flex;
  align-items: center;
  margin-top: auto;
}

.news-time {
  font-size: 24rpx;
  color: var(--color-text-muted);
}

.news-tag {
  margin-left: 16rpx;
  padding: 4rpx 12rpx;
  font-size: 20rpx;
  color: var(--color-primary);
  background-color: var(--color-primary-light);
  border-radius: var(--radius-xs);
}

.news-image {
  width: 200rpx;
  height: 140rpx;
  border-radius: var(--radius-lg);
  flex-shrink: 0;
  overflow: hidden;
}

.news-image image {
  width: 100%;
  height: 100%;
  transition: transform 0.3s ease;
}

.news-item:active .news-image image {
  transform: scale(1.05);
}

/* ==================== 快捷入口 ==================== */
.quick-section {
  padding: 0 24rpx 24rpx;
}

.quick-grid {
  display: flex;
  flex-wrap: wrap;
}

.quick-grid { margin-right: -16rpx; margin-bottom: -16rpx; }

.quick-grid > view { margin-right: 16rpx; margin-bottom: 16rpx; }

.quick-item {
  flex: 1 1 calc(33.333% - 12rpx);
  min-width: calc(33.333% - 12rpx);
  display: flex;
  align-items: center;
  padding: 24rpx 20rpx;
  background: linear-gradient(135deg, #FFFFFF 0%, #FAFBFC 100%);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-sm);
  transition: all var(--transition-normal);
  box-sizing: border-box;
}

.quick-item:active {
  transform: scale(0.98);
  box-shadow: var(--shadow-xs);
}

.quick-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: var(--radius-lg);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
}

.quick-icon text {
  font-size: 32rpx;
}

.quick-info {
  flex: 1;
}

.quick-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 4rpx;
}

.quick-desc {
  font-size: 22rpx;
  color: var(--color-text-muted);
}

.quick-arrow {
  font-size: 28rpx;
  color: var(--color-text-muted);
}

/* ==================== 今日天气入口 ==================== */
.weather-entry {
  margin: 0 24rpx 24rpx;
  background: linear-gradient(135deg, #3B82F6 0%, #1D4ED8 100%);
  border-radius: var(--radius-2xl);
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  box-shadow: 0 8rpx 32rpx rgba(29, 78, 216, 0.25);
  transition: all var(--transition-normal);
}

.weather-entry:active {
  transform: scale(0.98);
  opacity: 0.95;
}

.weather-entry-main {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.weather-entry-left {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.weather-entry-icon {
  font-size: 72rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
  filter: drop-shadow(0 4rpx 8rpx rgba(0, 0, 0, 0.2));
}

.weather-entry-info {
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.weather-entry-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.weather-entry-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
}

.weather-entry-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  margin-left: 20rpx;
}

.weather-entry-temp {
  font-size: 56rpx;
  font-weight: 700;
  color: #FFFFFF;
  line-height: 1.1;
}

.weather-entry-temp-range {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
}

.weather-entry-dress {
  background: rgba(255, 255, 255, 0.15);
  border-radius: var(--radius-lg);
  padding: 20rpx 24rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: flex-start;
}

.weather-entry-dress-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
  margin-top: 2rpx;
}

.weather-entry-dress-label {
  font-size: 24rpx;
  font-weight: 600;
  color: #FFFFFF;
  flex-shrink: 0;
  margin-right: 8rpx;
}

.weather-entry-dress-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.5;
  flex: 1;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.weather-entry-footer {
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.weather-entry-arrow-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-right: 8rpx;
}

.weather-entry-arrow {
  font-size: 28rpx;
  color: #FFFFFF;
  opacity: 0.8;
}

/* ==================== 暗色模式 - 轮播图对比度增强 ==================== */
.dark .banner-overlay {
  background: linear-gradient(to top, rgba(0, 0, 0, 0.85) 0%, rgba(0, 0, 0, 0.5) 50%, rgba(0, 0, 0, 0.15) 100%);
}

.dark .banner-tag {
  background: rgba(255, 138, 138, 0.95);
}

.dark .banner-title {
  text-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.5);
}

.dark .nav-item:active {
  transform: scale(0.92);
}

.dark .news-item:active {
  background-color: var(--color-bg-input);
}

.dark .quick-item:active {
  box-shadow: var(--shadow-xs);
}

.dark .search-entry-bar {
  background-color: var(--color-bg-card);
  border: 1rpx solid var(--color-border);
}
