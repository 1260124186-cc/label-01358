/* 首页 - 参考小红书/Airbnb设计风格 */
.page {
  min-height: 100vh;
  background-color: var(--color-bg-page);
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
}

/* ==================== 轮播区域 ==================== */
.banner-section {
  padding: 24rpx 24rpx 0;
}

.banner-swiper {
  height: 340rpx;
  border-radius: var(--radius-2xl);
  overflow: hidden;
  box-shadow: var(--shadow-lg);
}

.banner-item {
  position: relative;
  width: 100%;
  height: 100%;
  overflow: hidden;
}

.banner-image {
  width: 100%;
  height: 100%;
  transition: transform 0.5s ease;
}

.banner-item:active .banner-image {
  transform: scale(1.02);
}

.banner-overlay {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 65%;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.7) 0%, rgba(0, 0, 0, 0.3) 50%, transparent 100%);
  pointer-events: none;
}

.banner-content {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 32rpx;
}

.banner-tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  background: rgba(255, 107, 107, 0.9);
  color: #FFFFFF;
  font-size: 22rpx;
  font-weight: 500;
  border-radius: var(--radius-sm);
  margin-bottom: 12rpx;
}

.banner-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #FFFFFF;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
}

/* ==================== 功能导航 ==================== */
.nav-section {
  padding: 24rpx;
}

.nav-grid {
  display: flex;
  justify-content: space-between;
  background: linear-gradient(135deg, #FFFFFF 0%, #FAFBFC 100%);
  border-radius: var(--radius-2xl);
  padding: 32rpx 20rpx;
  box-shadow: var(--shadow-card);
}

.nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  transition: all var(--transition-normal);
}

.nav-item:active {
  transform: scale(0.92);
}

.nav-icon-wrap {
  width: 108rpx;
  height: 108rpx;
  border-radius: var(--radius-xl);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  position: relative;
  overflow: hidden;
  box-shadow: var(--shadow-sm);
}

.nav-icon-wrap::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(255,255,255,0.4) 0%, transparent 100%);
}

.nav-icon {
  width: 52rpx;
  height: 52rpx;
  position: relative;
  z-index: 1;
}

.nav-text {
  font-size: 26rpx;
  color: var(--color-text-primary);
  font-weight: 600;
}

/* ==================== 校园动态 ==================== */
.news-section {
  padding: 0 24rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-title-wrap {
  display: flex;
  align-items: center;
}

.section-icon {
  width: 8rpx;
  height: 32rpx;
  background: linear-gradient(180deg, var(--color-primary) 0%, #FF8E8E 100%);
  border-radius: 4rpx;
  margin-right: 12rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

.section-more {
  display: flex;
  align-items: center;
  padding: 8rpx 0;
}

.more-text {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.more-arrow {
  font-size: 24rpx;
  color: var(--color-text-muted);
  margin-left: 4rpx;
}

.news-card {
  background-color: var(--color-bg-card);
  border-radius: var(--radius-2xl);
  box-shadow: var(--shadow-card);
  overflow: hidden;
}

.news-scroll {
  padding: 8rpx 0;
  max-height: 800rpx;
}

.news-item {
  display: flex;
  padding: 20rpx 24rpx;
  transition: all var(--transition-fast);
}

.news-item:active {
  background-color: var(--color-bg-page);
}

.news-item:not(:last-child) {
  border-bottom: 1rpx solid var(--color-border-light);
}

.news-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  margin-right: 20rpx;
}

.news-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  line-height: 1.45;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  margin-bottom: 10rpx;
}

.news-summary {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.5;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.news-meta {
  display: flex;
  align-items: center;
  margin-top: auto;
}

.news-time {
  font-size: 24rpx;
  color: var(--color-text-muted);
}

.news-tag {
  margin-left: 16rpx;
  padding: 4rpx 12rpx;
  font-size: 20rpx;
  color: var(--color-primary);
  background-color: var(--color-primary-light);
  border-radius: var(--radius-xs);
}

.news-image {
  width: 200rpx;
  height: 140rpx;
  border-radius: var(--radius-lg);
  flex-shrink: 0;
  overflow: hidden;
}

.news-image image {
  width: 100%;
  height: 100%;
  transition: transform 0.3s ease;
}

.news-item:active .news-image image {
  transform: scale(1.05);
}

/* ==================== 快捷入口 ==================== */
.quick-section {
  padding: 0 24rpx 24rpx;
}

.quick-grid {
  display: flex;
  gap: 16rpx;
}

.quick-item {
  flex: 1;
  display: flex;
  align-items: center;
  padding: 24rpx 20rpx;
  background: linear-gradient(135deg, #FFFFFF 0%, #FAFBFC 100%);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-sm);
  transition: all var(--transition-normal);
}

.quick-item:active {
  transform: scale(0.98);
  box-shadow: var(--shadow-xs);
}

.quick-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: var(--radius-lg);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
}

.quick-icon text {
  font-size: 32rpx;
}

.quick-info {
  flex: 1;
}

.quick-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 4rpx;
}

.quick-desc {
  font-size: 22rpx;
  color: var(--color-text-muted);
}

.quick-arrow {
  font-size: 28rpx;
  color: var(--color-text-muted);
}

/* ==================== 暗色模式 - 轮播图对比度增强 ==================== */
.dark .banner-overlay {
  background: linear-gradient(to top, rgba(0, 0, 0, 0.85) 0%, rgba(0, 0, 0, 0.5) 50%, rgba(0, 0, 0, 0.15) 100%);
}

.dark .banner-tag {
  background: rgba(255, 138, 138, 0.95);
}

.dark .banner-title {
  text-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.5);
}

.dark .nav-item:active {
  transform: scale(0.92);
}

.dark .news-item:active {
  background-color: var(--color-bg-input);
}

.dark .quick-item:active {
  box-shadow: var(--shadow-xs);
}
