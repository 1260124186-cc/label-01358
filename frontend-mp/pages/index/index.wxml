<page-meta page-style="background-color: {{darkMode ? '#0F1117' : '#F8F9FA'}}; color: {{darkMode ? '#E8ECF1' : '#2C3E50'}}"/>
<view class="page {{darkMode ? 'dark' : ''}}">
  <!-- 搜索入口 -->
  <view class="search-entry" bindtap="onSearchTap">
    <view class="search-entry-bar">
      <text class="search-entry-icon">🔍</text>
      <text class="search-entry-placeholder">搜索失物招领、二手市场、校园动态...</text>
    </view>
  </view>

  <!-- 公告轮播 -->
  <view class="banner-section">
    <swiper
      class="banner-swiper"
      indicator-dots="{{true}}"
      indicator-color="rgba(255,255,255,0.4)"
      indicator-active-color="#FFFFFF"
      autoplay="{{true}}"
      interval="{{4000}}"
      duration="{{600}}"
      circular="{{true}}"
      easing-function="easeInOutCubic"
    >
      <swiper-item
        wx:for="{{announcements}}"
        wx:key="id"
        bindtap="onAnnouncementTap"
        data-item="{{item}}"
      >
        <view class="banner-item">
          <image class="banner-image" src="{{item.image}}" mode="aspectFill" />
          <view class="banner-overlay"></view>
          <view class="banner-content">
            <text class="banner-tag">公告</text>
            <text class="banner-title">{{item.title}}</text>
          </view>
        </view>
      </swiper-item>
    </swiper>
  </view>

  <!-- 功能分类导航 -->
  <view class="nav-section">
    <view class="nav-grid">
      <view
        class="nav-item"
        wx:for="{{navItems}}"
        wx:key="id"
        bindtap="onNavTap"
        data-item="{{item}}"
      >
        <view class="nav-icon-wrap" style="background: {{item.bgColor}};">
          <image class="nav-icon" src="{{item.icon}}" mode="aspectFit" />
        </view>
        <text class="nav-text">{{item.name}}</text>
      </view>
    </view>
  </view>

  <!-- 今日天气入口 -->
  <view class="weather-entry" wx:if="{{weatherData}}" bindtap="onWeatherTap">
    <view class="weather-entry-main">
      <view class="weather-entry-left">
        <text class="weather-entry-icon">{{weatherData.current.weatherIcon}}</text>
        <view class="weather-entry-info">
          <text class="weather-entry-title">今日天气</text>
          <text class="weather-entry-subtitle">{{weatherData.current.weather}} · 空气{{weatherData.airQuality.aqiLevel}}</text>
        </view>
      </view>
      <view class="weather-entry-right">
        <text class="weather-entry-temp">{{weatherData.current.temperature}}°</text>
        <text class="weather-entry-temp-range">{{weatherData.current.temperatureMin}}° / {{weatherData.current.temperatureMax}}°</text>
      </view>
    </view>
    <view class="weather-entry-dress">
      <text class="weather-entry-dress-icon">👕</text>
      <text class="weather-entry-dress-label">穿衣建议：</text>
      <text class="weather-entry-dress-text">{{weatherData.current.dressAdvice}}</text>
    </view>
    <view class="weather-entry-footer">
      <text class="weather-entry-arrow-text">查看详情</text>
      <text class="weather-entry-arrow">›</text>
    </view>
  </view>

  <!-- 快捷入口 -->
  <view class="quick-section">
    <view class="quick-grid">
      <view class="quick-item" hover-class="hover-scale" bindtap="onQuickPublish" data-type="lost">
        <view class="quick-icon" style="background: linear-gradient(135deg, #FFE8E8 0%, #FFD4D4 100%);">
          <text>📝</text>
        </view>
        <view class="quick-info">
          <text class="quick-title">发布寻物</text>
          <text class="quick-desc">快速发布</text>
        </view>
        <text class="quick-arrow">›</text>
      </view>
      <view class="quick-item" hover-class="hover-scale" bindtap="onQuickPublish" data-type="market">
        <view class="quick-icon" style="background: linear-gradient(135deg, #E8F4FF 0%, #D4EBFF 100%);">
          <text>🏷️</text>
        </view>
        <view class="quick-info">
          <text class="quick-title">发布闲置</text>
          <text class="quick-desc">一键出售</text>
        </view>
        <text class="quick-arrow">›</text>
      </view>
      <view class="quick-item" hover-class="hover-scale" bindtap="onQuickStudyEntry">
        <view class="quick-icon" style="background: linear-gradient(135deg, #E0F7FA 0%, #B2EBF2 100%);">
          <text>📚</text>
        </view>
        <view class="quick-info">
          <text class="quick-title">学习资料</text>
          <text class="quick-desc">笔记课件下载</text>
        </view>
        <text class="quick-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 校园动态 -->
  <view class="news-section">
    <view class="section-header">
      <view class="section-title-wrap">
        <view class="section-icon"></view>
        <text class="section-title">校园动态</text>
      </view>
      <view class="section-more" bindtap="onMoreNews">
        <text class="more-text">查看更多</text>
        <text class="more-arrow">›</text>
      </view>
    </view>

    <view class="news-card">
      <scroll-view
        class="news-scroll"
        scroll-y="{{true}}"
        enhanced="{{true}}"
        show-scrollbar="{{false}}"
        refresher-enabled="{{true}}"
        refresher-triggered="{{refreshing}}"
        bindrefresherrefresh="onRefresh"
      >
        <view
          class="news-item"
          wx:for="{{newsList}}"
          wx:key="id"
          bindtap="onNewsTap"
          data-item="{{item}}"
        >
          <view class="news-content">
            <text class="news-title">{{item.title}}</text>
            <text class="news-summary">{{item.summary}}</text>
            <view class="news-meta">
              <text class="news-time">{{item.timeText}}</text>
              <text class="news-tag">校园</text>
            </view>
          </view>
          <view class="news-image">
            <image src="{{item.image}}" mode="aspectFill" />
          </view>
        </view>
      </scroll-view>
    </view>
  </view>
</view>
