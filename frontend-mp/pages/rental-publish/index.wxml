<page-meta page-style="background-color: {{darkMode ? '#0F1117' : '#F8F9FA'}}; color: {{darkMode ? '#E8ECF1' : '#2C3E50'}}"/>
<view class="page {{darkMode ? 'dark' : ''}}">
  <scroll-view class="form-scroll" scroll-y="{{true}}">
    <view class="form-section">
      <view class="section-title">房源图片</view>
      <view class="image-uploader">
        <view
          class="image-item"
          wx:for="{{formData.images}}"
          wx:key="*this"
        >
          <image class="image" src="{{item}}" mode="aspectFill" bindtap="onPreviewImage" data-index="{{index}}"/>
          <view class="delete-btn" bindtap="onDeleteImage" data-index="{{index}}">×</view>
        </view>
        <view class="image-add" bindtap="onChooseImage" wx:if="{{formData.images.length < 9}}">
          <text class="add-icon">+</text>
          <text class="add-text">{{formData.images.length}}/9</text>
        </view>
      </view>
    </view>

    <view class="form-section">
      <view class="section-title">基本信息</view>
      <view class="form-group">
        <view class="form-item required">
          <view class="form-label">房源标题</view>
          <input
            class="form-input"
            placeholder="请输入房源标题（如：校内梅苑精致单间）"
            value="{{formData.title}}"
            bindinput="onInputChange"
            data-field="title"
            maxlength="30"
          />
        </view>

        <view class="form-item required">
          <view class="form-label">位置</view>
          <view class="selector-group">
            <view
              class="selector-item {{formData.locationType === item.value ? 'active' : ''}}"
              wx:for="{{locationTypes}}"
              wx:key="value"
              bindtap="onLocationTypeChange"
              data-value="{{item.value}}"
            >{{item.label}}</view>
          </view>
        </view>

        <view class="form-item required">
          <view class="form-label">户型</view>
          <picker
            mode="selector"
            range="{{houseTypes}}"
            range-key="label"
            value="{{houseTypeIndex}}"
            bindchange="onHouseTypeChange"
          >
            <view class="form-picker">
              <text class="{{houseTypeIndex === -1 ? 'placeholder' : ''}}">
                {{houseTypeIndex === -1 ? '请选择户型' : houseTypes[houseTypeIndex].label}}
              </text>
              <text class="picker-arrow">▼</text>
            </view>
          </picker>
        </view>

        <view class="form-item required">
          <view class="form-label">出租方式</view>
          <view class="selector-group">
            <view
              class="selector-item {{formData.rentType === item.value ? 'active' : ''}}"
              wx:for="{{rentTypes}}"
              wx:key="value"
              bindtap="onRentTypeChange"
              data-value="{{item.value}}"
            >{{item.label}}</view>
          </view>
        </view>

        <view class="form-item required">
          <view class="form-label">性别要求</view>
          <view class="selector-group">
            <view
              class="selector-item {{formData.genderRequirement === item.value ? 'active' : ''}}"
              wx:for="{{genderRequirements}}"
              wx:key="value"
              bindtap="onGenderChange"
              data-value="{{item.value}}"
            >{{item.label}}</view>
          </view>
        </view>

        <view class="form-item required">
          <view class="form-label">月租金</view>
          <input
            class="form-input"
            placeholder="请输入月租金"
            type="digit"
            value="{{formData.rent}}"
            bindinput="onInputChange"
            data-field="rent"
          />
          <text class="input-unit">元/月</text>
        </view>

        <view class="form-item required">
          <view class="form-label">押金</view>
          <input
            class="form-input"
            placeholder="请输入押金（0表示免押金）"
            type="digit"
            value="{{formData.deposit}}"
            bindinput="onInputChange"
            data-field="deposit"
          />
          <text class="input-unit">元</text>
        </view>

        <view class="form-row">
          <view class="form-item required flex-1">
            <view class="form-label">面积</view>
            <input
              class="form-input"
              placeholder="面积"
              type="digit"
              value="{{formData.area}}"
              bindinput="onInputChange"
              data-field="area"
            />
            <text class="input-unit">㎡</text>
          </view>
          <view class="form-item flex-1">
            <view class="form-label">楼层</view>
            <input
              class="form-input"
              placeholder="如：3/6"
              value="{{formData.floor}}"
              bindinput="onInputChange"
              data-field="floor"
            />
          </view>
        </view>

        <view class="form-row">
          <view class="form-item flex-1">
            <view class="form-label">朝向</view>
            <input
              class="form-input"
              placeholder="如：南"
              value="{{formData.orientation}}"
              bindinput="onInputChange"
              data-field="orientation"
            />
          </view>
          <view class="form-item required flex-1">
            <view class="form-label">距离</view>
            <input
              class="form-input"
              placeholder="距学校"
              type="digit"
              value="{{formData.distance}}"
              bindinput="onInputChange"
              data-field="distance"
            />
            <text class="input-unit">米</text>
          </view>
        </view>

        <view class="form-item required">
          <view class="form-label">租期</view>
          <picker
            mode="selector"
            range="{{leaseTerms}}"
            range-key="label"
            value="{{leaseTermIndex}}"
            bindchange="onLeaseTermChange"
          >
            <view class="form-picker">
              <text class="{{leaseTermIndex === -1 ? 'placeholder' : ''}}">
                {{leaseTermIndex === -1 ? '请选择租期' : leaseTerms[leaseTermIndex].label}}
              </text>
              <text class="picker-arrow">▼</text>
            </view>
          </picker>
        </view>
      </view>
    </view>

    <view class="form-section">
      <view class="section-title">房屋设施</view>
      <view class="facility-grid">
        <view
          class="facility-item {{facilitiesSelectedMap[item.value] ? 'active' : ''}}"
          wx:for="{{facilities}}"
          wx:key="value"
          bindtap="onFacilityToggle"
          data-value="{{item.value}}"
        >
          <text class="facility-icon">{{item.icon}}</text>
          <text class="facility-label">{{item.label}}</text>
        </view>
      </view>
    </view>

    <view class="form-section">
      <view class="section-title">位置信息</view>
      <view class="form-group">
        <view class="form-item required">
          <view class="form-label">详细地址</view>
          <view class="location-picker" bindtap="onChooseLocation">
            <text class="{{formData.address ? '' : 'placeholder'}}">
              {{formData.address || '点击选择位置'}}
            </text>
            <text class="location-icon">📍</text>
          </view>
        </view>

        <view class="form-item">
          <view class="form-label">周边配套</view>
          <textarea
            class="form-textarea"
            placeholder="请输入周边配套（如：超市、食堂、公交站，用逗号或换行分隔）"
            value="{{formData.surrounding}}"
            bindinput="onSurroundingInput"
            maxlength="200"
            auto-height
          />
        </view>
      </view>
    </view>

    <view class="form-section">
      <view class="section-title">房源描述</view>
      <textarea
        class="form-textarea large"
        placeholder="请详细描述房源情况，包括房屋配置、周边环境、注意事项等"
        value="{{formData.description}}"
        bindinput="onInputChange"
        data-field="description"
        maxlength="500"
        auto-height
      />
    </view>

    <view class="form-section">
      <view class="section-title">联系方式</view>
      <view class="form-group">
        <view class="form-item required">
          <view class="form-label">联系人</view>
          <input
            class="form-input"
            placeholder="请输入联系人姓名"
            value="{{formData.contactName}}"
            bindinput="onInputChange"
            data-field="contactName"
          />
        </view>

        <view class="form-item required">
          <view class="form-label">联系电话</view>
          <input
            class="form-input"
            placeholder="请输入手机号码"
            type="number"
            value="{{formData.contactPhone}}"
            bindinput="onInputChange"
            data-field="contactPhone"
            maxlength="11"
          />
        </view>

        <view class="form-item">
          <view class="form-label">发布身份</view>
          <view class="selector-group">
            <view
              class="selector-item {{formData.publisherType === item.value ? 'active' : ''}}"
              wx:for="{{publisherTypes}}"
              wx:key="value"
              bindtap="onPublisherTypeChange"
              data-value="{{item.value}}"
            >
              <text>{{item.label}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="form-section tips-section">
      <view class="tips-title">⚠️ 温馨提示</view>
      <view class="tips-content">
        <view class="tip-item">• 请如实填写房源信息，虚假信息将被举报处理</view>
        <view class="tip-item">• 被举报3次以上将自动标记为中介</view>
        <view class="tip-item">• 禁止发布违规、违法信息</view>
        <view class="tip-item">• 线下看房请注意人身安全</view>
      </view>
    </view>

    <view class="submit-section">
      <button
        class="submit-btn {{submitting ? 'disabled' : ''}}"
        bindtap="onSubmit"
        disabled="{{submitting}}"
        loading="{{submitting}}"
      >{{submitting ? '发布中...' : '立即发布'}}</button>
    </view>

    <view class="bottom-space"></view>
  </scroll-view>
</view>
