.page {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

.sos-banner {
  position: relative;
  padding: 60rpx 32rpx 56rpx;
  background: linear-gradient(135deg, #FF416C 0%, #FF4B2B 100%);
  overflow: hidden;
}

.sos-pulse {
  position: absolute;
  width: 300rpx;
  height: 300rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
  top: -100rpx;
  right: -100rpx;
  animation: pulse 2s ease-in-out infinite;
}

.sos-pulse.pulse-delayed {
  animation-delay: 1s;
}

@keyframes pulse {
  0% {
    transform: scale(0.8);
    opacity: 0.8;
  }
  50% {
    transform: scale(1.2);
    opacity: 0.3;
  }
  100% {
    transform: scale(0.8);
    opacity: 0.8;
  }
}

.sos-content {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.sos-content text {
  margin-bottom: 12rpx;
}

.sos-content text:last-child,
.sos-content view {
  margin-bottom: 0;
}

.sos-icon {
  font-size: 72rpx;
  margin-bottom: 20rpx;
}

.sos-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.sos-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-bottom: 32rpx !important;
}

.sos-btn {
  display: flex;
  align-items: center;
  padding: 24rpx 56rpx;
  background: #FFFFFF;
  border-radius: 48rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.2);
}

.sos-btn text {
  margin-bottom: 0;
  margin-right: 12rpx;
}

.sos-btn text:last-child {
  margin-right: 0;
}

.sos-btn-icon {
  font-size: 32rpx;
}

.sos-btn-text {
  font-size: 30rpx;
  font-weight: 700;
  color: #FF416C;
}

.section-title-bar {
  display: flex;
  align-items: center;
  padding: 32rpx 32rpx 20rpx;
}

.section-title-bar text {
  margin-right: 12rpx;
}

.section-title-bar text:last-child {
  margin-right: 0;
}

.section-icon {
  font-size: 32rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2C3E50;
}

.page.dark .section-title {
  color: #E8ECF1;
}

.contacts-list {
  padding: 0 24rpx;
}

.contacts-list view {
  margin-bottom: 20rpx;
}

.contacts-list view:last-child {
  margin-bottom: 0;
}

.contact-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.page.dark .contact-card {
  background: #1E2230;
}

.contact-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.contact-header view,
.contact-header text {
  margin-right: 20rpx;
}

.contact-header view:last-child,
.contact-header text:last-child {
  margin-right: 0;
}

.contact-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.contact-avatar text {
  margin-right: 0;
  font-size: 36rpx;
}

.contact-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.contact-info text {
  margin-right: 0;
}

.contact-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #2C3E50;
  margin-bottom: 6rpx;
}

.page.dark .contact-name {
  color: #E8ECF1;
}

.contact-desc {
  font-size: 22rpx;
  color: #6B7280;
}

.page.dark .contact-desc {
  color: #9CA3AF;
}

.contact-meta {
  margin-bottom: 20rpx;
}

.contact-meta text {
  margin-right: 0;
}

.contact-hours {
  font-size: 22rpx;
  color: #95A5A6;
}

.contact-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 20rpx;
  border-top: 1rpx solid #F5F5F5;
}

.page.dark .contact-footer {
  border-top-color: #2D3142;
}

.contact-footer view,
.contact-footer text {
  margin-right: 0;
}

.phone-display {
  display: flex;
  flex-direction: column;
}

.phone-label {
  font-size: 20rpx;
  color: #95A5A6;
  margin-bottom: 4rpx;
}

.phone-number {
  font-size: 32rpx;
  font-weight: 700;
  color: #2C3E50;
  letter-spacing: 1rpx;
}

.page.dark .phone-number {
  color: #E8ECF1;
}

.call-btn {
  padding: 16rpx 36rpx;
  background: linear-gradient(135deg, #10B981 0%, #059669 100%);
  border-radius: 32rpx;
}

.call-btn text {
  font-size: 26rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.phrases-section {
  margin: 32rpx 24rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.page.dark .phrases-section {
  background: #1E2230;
}

.phrases-header {
  display: flex;
  align-items: center;
}

.phrases-header text {
  margin-right: 12rpx;
}

.phrases-header text:last-child {
  margin-right: 0;
}

.toggle-arrow {
  margin-left: auto;
  font-size: 22rpx;
  color: #95A5A6;
}

.phrases-list {
  margin-top: 24rpx;
  display: flex;
  flex-direction: column;
}

.phrases-list view {
  margin-bottom: 16rpx;
}

.phrases-list view:last-child {
  margin-bottom: 0;
}

.phrase-item {
  background: #FAFAFA;
  border-radius: 16rpx;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
}

.page.dark .phrase-item {
  background: #2D3142;
}

.phrase-item text {
  margin-right: 0;
}

.phrase-zh {
  margin-bottom: 8rpx;
}

.phrase-zh text {
  margin-bottom: 0;
}

.phrase-cn {
  font-size: 26rpx;
  font-weight: 600;
  color: #2C3E50;
}

.page.dark .phrase-cn {
  color: #E8ECF1;
}

.phrase-en {
  font-size: 24rpx;
  color: #667EEA;
  margin-bottom: 12rpx;
}

.phrase-copy {
  font-size: 20rpx;
  color: #95A5A6;
  align-self: flex-end;
}

.safety-tips {
  margin: 0 24rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.page.dark .safety-tips {
  background: #1E2230;
}

.tips-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.tips-header text {
  margin-right: 12rpx;
}

.tips-header text:last-child {
  margin-right: 0;
}

.tips-icon {
  font-size: 32rpx;
}

.tips-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #2C3E50;
}

.page.dark .tips-title {
  color: #E8ECF1;
}

.tips-list {
  display: flex;
  flex-direction: column;
}

.tips-list view {
  margin-bottom: 20rpx;
}

.tips-list view:last-child {
  margin-bottom: 0;
}

.tip-item {
  display: flex;
  align-items: flex-start;
}

.tip-item text {
  margin-right: 16rpx;
}

.tip-item text:last-child {
  margin-right: 0;
}

.tip-dot {
  width: 40rpx;
  height: 40rpx;
  background: linear-gradient(135deg, #667EEA 0%, #764BA2 100%);
  color: #FFFFFF;
  font-size: 22rpx;
  font-weight: 600;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  line-height: 40rpx;
  text-align: center;
}

.tip-text {
  flex: 1;
  font-size: 24rpx;
  color: #6B7280;
  line-height: 1.7;
  padding-top: 4rpx;
}

.page.dark .tip-text {
  color: #9CA3AF;
}

.bottom-spacer {
  height: 40rpx;
}
