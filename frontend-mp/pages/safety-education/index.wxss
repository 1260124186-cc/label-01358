.page {
  min-height: 100vh;
}

.category-tabs {
  position: sticky;
  top: 0;
  z-index: 10;
  background: #FFFFFF;
  border-bottom: 1rpx solid #F3F4F6;
}

.tabs-container {
  display: flex;
  padding: 20rpx 10rpx;
  gap: 16rpx;
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #F8F9FA;
  border-radius: 12rpx;
  flex-shrink: 0;
  transition: all 0.2s ease;
}

.tab-item.active {
  background: linear-gradient(135deg, #FF6B6B 0%, #EE5A5A 100%);
}

.tab-icon {
  font-size: 32rpx;
  margin-bottom: 4rpx;
}

.tab-text {
  font-size: 24rpx;
  color: #6B7280;
}

.tab-item.active .tab-text {
  color: #FFFFFF;
  font-weight: 500;
}

.articles-list {
  padding: 20rpx 30rpx;
}

.article-card {
  display: flex;
  background: #FFFFFF;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.article-cover {
  width: 220rpx;
  height: 220rpx;
  flex-shrink: 0;
}

.article-content {
  flex: 1;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.article-category {
  margin-bottom: 8rpx;
}

.category-tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.article-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #2C3E50;
  line-height: 1.4;
  margin-bottom: 8rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.article-summary {
  font-size: 24rpx;
  color: #6B7280;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.article-meta {
  display: flex;
  gap: 24rpx;
}

.meta-item {
  font-size: 22rpx;
  color: #9CA3AF;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 120rpx;
  opacity: 0.3;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 32rpx;
  color: #6B7280;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #9CA3AF;
}

.page.dark .category-tabs {
  background: #1F2937;
  border-bottom-color: #374151;
}

.page.dark .tab-item {
  background: #374151;
}

.page.dark .tab-text {
  color: #9CA3AF;
}

.page.dark .article-card {
  background: #1F2937;
}

.page.dark .article-title {
  color: #E8ECF1;
}

.page.dark .article-summary {
  color: #9CA3AF;
}
