.page {
  min-height: 100vh;
  padding-bottom: 140rpx;
}

.welcome-banner {
  background: linear-gradient(135deg, #667EEA 0%, #764BA2 100%);
  padding: 48rpx 32rpx 64rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: -24rpx;
  position: relative;
  overflow: hidden;
}

.welcome-banner::before {
  content: '';
  position: absolute;
  top: -50rpx;
  right: -50rpx;
  width: 200rpx;
  height: 200rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.welcome-banner::after {
  content: '';
  position: absolute;
  bottom: -80rpx;
  left: -30rpx;
  width: 150rpx;
  height: 150rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 50%;
}

.banner-content {
  position: relative;
  z-index: 1;
}

.welcome-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #FFFFFF;
  display: block;
  margin-bottom: 12rpx;
}

.welcome-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

.banner-decoration {
  position: relative;
  z-index: 1;
}

.deco-icon {
  font-size: 80rpx;
}

.section {
  margin: 32rpx 24rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.page.dark .section {
  background: #1E2230;
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 28rpx;
}

.section-header > view { margin-right: 12rpx; }

.section-header > view:last-child { margin-right: 0; }

.section-icon {
  font-size: 36rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2C3E50;
}

.page.dark .section-title {
  color: #E8ECF1;
}

.flow-timeline {
  position: relative;
}

.flow-step {
  display: flex;
}

.flow-step > view { margin-right: 24rpx; }

.flow-step > view:last-child { margin-right: 0; }

.step-indicator {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.step-dot {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #E5E7EB;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.3s ease;
}

.page.dark .step-dot {
  background: #3D4152;
}

.flow-step.completed .step-dot {
  background: linear-gradient(135deg, #10B981 0%, #059669 100%);
}

.flow-step.active .step-dot {
  background: linear-gradient(135deg, #3B82F6 0%, #2563EB 100%);
  box-shadow: 0 0 0 8rpx rgba(59, 130, 246, 0.15);
}

.step-dot text {
  font-size: 24rpx;
  color: #9CA3AF;
  font-weight: 600;
}

.flow-step.completed .step-dot text,
.flow-step.active .step-dot text {
  color: #FFFFFF;
}

.step-line {
  width: 4rpx;
  flex: 1;
  min-height: 60rpx;
  background: #E5E7EB;
  margin: 8rpx 0;
}

.page.dark .step-line {
  background: #3D4152;
}

.flow-step.completed .step-line {
  background: linear-gradient(180deg, #10B981 0%, #10B981 100%);
}

.step-content {
  flex: 1;
  padding-bottom: 32rpx;
}

.flow-step:last-child .step-content {
  padding-bottom: 0;
}

.step-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.step-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #2C3E50;
}

.page.dark .step-title {
  color: #E8ECF1;
}

.flow-step.active .step-title {
  color: #3B82F6;
}

.step-status {
  font-size: 22rpx;
  color: #95A5A6;
  background: #F3F4F6;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
}

.page.dark .step-status {
  background: #2D3142;
  color: #9CA3AF;
}

.step-status.active {
  background: #DBEAFE;
  color: #3B82F6;
}

.flow-step.completed .step-status {
  background: #D1FAE5;
  color: #10B981;
}

.step-desc {
  font-size: 26rpx;
  color: #6B7280;
  line-height: 1.6;
  display: block;
  margin-bottom: 16rpx;
}

.page.dark .step-desc {
  color: #9CA3AF;
}

.step-poi {
  display: flex;
  align-items: center;
  background: #F0F9FF;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
}

.step-poi > view { margin-right: 12rpx; }

.step-poi > view:last-child { margin-right: 0; }

.page.dark .step-poi {
  background: rgba(59, 130, 246, 0.1);
}

.poi-icon {
  font-size: 28rpx;
}

.poi-name {
  font-size: 26rpx;
  color: #0369A1;
  font-weight: 500;
}

.page.dark .poi-name {
  color: #60A5FA;
}

.poi-action {
  font-size: 22rpx;
  color: #3B82F6;
  margin-left: auto;
}

.step-tips {
  display: flex;
  align-items: flex-start;
  background: #FFFBEB;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
}

.step-tips > view { margin-right: 12rpx; }

.step-tips > view:last-child { margin-right: 0; }

.page.dark .step-tips {
  background: rgba(245, 158, 11, 0.1);
}

.tips-icon {
  font-size: 28rpx;
  flex-shrink: 0;
}

.tips-text {
  font-size: 24rpx;
  color: #92400E;
  line-height: 1.5;
}

.page.dark .tips-text {
  color: #FCD34D;
}

.keypoints-grid {
  display: flex;
  flex-wrap: wrap;
}

.keypoints-grid { margin-right: -20rpx; margin-bottom: -20rpx; }

.keypoints-grid > view { margin-right: 20rpx; margin-bottom: 20rpx; }

.keypoint-card {
  width: calc(33.333% - 14rpx);
  background: #FAFAFA;
  border-radius: 16rpx;
  padding: 24rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.keypoint-card > view { margin-bottom: 12rpx; }

.keypoint-card > view:last-child { margin-bottom: 0; }

.page.dark .keypoint-card {
  background: #2D3142;
}

.keypoint-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.keypoint-icon text {
  font-size: 36rpx;
}

.keypoint-name {
  font-size: 26rpx;
  color: #2C3E50;
  font-weight: 500;
  text-align: center;
}

.page.dark .keypoint-name {
  color: #E8ECF1;
}

.keypoint-desc {
  font-size: 22rpx;
  color: #95A5A6;
}

.materials-list {
  display: flex;
  flex-direction: column;
}

.materials-list > view { margin-bottom: 4rpx; }

.materials-list > view:last-child { margin-bottom: 0; }

.material-item {
  display: flex;
  align-items: center;
  padding: 20rpx 16rpx;
  border-radius: 12rpx;
}

.material-item > view { margin-right: 20rpx; }

.material-item > view:last-child { margin-right: 0; }

.material-item:nth-child(odd) {
  background: #FAFAFA;
}

.page.dark .material-item:nth-child(odd) {
  background: #2D3142;
}

.material-icon {
  font-size: 32rpx;
}

.material-text {
  flex: 1;
  font-size: 28rpx;
  color: #2C3E50;
}

.page.dark .material-text {
  color: #E8ECF1;
}

.material-check {
  font-size: 28rpx;
  color: #10B981;
}

.contact-card {
  display: flex;
  flex-direction: column;
}

.contact-card > view { margin-bottom: 20rpx; }

.contact-card > view:last-child { margin-bottom: 0; }

.contact-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #FAFAFA;
  border-radius: 16rpx;
}

.contact-item > view { margin-right: 20rpx; }

.contact-item > view:last-child { margin-right: 0; }

.page.dark .contact-item {
  background: #2D3142;
}

.contact-icon {
  font-size: 40rpx;
}

.contact-info {
  flex: 1;
}

.contact-title {
  font-size: 28rpx;
  color: #2C3E50;
  font-weight: 500;
  display: block;
  margin-bottom: 4rpx;
}

.page.dark .contact-title {
  color: #E8ECF1;
}

.contact-desc {
  font-size: 22rpx;
  color: #95A5A6;
}

.contact-btn {
  padding: 12rpx 24rpx;
  background: linear-gradient(135deg, #3B82F6 0%, #2563EB 100%);
  border-radius: 24rpx;
}

.contact-btn text {
  font-size: 24rpx;
  color: #FFFFFF;
}

.bottom-action {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FFFFFF;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.bottom-action > view { margin-right: 16rpx; }

.bottom-action > view:last-child { margin-right: 0; }

.page.dark .bottom-action {
  background: #1E2230;
}

.action-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-btn > view { margin-right: 8rpx; }

.action-btn > view:last-child { margin-right: 0; }

.action-btn.secondary {
  background: #F0F2F5;
}

.page.dark .action-btn.secondary {
  background: #2D3142;
}

.action-btn.primary {
  flex: 1.5;
  background: linear-gradient(135deg, #667EEA 0%, #764BA2 100%);
}

.btn-icon {
  font-size: 28rpx;
}

.action-btn.secondary .btn-text {
  font-size: 28rpx;
  color: #2C3E50;
}

.page.dark .action-btn.secondary .btn-text {
  color: #E8ECF1;
}

.action-btn.primary .btn-text {
  font-size: 28rpx;
  color: #FFFFFF;
  font-weight: 500;
}
