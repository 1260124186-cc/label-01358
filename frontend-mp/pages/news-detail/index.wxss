.page {
  min-height: 100vh;
  background-color: var(--color-bg-page);
}

.cover-image {
  width: 100%;
  height: 420rpx;
  display: block;
}

.content-section {
  padding: 32rpx;
  margin: -60rpx 24rpx 24rpx;
  background-color: var(--color-bg-card);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-card);
  position: relative;
}

.news-header {
  margin-bottom: 24rpx;
}

.category-tag {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 20rpx;
  background: linear-gradient(135deg, rgba(255,107,107,0.1) 0%, rgba(255,138,138,0.1) 100%);
  border-radius: var(--radius-full);
  margin-bottom: 20rpx;
}

.category-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.category-text {
  font-size: 24rpx;
  color: var(--color-primary);
  font-weight: 500;
}

.content-title {
  display: block;
  font-size: 42rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  line-height: 1.4;
  margin-bottom: 20rpx;
}

.news-meta {
  display: flex;
  align-items: center;
  gap: 32rpx;
}

.meta-item {
  font-size: 26rpx;
  color: var(--color-text-tertiary);
}

.content-divider {
  height: 1rpx;
  background: linear-gradient(90deg, var(--color-primary-light), transparent);
  margin-bottom: 24rpx;
}

.news-summary {
  display: block;
  font-size: 30rpx;
  color: var(--color-text-secondary);
  line-height: 1.7;
  padding: 24rpx;
  background-color: var(--color-bg-tertiary);
  border-radius: var(--radius-lg);
  border-left: 6rpx solid var(--color-primary);
  margin-bottom: 32rpx;
}

.images-section {
  margin-bottom: 32rpx;
}

.images-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 20rpx;
}

.images-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.image-item {
  width: 100%;
  padding-top: 100%;
  position: relative;
  border-radius: var(--radius-md);
  overflow: hidden;
}

.image-item image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.content-text-section {
  margin-bottom: 24rpx;
}

.content-text {
  display: block;
  font-size: 30rpx;
  color: var(--color-text-secondary);
  line-height: 1.9;
  white-space: pre-wrap;
}

.share-tip {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
  background: linear-gradient(135deg, rgba(78,205,196,0.1) 0%, rgba(110,231,222,0.1) 100%);
  border-radius: var(--radius-lg);
  margin-top: 24rpx;
}

.share-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.share-text {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.related-section {
  padding: 0 24rpx;
  margin-bottom: 24rpx;
}

.section-header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.section-title-wrap {
  display: flex;
  align-items: center;
}

.section-icon {
  width: 8rpx;
  height: 32rpx;
  background: linear-gradient(180deg, var(--color-primary) 0%, var(--color-primary-light) 100%);
  border-radius: var(--radius-full);
  margin-right: 16rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

.section-subtitle {
  font-size: 26rpx;
  color: var(--color-text-tertiary);
}

.related-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.related-item {
  display: flex;
  background-color: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: 24rpx;
  box-shadow: var(--shadow-card);
}

.related-content {
  flex: 1;
  margin-right: 20rpx;
  display: flex;
  flex-direction: column;
}

.related-tag {
  display: inline-flex;
  align-items: center;
  font-size: 22rpx;
  color: var(--color-primary);
  background: rgba(255,107,107,0.1);
  padding: 4rpx 12rpx;
  border-radius: var(--radius-sm);
  margin-bottom: 12rpx;
  align-self: flex-start;
}

.related-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  line-height: 1.4;
  margin-bottom: 8rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.related-summary {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  line-height: 1.5;
  margin-bottom: 12rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  flex: 1;
}

.related-meta {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.related-time {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
}

.related-views {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
}

.related-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: var(--radius-lg);
  flex-shrink: 0;
}

.bottom-padding {
  height: 40rpx;
}

.empty-page {
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-text {
  font-size: 28rpx;
  color: var(--color-text-tertiary);
}
