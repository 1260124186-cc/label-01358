.page {
  min-height: 100vh;
  background-color: var(--color-bg-page);
}

.page-header {
  padding: 48rpx 32rpx 32rpx;
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-light) 100%);
  position: relative;
  overflow: hidden;
}

.header-content {
  position: relative;
  z-index: 1;
}

.header-title {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.header-subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
}

.header-decoration {
  position: absolute;
  right: 32rpx;
  top: 50%;
  transform: translateY(-50%);
  opacity: 0.3;
}

.deco-icon {
  font-size: 120rpx;
}

.filter-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  background-color: var(--color-bg-card);
  position: sticky;
  top: 0;
  z-index: 10;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.tab-scroll {
  flex: 1;
  white-space: nowrap;
}

.tab-list {
  display: inline-flex;
  padding: 0 16rpx;
  gap: 8rpx;
}

.tab-item {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 24rpx;
  border-radius: var(--radius-full);
  background-color: var(--color-bg-tertiary);
  margin-right: 8rpx;
  transition: all 0.2s ease;
  flex-shrink: 0;
}

.tab-item.active {
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-light) 100%);
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 107, 0.3);
}

.tab-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.tab-label {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  font-weight: 500;
}

.tab-item.active .tab-label {
  color: #FFFFFF;
}

.sort-btn {
  display: flex;
  align-items: center;
  padding: 0 24rpx 0 16rpx;
  border-left: 1rpx solid var(--color-border);
  flex-shrink: 0;
}

.sort-icon {
  font-size: 28rpx;
  color: var(--color-primary);
  margin-right: 8rpx;
}

.sort-text {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  white-space: nowrap;
}

.content-section {
  padding: 24rpx;
}

.list-header {
  margin-bottom: 20rpx;
}

.list-count {
  font-size: 26rpx;
  color: var(--color-text-tertiary);
}

.news-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.news-item {
  display: flex;
  background-color: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: 24rpx;
  box-shadow: var(--shadow-card);
  transition: transform 0.2s ease;
}

.news-item:active {
  transform: scale(0.98);
}

.news-content {
  flex: 1;
  margin-right: 20rpx;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.news-tags {
  margin-bottom: 12rpx;
}

.category-tag {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 16rpx;
  background: linear-gradient(135deg, rgba(255,107,107,0.1) 0%, rgba(255,138,138,0.1) 100%);
  border-radius: var(--radius-full);
}

.tag-icon {
  font-size: 24rpx;
  margin-right: 6rpx;
}

.tag-text {
  font-size: 22rpx;
  color: var(--color-primary);
  font-weight: 500;
}

.news-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  line-height: 1.4;
  margin-bottom: 8rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.news-summary {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.5;
  margin-bottom: 12rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  flex: 1;
}

.news-meta {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.meta-item {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
}

.news-image {
  width: 180rpx;
  height: 180rpx;
  border-radius: var(--radius-lg);
  flex-shrink: 0;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
  opacity: 0.6;
}

.empty-text {
  font-size: 30rpx;
  color: var(--color-text-secondary);
  margin-bottom: 12rpx;
}

.empty-subtitle {
  font-size: 26rpx;
  color: var(--color-text-tertiary);
}

.bottom-padding {
  height: 40rpx;
}

.sort-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.sort-modal.show {
  opacity: 1;
  visibility: visible;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
}

.modal-content {
  position: relative;
  width: 100%;
  background-color: var(--color-bg-card);
  border-radius: var(--radius-xl) var(--radius-xl) 0 0;
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  transform: translateY(100%);
  transition: transform 0.3s ease;
}

.sort-modal.show .modal-content {
  transform: translateY(0);
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.modal-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.close-icon {
  font-size: 32rpx;
  color: var(--color-text-tertiary);
}

.sort-options {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.sort-option {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  border-radius: var(--radius-lg);
  background-color: var(--color-bg-tertiary);
  transition: all 0.2s ease;
}

.sort-option.active {
  background: linear-gradient(135deg, rgba(255,107,107,0.1) 0%, rgba(255,138,138,0.1) 100%);
  border: 2rpx solid var(--color-primary);
}

.option-label {
  font-size: 28rpx;
  color: var(--color-text-primary);
}

.sort-option.active .option-label {
  color: var(--color-primary);
  font-weight: 600;
}

.option-check {
  font-size: 28rpx;
  color: var(--color-primary);
  font-weight: 600;
}
