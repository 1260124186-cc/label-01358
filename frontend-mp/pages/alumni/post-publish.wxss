.page {
  min-height: 100vh;
  background: var(--color-bg-page);
}

.page.dark {
  --color-bg-page: #0F1117;
  --color-bg-card: #1A1D29;
  --color-text-primary: #E8ECF1;
  --color-text-secondary: #9CA3AF;
  --color-border: #2D3142;
}

.form-scroll {
  height: 100vh;
  padding-bottom: 200rpx;
}

.form-section {
  background: var(--color-bg-card);
  margin: 24rpx;
  padding: 32rpx;
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-card);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 24rpx;
}

.required {
  color: #EF4444;
}

.form-item {
  margin-bottom: 28rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 26rpx;
  color: var(--color-text-primary);
  margin-bottom: 12rpx;
  font-weight: 500;
}

.form-input {
  width: 100%;
  padding: 24rpx 28rpx;
  background: var(--color-bg-page);
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-lg);
  font-size: 28rpx;
  color: var(--color-text-primary);
  box-sizing: border-box;
}

.form-textarea {
  width: 100%;
  min-height: 140rpx;
  padding: 24rpx 28rpx;
  background: var(--color-bg-page);
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-lg);
  font-size: 28rpx;
  color: var(--color-text-primary);
  box-sizing: border-box;
  line-height: 1.6;
}

.form-textarea.large {
  min-height: 280rpx;
}

.form-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 28rpx;
  background: var(--color-bg-page);
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-lg);
}

.picker-value {
  font-size: 28rpx;
  color: var(--color-text-primary);
  flex: 1;
}

.picker-value.placeholder {
  color: var(--color-text-secondary);
}

.picker-arrow {
  font-size: 32rpx;
  color: var(--color-text-secondary);
  margin-left: 16rpx;
}

.image-upload-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.image-item {
  position: relative;
  width: calc((100% - 32rpx) / 3);
  height: 200rpx;
}

.uploaded-img {
  width: 100%;
  height: 100%;
  border-radius: var(--radius-md);
  object-fit: cover;
}

.remove-img-btn {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #EF4444;
  color: #FFFFFF;
  border-radius: 20rpx;
  font-size: 28rpx;
  line-height: 1;
}

.add-image-btn {
  width: calc((100% - 32rpx) / 3);
  height: 200rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  background: var(--color-bg-page);
  border: 2rpx dashed var(--color-border);
  border-radius: var(--radius-md);
}

.add-img-icon {
  font-size: 48rpx;
  color: var(--color-text-secondary);
}

.add-img-text {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

.form-footer {
  padding: 24rpx 32rpx 48rpx;
}

.picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.picker-mask.show {
  opacity: 1;
  visibility: visible;
}

.picker-content {
  width: 100%;
  background: var(--color-bg-card);
  border-radius: 32rpx 32rpx 0 0;
  transform: translateY(100%);
  transition: transform 0.3s ease;
}

.picker-mask.show .picker-content {
  transform: translateY(0);
}

.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid var(--color-border);
}

.picker-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.picker-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: var(--color-text-secondary);
}

.picker-options {
  max-height: 60vh;
  overflow-y: auto;
  padding: 16rpx 0;
}

.picker-option {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  transition: background 0.2s ease;
}

.picker-option:active {
  background: var(--color-hover);
}

.picker-option.active {
  background: rgba(59, 130, 246, 0.1);
}

.option-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.option-label {
  flex: 1;
  font-size: 28rpx;
  color: var(--color-text-primary);
}

.picker-option.active .option-label {
  color: var(--color-primary);
  font-weight: 500;
}

.option-check {
  font-size: 32rpx;
  color: var(--color-primary);
}
