.page {
  min-height: 100vh;
  background: var(--color-bg-page);
  padding-bottom: 40rpx;
}

.page.dark {
  --color-bg-page: #0F1117;
  --color-bg-card: #1A1D29;
  --color-text-primary: #E8ECF1;
  --color-text-secondary: #9CA3AF;
  --color-border: #2D3142;
  --color-input-bg: #2A2E37;
  --color-input-border: #2A2E37;
}

.top-tabs {
  display: flex;
  background: var(--color-bg-card);
  margin: 24rpx 32rpx;
  border-radius: var(--radius-xl);
  padding: 8rpx;
  box-shadow: var(--shadow-card);
}

.top-tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 12rpx;
  border-radius: var(--radius-lg);
  transition: all 0.3s ease;
}

.top-tab-item.active {
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-dark));
}

.tab-icon {
  font-size: 36rpx;
  margin-bottom: 8rpx;
}

.tab-label {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  font-weight: 500;
}

.top-tab-item.active .tab-label {
  color: #FFFFFF;
}

.tab-content {
  flex: 1;
}

.form-scroll {
  height: calc(100vh - 200rpx);
  padding: 0 32rpx;
}

.records-scroll {
  height: calc(100vh - 200rpx);
  padding: 0 32rpx;
}

.notice-card {
  display: flex;
  align-items: flex-start;
  background: linear-gradient(135deg, #FFF8E1 0%, #FFECB3 100%);
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.page.dark .notice-card {
  background: linear-gradient(135deg, rgba(255, 193, 7, 0.15) 0%, rgba(255, 152, 0, 0.15) 100%);
}

.notice-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.notice-content {
  flex: 1;
}

.notice-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #F57C00;
  margin-bottom: 8rpx;
}

.page.dark .notice-title {
  color: #FFB74D;
}

.notice-text {
  font-size: 24rpx;
  color: #F57C00;
  line-height: 1.5;
}

.page.dark .notice-text {
  color: #FFCC80;
}

.form-section {
  background: var(--color-bg-card);
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-card);
}

.form-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 24rpx;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.label-text {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--color-text-primary);
}

.required {
  color: #F44336;
  font-size: 28rpx;
  margin-left: 4rpx;
}

.optional {
  color: var(--color-text-secondary);
  font-size: 24rpx;
  margin-left: 8rpx;
}

.form-input-wrap {
  background: var(--color-input-bg, #F8F9FA);
  border: 2rpx solid var(--color-input-border, #EEEEEE);
  border-radius: 12rpx;
  padding: 0 20rpx;
}

.form-input {
  height: 88rpx;
  font-size: 28rpx;
  color: var(--color-text-primary);
}

.form-placeholder {
  color: var(--color-text-secondary);
  font-size: 28rpx;
}

.form-picker-wrap {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: var(--color-input-bg, #F8F9FA);
  border: 2rpx solid var(--color-input-border, #EEEEEE);
  border-radius: 12rpx;
  padding: 0 20rpx;
  height: 88rpx;
}

.picker-selected {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.type-icon {
  font-size: 32rpx;
}

.type-label {
  font-size: 28rpx;
  font-weight: 500;
}

.form-picker-text {
  font-size: 28rpx;
  color: var(--color-text-primary);
}

.form-picker-text.placeholder {
  color: var(--color-text-secondary);
}

.picker-arrow {
  font-size: 32rpx;
  color: #CCCCCC;
}

.form-textarea-wrap {
  background: var(--color-input-bg, #F8F9FA);
  border: 2rpx solid var(--color-input-border, #EEEEEE);
  border-radius: 12rpx;
  padding: 20rpx;
}

.form-textarea {
  width: 100%;
  min-height: 160rpx;
  font-size: 28rpx;
  color: var(--color-text-primary);
  line-height: 1.6;
}

.word-count {
  text-align: right;
  font-size: 22rpx;
  color: var(--color-text-secondary);
  margin-top: 8rpx;
}

.submit-section {
  padding: 32rpx 0;
}

.appointment-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.appointment-card {
  background: var(--color-bg-card);
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: var(--shadow-card);
}

.appointment-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid var(--color-border, #F0F0F0);
}

.appointment-type {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.type-name {
  font-size: 30rpx;
  font-weight: 600;
}

.appointment-status {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 16rpx;
  border-radius: 24rpx;
}

.status-icon {
  font-size: 24rpx;
}

.status-label {
  font-size: 24rpx;
  font-weight: 500;
}

.appointment-info {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.info-row {
  display: flex;
  align-items: center;
}

.info-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.info-label {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  width: 120rpx;
  flex-shrink: 0;
}

.info-value {
  font-size: 26rpx;
  color: var(--color-text-primary);
  font-weight: 500;
  flex: 1;
}

.appointment-footer {
  padding-top: 16rpx;
  border-top: 1rpx solid var(--color-border, #F0F0F0);
}

.create-time {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

.picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.picker-mask.show {
  opacity: 1;
  visibility: visible;
}

.picker-content {
  width: 100%;
  background: var(--color-bg-card);
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx;
  max-height: 70vh;
  transform: translateY(100%);
  transition: transform 0.3s ease;
}

.picker-mask.show .picker-content {
  transform: translateY(0);
}

.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid var(--color-border);
}

.picker-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.picker-clear {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.picker-options {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  max-height: 50vh;
  overflow-y: auto;
}

.picker-option {
  display: flex;
  align-items: center;
  padding: 24rpx 20rpx;
  border-radius: var(--radius-lg);
  transition: background 0.2s ease;
}

.picker-option:active {
  background: var(--color-hover);
}

.picker-option.active {
  background: rgba(59, 130, 246, 0.1);
}

.option-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.option-label {
  flex: 1;
  font-size: 28rpx;
  color: var(--color-text-primary);
}

.option-check {
  font-size: 32rpx;
  color: var(--color-primary);
}

.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--color-bg-page);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2000;
}

.loading-content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 4rpx solid var(--color-border);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 24rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}
