<wxs src="../../utils/filters.wxs" module="f" />
<page-meta page-style="background-color: {{darkMode ? '#0F1117' : '#F8F9FA'}}; color: {{darkMode ? '#E8ECF1' : '#2C3E50'}}"/>
<view class="page {{darkMode ? 'dark' : ''}}">
  <!-- 认证状态卡片 -->
  <view class="status-card {{verifyInfo ? verifyInfo.status : 'unverified'}}" wx:if="{{verifyInfo}}">
    <view class="status-icon">{{verifyStatusInfo.icon}}</view>
    <view class="status-info">
      <text class="status-title">{{verifyStatusInfo.label}}</text>
      <text class="status-desc" wx:if="{{verifyInfo.status === 'approved'}}">
        您的校友认证已通过，享受更多校友权益
      </text>
      <text class="status-desc" wx:elif="{{verifyInfo.status === 'pending'}}">
        您的认证申请正在审核中，预计24小时内完成
      </text>
      <text class="status-desc" wx:elif="{{verifyInfo.status === 'rejected'}}">
        认证未通过原因：{{verifyInfo.rejectReason || '信息不完整，请重新提交'}}
      </text>
    </view>
  </view>

  <!-- 未认证提示 -->
  <view class="unverified-card" wx:if="{{!verifyInfo}}">
    <view class="unverified-icon">📝</view>
    <text class="unverified-title">尚未认证</text>
    <text class="unverified-desc">完成校友认证，解锁更多专属服务</text>
  </view>

  <!-- 认证说明卡片 -->
  <view class="intro-card" wx:if="{{!verifyInfo || verifyInfo.status === 'rejected'}}">
    <view class="intro-header">
      <text class="intro-icon">🎓</text>
      <text class="intro-title">校友认证权益</text>
    </view>
    <view class="intro-list">
      <view class="intro-item">
        <text class="intro-item-icon">✓</text>
        <text class="intro-item-text">获得校友专属标识，提升个人主页展示认证徽章</text>
      </view>
      <view class="intro-item">
        <text class="intro-item-icon">✓</text>
        <text class="intro-item-text">参与校友导师计划，获得职业发展指导</text>
      </view>
      <view class="intro-item">
        <text class="intro-item-icon">✓</text>
        <text class="intro-item-text">参加校友专属活动，拓展人脉资源</text>
      </view>
      <view class="intro-item">
        <text class="intro-item-icon">✓</text>
        <text class="intro-item-text">享受校友卡权益，校园服务优惠</text>
      </view>
    </view>
  </view>

  <!-- 认证表单 -->
  <view class="form-section" wx:if="{{!verifyInfo || verifyInfo.status === 'rejected'}}">
    <view class="form-title">填写认证信息</view>

    <view class="form-item">
      <view class="form-label">
        <text class="label-text">姓名</text>
        <text class="required">*</text>
      </view>
      <view class="form-input-wrap">
        <input
          class="form-input"
          placeholder="请输入您的真实姓名"
          placeholder-class="form-placeholder"
          value="{{formData.name}}"
          bindinput="onNameInput"
          maxlength="20"
        />
      </view>
    </view>

    <view class="form-item">
      <view class="form-label">
        <text class="label-text">学号</text>
        <text class="required">*</text>
      </view>
      <view class="form-input-wrap">
        <input
          class="form-input"
          placeholder="请输入您的学号"
          placeholder-class="form-placeholder"
          value="{{formData.studentId}}"
          bindinput="onStudentIdInput"
          maxlength="20"
        />
      </view>
    </view>

    <view class="form-item">
      <view class="form-label">
        <text class="label-text">毕业年份</text>
        <text class="required">*</text>
      </view>
      <picker
        mode="selector"
        range="{{graduationYearOptions}}"
        value="{{graduationYearIndex}}"
        bindchange="onGraduationYearChange"
      >
        <view class="form-picker-wrap">
          <text class="form-picker-text {{formData.graduationYear ? '' : 'placeholder'}}">
            {{formData.graduationYear || '请选择毕业年份'}}
          </text>
          <text class="picker-arrow">›</text>
        </view>
      </picker>
    </view>

    <view class="form-item">
      <view class="form-label">
        <text class="label-text">学院</text>
        <text class="required">*</text>
      </view>
      <picker
        mode="selector"
        range="{{collegeOptions}}"
        range-key="label"
        value="{{collegeIndex}}"
        bindchange="onCollegeChange"
      >
        <view class="form-picker-wrap">
          <text class="form-picker-text {{formData.college ? '' : 'placeholder'}}">
            {{formData.college ? f.getLabel(collegeOptions, formData.college) : '请选择学院'}}
          </text>
          <text class="picker-arrow">›</text>
        </view>
      </picker>
    </view>

    <view class="form-item">
      <view class="form-label">
        <text class="label-text">工作单位</text>
        <text class="required">*</text>
      </view>
      <view class="form-input-wrap">
        <input
          class="form-input"
          placeholder="请输入您的工作单位"
          placeholder-class="form-placeholder"
          value="{{formData.workUnit}}"
          bindinput="onWorkUnitInput"
          maxlength="50"
        />
      </view>
    </view>

    <view class="form-item">
      <view class="form-label">
        <text class="label-text">职位</text>
        <text class="required">*</text>
      </view>
      <view class="form-input-wrap">
        <input
          class="form-input"
          placeholder="请输入您的职位"
          placeholder-class="form-placeholder"
          value="{{formData.position}}"
          bindinput="onPositionInput"
          maxlength="30"
        />
      </view>
    </view>

    <view class="form-item">
      <view class="form-label">
        <text class="label-text">行业</text>
        <text class="required">*</text>
      </view>
      <picker
        mode="selector"
        range="{{industryOptions}}"
        range-key="label"
        value="{{industryIndex}}"
        bindchange="onIndustryChange"
      >
        <view class="form-picker-wrap">
          <text class="form-picker-text {{formData.industry ? '' : 'placeholder'}}">
            {{formData.industry ? f.getLabel(industryOptions, formData.industry) : '请选择行业'}}
          </text>
          <text class="picker-arrow">›</text>
        </view>
      </picker>
    </view>

    <view class="form-item">
      <view class="form-label">
        <text class="label-text">个人简介</text>
        <text class="optional">（选填）</text>
      </view>
      <view class="form-textarea-wrap">
        <textarea
          class="form-textarea"
          placeholder="请简单介绍一下自己，让更多校友认识你..."
          placeholder-class="form-placeholder"
          value="{{formData.bio}}"
          bindinput="onBioInput"
          maxlength="200"
          auto-height
        />
      </view>
      <view class="word-count">{{formData.bio.length}}/200</view>
    </view>

    <!-- 提交按钮 -->
    <view class="submit-section">
      <btn 
        type="primary" 
        size="large" 
        bind:click="onSubmit"
        loading="{{submitting}}"
        disabled="{{submitting}}"
        block
      >
        {{submitting ? '提交中...' : '提交认证'}}
      </btn>
    </view>
  </view>

  <!-- 已认证信息详情 -->
  <view class="info-section" wx:if="{{verifyInfo && verifyInfo.status === 'approved'}}">
    <view class="info-title">认证信息</view>
    <view class="info-list">
      <view class="info-item">
        <text class="info-label">姓名</text>
        <text class="info-value">{{formData.name}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">学号</text>
        <text class="info-value">{{formData.studentId}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">毕业年份</text>
        <text class="info-value">{{formData.graduationYear}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">学院</text>
        <text class="info-value">{{f.getLabel(collegeOptions, formData.college)}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">工作单位</text>
        <text class="info-value">{{formData.workUnit}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">职位</text>
        <text class="info-value">{{formData.position}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">行业</text>
        <text class="info-value">{{f.getLabel(industryOptions, formData.industry)}}</text>
      </view>
      <view class="info-item" wx:if="{{formData.bio}}">
        <text class="info-label">个人简介</text>
        <text class="info-value bio">{{formData.bio}}</text>
      </view>
    </view>
    <view class="info-tip">
      <text class="tip-icon">ℹ️</text>
      <text class="tip-text">认证信息不可随意修改，如需修改请联系管理员</text>
    </view>
  </view>

  <!-- 审核中信息展示 -->
  <view class="info-section" wx:if="{{verifyInfo && verifyInfo.status === 'pending'}}">
    <view class="info-title">已提交的信息</view>
    <view class="info-list">
      <view class="info-item">
        <text class="info-label">姓名</text>
        <text class="info-value">{{formData.name}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">学号</text>
        <text class="info-value">{{formData.studentId}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">毕业年份</text>
        <text class="info-value">{{formData.graduationYear}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">学院</text>
        <text class="info-value">{{f.getLabel(collegeOptions, formData.college)}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">工作单位</text>
        <text class="info-value">{{formData.workUnit}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">职位</text>
        <text class="info-value">{{formData.position}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">行业</text>
        <text class="info-value">{{f.getLabel(industryOptions, formData.industry)}}</text>
      </view>
    </view>
    <view class="info-tip">
      <text class="tip-icon">⏳</text>
      <text class="tip-text">审核期间请耐心等待，如有疑问可联系管理员</text>
    </view>
  </view>

  <!-- 加载状态 -->
  <view class="loading-overlay" wx:if="{{loading}}">
    <view class="loading-content">
      <view class="loading-spinner"></view>
      <text class="loading-text">加载中...</text>
    </view>
  </view>
</view>
