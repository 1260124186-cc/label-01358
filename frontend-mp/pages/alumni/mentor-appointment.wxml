<page-meta page-style="background-color: {{darkMode ? '#0F1117' : '#F8F9FA'}}; color: {{darkMode ? '#E8ECF1' : '#2C3E50'}}"/>
<view class="page {{darkMode ? 'dark' : ''}}" wx:if="{{mentor}}">
  <view class="mentor-card">
    <image class="mentor-avatar" src="{{mentor.avatar}}" mode="aspectFill"/>
    <view class="mentor-info">
      <view class="mentor-name-row">
        <text class="mentor-name">{{mentor.name}}</text>
        <view class="mentor-badge" style="background: {{mentor.titleInfo.color}}">
          {{mentor.titleInfo.label}}
        </view>
      </view>
      <view class="mentor-company">{{mentor.company}} · {{mentor.position}}</view>
      <view class="mentor-fee">咨询费用：<text class="fee-value">¥{{mentor.appointmentFee}}</text>/次</view>
    </view>
  </view>

  <scroll-view class="form-scroll" scroll-y="{{true}}" enhanced="{{true}}" show-scrollbar="{{false}}">
    <view class="form-section">
      <view class="section-title">📅 预约信息</view>

      <view class="form-item">
        <text class="form-label">预约日期 <text class="required">*</text></text>
        <view class="form-picker" bindtap="onDatePickerTap">
          <text class="picker-value {{appointmentDate ? '' : 'placeholder'}}">
            {{appointmentDateText || '请选择预约日期'}}
          </text>
          <text class="picker-arrow">›</text>
        </view>
      </view>

      <view class="form-item">
        <text class="form-label">预约时间 <text class="required">*</text></text>
        <view class="form-picker" bindtap="onTimePickerTap">
          <text class="picker-value {{appointmentTime ? '' : 'placeholder'}}">
            {{appointmentTimeText || '请选择预约时间'}}
          </text>
          <text class="picker-arrow">›</text>
        </view>
      </view>
    </view>

    <view class="form-section">
      <view class="section-title">📝 咨询内容</view>

      <view class="form-item">
        <text class="form-label">咨询主题 <text class="required">*</text></text>
        <input
          class="form-input"
          placeholder="请输入咨询主题"
          value="{{appointmentTopic}}"
          bindinput="onTopicInput"
          maxlength="50"
        />
      </view>

      <view class="form-item">
        <text class="form-label">问题描述 <text class="required">*</text></text>
        <textarea
          class="form-textarea"
          placeholder="请详细描述您的问题和咨询目的（至少10个字符）"
          value="{{appointmentDescription}}"
          bindinput="onDescriptionInput"
          maxlength="500"
          auto-height="{{true}}"
        />
      </view>
    </view>

    <view class="form-section">
      <view class="section-title">📞 联系方式</view>

      <view class="form-item">
        <text class="form-label">联系方式 <text class="required">*</text></text>
        <input
          class="form-input"
          placeholder="请输入您的手机号或微信"
          value="{{contactInfo}}"
          bindinput="onContactInput"
          maxlength="50"
        />
      </view>
    </view>

    <view class="notice-section">
      <view class="notice">
        <text class="notice-icon">⚠️</text>
        <text class="notice-text">预约提交后请耐心等待导师确认，取消预约请提前24小时联系导师</text>
      </view>
    </view>

    <view class="bottom-spacing"></view>
  </scroll-view>

  <view class="bottom-bar">
    <btn type="primary" size="large" block="{{true}}" bind:click="onSubmitAppointment" loading="{{submitting}}">
      提交预约
    </btn>
  </view>

  <view class="picker-mask {{showDatePicker ? 'show' : ''}}" bindtap="onCloseDatePicker">
    <view class="picker-content" catchtap="stopPropagation">
      <view class="picker-header">
        <text class="picker-title">选择预约日期</text>
        <view class="picker-close" bindtap="onCloseDatePicker">✕</view>
      </view>
      <view class="picker-options">
        <view
          class="picker-option {{appointmentDate === item.value ? 'active' : ''}}"
          wx:for="{{appointmentDateOptions}}"
          wx:key="value"
          bindtap="onDateSelect"
          data-value="{{item.value}}"
          data-label="{{item.label}}"
        >
          <text class="option-label">{{item.label}}</text>
          <text class="option-check" wx:if="{{appointmentDate === item.value}}">✓</text>
        </view>
      </view>
    </view>
  </view>

  <view class="picker-mask {{showTimePicker ? 'show' : ''}}" bindtap="onCloseTimePicker">
    <view class="picker-content" catchtap="stopPropagation">
      <view class="picker-header">
        <text class="picker-title">选择预约时间</text>
        <view class="picker-close" bindtap="onCloseTimePicker">✕</view>
      </view>
      <view class="picker-options">
        <view
          class="picker-option {{appointmentTime === item.value ? 'active' : ''}}"
          wx:for="{{appointmentTimeOptions}}"
          wx:key="value"
          bindtap="onTimeSelect"
          data-value="{{item.value}}"
          data-label="{{item.label}}"
        >
          <text class="option-label">{{item.label}}</text>
          <text class="option-check" wx:if="{{appointmentTime === item.value}}">✓</text>
        </view>
      </view>
    </view>
  </view>

  <view class="loading-overlay" wx:if="{{loading}}">
    <view class="loading-content">
      <view class="loading-spinner"></view>
      <text class="loading-text">加载中...</text>
    </view>
  </view>
</view>
