<wxs src="../../utils/filters.wxs" module="f" />
<page-meta page-style="background-color: {{darkMode ? '#0F1117' : '#F8F9FA'}}; color: {{darkMode ? '#E8ECF1' : '#2C3E50'}}"/>
<view class="page {{darkMode ? 'dark' : ''}}">

  <!-- 行业分布视图 -->
  <view class="distribution-view" wx:if="{{!showList}}">
    <!-- 顶部总览 -->
    <view class="overview-section">
      <view class="overview-card">
        <view class="overview-label">校友总数</view>
        <view class="overview-count">{{totalCount}}</view>
        <view class="overview-sub">覆盖 {{distribution.length}} 个行业</view>
      </view>
    </view>

    <!-- 行业分布标题 -->
    <view class="section-title-row">
      <text class="section-title">行业分布</text>
      <text class="section-subtitle">按人数排序</text>
    </view>

    <!-- 横向条形图 -->
    <view class="chart-section">
      <view class="chart-card">
        <view
          class="chart-item {{selectedIndustry === item.value ? 'active' : ''}}"
          wx:for="{{distribution}}"
          wx:key="value"
          bindtap="onIndustryTap"
          data-value="{{item.value}}"
        >
          <view class="chart-item-header">
            <view class="chart-item-left">
              <text class="chart-icon">{{item.icon}}</text>
              <text class="chart-label">{{item.label}}</text>
            </view>
            <view class="chart-item-right">
              <text class="chart-count">{{item.count}}人</text>
              <text class="chart-percent">{{item.percent}}%</text>
            </view>
          </view>
          <view class="chart-bar-container">
            <view
              class="chart-bar-fill"
              style="width: {{item.percent}}%; background: {{item.color}}"
            ></view>
          </view>
        </view>
      </view>
    </view>

    <!-- 行业卡片列表 -->
    <view class="section-title-row">
      <text class="section-title">行业详情</text>
      <text class="section-subtitle">点击查看校友</text>
    </view>

    <view class="industry-grid">
      <view
        class="industry-card"
        wx:for="{{distribution}}"
        wx:key="value"
        bindtap="onIndustryTap"
        data-value="{{item.value}}"
        style="border-left: 8rpx solid {{item.color}}"
      >
        <view class="industry-card-header">
          <text class="industry-card-icon">{{item.icon}}</text>
          <text class="industry-card-name">{{item.label}}</text>
        </view>
        <view class="industry-card-stats">
          <view class="industry-stat">
            <text class="industry-stat-value">{{item.count}}</text>
            <text class="industry-stat-label">人数</text>
          </view>
          <view class="industry-stat">
            <text class="industry-stat-value" style="color: {{item.color}}">{{item.percent}}%</text>
            <text class="industry-stat-label">占比</text>
          </view>
        </view>
        <view class="industry-card-arrow">
          <text>查看校友 ›</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 校友列表视图 -->
  <view class="alumni-view" wx:if="{{showList}}">
    <!-- 返回和标题 -->
    <view class="alumni-header">
      <view class="back-btn" bindtap="onBackToList">
        <text class="back-icon">‹</text>
        <text class="back-text">返回分布</text>
      </view>
      <view class="alumni-header-title">
        <text class="header-icon" wx:if="{{selectedIndustryInfo}}">{{selectedIndustryInfo.icon}}</text>
        <text class="header-name" wx:if="{{selectedIndustryInfo}}">{{selectedIndustryInfo.label}}</text>
        <text class="header-count"> · {{alumniList.length}}人</text>
      </view>
    </view>

    <!-- 筛选栏 -->
    <view class="filter-bar">
      <view class="filter-item" bindtap="onIndustryFilterTap">
        <text class="filter-item-text">{{selectedIndustry ? f.getLabel(industryOptions, selectedIndustry) : '全部行业'}}</text>
        <text class="filter-arrow">▾</text>
      </view>
      <view class="filter-item" bindtap="onCollegeFilterTap">
        <text class="filter-item-text">{{selectedCollege ? f.getLabel(collegeOptions, selectedCollege) : '全部学院'}}</text>
        <text class="filter-arrow">▾</text>
      </view>
      <view class="filter-item" bindtap="onYearFilterTap">
        <text class="filter-item-text">{{selectedYear ? selectedYear + '届' : '毕业年份'}}</text>
        <text class="filter-arrow">▾</text>
      </view>
    </view>

    <!-- 校友列表 -->
    <scroll-view class="alumni-scroll" scroll-y="{{true}}" enhanced="{{true}}" show-scrollbar="{{false}}">
      <view class="alumni-list" wx:if="{{alumniList.length > 0}}">
        <view
          class="alumni-card"
          wx:for="{{alumniList}}"
          wx:key="id"
          bindtap="onAlumniTap"
          data-id="{{item.id}}"
        >
          <image class="alumni-avatar" src="{{item.avatar}}" mode="aspectFill"/>
          <view class="alumni-info">
            <view class="alumni-name-row">
              <text class="alumni-name">{{item.name}}</text>
              <view class="verified-badge" wx:if="{{item.verified}}">✓</view>
            </view>
            <text class="alumni-position">{{item.position}}</text>
            <text class="alumni-company">{{item.company}}</text>
            <view class="alumni-meta">
              <text class="meta-tag" wx:if="{{item.graduationYear}}">{{item.graduationYear}}届</text>
              <text class="meta-tag" wx:if="{{item.collegeInfo}}">{{item.collegeInfo.label}}</text>
            </view>
          </view>
          <text class="alumni-arrow">›</text>
        </view>
      </view>
      <empty wx:else text="暂无该条件下的校友" icon="👥"/>
    </scroll-view>
  </view>

  <!-- 学院筛选弹窗 -->
  <view class="picker-mask {{showCollegeFilter ? 'show' : ''}}" bindtap="onCloseFilter">
    <view class="picker-content" catchtap="stopPropagation">
      <view class="picker-header">
        <text class="picker-title">选择学院</text>
        <text class="picker-clear" bindtap="onClearCollegeFilter">清除</text>
      </view>
      <view class="picker-options">
        <view
          class="picker-option {{selectedCollege === item.value ? 'active' : ''}}"
          wx:for="{{collegeOptions}}"
          wx:key="value"
          bindtap="onCollegeSelect"
          data-value="{{item.value}}"
        >
          <text class="option-label">{{item.label}}</text>
          <text class="option-check" wx:if="{{selectedCollege === item.value}}">✓</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 毕业年份筛选弹窗 -->
  <view class="picker-mask {{showYearFilter ? 'show' : ''}}" bindtap="onCloseFilter">
    <view class="picker-content" catchtap="stopPropagation">
      <view class="picker-header">
        <text class="picker-title">选择毕业年份</text>
        <text class="picker-clear" bindtap="onClearYearFilter">清除</text>
      </view>
      <view class="picker-options">
        <view
          class="picker-option {{selectedYear === item.value ? 'active' : ''}}"
          wx:for="{{yearOptions}}"
          wx:key="value"
          bindtap="onYearSelect"
          data-value="{{item.value}}"
        >
          <text class="option-label">{{item.label}}</text>
          <text class="option-check" wx:if="{{selectedYear === item.value}}">✓</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 行业筛选弹窗 -->
  <view class="picker-mask {{showIndustryFilter ? 'show' : ''}}" bindtap="onCloseFilter">
    <view class="picker-content" catchtap="stopPropagation">
      <view class="picker-header">
        <text class="picker-title">选择行业</text>
        <text class="picker-clear" bindtap="onClearIndustryFilter">清除</text>
      </view>
      <view class="picker-options">
        <view
          class="picker-option {{selectedIndustry === item.value ? 'active' : ''}}"
          wx:for="{{industryOptions}}"
          wx:key="value"
          bindtap="onIndustryFilterSelect"
          data-value="{{item.value}}"
        >
          <text class="option-icon">{{item.icon}}</text>
          <text class="option-label">{{item.label}}</text>
          <text class="option-check" wx:if="{{selectedIndustry === item.value}}">✓</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 加载状态 -->
  <view class="loading-overlay" wx:if="{{loading}}">
    <view class="loading-content">
      <view class="loading-spinner"></view>
      <text class="loading-text">加载中...</text>
    </view>
  </view>
</view>
