<wxs src="../../utils/filters.wxs" module="f" />
<page-meta page-style="background-color: {{darkMode ? '#0F1117' : '#F8F9FA'}}; color: {{darkMode ? '#E8ECF1' : '#2C3E50'}}"/>
<view class="page {{darkMode ? 'dark' : ''}}">
  <!-- 顶部标签栏 -->
  <view class="top-tabs">
    <view
      class="top-tab-item {{activeTab === 'form' ? 'active' : ''}}"
      bindtap="onTabChange"
      data-value="form"
    >
      <text class="tab-icon">📝</text>
      <text class="tab-label">预约申请</text>
    </view>
    <view
      class="top-tab-item {{activeTab === 'records' ? 'active' : ''}}"
      bindtap="onTabChange"
      data-value="records"
    >
      <text class="tab-icon">📋</text>
      <text class="tab-label">我的预约</text>
    </view>
  </view>

  <!-- 预约表单 -->
  <view class="tab-content" wx:if="{{activeTab === 'form'}}">
    <scroll-view class="form-scroll" scroll-y="{{true}}" enhanced="{{true}}" show-scrollbar="{{false}}">
      <!-- 预约说明 -->
      <view class="notice-card">
        <view class="notice-icon">📌</view>
        <view class="notice-content">
          <text class="notice-title">预约须知</text>
          <text class="notice-text">请提前1-3天预约，审核通过后凭身份证入校。同行人员请如实填写信息。</text>
        </view>
      </view>

      <!-- 表单区域 -->
      <view class="form-section">
        <view class="form-title">基本信息</view>

        <view class="form-item">
          <view class="form-label">
            <text class="label-text">返校类型</text>
            <text class="required">*</text>
          </view>
          <view class="form-picker-wrap" bindtap="onTypePickerTap">
            <view class="picker-selected" wx:if="{{formData.visitType}}">
              <text class="type-icon">{{f.getItem(visitTypes, formData.visitType).icon}}</text>
              <text class="type-label" style="color: {{f.getItem(visitTypes, formData.visitType).color}}">
                {{f.getItem(visitTypes, formData.visitType).label}}
              </text>
            </view>
            <text class="form-picker-text placeholder" wx:else>请选择返校类型</text>
            <text class="picker-arrow">›</text>
          </view>
        </view>

        <view class="form-item">
          <view class="form-label">
            <text class="label-text">预约日期</text>
            <text class="required">*</text>
          </view>
          <picker
            mode="date"
            value="{{formData.visitDate}}"
            bindchange="onDateChange"
          >
            <view class="form-picker-wrap">
              <text class="form-picker-text {{formData.visitDate ? '' : 'placeholder'}}">
                {{formData.visitDate || '请选择预约日期'}}
              </text>
              <text class="picker-arrow">›</text>
            </view>
          </picker>
        </view>

        <view class="form-item">
          <view class="form-label">
            <text class="label-text">同行人数</text>
            <text class="required">*</text>
          </view>
          <picker
            mode="selector"
            range="{{companionOptions}}"
            value="{{companionIndex}}"
            bindchange="onCompanionChange"
          >
            <view class="form-picker-wrap">
              <text class="form-picker-text">
                {{formData.companionCount}} 人
              </text>
              <text class="picker-arrow">›</text>
            </view>
          </picker>
        </view>
      </view>

      <!-- 来访人员信息 -->
      <view class="form-section">
        <view class="form-title">来访人员信息</view>

        <view class="form-item">
          <view class="form-label">
            <text class="label-text">姓名</text>
            <text class="required">*</text>
          </view>
          <view class="form-input-wrap">
            <input
              class="form-input"
              placeholder="请输入来访人员姓名"
              placeholder-class="form-placeholder"
              value="{{formData.visitorName}}"
              bindinput="onVisitorNameInput"
              maxlength="20"
            />
          </view>
        </view>

        <view class="form-item">
          <view class="form-label">
            <text class="label-text">身份证号</text>
            <text class="required">*</text>
          </view>
          <view class="form-input-wrap">
            <input
              class="form-input"
              placeholder="请输入身份证号"
              placeholder-class="form-placeholder"
              value="{{formData.visitorIdCard}}"
              bindinput="onVisitorIdCardInput"
              maxlength="18"
            />
          </view>
        </view>

        <view class="form-item">
          <view class="form-label">
            <text class="label-text">联系方式</text>
            <text class="required">*</text>
          </view>
          <view class="form-input-wrap">
            <input
              class="form-input"
              type="number"
              placeholder="请输入手机号"
              placeholder-class="form-placeholder"
              value="{{formData.visitorPhone}}"
              bindinput="onVisitorPhoneInput"
              maxlength="11"
            />
          </view>
        </view>
      </view>

      <!-- 车辆信息 -->
      <view class="form-section">
        <view class="form-title">车辆信息</view>

        <view class="form-item">
          <view class="form-label">
            <text class="label-text">车牌号</text>
            <text class="optional">（选填）</text>
          </view>
          <view class="form-input-wrap">
            <input
              class="form-input"
              placeholder="请输入车牌号"
              placeholder-class="form-placeholder"
              value="{{formData.plateNumber}}"
              bindinput="onPlateNumberInput"
              maxlength="10"
            />
          </view>
        </view>
      </view>

      <!-- 访问目的 -->
      <view class="form-section">
        <view class="form-title">访问目的</view>

        <view class="form-item">
          <view class="form-textarea-wrap">
            <textarea
              class="form-textarea"
              placeholder="请简要描述您的访问目的..."
              placeholder-class="form-placeholder"
              value="{{formData.purpose}}"
              bindinput="onPurposeInput"
              maxlength="200"
              auto-height
            />
          </view>
          <view class="word-count">{{formData.purpose.length}}/200</view>
        </view>
      </view>

      <!-- 提交按钮 -->
      <view class="submit-section">
        <btn
          type="primary"
          size="large"
          bind:click="onSubmit"
          loading="{{submitting}}"
          disabled="{{submitting}}"
          block
        >
          {{submitting ? '提交中...' : '提交预约'}}
        </btn>
      </view>
    </scroll-view>
  </view>

  <!-- 我的预约记录 -->
  <view class="tab-content" wx:if="{{activeTab === 'records'}}">
    <scroll-view class="records-scroll" scroll-y="{{true}}" enhanced="{{true}}" show-scrollbar="{{false}}">
      <view class="appointment-list" wx:if="{{appointments.length > 0}}">
        <view
          class="appointment-card"
          wx:for="{{appointments}}"
          wx:key="id"
        >
          <view class="appointment-header">
            <view class="appointment-type">
              <text class="type-icon">{{item.typeInfo.icon}}</text>
              <text class="type-name" style="color: {{item.typeInfo.color}}">{{item.typeInfo.label}}</text>
            </view>
            <view class="appointment-status" style="background: {{item.statusInfo.color}}15; color: {{item.statusInfo.color}}">
              <text class="status-icon">{{item.statusInfo.icon}}</text>
              <text class="status-label">{{item.statusInfo.label}}</text>
            </view>
          </view>

          <view class="appointment-info">
            <view class="info-row">
              <text class="info-icon">📅</text>
              <text class="info-label">预约日期</text>
              <text class="info-value">{{item.visitDate}}</text>
            </view>
            <view class="info-row">
              <text class="info-icon">👥</text>
              <text class="info-label">同行人数</text>
              <text class="info-value">{{item.companionCount}} 人</text>
            </view>
            <view class="info-row">
              <text class="info-icon">👤</text>
              <text class="info-label">来访人员</text>
              <text class="info-value">{{item.visitorName}}</text>
            </view>
            <view class="info-row" wx:if="{{item.plateNumber}}">
              <text class="info-icon">🚗</text>
              <text class="info-label">车牌号</text>
              <text class="info-value">{{item.plateNumber}}</text>
            </view>
          </view>

          <view class="appointment-footer">
            <text class="create-time">申请时间：{{item.formattedTime}}</text>
          </view>
        </view>
      </view>
      <empty wx:else text="暂无预约记录" icon="📋"/>
    </scroll-view>
  </view>

  <!-- 返校类型选择弹窗 -->
  <view class="picker-mask {{showTypePicker ? 'show' : ''}}" bindtap="onCloseTypePicker">
    <view class="picker-content" catchtap="stopPropagation">
      <view class="picker-header">
        <text class="picker-title">选择返校类型</text>
        <text class="picker-clear" bindtap="onCloseTypePicker">关闭</text>
      </view>
      <view class="picker-options">
        <view
          class="picker-option {{formData.visitType === item.value ? 'active' : ''}}"
          wx:for="{{visitTypes}}"
          wx:key="value"
          bindtap="onTypeSelect"
          data-value="{{item.value}}"
        >
          <text class="option-icon">{{item.icon}}</text>
          <text class="option-label" style="color: {{formData.visitType === item.value ? item.color : ''}}">
            {{item.label}}
          </text>
          <text class="option-check" wx:if="{{formData.visitType === item.value}}" style="color: {{item.color}}">✓</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 加载状态 -->
  <view class="loading-overlay" wx:if="{{loading}}">
    <view class="loading-content">
      <view class="loading-spinner"></view>
      <text class="loading-text">加载中...</text>
    </view>
  </view>
</view>
