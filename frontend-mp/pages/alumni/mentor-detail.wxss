.page {
  min-height: 100vh;
  background: var(--color-bg-page);
  padding-bottom: 140rpx;
}

.page.dark {
  --color-bg-page: #0F1117;
  --color-bg-card: #1A1D29;
  --color-text-primary: #E8ECF1;
  --color-text-secondary: #9CA3AF;
  --color-border: #2D3142;
}

.header-section {
  position: relative;
  margin-bottom: 24rpx;
}

.header-bg {
  height: 200rpx;
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-dark));
}

.mentor-info {
  position: relative;
  background: var(--color-bg-card);
  margin: -80rpx 24rpx 0;
  border-radius: var(--radius-xl);
  padding: 40rpx 32rpx;
  box-shadow: var(--shadow-card);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.mentor-avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 80rpx;
  object-fit: cover;
  border: 4rpx solid var(--color-bg-card);
  margin-bottom: 16rpx;
}

.mentor-badge {
  padding: 6rpx 20rpx;
  border-radius: 24rpx;
  font-size: 22rpx;
  color: #FFFFFF;
  margin-bottom: 12rpx;
}

.mentor-name {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  margin-bottom: 8rpx;
}

.mentor-company {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  margin-bottom: 12rpx;
}

.mentor-rating {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.rating-value {
  font-size: 28rpx;
  color: #F59E0B;
  font-weight: 600;
}

.rating-count {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

.content-scroll {
  height: calc(100vh - 460rpx);
}

.info-section {
  background: var(--color-bg-card);
  margin: 0 24rpx 24rpx;
  padding: 32rpx;
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-card);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 24rpx;
}

.info-grid {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.info-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.info-label {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  flex-shrink: 0;
  width: 160rpx;
}

.info-value {
  flex: 1;
  font-size: 26rpx;
  color: var(--color-text-primary);
  line-height: 1.6;
}

.tags-container {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag-chip {
  padding: 10rpx 24rpx;
  background: rgba(59, 130, 246, 0.1);
  color: var(--color-primary);
  border-radius: 28rpx;
  font-size: 24rpx;
}

.stats-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.stat-card {
  width: calc((100% - 48rpx) / 4);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 12rpx;
  background: var(--color-bg-page);
  border-radius: var(--radius-lg);
}

.stat-value {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-primary);
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

.bio-content {
  font-size: 28rpx;
  color: var(--color-text-primary);
  line-height: 1.8;
}

.time-slots {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.time-slot-item {
  padding: 12rpx 24rpx;
  background: var(--color-bg-page);
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-md);
}

.time-slot-label {
  font-size: 24rpx;
  color: var(--color-text-primary);
}

.bottom-spacing {
  height: 40rpx;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 32rpx;
  background: var(--color-bg-card);
  border-top: 1rpx solid var(--color-border);
  z-index: 100;
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.fee-info {
  display: flex;
  flex-direction: column;
}

.fee-label {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  margin-bottom: 4rpx;
}

.fee-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #EF4444;
}

.fee-unit {
  font-size: 24rpx;
  font-weight: 400;
  color: var(--color-text-secondary);
}

.bottom-bar .btn {
  flex: 1;
}

.btn-icon {
  margin-right: 12rpx;
}

.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--color-bg-page);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2000;
}

.loading-content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 4rpx solid var(--color-border);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 24rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}
