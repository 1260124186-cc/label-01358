.page {
  min-height: 100vh;
  background: var(--color-bg-page);
  padding-bottom: 40rpx;
}

.page.dark {
  --color-bg-page: #0F1117;
  --color-bg-card: #1A1D29;
  --color-text-primary: #E8ECF1;
  --color-text-secondary: #9CA3AF;
  --color-border: #2D3142;
}

.search-section {
  padding: 24rpx 32rpx 16rpx;
  background: var(--color-bg-page);
}

.search-bar {
  display: flex;
  align-items: center;
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: 20rpx 28rpx;
  box-shadow: var(--shadow-card);
}

.search-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
  opacity: 0.6;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--color-text-primary);
}

.search-placeholder {
  color: var(--color-text-secondary);
  font-size: 28rpx;
}

.quick-nav {
  display: flex;
  justify-content: space-around;
  padding: 16rpx 32rpx 24rpx;
}

.nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 12rpx;
  transition: transform 0.2s ease;
}

.nav-item:active {
  transform: scale(0.95);
}

.nav-icon {
  width: 96rpx;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, rgba(59, 130, 246, 0.1), rgba(99, 102, 241, 0.1));
  border-radius: 28rpx;
  font-size: 44rpx;
}

.nav-label {
  font-size: 24rpx;
  color: var(--color-text-primary);
  font-weight: 500;
}

.main-tabs {
  display: flex;
  background: var(--color-bg-card);
  margin: 0 32rpx 24rpx;
  border-radius: var(--radius-xl);
  padding: 8rpx;
  box-shadow: var(--shadow-card);
}

.main-tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 12rpx;
  border-radius: var(--radius-lg);
  transition: all 0.3s ease;
}

.main-tab-item.active {
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-dark));
}

.tab-icon {
  font-size: 36rpx;
  margin-bottom: 8rpx;
}

.tab-label {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  font-weight: 500;
}

.main-tab-item.active .tab-label {
  color: #FFFFFF;
}

.sub-tabs {
  display: flex;
  align-items: center;
  padding: 0 32rpx;
  margin-bottom: 20rpx;
}

.sub-tabs-scroll {
  flex: 1;
  white-space: nowrap;
}

.sub-tab-item {
  display: inline-block;
  padding: 16rpx 32rpx;
  margin-right: 16rpx;
  border-radius: 48rpx;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  background: var(--color-bg-card);
  transition: all 0.3s ease;
}

.sub-tab-item.active {
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-dark));
  color: #FFFFFF;
  font-weight: 500;
}

.filter-btn {
  display: flex;
  align-items: center;
  margin-left: auto;
  padding: 12rpx 24rpx;
  background: var(--color-bg-card);
  border-radius: 48rpx;
  font-size: 24rpx;
  color: var(--color-text-primary);
  flex-shrink: 0;
}

.filter-btn.small {
  padding: 8rpx 20rpx;
  font-size: 22rpx;
}

.filter-icon {
  margin-right: 8rpx;
  font-size: 24rpx;
}

.publish-section {
  padding: 0 32rpx;
  margin-bottom: 24rpx;
}

.publish-icon {
  margin-right: 12rpx;
}

.list-scroll {
  height: calc(100vh - 480rpx);
  padding: 0 32rpx;
}

.post-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.post-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: 32rpx;
  box-shadow: var(--shadow-card);
  transition: transform 0.3s ease;
}

.post-card:active {
  transform: scale(0.98);
}

.post-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.post-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 40rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.post-user-info {
  flex: 1;
  min-width: 0;
}

.post-user-row {
  display: flex;
  align-items: center;
  margin-bottom: 6rpx;
}

.post-user-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-right: 16rpx;
}

.post-type-tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 16rpx;
  border-radius: 24rpx;
  font-size: 20rpx;
  font-weight: 500;
}

.post-user-meta {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.post-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 12rpx;
  line-height: 1.4;
}

.post-content {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.6;
  margin-bottom: 20rpx;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.post-images {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.post-img {
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  object-fit: cover;
}

.post-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--color-border);
}

.post-time {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

.post-stats {
  display: flex;
  gap: 24rpx;
}

.stat-item {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

.mentor-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.mentor-card {
  display: flex;
  align-items: center;
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: 28rpx;
  box-shadow: var(--shadow-card);
  transition: transform 0.3s ease;
}

.mentor-card:active {
  transform: scale(0.98);
}

.mentor-avatar {
  position: relative;
  flex-shrink: 0;
  margin-right: 24rpx;
}

.avatar-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  object-fit: cover;
}

.mentor-badge {
  position: absolute;
  bottom: -8rpx;
  left: 50%;
  transform: translateX(-50%);
  padding: 4rpx 16rpx;
  border-radius: 24rpx;
  font-size: 20rpx;
  color: #FFFFFF;
  white-space: nowrap;
}

.mentor-info {
  flex: 1;
  min-width: 0;
}

.mentor-name-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.mentor-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-right: 16rpx;
}

.mentor-rating {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.star {
  font-size: 24rpx;
}

.rating-value {
  font-size: 24rpx;
  color: #F59E0B;
  font-weight: 600;
}

.mentor-dept {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-bottom: 8rpx;
  display: block;
}

.mentor-research {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-bottom: 12rpx;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.mentor-stats {
  display: flex;
  gap: 20rpx;
}

.stat-item {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

.arrow {
  font-size: 36rpx;
  color: var(--color-text-secondary);
  margin-left: 16rpx;
}

.industry-entry {
  padding: 0 32rpx 24rpx;
}

.industry-entry-card {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, rgba(59, 130, 246, 0.15), rgba(99, 102, 241, 0.15));
  border-radius: var(--radius-xl);
  padding: 32rpx;
}

.entry-icon {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(59, 130, 246, 0.2);
  border-radius: 40rpx;
  font-size: 40rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.entry-content {
  flex: 1;
  min-width: 0;
}

.entry-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 8rpx;
}

.entry-desc {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.industry-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  padding: 16rpx 0;
}

.industry-item {
  width: calc((100% - 40rpx) / 3);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 16rpx;
  border-radius: var(--radius-xl);
  transition: transform 0.2s ease;
}

.industry-item:active {
  transform: scale(0.95);
}

.industry-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.industry-label {
  font-size: 24rpx;
  font-weight: 500;
}

.service-card {
  display: flex;
  align-items: center;
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-card);
  transition: transform 0.3s ease;
}

.service-card:active {
  transform: scale(0.98);
}

.service-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  flex-shrink: 0;
  margin-right: 24rpx;
}

.service-content {
  flex: 1;
  min-width: 0;
}

.service-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 8rpx;
}

.service-desc {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.service-status {
  margin-right: 12rpx;
}

.status-text {
  font-size: 24rpx;
  font-weight: 500;
}

.picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.picker-mask.show {
  opacity: 1;
  visibility: visible;
}

.picker-content {
  width: 100%;
  background: var(--color-bg-card);
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx;
  max-height: 70vh;
  transform: translateY(100%);
  transition: transform 0.3s ease;
}

.picker-mask.show .picker-content {
  transform: translateY(0);
}

.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid var(--color-border);
}

.picker-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.picker-clear {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.picker-options {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  max-height: 50vh;
  overflow-y: auto;
}

.picker-option {
  display: flex;
  align-items: center;
  padding: 24rpx 20rpx;
  border-radius: var(--radius-lg);
  transition: background 0.2s ease;
}

.picker-option:active {
  background: var(--color-hover);
}

.picker-option.active {
  background: rgba(59, 130, 246, 0.1);
}

.option-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.option-label {
  flex: 1;
  font-size: 28rpx;
  color: var(--color-text-primary);
}

.picker-option.active .option-label {
  color: var(--color-primary);
  font-weight: 500;
}

.option-check {
  font-size: 32rpx;
  color: var(--color-primary);
}

.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--color-bg-page);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2000;
}

.loading-content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 4rpx solid var(--color-border);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 24rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}
