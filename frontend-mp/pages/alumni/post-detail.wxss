.page {
  min-height: 100vh;
  background: var(--color-bg-page);
  padding-bottom: 140rpx;
}

.page.dark {
  --color-bg-page: #0F1117;
  --color-bg-card: #1A1D29;
  --color-text-primary: #E8ECF1;
  --color-text-secondary: #9CA3AF;
  --color-border: #2D3142;
}

.content-scroll {
  height: 100vh;
}

.post-section {
  background: var(--color-bg-card);
  margin: 24rpx;
  padding: 32rpx;
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-card);
}

.post-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.post-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 44rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.post-user-info {
  flex: 1;
  min-width: 0;
}

.post-user-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
  flex-wrap: wrap;
  gap: 12rpx;
}

.post-user-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.post-type-tag {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 16rpx;
  border-radius: 24rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.post-user-meta {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.post-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  line-height: 1.4;
  margin-bottom: 16rpx;
}

.post-content {
  font-size: 28rpx;
  color: var(--color-text-primary);
  line-height: 1.8;
  margin-bottom: 24rpx;
  white-space: pre-wrap;
  word-break: break-all;
}

.post-images {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.post-img {
  width: calc((100% - 24rpx) / 3);
  height: 200rpx;
  border-radius: var(--radius-md);
  object-fit: cover;
}

.post-meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid var(--color-border);
  margin-bottom: 24rpx;
}

.meta-item {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.action-bar {
  display: flex;
  justify-content: space-around;
  padding-top: 8rpx;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 32rpx;
  border-radius: var(--radius-lg);
  transition: all 0.2s ease;
}

.action-item:active {
  transform: scale(0.95);
}

.action-item.active .action-text {
  color: var(--color-primary);
}

.action-icon {
  font-size: 40rpx;
}

.action-text {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.comments-section {
  background: var(--color-bg-card);
  margin: 0 24rpx 24rpx;
  padding: 32rpx;
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-card);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 24rpx;
}

.comments-list {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.comment-item {
  display: flex;
  gap: 20rpx;
}

.comment-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 32rpx;
  flex-shrink: 0;
}

.comment-content {
  flex: 1;
  min-width: 0;
}

.comment-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.comment-name {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--color-text-primary);
}

.comment-time {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

.comment-text {
  font-size: 26rpx;
  color: var(--color-text-primary);
  line-height: 1.6;
  word-break: break-all;
}

.empty-comments {
  padding: 40rpx 0;
  text-align: center;
}

.empty-text {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.bottom-spacing {
  height: 40rpx;
}

.comment-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: var(--color-bg-card);
  border-top: 1rpx solid var(--color-border);
  z-index: 100;
}

.comment-input {
  flex: 1;
  padding: 20rpx 28rpx;
  background: var(--color-bg-page);
  border-radius: 48rpx;
  font-size: 28rpx;
  color: var(--color-text-primary);
}

.send-btn {
  padding: 20rpx 36rpx;
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-dark));
  color: #FFFFFF;
  border-radius: 48rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--color-bg-page);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2000;
}

.loading-content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 4rpx solid var(--color-border);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 24rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}
