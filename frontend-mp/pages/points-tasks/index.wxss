.page {
  min-height: 100vh;
  background-color: #F8F9FA;
  padding-bottom: 40rpx;
}

.page.dark {
  background-color: #0F1117;
}

.header-card {
  position: relative;
  margin: 0;
  border-radius: 0 0 32rpx 32rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 50%, #FFA726 100%);
}

.header-content {
  position: relative;
  padding: 32rpx;
  padding-top: 48rpx;
}

.points-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 32rpx;
}

.points-info {
  display: flex;
  flex-direction: column;
}

.points-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-bottom: 8rpx;
}

.points-value {
  font-size: 72rpx;
  font-weight: 700;
  color: #FFFFFF;
  line-height: 1;
}

.header-actions {
  display: flex;
  gap: 16rpx;
}

.header-action {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 20rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
  min-width: 100rpx;
}

.action-icon {
  font-size: 32rpx;
  margin-bottom: 4rpx;
}

.action-text {
  font-size: 22rpx;
  color: #FFFFFF;
}

.signin-section {
  background: rgba(255, 255, 255, 0.15);
  border-radius: 24rpx;
  padding: 24rpx;
}

.signin-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.signin-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.signin-stats {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.stats-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.stats-highlight {
  color: #FFD700;
  font-weight: 600;
  font-size: 28rpx;
}

.stats-divider {
  color: rgba(255, 255, 255, 0.4);
}

.week-calendar {
  display: flex;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.week-day {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.day-name {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-bottom: 12rpx;
}

.day-circle {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.day-date {
  font-size: 26rpx;
  color: #FFFFFF;
  font-weight: 500;
}

.day-check {
  position: absolute;
  font-size: 24rpx;
  color: #4CAF50;
}

.week-day.today .day-circle {
  background: rgba(255, 255, 255, 0.3);
  border: 2rpx solid #FFD700;
}

.week-day.signed .day-circle {
  background: #4CAF50;
}

.week-day.signed .day-date {
  opacity: 0;
}

.signin-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
  border-radius: 40rpx;
  box-shadow: 0 4rpx 16rpx rgba(255, 165, 0, 0.4);
}

.signin-btn.signed {
  background: rgba(255, 255, 255, 0.2);
  box-shadow: none;
}

.signin-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.signin-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.signin-success {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.signin-success.show {
  opacity: 1;
  visibility: visible;
}

.success-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 64rpx;
  background: rgba(0, 0, 0, 0.8);
  border-radius: 24rpx;
}

.success-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.success-text {
  font-size: 64rpx;
  font-weight: 700;
  color: #FFD700;
}

.success-label {
  font-size: 28rpx;
  color: #FFFFFF;
  margin-top: 8rpx;
}

.tasks-container {
  padding: 24rpx;
}

.task-section {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.page.dark .task-section {
  background: #1E2128;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
}

.page.dark .section-title {
  color: #E8ECF1;
}

.section-desc {
  font-size: 24rpx;
  color: #999999;
}

.page.dark .section-desc {
  color: #8B95A7;
}

.task-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.task-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #FAFAFA;
  border-radius: 16rpx;
}

.page.dark .task-item {
  background: #2A2E37;
}

.task-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.task-info {
  flex: 1;
  min-width: 0;
  margin-right: 16rpx;
}

.task-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.task-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
}

.page.dark .task-title {
  color: #E8ECF1;
}

.task-points {
  font-size: 28rpx;
  font-weight: 600;
  color: #FF6B6B;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.task-desc {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
}

.page.dark .task-desc {
  color: #8B95A7;
}

.task-progress {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.progress-bar {
  flex: 1;
  height: 8rpx;
  background: #EEEEEE;
  border-radius: 4rpx;
  overflow: hidden;
}

.page.dark .progress-bar {
  background: #3A3F4B;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #FF6B6B 0%, #FF8E53 100%);
  border-radius: 4rpx;
  transition: width 0.5s ease;
}

.progress-text {
  font-size: 22rpx;
  color: #999999;
  flex-shrink: 0;
}

.page.dark .progress-text {
  color: #8B95A7;
}

.task-status {
  font-size: 22rpx;
  color: #FF6B6B;
}

.task-btn {
  padding: 12rpx 24rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  border-radius: 32rpx;
  flex-shrink: 0;
}

.task-btn text {
  font-size: 24rpx;
  color: #FFFFFF;
  font-weight: 500;
}

.task-btn.disabled {
  background: #E0E0E0;
}

.page.dark .task-btn.disabled {
  background: #3A3F4B;
}

.task-btn.disabled text {
  color: #999999;
}

.rules-entry {
  display: flex;
  align-items: center;
  margin: 24rpx;
  padding: 24rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.page.dark .rules-entry {
  background: #1E2128;
}

.rules-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.rules-text {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
}

.page.dark .rules-text {
  color: #E8ECF1;
}

.rules-arrow {
  font-size: 32rpx;
  color: #999999;
}

.bottom-space {
  height: 40rpx;
}

.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}

.loading-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #999999;
}

.page.dark .loading-text {
  color: #8B95A7;
}
