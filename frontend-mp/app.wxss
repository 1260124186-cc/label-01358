/*
 * 全局设计系统 - 参考 Airbnb / 闲鱼 / 小红书 设计规范
 * 特点：大圆角、柔和阴影、渐变色、微动效、呼吸感留白
 */

page.dark {
  --color-primary: #FF8A8A;
  --color-primary-dark: #FF6B6B;
  --color-primary-light: #3D2020;
  --color-secondary: #5ED4CB;
  --color-accent: #FFE88A;

  --color-success: #4ADE80;
  --color-warning: #FBBF24;
  --color-danger: #F87171;
  --color-info: #60A5FA;

  --color-text-primary: #E8ECF1;
  --color-text-secondary: #9CA3AF;
  --color-text-muted: #6B7280;
  --color-text-inverse: #111827;

  --color-bg-page: #0F1117;
  --color-bg-card: #1A1D28;
  --color-bg-elevated: #222639;
  --color-bg-input: #262A3A;

  --color-border: #2E3348;
  --color-border-light: #242839;
  --color-divider: #1E2235;

  --shadow-xs: 0 1px 2px rgba(0, 0, 0, 0.2);
  --shadow-sm: 0 2px 8px rgba(0, 0, 0, 0.25);
  --shadow-md: 0 4px 16px rgba(0, 0, 0, 0.3);
  --shadow-lg: 0 8px 24px rgba(0, 0, 0, 0.35);
  --shadow-xl: 0 16px 48px rgba(0, 0, 0, 0.4);
  --shadow-card: 0 2px 12px rgba(0, 0, 0, 0.3);
  --shadow-float: 0 8px 32px rgba(0, 0, 0, 0.4);
}

page.dark .bg-white {
  background-color: var(--color-bg-card);
}

page.dark .glass {
  background: rgba(26, 29, 40, 0.85);
}

page.dark .skeleton {
  background: linear-gradient(90deg, #262A3A 25%, #2E3348 50%, #262A3A 75%);
  background-size: 200% 100%;
  animation: skeleton-loading 1.5s infinite;
}

page.dark .gradient-primary {
  background: linear-gradient(135deg, #C04040 0%, #D06060 100%);
}

page.dark .gradient-secondary {
  background: linear-gradient(135deg, #3A9E96 0%, #4AB8AE 100%);
}

page.dark .gradient-warm {
  background: linear-gradient(135deg, #C04040 0%, #C0A030 100%);
}

page.dark .gradient-cool {
  background: linear-gradient(135deg, #4A5EB0 0%, #5A3A80 100%);
}

page.dark .gradient-sunset {
  background: linear-gradient(135deg, #C05070 0%, #C0A030 100%);
}

page.dark .tag-primary {
  background-color: var(--color-primary-light);
}

page.dark .tag-success {
  background-color: rgba(74, 222, 128, 0.15);
}

page.dark .tag-warning {
  background-color: rgba(251, 191, 36, 0.15);
}

page.dark .tag-danger {
  background-color: rgba(248, 113, 113, 0.15);
}

page.dark .tag-info {
  background-color: rgba(96, 165, 250, 0.15);
}

page {
  /* 色彩系统 */
  --color-primary: #FF6B6B;
  --color-primary-dark: #EE5A5A;
  --color-primary-light: #FFE8E8;
  --color-secondary: #4ECDC4;
  --color-accent: #FFE66D;

  --color-success: #2ECC71;
  --color-warning: #F39C12;
  --color-danger: #E74C3C;
  --color-info: #3498DB;

  /* 中性色 */
  --color-text-primary: #2C3E50;
  --color-text-secondary: #7F8C8D;
  --color-text-muted: #BDC3C7;
  --color-text-inverse: #FFFFFF;

  /* 背景色 */
  --color-bg-page: #F8F9FA;
  --color-bg-card: #FFFFFF;
  --color-bg-elevated: #FFFFFF;
  --color-bg-input: #F1F3F4;

  /* 边框 */
  --color-border: #EAECEF;
  --color-border-light: #F4F5F6;
  --color-divider: #F0F0F0;

  /* 阴影系统 */
  --shadow-xs: 0 1px 2px rgba(0, 0, 0, 0.04);
  --shadow-sm: 0 2px 8px rgba(0, 0, 0, 0.06);
  --shadow-md: 0 4px 16px rgba(0, 0, 0, 0.08);
  --shadow-lg: 0 8px 24px rgba(0, 0, 0, 0.12);
  --shadow-xl: 0 16px 48px rgba(0, 0, 0, 0.16);
  --shadow-card: 0 2px 12px rgba(0, 0, 0, 0.08);
  --shadow-float: 0 8px 32px rgba(0, 0, 0, 0.12);

  /* 圆角系统 */
  --radius-xs: 8rpx;
  --radius-sm: 12rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --radius-xl: 32rpx;
  --radius-2xl: 40rpx;
  --radius-full: 9999rpx;

  /* 间距系统 */
  --spacing-xs: 8rpx;
  --spacing-sm: 12rpx;
  --spacing-md: 16rpx;
  --spacing-lg: 24rpx;
  --spacing-xl: 32rpx;
  --spacing-2xl: 48rpx;
  --spacing-3xl: 64rpx;

  /* 字体系统 */
  --font-xs: 22rpx;
  --font-sm: 24rpx;
  --font-base: 28rpx;
  --font-md: 30rpx;
  --font-lg: 32rpx;
  --font-xl: 36rpx;
  --font-2xl: 40rpx;
  --font-3xl: 48rpx;
  --font-4xl: 56rpx;

  /* 动画 */
  --transition-fast: 0.15s ease;
  --transition-normal: 0.25s ease;
  --transition-slow: 0.35s ease;
  --transition-bounce: 0.4s cubic-bezier(0.68, -0.55, 0.265, 1.55);

  background-color: var(--color-bg-page);
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'PingFang SC', 'Helvetica Neue', sans-serif;
  font-size: var(--font-base);
  color: var(--color-text-primary);
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
}

/* 重置样式 */
view, text, image, navigator, button, input, textarea, scroll-view, swiper {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

button {
  background: transparent;
  border: none;
  outline: none;
  line-height: inherit;
}

button::after {
  border: none;
}

image {
  display: block;
  width: 100%;
  height: 100%;
}

/* ==================== Flex 布局 ==================== */
.flex { display: flex; }
.flex-col { flex-direction: column; }
.flex-row { flex-direction: row; }
.flex-wrap { flex-wrap: wrap; }
.flex-1 { flex: 1; }
.flex-shrink-0 { flex-shrink: 0; }
.items-start { align-items: flex-start; }
.items-center { align-items: center; }
.items-end { align-items: flex-end; }
.items-stretch { align-items: stretch; }
.justify-start { justify-content: flex-start; }
.justify-center { justify-content: center; }
.justify-end { justify-content: flex-end; }
.justify-between { justify-content: space-between; }
.justify-around { justify-content: space-around; }
.justify-evenly { justify-content: space-evenly; }
.self-start { align-self: flex-start; }
.self-center { align-self: center; }
.self-end { align-self: flex-end; }

/* ==================== 间距工具类 ==================== */
.gap-xs { gap: var(--spacing-xs); }
.gap-sm { gap: var(--spacing-sm); }
.gap-md { gap: var(--spacing-md); }
.gap-lg { gap: var(--spacing-lg); }
.gap-xl { gap: var(--spacing-xl); }

.m-0 { margin: 0; }
.mt-xs { margin-top: var(--spacing-xs); }
.mt-sm { margin-top: var(--spacing-sm); }
.mt-md { margin-top: var(--spacing-md); }
.mt-lg { margin-top: var(--spacing-lg); }
.mt-xl { margin-top: var(--spacing-xl); }
.mb-xs { margin-bottom: var(--spacing-xs); }
.mb-sm { margin-bottom: var(--spacing-sm); }
.mb-md { margin-bottom: var(--spacing-md); }
.mb-lg { margin-bottom: var(--spacing-lg); }
.mb-xl { margin-bottom: var(--spacing-xl); }
.ml-xs { margin-left: var(--spacing-xs); }
.ml-sm { margin-left: var(--spacing-sm); }
.ml-md { margin-left: var(--spacing-md); }
.mr-xs { margin-right: var(--spacing-xs); }
.mr-sm { margin-right: var(--spacing-sm); }
.mr-md { margin-right: var(--spacing-md); }

.p-0 { padding: 0; }
.p-xs { padding: var(--spacing-xs); }
.p-sm { padding: var(--spacing-sm); }
.p-md { padding: var(--spacing-md); }
.p-lg { padding: var(--spacing-lg); }
.p-xl { padding: var(--spacing-xl); }
.px-md { padding-left: var(--spacing-md); padding-right: var(--spacing-md); }
.px-lg { padding-left: var(--spacing-lg); padding-right: var(--spacing-lg); }
.px-xl { padding-left: var(--spacing-xl); padding-right: var(--spacing-xl); }
.py-sm { padding-top: var(--spacing-sm); padding-bottom: var(--spacing-sm); }
.py-md { padding-top: var(--spacing-md); padding-bottom: var(--spacing-md); }
.py-lg { padding-top: var(--spacing-lg); padding-bottom: var(--spacing-lg); }

/* ==================== 文字工具类 ==================== */
.text-xs { font-size: var(--font-xs); }
.text-sm { font-size: var(--font-sm); }
.text-base { font-size: var(--font-base); }
.text-md { font-size: var(--font-md); }
.text-lg { font-size: var(--font-lg); }
.text-xl { font-size: var(--font-xl); }
.text-2xl { font-size: var(--font-2xl); }
.text-3xl { font-size: var(--font-3xl); }

.font-normal { font-weight: 400; }
.font-medium { font-weight: 500; }
.font-semibold { font-weight: 600; }
.font-bold { font-weight: 700; }

.text-left { text-align: left; }
.text-center { text-align: center; }
.text-right { text-align: right; }

.text-primary { color: var(--color-primary); }
.text-secondary { color: var(--color-text-secondary); }
.text-muted { color: var(--color-text-muted); }
.text-success { color: var(--color-success); }
.text-warning { color: var(--color-warning); }
.text-danger { color: var(--color-danger); }
.text-white { color: #FFFFFF; }

.leading-tight { line-height: 1.25; }
.leading-normal { line-height: 1.5; }
.leading-relaxed { line-height: 1.75; }

/* 文字截断 */
.truncate {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.line-clamp-2 {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.line-clamp-3 {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
  overflow: hidden;
}

/* ==================== 卡片组件 ==================== */
.card {
  background-color: var(--color-bg-card);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-card);
  overflow: hidden;
}

.card-elevated {
  box-shadow: var(--shadow-lg);
}

.card-flat {
  box-shadow: none;
  border: 1rpx solid var(--color-border);
}

.card-body {
  padding: var(--spacing-lg);
}

/* ==================== 分割线 ==================== */
.divider {
  height: 1rpx;
  background-color: var(--color-divider);
}

.divider-thick {
  height: 16rpx;
  background-color: var(--color-bg-page);
}

/* ==================== 圆角 ==================== */
.rounded-none { border-radius: 0; }
.rounded-xs { border-radius: var(--radius-xs); }
.rounded-sm { border-radius: var(--radius-sm); }
.rounded-md { border-radius: var(--radius-md); }
.rounded-lg { border-radius: var(--radius-lg); }
.rounded-xl { border-radius: var(--radius-xl); }
.rounded-2xl { border-radius: var(--radius-2xl); }
.rounded-full { border-radius: var(--radius-full); }

/* ==================== 背景 ==================== */
.bg-white { background-color: #FFFFFF; }
.bg-page { background-color: var(--color-bg-page); }
.bg-primary { background-color: var(--color-primary); }
.bg-primary-light { background-color: var(--color-primary-light); }

/* ==================== 边框 ==================== */
.border { border: 1rpx solid var(--color-border); }
.border-t { border-top: 1rpx solid var(--color-border); }
.border-b { border-bottom: 1rpx solid var(--color-border); }
.border-l { border-left: 1rpx solid var(--color-border); }
.border-r { border-right: 1rpx solid var(--color-border); }

/* ==================== 定位 ==================== */
.relative { position: relative; }
.absolute { position: absolute; }
.fixed { position: fixed; }
.sticky { position: sticky; }
.inset-0 { top: 0; right: 0; bottom: 0; left: 0; }
.top-0 { top: 0; }
.bottom-0 { bottom: 0; }
.left-0 { left: 0; }
.right-0 { right: 0; }

/* ==================== 层级 ==================== */
.z-0 { z-index: 0; }
.z-10 { z-index: 10; }
.z-20 { z-index: 20; }
.z-50 { z-index: 50; }
.z-100 { z-index: 100; }
.z-max { z-index: 9999; }

/* ==================== 尺寸 ==================== */
.w-full { width: 100%; }
.h-full { height: 100%; }
.min-h-screen { min-height: 100vh; }

/* ==================== 显示 ==================== */
.hidden { display: none !important; }
.invisible { visibility: hidden; }
.visible { visibility: visible; }
.overflow-hidden { overflow: hidden; }
.overflow-auto { overflow: auto; }

/* ==================== 安全区域 ==================== */
.safe-top {
  padding-top: constant(safe-area-inset-top);
  padding-top: env(safe-area-inset-top);
}

.safe-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

/* ==================== 页面容器 ==================== */
.page-container {
  min-height: 100vh;
  background-color: var(--color-bg-page);
  padding: var(--spacing-lg);
  padding-bottom: calc(var(--spacing-lg) + constant(safe-area-inset-bottom));
  padding-bottom: calc(var(--spacing-lg) + env(safe-area-inset-bottom));
}

/* ==================== 渐变背景 ==================== */
.gradient-primary {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
}

.gradient-secondary {
  background: linear-gradient(135deg, #4ECDC4 0%, #6EE7DE 100%);
}

.gradient-warm {
  background: linear-gradient(135deg, #FF6B6B 0%, #FFE66D 100%);
}

.gradient-cool {
  background: linear-gradient(135deg, #667EEA 0%, #764BA2 100%);
}

.gradient-sunset {
  background: linear-gradient(135deg, #FA709A 0%, #FEE140 100%);
}

/* ==================== 毛玻璃效果 ==================== */
.glass {
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
}

.glass-dark {
  background: rgba(0, 0, 0, 0.6);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
}

/* ==================== 动画效果 ==================== */
.transition-all {
  transition: all var(--transition-normal);
}

.transition-fast {
  transition: all var(--transition-fast);
}

.hover-scale:active {
  transform: scale(0.98);
}

.hover-opacity:active {
  opacity: 0.8;
}

/* ==================== 骨架屏 ==================== */
.skeleton {
  background: linear-gradient(90deg, #F0F0F0 25%, #E8E8E8 50%, #F0F0F0 75%);
  background-size: 200% 100%;
  animation: skeleton-loading 1.5s infinite;
}

@keyframes skeleton-loading {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* ==================== 价格样式 ==================== */
.price {
  color: var(--color-primary);
  font-weight: 700;
}

.price-symbol {
  font-size: 0.75em;
  margin-right: 2rpx;
}

.price-original {
  color: var(--color-text-muted);
  text-decoration: line-through;
  font-weight: 400;
}

/* ==================== 标签样式 ==================== */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 16rpx;
  font-size: var(--font-xs);
  font-weight: 500;
  border-radius: var(--radius-sm);
}

.tag-primary {
  color: var(--color-primary);
  background-color: var(--color-primary-light);
}

.tag-success {
  color: var(--color-success);
  background-color: rgba(46, 204, 113, 0.1);
}

.tag-warning {
  color: var(--color-warning);
  background-color: rgba(243, 156, 18, 0.1);
}

.tag-danger {
  color: var(--color-danger);
  background-color: rgba(231, 76, 60, 0.1);
}

.tag-info {
  color: var(--color-info);
  background-color: rgba(52, 152, 219, 0.1);
}

/* ==================== 头像样式 ==================== */
.avatar {
  border-radius: var(--radius-full);
  overflow: hidden;
  flex-shrink: 0;
}

.avatar-xs { width: 48rpx; height: 48rpx; }
.avatar-sm { width: 64rpx; height: 64rpx; }
.avatar-md { width: 80rpx; height: 80rpx; }
.avatar-lg { width: 120rpx; height: 120rpx; }
.avatar-xl { width: 160rpx; height: 160rpx; }

/* ==================== 徽章样式 ==================== */
.badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 10rpx;
  font-size: 20rpx;
  font-weight: 600;
  color: #FFFFFF;
  background-color: var(--color-primary);
  border-radius: var(--radius-full);
}

.badge-dot {
  min-width: 16rpx;
  width: 16rpx;
  height: 16rpx;
  padding: 0;
}

/* ==================== 暗色模式 - 按钮适配 ==================== */
page.dark .btn-secondary {
  background-color: var(--color-bg-input);
  color: var(--color-text-primary);
}

page.dark .btn-secondary.btn-hover {
  background-color: var(--color-border);
}

page.dark .btn-outline {
  color: var(--color-primary);
  border-color: var(--color-primary);
}

page.dark .btn-outline.btn-hover {
  background-color: rgba(255, 138, 138, 0.1);
}

page.dark .btn-text {
  color: var(--color-primary);
}

/* ==================== 暗色模式 - 导航栏适配 ==================== */
page.dark .nav-grid {
  background: linear-gradient(135deg, var(--color-bg-card) 0%, var(--color-bg-elevated) 100%);
}

page.dark .quick-item {
  background: linear-gradient(135deg, var(--color-bg-card) 0%, var(--color-bg-elevated) 100%);
}

/* ==================== 主题切换开关 ==================== */
.theme-switch {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 24rpx;
  transition: all var(--transition-fast);
}

.theme-switch-label {
  display: flex;
  align-items: center;
}

.theme-switch-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: var(--radius-lg);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  position: relative;
  overflow: hidden;
}

.theme-switch-icon::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(255,255,255,0.5) 0%, transparent 100%);
}

.theme-switch-text {
  flex: 1;
  font-size: 30rpx;
  font-weight: 500;
  color: var(--color-text-primary);
}

.theme-switch-desc {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-top: 4rpx;
}

.switch-track {
  width: 100rpx;
  height: 56rpx;
  border-radius: 28rpx;
  background-color: var(--color-bg-input);
  position: relative;
  transition: background-color var(--transition-normal);
  flex-shrink: 0;
  border: 2rpx solid var(--color-border);
}

.switch-track.active {
  background-color: var(--color-primary);
  border-color: var(--color-primary);
}

.switch-thumb {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background-color: #FFFFFF;
  position: absolute;
  top: 2rpx;
  left: 2rpx;
  transition: transform var(--transition-normal);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
}

.switch-track.active .switch-thumb {
  transform: translateX(44rpx);
}

.theme-mode-group {
  display: flex;
  background-color: var(--color-bg-input);
  border-radius: var(--radius-lg);
  padding: 6rpx;
  margin: 0 24rpx 24rpx;
}

.theme-mode-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 0;
  font-size: 26rpx;
  font-weight: 500;
  color: var(--color-text-secondary);
  border-radius: var(--radius-md);
  transition: all var(--transition-fast);
}

.theme-mode-item.active {
  background-color: var(--color-bg-card);
  color: var(--color-text-primary);
  box-shadow: var(--shadow-sm);
}
