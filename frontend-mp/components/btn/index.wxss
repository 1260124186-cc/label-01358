/* 按钮组件 - 现代设计风格 */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 0 32rpx;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: var(--radius-lg);
  transition: all 0.2s ease;
  border: none;
  outline: none;
  line-height: 1;
  position: relative;
  overflow: hidden;
  box-sizing: border-box;
}

.btn::after {
  border: none;
}

/* 尺寸 */
.btn-small {
  height: 64rpx;
  padding: 0 24rpx;
  font-size: 24rpx;
  border-radius: var(--radius-md);
}

.btn-medium {
  height: 88rpx;
  padding: 0 36rpx;
  font-size: 28rpx;
}

.btn-large {
  height: 100rpx;
  padding: 0 48rpx;
  font-size: 32rpx;
  border-radius: var(--radius-xl);
}

/* 主要按钮 */
.btn-primary {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  color: #FFFFFF;
  box-shadow: 0 6rpx 20rpx rgba(255, 107, 107, 0.35);
}

.btn-primary.btn-hover {
  background: linear-gradient(135deg, #EE5A5A 0%, #FF7D7D 100%);
  transform: translateY(-2rpx);
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 107, 0.45);
}

/* 次要按钮 */
.btn-secondary {
  background-color: #F1F3F4;
  color: #2C3E50;
}

.btn-secondary.btn-hover {
  background-color: #E8EAEB;
  transform: scale(0.98);
}

/* 轮廓按钮 */
.btn-outline {
  background-color: transparent;
  color: #FF6B6B;
  border: 2rpx solid #FF6B6B;
}

.btn-outline.btn-hover {
  background-color: rgba(255, 107, 107, 0.08);
  transform: scale(0.98);
}

/* 文字按钮 */
.btn-text {
  background-color: transparent;
  color: #FF6B6B;
  padding: 0 16rpx;
}

.btn-text.btn-hover {
  opacity: 0.7;
}

/* 危险按钮 */
.btn-danger {
  background: linear-gradient(135deg, #E74C3C 0%, #EC7063 100%);
  color: #FFFFFF;
  box-shadow: 0 6rpx 20rpx rgba(231, 76, 60, 0.35);
}

.btn-danger.btn-hover {
  background: linear-gradient(135deg, #C0392B 0%, #E74C3C 100%);
  transform: translateY(-2rpx);
}

/* 成功按钮 */
.btn-success {
  background: linear-gradient(135deg, #2ECC71 0%, #58D68D 100%);
  color: #FFFFFF;
  box-shadow: 0 6rpx 20rpx rgba(46, 204, 113, 0.35);
}

.btn-success.btn-hover {
  background: linear-gradient(135deg, #27AE60 0%, #2ECC71 100%);
  transform: translateY(-2rpx);
}

/* 块级按钮 */
.btn-block {
  display: flex;
  width: 100%;
}

/* 禁用状态 */
.btn-disabled {
  opacity: 0.5;
  pointer-events: none;
  box-shadow: none;
}

/* 图标 */
.btn-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 10rpx;
}

/* 加载状态 */
.btn-loading {
  margin-right: 12rpx;
}

.loading-spinner {
  width: 32rpx;
  height: 32rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: currentColor;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

.btn-secondary .loading-spinner,
.btn-outline .loading-spinner,
.btn-text .loading-spinner {
  border-color: rgba(255, 107, 107, 0.3);
  border-top-color: #FF6B6B;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

/* 按钮文字 */
.btn-label {
  position: relative;
  z-index: 1;
  color: inherit;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
  height: 100%;
}
