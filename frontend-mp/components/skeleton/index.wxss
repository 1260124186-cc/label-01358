.skeleton {
  width: 100%;
}

.skeleton-loading .skeleton-avatar,
.skeleton-loading .skeleton-title,
.skeleton-loading .skeleton-paragraph,
.skeleton-loading .skeleton-card-image,
.skeleton-loading .skeleton-card-title,
.skeleton-loading .skeleton-card-desc,
.skeleton-loading .skeleton-card-tag,
.skeleton-loading .skeleton-grid-image,
.skeleton-loading .skeleton-grid-title,
.skeleton-loading .skeleton-grid-subtitle {
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: skeleton-loading 1.5s ease-in-out infinite;
}

@keyframes skeleton-loading {
  0% {
    background-position: 200% 0;
  }
  100% {
    background-position: -200% 0;
  }
}

.skeleton-item {
  display: flex;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.skeleton-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #f0f0f0;
  flex-shrink: 0;
  margin-right: 24rpx;
}

.skeleton-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.skeleton-title {
  width: 60%;
  height: 28rpx;
  background: #f0f0f0;
  border-radius: 4rpx;
  margin-bottom: 16rpx;
}

.skeleton-paragraphs {
  display: flex;
  flex-direction: column;
}

.skeleton-paragraph {
  height: 24rpx;
  background: #f0f0f0;
  border-radius: 4rpx;
  margin-bottom: 12rpx;
}

.skeleton-paragraph:last-child {
  margin-bottom: 0;
}

.skeleton-paragraph:nth-child(1) {
  width: 100%;
}

.skeleton-paragraph:nth-child(2) {
  width: 80%;
}

.skeleton-paragraph:nth-child(3) {
  width: 60%;
}

.skeleton-card {
  display: flex;
  padding: 24rpx;
  margin-bottom: 20rpx;
  background: #fff;
  border-radius: 16rpx;
}

.skeleton-card-image {
  width: 180rpx;
  height: 180rpx;
  background: #f0f0f0;
  border-radius: 12rpx;
  flex-shrink: 0;
  margin-right: 24rpx;
}

.skeleton-card-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.skeleton-card-title {
  width: 80%;
  height: 32rpx;
  background: #f0f0f0;
  border-radius: 4rpx;
}

.skeleton-card-desc {
  width: 100%;
  height: 48rpx;
  background: #f0f0f0;
  border-radius: 4rpx;
}

.skeleton-card-tags {
  display: flex;
}

.skeleton-card-tag {
  width: 100rpx;
  height: 36rpx;
  background: #f0f0f0;
  border-radius: 18rpx;
  margin-right: 16rpx;
}

.skeleton-card-tag:last-child {
  margin-right: 0;
}

.skeleton-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 20rpx;
  margin-right: -20rpx;
  margin-bottom: -20rpx;
}

.skeleton-grid-item {
  width: calc((100% - 20rpx) / 2);
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-right: 20rpx;
  margin-bottom: 20rpx;
}

.skeleton-grid-image {
  width: 100%;
  height: 240rpx;
  background: #f0f0f0;
}

.skeleton-grid-title {
  width: 80%;
  height: 28rpx;
  background: #f0f0f0;
  border-radius: 4rpx;
  margin: 16rpx;
}

.skeleton-grid-subtitle {
  width: 50%;
  height: 24rpx;
  background: #f0f0f0;
  border-radius: 4rpx;
  margin: 0 16rpx 16rpx;
}

.dark .skeleton-avatar,
.dark .skeleton-title,
.dark .skeleton-paragraph,
.dark .skeleton-card-image,
.dark .skeleton-card-title,
.dark .skeleton-card-desc,
.dark .skeleton-card-tag,
.dark .skeleton-grid-image,
.dark .skeleton-grid-title,
.dark .skeleton-grid-subtitle {
  background: #1a1d24;
}

.dark .skeleton-loading .skeleton-avatar,
.dark .skeleton-loading .skeleton-title,
.dark .skeleton-loading .skeleton-paragraph,
.dark .skeleton-loading .skeleton-card-image,
.dark .skeleton-loading .skeleton-card-title,
.dark .skeleton-loading .skeleton-card-desc,
.dark .skeleton-loading .skeleton-card-tag,
.dark .skeleton-loading .skeleton-grid-image,
.dark .skeleton-loading .skeleton-grid-title,
.dark .skeleton-loading .skeleton-grid-subtitle {
  background: linear-gradient(90deg, #1a1d24 25%, #2a2d34 50%, #1a1d24 75%);
  background-size: 200% 100%;
}

.dark .skeleton-item {
  border-bottom-color: #1a1d24;
}

.dark .skeleton-card {
  background: #1a1d24;
}

.dark .skeleton-grid-item {
  background: #1a1d24;
}
