.campus-selector-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 9999;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.campus-selector-container {
  width: 100%;
  max-height: 80vh;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.campus-selector-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 32rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.campus-selector-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.campus-selector-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: #999;
  line-height: 1;
}

.campus-selector-tip {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx 32rpx;
  background: linear-gradient(135deg, #e6f7ff 0%, #f0f9ff 100%);
  font-size: 26rpx;
  color: #1890ff;
  margin: 0 24rpx 24rpx;
  border-radius: 16rpx;
  margin-top: 24rpx;
}

.tip-icon {
  font-size: 32rpx;
}

.campus-selector-list {
  flex: 1;
  max-height: 50vh;
  padding: 0 24rpx;
}

.campus-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 24rpx;
  margin-bottom: 16rpx;
  background: #fafafa;
  border-radius: 20rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
}

.campus-item.active {
  background: linear-gradient(135deg, #e6f7ff 0%, #f0f9ff 100%);
  border-color: #1890ff;
}

.campus-item.current {
  background: linear-gradient(135deg, #f6ffed 0%, #f0f9ff 100%);
}

.campus-item-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex: 1;
}

.campus-item-icon {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
  border-radius: 20rpx;
  font-size: 40rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}

.campus-item-info {
  flex: 1;
  overflow: hidden;
}

.campus-item-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 6rpx;
}

.campus-item-tag {
  display: inline-block;
  padding: 2rpx 12rpx;
  font-size: 20rpx;
  font-weight: 500;
  border-radius: 8rpx;
  background: #e6f7ff;
  color: #1890ff;
}

.campus-item-tag.current-tag {
  background: #f6ffed;
  color: #52c41a;
}

.campus-item-address {
  font-size: 24rpx;
  color: #8c8c8c;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.campus-item-right {
  width: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.campus-check {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #1890ff;
  color: #fff;
  border-radius: 50%;
  font-size: 28rpx;
  font-weight: bold;
}

.campus-selector-footer {
  padding: 24rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #f0f0f0;
}

.campus-selector-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 44rpx;
  border: none;
}

.campus-selector-btn::after {
  border: none;
}
