.empty-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
}

.empty-image {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 32rpx;
  opacity: 0.8;
}

.empty-text {
  font-size: 28rpx;
  color: var(--color-text-tertiary);
  margin-bottom: 32rpx;
}

.empty-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 200rpx;
  height: 72rpx;
  padding: 0 40rpx;
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1;
  border-radius: 36rpx;
  transition: all 0.2s ease;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 107, 0.35);
}

.empty-btn::after {
  border: none;
}

.empty-btn-hover {
  transform: scale(0.96);
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 107, 0.4);
}

.empty-btn.loading {
  opacity: 0.7;
}

.loading-icon {
  display: inline-block;
  width: 28rpx;
  height: 28rpx;
  margin-right: 12rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: #FFFFFF;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}
